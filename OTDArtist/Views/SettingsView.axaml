<UserControl x:Class="OtdArtist.Views.SettingsView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- DataContext is the SettingsViewModel, supplied by the typed-nav DataTemplate (#15). -->
    <StackPanel MaxWidth="900" HorizontalAlignment="Left">
        <TextBlock Classes="PageTitle" Text="Settings" />

        <Border Classes="GlassPanel">
            <StackPanel>
                <TextBlock Text="Appearance" FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12" />
                <Grid ColumnDefinitions="Auto,*" VerticalAlignment="Center">
                    <TextBlock Grid.Column="0" Text="Theme" FontSize="13" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}" Width="120" />
                    <ComboBox Grid.Column="1" HorizontalAlignment="Left" MinWidth="200"
                              ItemsSource="{Binding ThemeOptions}"
                              SelectedItem="{Binding SelectedTheme}"
                              ToolTip.Tip="Light, Dark, or follow the system setting" />
                </Grid>
                <TextBlock Text="System follows your Windows light/dark setting. Your choice is remembered across restarts."
                           FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                           TextWrapping="Wrap" Margin="0,8,0,0" />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
