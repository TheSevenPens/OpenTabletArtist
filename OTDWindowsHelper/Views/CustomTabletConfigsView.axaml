<UserControl x:Class="OtdWindowsHelper.Views.CustomTabletConfigsView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="using:OtdWindowsHelper.Controls">

    <!-- DataContext is the CustomTabletConfigsViewModel, supplied by the typed-nav DataTemplate (#15). -->
    <StackPanel MaxWidth="900" HorizontalAlignment="Left">
        <TextBlock Classes="PageTitle" Text="Custom Tablet Configs" />
        <TextBlock Classes="PageSubtitle"
                   Text="Tablet config JSON files in OpenTabletDriver's Configurations folder" />

        <Border Classes="GlassPanel" Padding="16">
            <StackPanel>
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Configurations Folder" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Text="{Binding ConfigurationsDirectory}" FontSize="10"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   TextTrimming="CharacterEllipsis" Margin="0,4,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="Refresh" Command="{Binding RefreshConfigurationsCommand}"
                                ToolTip.Tip="Reload list"
                                Theme="{StaticResource GhostButton}" Padding="12,6" FontSize="12" Margin="0,0,6,0" />
                        <Button Content="Open Folder" Theme="{StaticResource GhostButton}"
                                Command="{Binding OpenConfigurationsFolderCommand}"
                                Padding="12,6" FontSize="12" />
                    </StackPanel>
                </Grid>

                <!-- Empty state -->
                <TextBlock Text="No configurations in this folder."
                           FontSize="11" FontStyle="Italic"
                           Foreground="{DynamicResource TextMutedBrush}"
                           Margin="0,12,0,0"
                           IsVisible="{Binding !HasConfigurations}" />

                <!-- Configurations list -->
                <ItemsControl ItemsSource="{Binding Configurations}"
                              Margin="0,12,0,0"
                              IsVisible="{Binding HasConfigurations}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource GlassBgBrush}"
                                    CornerRadius="8" Padding="12,8" Margin="0,0,0,6">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="{Binding FileName}" FontSize="10"
                                                       Foreground="{DynamicResource TextMutedBrush}" />
                                            <TextBlock Text="  •  " FontSize="10"
                                                       Foreground="{DynamicResource TextMutedBrush}" />
                                            <TextBlock Text="{Binding SizeText}" FontSize="10"
                                                       Foreground="{DynamicResource TextMutedBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="View"
                                                Theme="{StaticResource GhostButton}"
                                                Command="{Binding $parent[ItemsControl].DataContext.ViewConfigurationCommand}"
                                                CommandParameter="{Binding Path}"
                                                Padding="10,4" FontSize="11" Margin="0,0,6,0" />
                                        <Button Content="Delete"
                                                Theme="{StaticResource DeleteButton}"
                                                Command="{Binding $parent[ItemsControl].DataContext.DeleteConfigurationCommand}"
                                                CommandParameter="{Binding Path}"
                                                Padding="10,4" FontSize="11" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
