<UserControl x:Class="OtdWindowsHelper.Views.TestView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="using:OtdWindowsHelper.Controls">

    <!-- DataContext is the TestViewModel, supplied by the typed-nav DataTemplate (#15). -->
    <DockPanel LastChildFill="True">

        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Classes="PageTitle" Text="Test" />
            <TextBlock Classes="PageSubtitle"
                       Text="Paint with your pen to verify pressure, tilt, and twist are working." />

            <!-- Controls -->
            <WrapPanel Orientation="Horizontal" Margin="0,8,0,0">
                <ToggleSwitch OffContent="App input (Windows Ink)" OnContent="Driver input (OTD)"
                              IsChecked="{Binding UseDriverInput}"
                              VerticalAlignment="Center" Margin="0,0,20,0" />
                <TextBlock Text="Mode" VerticalAlignment="Center" Margin="0,0,6,0"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
                <ComboBox ItemsSource="{Binding BrushModes}" SelectedItem="{Binding BrushMode}"
                          MinWidth="170" VerticalAlignment="Center" Margin="0,0,20,0" />
                <Button Content="Clear" Command="{Binding ClearCommand}"
                        Theme="{StaticResource GhostButton}" Padding="14,6" />
            </WrapPanel>

            <!-- Live readouts -->
            <WrapPanel Orientation="Horizontal" Margin="0,10,0,0">
                <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                    <TextBlock Text="Pressure: " FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding PressureText}" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                    <TextBlock Text="Tilt X: " FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding TiltXText}" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                    <TextBlock Text="Tilt Y: " FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding TiltYText}" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                    <TextBlock Text="Azimuth: " FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding AzimuthText}" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                    <TextBlock Text="Altitude: " FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding AltitudeText}" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Twist: " FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding TwistText}" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>
            </WrapPanel>
        </StackPanel>

        <!-- Paint surface fills the rest -->
        <Border Classes="GlassPanel" Padding="0" ClipToBounds="True" MinHeight="320">
            <c:PenTestCanvas x:Name="PaintCanvas"
                             BrushMode="{Binding BrushMode}"
                             AcceptPointerInput="{Binding !UseDriverInput}" />
        </Border>
    </DockPanel>
</UserControl>
