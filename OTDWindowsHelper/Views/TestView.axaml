<UserControl x:Class="OtdWindowsHelper.Views.TestView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="using:OtdWindowsHelper.Controls">

    <!-- DataContext is the TestViewModel, supplied by the typed-nav DataTemplate (#15). -->
    <DockPanel LastChildFill="True">

        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Classes="PageTitle" Text="Test" />
            <!-- Controls -->
            <WrapPanel Orientation="Horizontal" Margin="0,8,0,0">
                <ToggleSwitch OffContent="App input (Windows Ink)" OnContent="Driver input (OTD)"
                              IsChecked="{Binding UseDriverInput}"
                              VerticalAlignment="Center" Margin="0,0,20,0" />
                <TextBlock Text="Mode" VerticalAlignment="Center" Margin="0,0,6,0"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
                <ComboBox ItemsSource="{Binding BrushModes}" SelectedItem="{Binding BrushMode}"
                          MinWidth="170" VerticalAlignment="Center" Margin="0,0,20,0" />
                <Button Content="Clear" Command="{Binding ClearCommand}"
                        Theme="{StaticResource GhostButton}" Padding="14,6" />
                <Button Content="Dynamics" Command="{Binding OpenDynamicsCommand}"
                        Theme="{StaticResource GhostButton}" Padding="14,6" Margin="8,0,0,0"
                        ToolTip.Tip="Open this tablet's Dynamics settings (curve + smoothing) without leaving Test" />
            </WrapPanel>

            <!-- Live readouts. UniformGrid = equal-width cells, so values changing width can't
                 shift the row; monospace values keep the digits from jittering. -->
            <UniformGrid Columns="5" Margin="0,10,0,0">
                <StackPanel Orientation="Horizontal" Margin="0,2">
                    <TextBlock Text="Canvas X:" Width="62" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding CanvasXText}" FontFamily="Consolas" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2">
                    <TextBlock Text="Canvas Y:" Width="62" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding CanvasYText}" FontFamily="Consolas" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2">
                    <TextBlock Text="Pressure:" Width="62" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding PressureText}" FontFamily="Consolas" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2">
                    <TextBlock Text="Raw X:" Width="62" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding RawXText}" FontFamily="Consolas" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2">
                    <TextBlock Text="Raw Y:" Width="62" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding RawYText}" FontFamily="Consolas" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2">
                    <TextBlock Text="Twist:" Width="62" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding TwistText}" FontFamily="Consolas" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2">
                    <TextBlock Text="Tilt X:" Width="62" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding TiltXText}" FontFamily="Consolas" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2">
                    <TextBlock Text="Tilt Y:" Width="62" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding TiltYText}" FontFamily="Consolas" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2">
                    <TextBlock Text="Azimuth:" Width="62" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding AzimuthText}" FontFamily="Consolas" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2">
                    <TextBlock Text="Altitude:" Width="62" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding AltitudeText}" FontFamily="Consolas" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>
            </UniformGrid>
        </StackPanel>

        <!-- Paint surface fills the rest. Square corners (override the GlassPanel rounding). -->
        <Border Classes="GlassPanel" CornerRadius="0" Padding="0" ClipToBounds="True" MinHeight="320">
            <c:PenTestCanvas x:Name="PaintCanvas"
                             BrushMode="{Binding BrushMode}" />
        </Border>
    </DockPanel>
</UserControl>
