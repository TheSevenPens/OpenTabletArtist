<UserControl x:Class="OtdWindowsHelper.Views.AboutView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- DataContext is the AboutViewModel, supplied by the typed-nav DataTemplate (#15). -->
    <StackPanel MaxWidth="900" HorizontalAlignment="Left">
        <TextBlock Classes="PageTitle" Text="About" />

        <Border Classes="GlassPanel">
            <StackPanel>
                <TextBlock Text="What is this?" FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12" />
                <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="22"
                           Foreground="{DynamicResource TextSecondaryBrush}">
                    A simpler way of using OpenTabletDriver on Windows.
                </TextBlock>
            </StackPanel>
        </Border>

        <Border Classes="GlassPanel" Margin="0,12,0,0">
            <StackPanel>
                <TextBlock Text="Source code" FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12" />
                <!-- Clickable link: opens the GitHub repo in the default browser -->
                <Button Command="{Binding OpenUrlCommand}" CommandParameter="{Binding RepoUrl}"
                        Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand"
                        HorizontalAlignment="Left"
                        ToolTip.Tip="{Binding RepoUrl}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding RepoUrl}" FontSize="13"
                                   Foreground="{DynamicResource AccentBrush}"
                                   TextDecorations="Underline" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
