<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="using:OtdWindowsHelper.Controls">

    <Styles.Resources>
        <!-- Card-header icon box: rounded 48x48 with a centered Segoe MDL2 glyph (#24).
             Default ControlTheme (type-keyed → auto-applied). IsActive=True → green. -->
        <ControlTheme x:Key="{x:Type c:IconBox}" TargetType="c:IconBox">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="PART_Box" CornerRadius="12"
                            Background="{DynamicResource GlassBgBrush}">
                        <TextBlock x:Name="PART_Glyph" Text="{TemplateBinding Glyph}"
                                   FontFamily="Segoe MDL2 Assets" FontSize="{TemplateBinding GlyphSize}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextMutedBrush}" />
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^[IsActive=True] /template/ Border#PART_Box">
                <Setter Property="Background" Value="{DynamicResource SuccessMutedBrush}" />
            </Style>
            <Style Selector="^[IsActive=True] /template/ TextBlock#PART_Glyph">
                <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
            </Style>
        </ControlTheme>

        <!-- Tablet status banner: shared detection/connection indicator (#128/#129/#130/#132).
             Green check + text when detected; amber warning otherwise; optional "Dynamics on" chip. -->
        <ControlTheme x:Key="{x:Type c:TabletStatusBanner}" TargetType="c:TabletStatusBanner">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Template">
                <ControlTemplate>
                    <!-- Full-width band: status-tinted fill + a colored left stripe. -->
                    <Border x:Name="PART_Band" CornerRadius="8" ClipToBounds="True"
                            Background="{DynamicResource WarningMutedBrush}">
                        <Grid ColumnDefinitions="4,*">
                            <Border x:Name="PART_Stripe" Grid.Column="0"
                                    Background="{DynamicResource WarningBrush}" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                                        Margin="14,10">
                                <TextBlock Classes="statusMarkWarn"
                                           Classes.success="{Binding IsDetected, RelativeSource={RelativeSource TemplatedParent}}" />
                                <TextBlock Text="{TemplateBinding Text}" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center" TextWrapping="Wrap" />
                                <Border IsVisible="{TemplateBinding DynamicsOn}" VerticalAlignment="Center"
                                        Background="{DynamicResource AccentMutedBrush}"
                                        BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1"
                                        CornerRadius="4" Padding="6,1" Margin="10,0,0,0">
                                    <TextBlock Text="Dynamics on" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentBrush}" />
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter>
            <!-- Detected → success treatment (default is the warning treatment above). -->
            <Style Selector="^[IsDetected=True] /template/ Border#PART_Band">
                <Setter Property="Background" Value="{DynamicResource SuccessMutedBrush}" />
            </Style>
            <Style Selector="^[IsDetected=True] /template/ Border#PART_Stripe">
                <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
            </Style>
        </ControlTheme>

        <!-- Nav Item Button -->
        <ControlTheme x:Key="NavButton" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="Bd"
                            Background="Transparent"
                            CornerRadius="12"
                            Padding="8,8,16,8">
                        <Grid ColumnDefinitions="Auto,12,*">
                            <!-- Active indicator bar -->
                            <Border x:Name="Indicator"
                                    Width="3" Height="20"
                                    CornerRadius="2"
                                    Background="{DynamicResource AccentBrush}"
                                    IsVisible="False"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Left"
                                    Margin="-4,0,0,0" />
                            <ContentPresenter Grid.Column="0"
                                              Content="{TemplateBinding Tag}"
                                              VerticalAlignment="Center"
                                              Margin="8,0,0,0" />
                            <TextBlock Grid.Column="2"
                                       x:Name="Label"
                                       Text="{TemplateBinding Content}"
                                       FontSize="13"
                                       FontWeight="Medium"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#Bd">
                <Setter Property="Background" Value="{DynamicResource GlassBgHoverBrush}" />
            </Style>
            <Style Selector="^:pointerover /template/ TextBlock#Label">
                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            </Style>
            <Style Selector="^:checked /template/ Border#Bd">
                <Setter Property="Background" Value="{DynamicResource NavActiveBrush}" />
            </Style>
            <Style Selector="^:checked /template/ TextBlock#Label">
                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
            </Style>
            <Style Selector="^:checked /template/ Border#Indicator">
                <Setter Property="IsVisible" Value="True" />
            </Style>
        </ControlTheme>

        <!-- Accent Button -->
        <ControlTheme x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentMutedBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalContentAlignment="Center"
                                          VerticalContentAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource TextInverseBrush}" />
            </Style>
        </ControlTheme>

        <!-- Ghost Button (subtle, no background) -->
        <ControlTheme x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalContentAlignment="Center"
                                          VerticalContentAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="{DynamicResource GlassBgHoverBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            </Style>
        </ControlTheme>

        <!-- Tab RadioButton (for dialog tabs) -->
        <ControlTheme x:Key="TabRadioButton" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="Bd" Background="Transparent" CornerRadius="8"
                            Padding="12,6" BorderThickness="1" BorderBrush="Transparent">
                        <TextBlock x:Name="Label" Text="{TemplateBinding Content}"
                                   FontSize="12" FontWeight="Medium"
                                   Foreground="{DynamicResource TextMutedBrush}" />
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#Bd">
                <Setter Property="Background" Value="{DynamicResource GlassBgHoverBrush}" />
            </Style>
            <Style Selector="^:pointerover /template/ TextBlock#Label">
                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            </Style>
            <Style Selector="^:checked /template/ Border#Bd">
                <Setter Property="Background" Value="{DynamicResource AccentMutedBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            </Style>
            <Style Selector="^:checked /template/ TextBlock#Label">
                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
            </Style>
        </ControlTheme>

        <!-- Icon Button (small, borderless icon) -->
        <ControlTheme x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="Bd" Background="Transparent" CornerRadius="8"
                            Padding="{TemplateBinding Padding}"
                            BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1">
                        <ContentPresenter Content="{TemplateBinding Content}" />
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#Bd">
                <Setter Property="Background" Value="{DynamicResource GlassBgHoverBrush}" />
            </Style>
        </ControlTheme>

        <!-- Delete Button (red outline) -->
        <ControlTheme x:Key="DeleteButton" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="Transparent" CornerRadius="8"
                            Padding="{TemplateBinding Padding}"
                            BorderBrush="{DynamicResource ErrorBrush}" BorderThickness="1">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalContentAlignment="Center"
                                          VerticalContentAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </ControlTheme>
    </Styles.Resources>

    <!-- Glass Panel Style (applied via Classes="GlassPanel") -->
    <Style Selector="Border.GlassPanel">
        <Setter Property="Background" Value="{DynamicResource GlassBgBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="24" />
        <Setter Property="BoxShadow" Value="0 2 12 0 #14000000" />
    </Style>

    <!-- Page Title -->
    <Style Selector="TextBlock.PageTitle">
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="Margin" Value="0,0,0,4" />
    </Style>

    <!-- Page Subtitle -->
    <Style Selector="TextBlock.PageSubtitle">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="Margin" Value="0,0,0,28" />
    </Style>

    <!-- Section Label -->
    <Style Selector="TextBlock.SectionLabel">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
    </Style>

    <!-- ===== Status marks ===========================================================
         Standardized status iconography (Segoe MDL2 Assets):
           success  → green check  (E73E)
           warning  → amber warning (E7BA)   problem needing attention
           neutral  → muted dash   (E738)    normal off / idle / not applicable
           error    → red X        (EB90)    hard failure (available if needed)

         Two bool-driven base classes for the common "success vs not" indicator.
         Apply Classes.success="{Binding ...}" to toggle the success state:
           statusMark      → not-success shows the NEUTRAL dash  (off/idle is normal)
           statusMarkWarn  → not-success shows the WARNING mark   (off is a problem)

         For multi-state rows, use a literal class (success/warning/neutral/error). -->
    <Style Selector="TextBlock.statusMark, TextBlock.statusMarkWarn,
                     TextBlock.success, TextBlock.warning, TextBlock.neutral, TextBlock.error">
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,0,6,0" />
    </Style>

    <!-- Base appearance: neutral off-state -->
    <Style Selector="TextBlock.statusMark">
        <Setter Property="Text" Value="&#xE738;" />
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
    </Style>
    <!-- Base appearance: warning off-state -->
    <Style Selector="TextBlock.statusMarkWarn">
        <Setter Property="Text" Value="&#xE7BA;" />
        <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
    </Style>
    <!-- Success override for either base -->
    <Style Selector="TextBlock.statusMark.success, TextBlock.statusMarkWarn.success">
        <Setter Property="Text" Value="&#xE73E;" />
        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
    </Style>

    <!-- Literal single-state marks (for multi-state rows) -->
    <Style Selector="TextBlock.success">
        <Setter Property="Text" Value="&#xE73E;" />
        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
    </Style>
    <Style Selector="TextBlock.warning">
        <Setter Property="Text" Value="&#xE7BA;" />
        <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
    </Style>
    <Style Selector="TextBlock.neutral">
        <Setter Property="Text" Value="&#xE738;" />
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
    </Style>
    <Style Selector="TextBlock.error">
        <Setter Property="Text" Value="&#xEB90;" />
        <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}" />
    </Style>

    <!-- Always-visible, full-size scrollbars. The default Fluent scrollbars (a) auto-hide and
         (b) sit as a thin line until hovered (the thumb is scaled down by a RenderTransform in the
         collapsed state). Disable auto-hide AND clear the thumb's shrink transform so the bar is
         always the full, easy-to-grab width. -->
    <Style Selector="ScrollViewer">
        <Setter Property="AllowAutoHide" Value="False" />
    </Style>
    <Style Selector="ScrollBar">
        <Setter Property="AllowAutoHide" Value="False" />
    </Style>
    <Style Selector="ScrollBar /template/ Thumb">
        <Setter Property="RenderTransform" Value="none" />
    </Style>

</Styles>
