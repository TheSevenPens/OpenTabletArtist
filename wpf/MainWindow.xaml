<Window x:Class="TabletDriverUX.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TabletDriverUX.ViewModels"
        xmlns:views="clr-namespace:TabletDriverUX.Views"
        Title="Driver UX Experiment"
        Width="1100" Height="720"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgBaseBrush}">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="36" />
        </Grid.RowDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Grid.Row="0"
                Background="{DynamicResource GlassBgBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Brand -->
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                            Margin="16,20,16,16">
                    <Border Width="28" Height="28" CornerRadius="8"
                            Background="{DynamicResource AccentBrush}">
                        <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets"
                                   Foreground="White" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Driver UX Experiment"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Margin="12,0,0,0" />
                </StackPanel>

                <!-- Version -->
                <Border DockPanel.Dock="Bottom"
                        BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,1,0,0"
                        Padding="0,8">
                    <TextBlock Text="v0.1.0-proto" FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"
                               HorizontalAlignment="Center" />
                </Border>

                <!-- Nav Items -->
                <StackPanel Margin="8,0,8,0">
                    <RadioButton Style="{StaticResource NavButton}" Content="Dashboard"
                                 IsChecked="{Binding CurrentPage, Converter={StaticResource StrEquals}, ConverterParameter=Dashboard, Mode=OneWay}"
                                 Command="{Binding NavigateCommand}" CommandParameter="Dashboard" />
                    <RadioButton Style="{StaticResource NavButton}" Content="Tablet Settings"
                                 IsChecked="{Binding CurrentPage, Converter={StaticResource StrEquals}, ConverterParameter=TabletSettings, Mode=OneWay}"
                                 Command="{Binding NavigateCommand}" CommandParameter="TabletSettings"
                                 Margin="0,2,0,0" />
                    <RadioButton Style="{StaticResource NavButton}" Content="Settings Snapshots"
                                 IsChecked="{Binding CurrentPage, Converter={StaticResource StrEquals}, ConverterParameter=Presets, Mode=OneWay}"
                                 Command="{Binding NavigateCommand}" CommandParameter="Presets"
                                 Margin="0,2,0,0" />
                    <RadioButton Style="{StaticResource NavButton}" Content="Console"
                                 IsChecked="{Binding CurrentPage, Converter={StaticResource StrEquals}, ConverterParameter=Console, Mode=OneWay}"
                                 Command="{Binding NavigateCommand}" CommandParameter="Console"
                                 Margin="0,2,0,0" />
                    <RadioButton Style="{StaticResource NavButton}" Content="About"
                                 IsChecked="{Binding CurrentPage, Converter={StaticResource StrEquals}, ConverterParameter=About, Mode=OneWay}"
                                 Command="{Binding NavigateCommand}" CommandParameter="About"
                                 Margin="0,2,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- CONTENT AREA -->
        <ScrollViewer Grid.Column="1" Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Border Padding="28">
                <ContentControl>
                    <ContentControl.Style>
                        <Style TargetType="ContentControl">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentPage}" Value="Dashboard">
                                    <Setter Property="Content">
                                        <Setter.Value><views:DashboardView /></Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding CurrentPage}" Value="TabletSettings">
                                    <Setter Property="Content">
                                        <Setter.Value><views:TabletSettingsView /></Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding CurrentPage}" Value="Presets">
                                    <Setter Property="Content">
                                        <Setter.Value><views:PresetsView /></Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding CurrentPage}" Value="Console">
                                    <Setter Property="Content">
                                        <Setter.Value><views:ConsoleView /></Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding CurrentPage}" Value="About">
                                    <Setter Property="Content">
                                        <Setter.Value><views:AboutView /></Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ContentControl.Style>
                </ContentControl>
            </Border>
        </ScrollViewer>

        <!-- STATUS BAR -->
        <Border Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1"
                Background="{DynamicResource GlassBgBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="6" Height="6" Margin="0,0,8,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource TextMutedBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Fill" Value="{DynamicResource SuccessBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding ConnectionStatus}" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                               Visibility="{Binding HasTablet, Converter={StaticResource InvBoolToVis}}"
                               Text="No tablet connected" FontStyle="Italic" />
                    <TextBlock FontSize="11" FontWeight="Medium"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Visibility="{Binding HasTablet, Converter={StaticResource BoolToVis}}"
                               Text="{Binding TabletName}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
