<Application x:Class="TabletDriverUX.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:TabletDriverUX.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Colors.xaml" />
                <ResourceDictionary Source="Themes/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
            <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis" />
            <conv:NotFirstAndSecondToVisibilityConverter x:Key="NotFirstAndSecondToVis" />
            <conv:AllFalseToVisibilityConverter x:Key="AllFalseToVis" />
            <conv:StringEqualsConverter x:Key="StrEquals" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
