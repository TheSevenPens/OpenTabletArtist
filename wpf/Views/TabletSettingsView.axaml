<UserControl x:Class="OtdWindowsHelper.Views.TabletSettingsView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel MaxWidth="900" HorizontalAlignment="Left">
        <TextBlock Classes="PageTitle" Text="Paired Tablets" />
        <TextBlock Classes="PageSubtitle" Text="Tablets that have been detected" />

        <ItemsControl ItemsSource="{Binding Profiles}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Classes="GlassPanel" Margin="0,0,0,12" Padding="16"
                            Cursor="Hand"
                            DoubleTapped="ProfileCard_DoubleTapped">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <!-- Icon: green when detected, muted when not -->
                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="10"
                                    Margin="0,0,16,0"
                                    Background="{DynamicResource AccentMutedBrush}"
                                    Classes.active="{Binding IsDetected}">
                                <Border.Styles>
                                    <Style Selector="Border.active">
                                        <Setter Property="Background" Value="{DynamicResource SuccessMutedBrush}" />
                                    </Style>
                                </Border.Styles>
                                <TextBlock Text="&#xE70A;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="18" Foreground="{DynamicResource AccentBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Classes.active="{Binding IsDetected}">
                                    <TextBlock.Styles>
                                        <Style Selector="TextBlock.active">
                                            <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                        </Style>
                                    </TextBlock.Styles>
                                </TextBlock>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Tablet}" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Classes="statusMark" Classes.success="{Binding IsDetected}" />
                                    <TextBlock Text="{Binding StatusText}" FontSize="11"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               Classes.active="{Binding IsDetected}">
                                        <TextBlock.Styles>
                                            <Style Selector="TextBlock.active">
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                                            </Style>
                                        </TextBlock.Styles>
                                    </TextBlock>
                                </StackPanel>
                                <TextBlock Text="{Binding LastSeenDetail}" FontSize="10"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           FontStyle="Italic" Margin="0,2,0,0"
                                           IsVisible="{Binding LastSeenDetail, Converter={StaticResource NonEmptyToBool}}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="6">
                                <Button Content="Open" Theme="{StaticResource AccentButton}"
                                        Command="{Binding $parent[ItemsControl].DataContext.OpenTabletSettingsCommand}"
                                        CommandParameter="{Binding}"
                                        Padding="12,6" FontSize="12" />
                                <Button Content="Forget" Theme="{StaticResource DeleteButton}"
                                        Command="{Binding $parent[ItemsControl].DataContext.ForgetProfileCommand}"
                                        CommandParameter="{Binding Tablet}"
                                        Padding="12,6" FontSize="12" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Border Classes="GlassPanel" Padding="32"
                IsVisible="{Binding !HasProfiles}">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="No Tablets Configured" FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="Connect a tablet and it will appear here"
                           FontSize="13" Foreground="{DynamicResource TextMutedBrush}"
                           HorizontalAlignment="Center" Margin="0,8,0,0" />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
