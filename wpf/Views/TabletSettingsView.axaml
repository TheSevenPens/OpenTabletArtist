<UserControl x:Class="TabletDriverUX.Views.TabletSettingsView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel MaxWidth="900" HorizontalAlignment="Left">
        <TextBlock Classes="PageTitle" Text="Tablet Settings" />
        <TextBlock Classes="PageSubtitle" Text="Manage per-tablet configurations" />

        <ItemsControl ItemsSource="{Binding Profiles}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Classes="GlassPanel" Margin="0,0,0,12" Padding="16"
                            Cursor="Hand"
                            DoubleTapped="ProfileCard_DoubleTapped">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="10"
                                    Background="{DynamicResource AccentMutedBrush}" Margin="0,0,16,0">
                                <TextBlock Text="&#xE70A;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="18" Foreground="{DynamicResource AccentBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Tablet}" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                            </StackPanel>
                            <Button Grid.Column="2" Content="Open" Theme="{StaticResource AccentButton}"
                                    Command="{Binding $parent[ItemsControl].DataContext.OpenTabletSettingsCommand}"
                                    CommandParameter="{Binding}"
                                    Padding="12,6" FontSize="12" VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Border Classes="GlassPanel" Padding="32"
                IsVisible="{Binding !HasTablet}">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="No Tablets Configured" FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="Connect a tablet and it will appear here"
                           FontSize="13" Foreground="{DynamicResource TextMutedBrush}"
                           HorizontalAlignment="Center" Margin="0,8,0,0" />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
