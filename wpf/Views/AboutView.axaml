<UserControl x:Class="OtdWindowsHelper.Views.AboutView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel MaxWidth="900" HorizontalAlignment="Left">
        <TextBlock Classes="PageTitle" Text="About" />
        <TextBlock Classes="PageSubtitle" Text="Driver UX Experiment" />

        <Border Classes="GlassPanel">
            <StackPanel>
                <TextBlock Text="What is this?" FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12" />
                <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="22"
                           Foreground="{DynamicResource TextSecondaryBrush}">
                    A UX experiment exploring ideas in simplifying the experience for tablet drivers.
                    Currently interfacing with OpenTabletDriver &#x2014; an open-source, cross-platform tablet driver.
                </TextBlock>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
