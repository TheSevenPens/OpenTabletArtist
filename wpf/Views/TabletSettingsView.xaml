<UserControl x:Class="TabletDriverUX.Views.TabletSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel MaxWidth="900" HorizontalAlignment="Left">
        <TextBlock Style="{StaticResource PageTitle}" Text="Tablet Settings" />
        <TextBlock Style="{StaticResource PageSubtitle}" Text="Manage per-tablet configurations" />

        <ItemsControl ItemsSource="{Binding Profiles}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource GlassPanel}" Margin="0,0,0,12" Padding="16">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="40" Height="40" CornerRadius="10"
                                    Background="{DynamicResource AccentMutedBrush}" Margin="0,0,16,0">
                                <TextBlock Text="&#xE70A;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="18" Foreground="{DynamicResource AccentBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding [Tablet]}" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                <TextBlock FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,2,0,0">
                                    <Run Text="{Binding [OutputMode][Path], Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Border Style="{StaticResource GlassPanel}" Padding="32"
                Visibility="{Binding HasTablet, Converter={StaticResource InvBoolToVis}}">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="No Tablets Configured" FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="Connect a tablet and it will appear here"
                           FontSize="13" Foreground="{DynamicResource TextMutedBrush}"
                           HorizontalAlignment="Center" Margin="0,8,0,0" />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
