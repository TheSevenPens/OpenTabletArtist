<Window x:Class="TabletDriverUX.Views.TabletSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tablet Settings"
        Width="700" Height="550"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBaseBrush}"
        ResizeMode="CanResizeWithGrip">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="{Binding TabletName}" FontSize="20" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
            <Button Command="{Binding RefreshCommand}" HorizontalAlignment="Right"
                    ToolTip="Reload settings from daemon" Padding="8,6" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" CornerRadius="8" Padding="{TemplateBinding Padding}"
                                BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1" x:Name="Bd">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Foreground="{DynamicResource TextSecondaryBrush}" x:Name="Icon" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GlassBgHoverBrush}" />
                                <Setter TargetName="Icon" Property="Foreground" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <!-- Tab buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
            <RadioButton Content="Screen Mapping" IsChecked="True" x:Name="ScreenMappingTab"
                         Style="{StaticResource TabRadioButton}" />
            <RadioButton Content="Pen Tip &amp; Eraser" x:Name="PenTipTab"
                         Style="{StaticResource TabRadioButton}" Margin="4,0,0,0" />
            <RadioButton Content="Pen Buttons" x:Name="PenButtonsTab"
                         Style="{StaticResource TabRadioButton}" Margin="4,0,0,0" />
            <RadioButton Content="Filters" x:Name="FiltersTab"
                         Style="{StaticResource TabRadioButton}" Margin="4,0,0,0" />
            <RadioButton Content="JSON" x:Name="JsonTab"
                         Style="{StaticResource TabRadioButton}" Margin="4,0,0,0" />
        </StackPanel>

        <!-- Screen Mapping tab content -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsChecked, ElementName=ScreenMappingTab, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <!-- Output Mode -->
                <Border Style="{StaticResource GlassPanel}" Padding="16" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="OUTPUT MODE" Style="{StaticResource SectionLabel}" />
                            <TextBlock Text="{Binding OutputModeShort}" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,0" />
                            <TextBlock Text="{Binding OutputModePath}" FontSize="11"
                                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,2,0,0"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="Not using Windows Ink — pressure and tilt won't work in drawing apps"
                                       FontSize="10" Foreground="#e87930" FontStyle="Italic" Margin="0,4,0,0"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding CanFixOutputMode, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="Fix" Style="{StaticResource AccentButton}"
                                Command="{Binding FixOutputModeCommand}"
                                Padding="16,8" FontSize="12" VerticalAlignment="Center"
                                Visibility="{Binding CanFixOutputMode, Converter={StaticResource BoolToVis}}" />
                    </Grid>
                </Border>

                <!-- Area Mapping -->
                <Border Style="{StaticResource GlassPanel}" Padding="16" Margin="0,0,0,12"
                        Visibility="{Binding HasAreaMapping, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="AREA MAPPING" Style="{StaticResource SectionLabel}" />

                        <!-- Display selection as radio buttons -->
                        <TextBlock Text="Map tablet to display" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,8,0,6" />
                        <ListBox ItemsSource="{Binding Displays}"
                                 SelectedItem="{Binding SelectedDisplay}"
                                 Background="Transparent" BorderThickness="0"
                                 Padding="0">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <RadioButton IsChecked="{Binding IsSelected, RelativeSource={RelativeSource TemplatedParent}}"
                                                             Margin="0,3,0,3" Cursor="Hand"
                                                             Foreground="{DynamicResource TextPrimaryBrush}">
                                                    <TextBlock Text="{Binding Label}" FontSize="11" />
                                                </RadioButton>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>

                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Pen Tip & Eraser tab content -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsChecked, ElementName=PenTipTab, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <!-- Tip -->
                <Border Style="{StaticResource GlassPanel}" Padding="16" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="PEN TIP" Style="{StaticResource SectionLabel}" />
                            <TextBlock FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,8,0,0"
                                       FontWeight="SemiBold" Text="{Binding TipBinding}" />
                            <TextBlock FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0"
                                       Visibility="{Binding TipPressure, Converter={StaticResource NonEmptyToVis}}">
                                <Run Text="Activation threshold: " /><Run Text="{Binding TipPressure, Mode=OneWay}" />
                            </TextBlock>
                            <TextBlock Text="Not using recommended Adaptive Binding — pressure may not work correctly in drawing apps"
                                       FontSize="10" Foreground="#e87930" FontStyle="Italic" Margin="0,4,0,0"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding CanFixTip, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="Fix" Style="{StaticResource AccentButton}"
                                Command="{Binding FixTipBindingCommand}"
                                Padding="16,8" FontSize="12" VerticalAlignment="Center"
                                Visibility="{Binding CanFixTip, Converter={StaticResource BoolToVis}}" />
                    </Grid>
                </Border>

                <!-- Eraser -->
                <Border Style="{StaticResource GlassPanel}" Padding="16" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="ERASER" Style="{StaticResource SectionLabel}" />
                            <TextBlock FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,8,0,0"
                                       FontWeight="SemiBold" Text="{Binding EraserBinding}" />
                            <TextBlock FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0"
                                       Visibility="{Binding EraserPressure, Converter={StaticResource NonEmptyToVis}}">
                                <Run Text="Activation threshold: " /><Run Text="{Binding EraserPressure, Mode=OneWay}" />
                            </TextBlock>
                            <TextBlock Text="Not using recommended Adaptive Binding"
                                       FontSize="10" Foreground="#e87930" FontStyle="Italic" Margin="0,4,0,0"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding CanFixEraser, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="Fix" Style="{StaticResource AccentButton}"
                                Command="{Binding FixEraserBindingCommand}"
                                Padding="16,8" FontSize="12" VerticalAlignment="Center"
                                Visibility="{Binding CanFixEraser, Converter={StaticResource BoolToVis}}" />
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Pen Buttons tab content -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsChecked, ElementName=PenButtonsTab, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <!-- Pen Buttons -->
                <Border Style="{StaticResource GlassPanel}" Padding="16" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="PEN BUTTONS" Style="{StaticResource SectionLabel}" />
                            <ItemsControl ItemsSource="{Binding PenButtons}" Margin="0,8,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,3">
                                            <TextBlock Text="{Binding Label}" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" Width="80" />
                                            <TextBlock Text="{Binding Name}" FontSize="11"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="No pen buttons configured" FontSize="11" FontStyle="Italic"
                                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,8,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PenButtons.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="Not all pen buttons use recommended Adaptive Binding"
                                       FontSize="10" Foreground="#e87930" FontStyle="Italic" Margin="0,4,0,0"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding CanFixPenButtons, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="Fix All" Style="{StaticResource AccentButton}"
                                Command="{Binding FixPenButtonsCommand}"
                                Padding="16,8" FontSize="12" VerticalAlignment="Top" Margin="12,0,0,0"
                                Visibility="{Binding CanFixPenButtons, Converter={StaticResource BoolToVis}}" />
                    </Grid>
                </Border>

                <!-- Aux Buttons -->
                <Border Style="{StaticResource GlassPanel}" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="AUXILIARY BUTTONS" Style="{StaticResource SectionLabel}" />
                        <ItemsControl ItemsSource="{Binding AuxButtons}" Margin="0,8,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,3,0,3">
                                        <TextBlock Text="{Binding Label}" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" Width="80" />
                                        <TextBlock Text="{Binding Name}" FontSize="11"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="No auxiliary buttons configured" FontSize="11" FontStyle="Italic"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,8,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AuxButtons.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Filters tab content -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsChecked, ElementName=FiltersTab, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <Border Style="{StaticResource GlassPanel}" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="FILTERS" Style="{StaticResource SectionLabel}" />
                        <TextBlock Text="{Binding FiltersText}" FontSize="11"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,8,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- JSON tab content -->
        <Border Grid.Row="2" Style="{StaticResource GlassPanel}" Padding="16"
                Visibility="{Binding IsChecked, ElementName=JsonTab, Converter={StaticResource BoolToVis}}">
            <TextBox Text="{Binding RawJson, Mode=OneWay}" IsReadOnly="True"
                     FontFamily="Cascadia Code, Consolas, Courier New" FontSize="11"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     Background="Transparent" BorderThickness="0"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                     TextWrapping="NoWrap" />
        </Border>
    </Grid>
</Window>
