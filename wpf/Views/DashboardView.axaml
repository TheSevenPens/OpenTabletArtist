<UserControl x:Class="OtdWindowsHelper.Views.DashboardView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel MaxWidth="900" HorizontalAlignment="Left">
        <!-- Page Header -->
        <TextBlock Classes="PageTitle" Text="Dashboard" />
        <TextBlock Classes="PageSubtitle" Text="Overview of your tablet configuration" />

        <StackPanel>
            <!-- OpenTabletDriver Version -->
            <Border Classes="GlassPanel" Margin="0,0,0,12" Padding="16">
                <StackPanel Orientation="Horizontal">
                    <Border Width="48" Height="48" CornerRadius="12" Margin="0,0,16,0"
                            Background="{DynamicResource GlassBgBrush}">
                        <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextMutedBrush}" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="OpenTabletDriver Version" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Text="{Binding CurrentOtdVersion}" Margin="0,4,0,0" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- OTD Status -->
            <Border Classes="GlassPanel" Margin="0,0,0,12" Padding="16">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Border Width="48" Height="48" CornerRadius="12" Margin="0,0,16,0"
                                Background="{DynamicResource GlassBgBrush}"
                                Classes.active="{Binding IsConnected}">
                            <Border.Styles>
                                <Style Selector="Border.active">
                                    <Setter Property="Background" Value="{DynamicResource SuccessMutedBrush}" />
                                </Style>
                            </Border.Styles>
                            <TextBlock Text="&#xE839;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Classes.active="{Binding IsConnected}">
                                <TextBlock.Styles>
                                    <Style Selector="TextBlock.active">
                                        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                    </Style>
                                </TextBlock.Styles>
                            </TextBlock>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="OpenTabletDriver Daemon" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Classes="statusMarkWarn" Classes.success="{Binding IsConnected}" />
                                <TextBlock Text="{Binding DaemonStatusText}" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                            </StackPanel>

                            <!-- Daemon ownership indicator (one of three states while connected) -->

                            <!-- App-owned: connected to this project's build -->
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                                        IsVisible="{Binding ShowAppOwnedDaemon}">
                                <TextBlock Classes="success" />
                                <TextBlock FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource SuccessBrush}"
                                           Text="App-owned daemon"
                                           ToolTip.Tip="{Binding DaemonSourcePath}" />
                            </StackPanel>

                            <!-- External: connected to an OTD instance that isn't this project's build -->
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                                        IsVisible="{Binding ShowForeignDaemonWarning}">
                                <TextBlock Classes="warning" />
                                <TextBlock FontSize="10" FontWeight="SemiBold" TextWrapping="Wrap"
                                           Foreground="{DynamicResource WarningBrush}"
                                           Text="External daemon (not app-owned) — click Restart to use this project's build"
                                           ToolTip.Tip="{Binding DaemonSourcePath}" />
                            </StackPanel>

                            <!-- Unknown: connected but couldn't read the daemon's exe path -->
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                                        IsVisible="{Binding ShowDaemonSourceUnknown}">
                                <TextBlock Classes="neutral" />
                                <TextBlock FontSize="10"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Text="Daemon source unknown" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Refresh button -->
                        <Button Command="{Binding RefreshConnectionCommand}"
                                ToolTip.Tip="Check daemon status"
                                Theme="{StaticResource IconButton}" Margin="0,0,6,0">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </Button>
                        <!-- Start button: show when NOT connected -->
                        <Button Content="Start" Theme="{StaticResource AccentButton}"
                                Command="{Binding StartDaemonCommand}"
                                IsVisible="{Binding !IsConnected}"
                                Padding="12,6" FontSize="12" />
                        <!-- Restart button: show when connected -->
                        <Button Content="Restart" Theme="{StaticResource AccentButton}"
                                Command="{Binding RestartDaemonCommand}"
                                IsVisible="{Binding IsConnected}"
                                Padding="12,6" FontSize="12" />
                        <!-- Stop button: show when connected -->
                        <Button Content="Stop" Theme="{StaticResource DeleteButton}"
                                Command="{Binding StopDaemonCommand}"
                                IsVisible="{Binding IsConnected}"
                                Padding="12,6" FontSize="12" Margin="6,0,0,0" />
                        <!-- Launch OTD's own UX -->
                        <Button Content="OTD UX" Theme="{StaticResource GhostButton}"
                                Command="{Binding LaunchOtdUxCommand}"
                                Padding="12,6" FontSize="12" Margin="6,0,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Tablet Status -->
            <Border Classes="GlassPanel" Margin="0,0,0,12" Padding="16">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Border Width="48" Height="48" CornerRadius="12" Margin="0,0,16,0"
                                Background="{DynamicResource GlassBgBrush}"
                                Classes.active="{Binding HasTablet}">
                            <Border.Styles>
                                <Style Selector="Border.active">
                                    <Setter Property="Background" Value="{DynamicResource SuccessMutedBrush}" />
                                </Style>
                            </Border.Styles>
                            <TextBlock Text="&#xE70A;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Classes.active="{Binding HasTablet}">
                                <TextBlock.Styles>
                                    <Style Selector="TextBlock.active">
                                        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                    </Style>
                                </TextBlock.Styles>
                            </TextBlock>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Tablet" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Classes="statusMark" Classes.success="{Binding HasTablet}" />
                                <TextBlock Text="{Binding TabletStatusText}" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="1" Content="Open"
                            Command="{Binding OpenConnectedTabletSettingsCommand}"
                            IsEnabled="{Binding HasTablet}"
                            VerticalAlignment="Center"
                            Theme="{StaticResource AccentButton}"
                            Padding="12,6" FontSize="12" />
                </Grid>
            </Border>

            <!-- VMulti Status -->
            <Border Classes="GlassPanel" Margin="0,0,0,12" Padding="16">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Border Grid.Column="0" Width="48" Height="48" CornerRadius="12" Margin="0,0,16,0"
                            Background="{DynamicResource GlassBgBrush}"
                            Classes.active="{Binding VmultiInstalled}">
                        <Border.Styles>
                            <Style Selector="Border.active">
                                <Setter Property="Background" Value="{DynamicResource SuccessMutedBrush}" />
                            </Style>
                        </Border.Styles>
                        <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Classes.active="{Binding VmultiInstalled}">
                            <TextBlock.Styles>
                                <Style Selector="TextBlock.active">
                                    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                </Style>
                            </TextBlock.Styles>
                        </TextBlock>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="VMulti Driver" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <Button Command="{Binding RefreshVmultiDetectionCommand}" Cursor="Hand"
                                    Width="20" Height="20" Margin="6,0,0,0" VerticalAlignment="Center"
                                    ToolTip.Tip="Refresh VMulti status"
                                    Background="Transparent" BorderThickness="0" Padding="0">
                                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Button>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Classes="statusMarkWarn" Classes.success="{Binding VmultiInstalled}" />
                            <TextBlock Text="{Binding VmultiMessage}" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </StackPanel>
                        <TextBlock FontSize="10" Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0">
                            <Run Text="Setup API: " /><Run Text="{Binding VmultiSetupApiStatus}" />
                        </TextBlock>
                        <TextBlock FontSize="10" Foreground="{DynamicResource TextMutedBrush}" Margin="0,2,0,0">
                            <Run Text="HID: " /><Run Text="{Binding VmultiHidStatus}" />
                        </TextBlock>
                        <!-- Install status text (shown during installation) -->
                        <TextBlock Text="{Binding VmultiInstallStatus}" FontSize="10"
                                   Foreground="{DynamicResource AccentBrush}" Margin="0,2,0,0"
                                   IsVisible="{Binding VmultiInstalling}" />
                        <TextBlock Text="Required for pressure &amp; tilt" FontSize="10"
                                   Foreground="{DynamicResource TextMutedBrush}" FontStyle="Italic"
                                   Margin="0,2,0,0"
                                   IsVisible="{Binding !VmultiInstalled}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Browse button -->
                        <Button Content="Browse" Theme="{StaticResource AccentButton}"
                                Command="{Binding OpenFolderCommand}"
                                CommandParameter="C:\Program Files\VMulti"
                                Padding="12,6" FontSize="12" Margin="0,0,8,0" />
                        <!-- Install button -->
                        <Button Content="Install" Theme="{StaticResource AccentButton}"
                                Command="{Binding InstallVmultiCommand}"
                                Padding="12,6" FontSize="12" Margin="0,0,8,0"
                                IsVisible="{Binding ShowInstallButton}" />
                        <!-- Uninstall button -->
                        <Button Content="Uninstall" Theme="{StaticResource AccentButton}"
                                Command="{Binding UninstallVmultiCommand}"
                                Padding="12,6" FontSize="12"
                                IsVisible="{Binding ShowUninstallButton}" />
                        <!-- Progress indicator -->
                        <TextBlock Text="{Binding VmultiInstallStatus}" FontSize="11"
                                   Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"
                                   IsVisible="{Binding VmultiInstalling}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Windows Ink Status -->
            <Border Classes="GlassPanel" Margin="0,0,0,12" Padding="16">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Border Grid.Column="0" Width="48" Height="48" CornerRadius="12" Margin="0,0,16,0"
                            VerticalAlignment="Top"
                            Classes.active="{Binding WinInkInstalled}">
                        <Border.Styles>
                            <Style Selector="Border">
                                <Setter Property="Background" Value="{DynamicResource GlassBgBrush}" />
                            </Style>
                            <Style Selector="Border.active">
                                <Setter Property="Background" Value="{DynamicResource SuccessMutedBrush}" />
                            </Style>
                        </Border.Styles>
                        <TextBlock Text="&#xEDC6;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Classes.active="{Binding WinInkInstalled}">
                            <TextBlock.Styles>
                                <Style Selector="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                </Style>
                                <Style Selector="TextBlock.active">
                                    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                </Style>
                            </TextBlock.Styles>
                        </TextBlock>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <!-- Title + installed plugin version -->
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Kuuube's Windows Ink plugin" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
                            <Border Margin="8,0,0,0" CornerRadius="4" Padding="6,1"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource GlassBgBrush}"
                                    IsVisible="{Binding WinInkInstalled}">
                                <TextBlock Text="{Binding WinInkPluginVersion, StringFormat='v{0}'}"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                            </Border>
                        </StackPanel>

                        <!-- Install status -->
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Classes="statusMarkWarn" Classes.success="{Binding WinInkInstalled}" />
                            <TextBlock Text="{Binding WinInkInstallStatusText}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </StackPanel>

                        <!-- Output-mode usage (only meaningful when installed) -->
                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0"
                                    IsVisible="{Binding WinInkInstalled}">
                            <TextBlock Text="Output mode:" FontSize="10"
                                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,6,0" />
                            <TextBlock Text="{Binding WindowsInkStatusText}" FontSize="10"
                                       Foreground="{DynamicResource TextMutedBrush}" />
                        </StackPanel>

                        <!-- Supported driver version vs running OTD version -->
                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0"
                                    IsVisible="{Binding WinInkInstalled}">
                            <TextBlock FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                                       Text="{Binding WinInkSupportedDriverVersion, StringFormat='Supported driver: v{0}'}" />
                            <TextBlock FontSize="10" Foreground="{DynamicResource TextMutedBrush}" Margin="8,0,0,0"
                                       Text="{Binding CurrentOtdVersion, StringFormat='· OTD: v{0}'}" />
                        </StackPanel>

                        <!-- Compatibility mismatch warning -->
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                                    IsVisible="{Binding WinInkVersionMismatch}">
                            <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                       Foreground="{DynamicResource WarningBrush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock FontSize="10" FontWeight="SemiBold" TextWrapping="Wrap"
                                       Foreground="{DynamicResource WarningBrush}"
                                       Text="{Binding CurrentOtdVersion, StringFormat='May be incompatible with OpenTabletDriver v{0}'}" />
                        </StackPanel>

                        <!-- Not-installed hint -->
                        <TextBlock Text="Install to enable pressure &amp; tilt in drawing apps"
                                   FontSize="10" Foreground="{DynamicResource TextMutedBrush}" FontStyle="Italic"
                                   TextWrapping="Wrap" Margin="0,4,0,0"
                                   IsVisible="{Binding !WinInkInstalled}" />

                        <!-- Update-check result -->
                        <TextBlock Text="{Binding WinInkUpdateCheckStatus}" FontSize="10" FontStyle="Italic"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,6,0,0"
                                   IsVisible="{Binding HasWinInkUpdateCheckStatus}" />

                        <!-- Action buttons -->
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0" Spacing="8">
                            <Button Content="Install" Theme="{StaticResource AccentButton}"
                                    Command="{Binding InstallWindowsInkCommand}"
                                    IsVisible="{Binding ShowWinInkInstall}" />
                            <Button Content="Check for Update" Theme="{StaticResource GhostButton}"
                                    Command="{Binding CheckForWindowsInkUpdateCommand}"
                                    IsVisible="{Binding ShowWinInkCheckUpdate}" />
                            <Button Content="{Binding WinInkLatestVersion, StringFormat='Install Update (v{0})'}"
                                    Theme="{StaticResource AccentButton}"
                                    Command="{Binding InstallWindowsInkUpdateCommand}"
                                    IsVisible="{Binding ShowWinInkInstallUpdate}" />
                            <Button Content="Uninstall" Theme="{StaticResource DeleteButton}"
                                    Command="{Binding UninstallWindowsInkCommand}"
                                    IsVisible="{Binding ShowWinInkUninstall}" />
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center"
                                        IsVisible="{Binding WinInkBusy}">
                                <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding WinInkBusyStatus}" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Refresh plugin info -->
                    <Button Grid.Column="2" VerticalAlignment="Top"
                            Command="{Binding RefreshWindowsInkCommand}"
                            IsVisible="{Binding ShowWinInkRefresh}"
                            ToolTip.Tip="Refresh plugin info"
                            Theme="{StaticResource IconButton}">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                    </Button>
                </Grid>
            </Border>

        </StackPanel>
    </StackPanel>
</UserControl>
