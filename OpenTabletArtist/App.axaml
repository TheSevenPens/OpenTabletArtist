<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="using:System"
             xmlns:conv="using:OpenTabletArtist.Converters"
             xmlns:vm="using:OpenTabletArtist.ViewModels"
             xmlns:views="using:OpenTabletArtist.Views"
             x:Class="OpenTabletArtist.App">

    <Application.Styles>
        <FluentTheme />
        <!-- Theme for the ColorPicker control (Custom theme accent picker); not bundled in FluentTheme. -->
        <StyleInclude Source="avares://Avalonia.Controls.ColorPicker/Themes/Fluent/Fluent.xaml" />
        <StyleInclude Source="avares://OpenTabletArtist/Themes/Styles.axaml" />
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://OpenTabletArtist/Themes/Colors.axaml" />
                <!-- Dependency-free icon geometries (Path/PathIcon). See Themes/Icons.axaml. -->
                <ResourceInclude Source="avares://OpenTabletArtist/Themes/Icons.axaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- ===== Content font size (#fontstd) =========================================
                 THE one knob for content text size. `ContentFontSize` is the app-wide body/
                 label/control size; overriding Fluent's `ControlContentThemeFontSize` with the
                 same value makes native controls (ComboBox, TextBox, CheckBox, …) match. Nav
                 bars and page headers set their own sizes and are unaffected. Change both to
                 retune the whole content scale. -->
            <sys:Double x:Key="ContentFontSize">12</sys:Double>
            <sys:Double x:Key="ControlContentThemeFontSize">12</sys:Double>

            <!-- ===== Zune type ramp (redesign Phase 0.4) ===================================
                 Named heading scale so the redesign can retune the display sizes in one place
                 (Phase 3 grows the page/pivot type). Segoe UI Light is the Zune display face.
                 Values match today's look — this is a rename, not a resize. `TypeBodySize` == the
                 content scale above. See docs/design/zune-redesign.md. -->
            <FontFamily x:Key="DisplayFontFamily">Segoe UI, Inter</FontFamily>
            <sys:Double x:Key="TypeDisplaySize">28</sys:Double>   <!-- page title (later: pivots) -->
            <sys:Double x:Key="TypeTitleSize">15</sys:Double>     <!-- subpage / body title -->
            <sys:Double x:Key="TypeBodySize">12</sys:Double>      <!-- body + labels -->
            <sys:Double x:Key="TypeCaptionSize">10</sys:Double>   <!-- captions, badges, chips, status text -->

            <!-- Shared page transition: a quick crossfade for subpage/content swaps (the Zune motion
                 layer). Applied to the tabbed-page content host now; the top-level shell adopts it in a
                 later phase. -->
            <CrossFade x:Key="PageFade" Duration="0:0:0.18" />

            <!-- One shared width for every tabbed page's vertical tab rail, so they line up across pages.
                 Sized to fit the longest tab name in the app ("PRESSURE DYNAMICS" / "POSITION DYNAMICS"). -->
            <sys:Double x:Key="TabRailWidth">160</sys:Double>

            <!-- Square everything (Metro/Zune). Overriding Fluent's control + overlay corner radii squares
                 the built-in controls (ComboBox, TextBox, CheckBox, Slider, flyouts/menus/popups); the
                 app's own cards, buttons, chips, and badges are squared at their source. -->
            <CornerRadius x:Key="ControlCornerRadius">0</CornerRadius>
            <CornerRadius x:Key="OverlayCornerRadius">0</CornerRadius>

            <conv:InverseBoolConverter x:Key="InvBool" />
            <conv:EnumEqualsConverter x:Key="EnumEquals" />
            <conv:NotNullConverter x:Key="NotNull" />
            <conv:NonEmptyToBoolConverter x:Key="NonEmptyToBool" />
            <conv:AllFalseBoolConverter x:Key="AllFalseBool" />
            <conv:NotFirstAndSecondBoolConverter x:Key="NotFirstAndSecondBool" />
        </ResourceDictionary>
    </Application.Resources>

    <!-- Typed navigation (#15): the content host maps each page VM to its view by type.
         This replaces the page-name string + PageToViewConverter, and lets each view inherit
         its VM as DataContext directly (no per-view DataContext re-point). -->
    <Application.DataTemplates>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}"><views:DashboardView /></DataTemplate>
        <!-- PenPageViewModel derives from TabletPageViewModel, and DataTemplate matching is polymorphic +
             first-match-wins, so the derived pen template MUST precede the tablet one. -->
        <DataTemplate DataType="{x:Type vm:PenPageViewModel}"><views:PenPageView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:TabletPageViewModel}"><views:TabletPageView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:TabletDetailViewModel}"><views:TabletDetailView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:PresetsViewModel}"><views:PresetsView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:HotkeysViewModel}"><views:HotkeysView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:PerAppViewModel}"><views:PerAppView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:CustomTabletConfigsViewModel}"><views:CustomTabletConfigsView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:DriverCleanupViewModel}"><views:DriverCleanupView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:DiagnosticsViewModel}"><views:DiagnosticsView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:TestViewModel}"><views:TestView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:LogViewModel}"><views:LogView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:DaemonViewModel}"><views:DaemonView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:WindowsInkViewModel}"><views:WindowsInkView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:VMultiViewModel}"><views:VMultiView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:PluginsViewModel}"><views:PluginsView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:AdvancedViewModel}"><views:AdvancedView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}"><views:SettingsView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:CompositeSectionViewModel}"><views:CompositeSectionView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:StartupViewModel}"><views:StartupView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:DeveloperViewModel}"><views:DeveloperView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ShortcutViewModel}"><views:ShortcutView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ThemeViewModel}"><views:ThemeView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:AboutViewModel}"><views:AboutView /></DataTemplate>
    </Application.DataTemplates>
</Application>
