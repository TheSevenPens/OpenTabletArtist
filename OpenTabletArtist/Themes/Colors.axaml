<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:svc="using:OpenTabletArtist.Services">

    <!-- ============================================================================
         Theming (#139): light + dark, switched by the app's ThemeVariant.
         - Variant-INDEPENDENT colors/brushes (accent + status) live at the top level.
         - Variant-SPECIFIC colors/brushes (backgrounds, text, glass, dividers) live in
           the Light/Dark theme dictionaries below; consumers bind with DynamicResource so
           they re-resolve when Application.RequestedThemeVariant changes.
         ============================================================================ -->

    <!-- Shared status colours (variant-independent). NOTE: the ACCENT (and its derived button/card
         resources) is intentionally NOT here — it lives in each theme dictionary instead, because a
         top-level resource shadows a same-key entry in the ThemeDictionaries, which would stop the
         Sakura skin from re-colouring the accent (#207). -->
    <Color x:Key="Success">#10B981</Color>
    <Color x:Key="SuccessMuted">#1A10B981</Color>
    <Color x:Key="Warning">#F59E0B</Color>
    <Color x:Key="WarningMuted">#1AF59E0B</Color>
    <Color x:Key="Error">#EF4444</Color>
    <Color x:Key="ErrorMuted">#1AEF4444</Color>
    <Color x:Key="Info">#3B82F6</Color>
    <Color x:Key="InfoMuted">#1A3B82F6</Color>
    <!-- Neutral grey for "inactive / not applicable" states (e.g. the tablet page's not-detected status
         chip). Mid-grey so white chip text keeps AA contrast on every theme. -->
    <Color x:Key="Neutral">#6B7280</Color>
    <Color x:Key="TextInverse">#FFFFFF</Color>

    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Success}" />
    <SolidColorBrush x:Key="SuccessMutedBrush" Color="{StaticResource SuccessMuted}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Warning}" />
    <SolidColorBrush x:Key="WarningMutedBrush" Color="{StaticResource WarningMuted}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource Error}" />
    <SolidColorBrush x:Key="ErrorMutedBrush" Color="{StaticResource ErrorMuted}" />
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource Info}" />
    <SolidColorBrush x:Key="InfoMutedBrush" Color="{StaticResource InfoMuted}" />
    <SolidColorBrush x:Key="NeutralBrush" Color="{StaticResource Neutral}" />
    <SolidColorBrush x:Key="TextInverseBrush" Color="{StaticResource TextInverse}" />

    <!-- Dimming scrim drawn over the backdrop image so text stays legible on a busy photo. Transparent
         by default (a no-op for every theme); the Custom skin sets it at runtime when an image is chosen. -->
    <SolidColorBrush x:Key="BackdropScrimBrush" Color="Transparent" />

    <!-- Canonical monospace family for code / numeric readouts (Log, Diagnostics, JSON, dynamics values).
         One definition so these don't drift into several different Consolas/Cascadia spellings. Consolas
         first — it ships on every Windows and is what most of these readouts already used, so the look
         stays familiar; Cascadia Mono / the generic monospace are fallbacks. -->
    <FontFamily x:Key="MonoFontFamily">Consolas, Cascadia Mono, monospace</FontFamily>

    <ResourceDictionary.ThemeDictionaries>

        <!-- ===== Light ===== -->
        <ResourceDictionary x:Key="Light">
            <Color x:Key="BgBase">#F0F0F6</Color>
            <Color x:Key="BgElevated">#F7F7FC</Color>
            <Color x:Key="BgSurface">#FFFFFF</Color>
            <Color x:Key="GlassBg">#A6FFFFFF</Color>
            <Color x:Key="GlassBgHover">#BFFFFFFF</Color>
            <Color x:Key="GlassBorder">#33000000</Color>
            <Color x:Key="TextPrimary">#F0000000</Color>
            <Color x:Key="TextSecondary">#CC000000</Color>
            <Color x:Key="TextMuted">#99000000</Color>
            <Color x:Key="Divider">#1A000000</Color>

            <SolidColorBrush x:Key="BgBaseBrush" Color="{StaticResource BgBase}" />
            <SolidColorBrush x:Key="BgElevatedBrush" Color="{StaticResource BgElevated}" />
            <SolidColorBrush x:Key="BgSurfaceBrush" Color="{StaticResource BgSurface}" />
            <SolidColorBrush x:Key="GlassBgBrush" Color="{StaticResource GlassBg}" />
            <SolidColorBrush x:Key="GlassBgHoverBrush" Color="{StaticResource GlassBgHover}" />
            <SolidColorBrush x:Key="GlassBorderBrush" Color="{StaticResource GlassBorder}" />
            <!-- Unified with the nav-bar text colour (TextSecondary): all general body text uses one value;
                 only specially-coloured text (Success/Accent/Warning) differs. -->
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextSecondary}" />
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
            <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextSecondary}" />
            <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource Divider}" />

            <!-- Sidebar fill — same as the card glass here; the Anime skin gives it its own look. -->
            <SolidColorBrush x:Key="SidebarBgBrush" Color="{StaticResource GlassBg}" />

            <!-- Accent + derived button/card resources. Per-theme (not top-level) so the Sakura skin
                 can override them — see the note at the top. Light + Dark share the indigo accent. -->
            <Color x:Key="Accent">#6366F1</Color>
            <Color x:Key="AccentMuted">#1A6366F1</Color>
            <Color x:Key="NavActive">#1A6366F1</Color>
            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}" />
            <SolidColorBrush x:Key="AccentMutedBrush" Color="{StaticResource AccentMuted}" />
            <SolidColorBrush x:Key="NavActiveBrush" Color="{StaticResource NavActive}" />
            <SolidColorBrush x:Key="AccentButtonFillBrush" Color="{StaticResource AccentMuted}" />
            <SolidColorBrush x:Key="AccentButtonForegroundBrush" Color="{StaticResource Accent}" />
            <SolidColorBrush x:Key="AccentButtonFillHoverBrush" Color="{StaticResource Accent}" />
            <SolidColorBrush x:Key="AccentButtonForegroundHoverBrush" Color="{StaticResource TextInverse}" />
            <CornerRadius x:Key="CardCornerRadius">8</CornerRadius>
            <BoxShadows x:Key="CardShadow">0 2 12 0 #14000000</BoxShadows>

            <!-- Full-window backdrop layer behind content; flat themes have none (see Anime). -->
            <SolidColorBrush x:Key="AppBackdropBrush" Color="Transparent" />

            <Color x:Key="PenDiagramFill">#D8DCE8</Color>
            <Color x:Key="PenDiagramButtonFill">#C8CDE0</Color>
            <Color x:Key="PenDiagramStroke">#6366F1</Color>
            <SolidColorBrush x:Key="PenDiagramFillBrush" Color="{StaticResource PenDiagramFill}" />
            <SolidColorBrush x:Key="PenDiagramButtonFillBrush" Color="{StaticResource PenDiagramButtonFill}" />
            <SolidColorBrush x:Key="PenDiagramStrokeBrush" Color="{StaticResource PenDiagramStroke}" />
        </ResourceDictionary>

        <!-- ===== Dark ===== -->
        <ResourceDictionary x:Key="Dark">
            <Color x:Key="BgBase">#13131C</Color>
            <Color x:Key="BgElevated">#1B1B28</Color>
            <Color x:Key="BgSurface">#232336</Color>
            <Color x:Key="GlassBg">#1FFFFFFF</Color>
            <Color x:Key="GlassBgHover">#2EFFFFFF</Color>
            <Color x:Key="GlassBorder">#26FFFFFF</Color>
            <Color x:Key="TextPrimary">#F2FFFFFF</Color>
            <Color x:Key="TextSecondary">#CCFFFFFF</Color>
            <Color x:Key="TextMuted">#80FFFFFF</Color>
            <Color x:Key="Divider">#1AFFFFFF</Color>

            <SolidColorBrush x:Key="BgBaseBrush" Color="{StaticResource BgBase}" />
            <SolidColorBrush x:Key="BgElevatedBrush" Color="{StaticResource BgElevated}" />
            <SolidColorBrush x:Key="BgSurfaceBrush" Color="{StaticResource BgSurface}" />
            <SolidColorBrush x:Key="GlassBgBrush" Color="{StaticResource GlassBg}" />
            <SolidColorBrush x:Key="GlassBgHoverBrush" Color="{StaticResource GlassBgHover}" />
            <SolidColorBrush x:Key="GlassBorderBrush" Color="{StaticResource GlassBorder}" />
            <!-- Unified with the nav-bar text colour (TextSecondary): all general body text uses one value;
                 only specially-coloured text (Success/Accent/Warning) differs. -->
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextSecondary}" />
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
            <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextSecondary}" />
            <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource Divider}" />

            <SolidColorBrush x:Key="SidebarBgBrush" Color="{StaticResource GlassBg}" />

            <!-- Accent + derived button/card resources (indigo; matches Light). Per-theme so Sakura
                 can override — see the note at the top. -->
            <Color x:Key="Accent">#6366F1</Color>
            <Color x:Key="AccentMuted">#1A6366F1</Color>
            <Color x:Key="NavActive">#1A6366F1</Color>
            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}" />
            <SolidColorBrush x:Key="AccentMutedBrush" Color="{StaticResource AccentMuted}" />
            <SolidColorBrush x:Key="NavActiveBrush" Color="{StaticResource NavActive}" />
            <SolidColorBrush x:Key="AccentButtonFillBrush" Color="{StaticResource AccentMuted}" />
            <SolidColorBrush x:Key="AccentButtonForegroundBrush" Color="{StaticResource Accent}" />
            <SolidColorBrush x:Key="AccentButtonFillHoverBrush" Color="{StaticResource Accent}" />
            <SolidColorBrush x:Key="AccentButtonForegroundHoverBrush" Color="{StaticResource TextInverse}" />
            <CornerRadius x:Key="CardCornerRadius">8</CornerRadius>
            <BoxShadows x:Key="CardShadow">0 2 12 0 #14000000</BoxShadows>

            <SolidColorBrush x:Key="AppBackdropBrush" Color="Transparent" />

            <Color x:Key="PenDiagramFill">#3A3A50</Color>
            <Color x:Key="PenDiagramButtonFill">#4A4A64</Color>
            <Color x:Key="PenDiagramStroke">#7C7EF4</Color>
            <SolidColorBrush x:Key="PenDiagramFillBrush" Color="{StaticResource PenDiagramFill}" />
            <SolidColorBrush x:Key="PenDiagramButtonFillBrush" Color="{StaticResource PenDiagramButtonFill}" />
            <SolidColorBrush x:Key="PenDiagramStrokeBrush" Color="{StaticResource PenDiagramStroke}" />
        </ResourceDictionary>

        <!-- ===== Anime (experimental skin, #anime) =====
             A pink light-mode skin: re-skins app surfaces over a sakura backdrop image, leaning on
             the existing translucent "glass" panels so the image shows through. Keyed by the custom
             AnimeVariant, which inherits Light — so anything not overridden here (incl. all Fluent
             control resources) resolves from the Light theme. Cards stay translucent so the sakura
             backdrop shows through; the sidebar gets its own pink translucent gradient. -->
        <ResourceDictionary x:Key="{x:Static svc:ThemeService.AnimeVariant}">
            <!-- Pink accent (ties to the app's magenta mark) overriding the shared indigo. -->
            <Color x:Key="Accent">#E0218A</Color>
            <Color x:Key="AccentMuted">#1FE0218A</Color>
            <Color x:Key="NavActive">#24E0218A</Color>
            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}" />
            <SolidColorBrush x:Key="AccentMutedBrush" Color="{StaticResource AccentMuted}" />
            <SolidColorBrush x:Key="NavActiveBrush" Color="{StaticResource NavActive}" />

            <!-- Fluent's native-control accent ramp (#216): toggles, checkboxes, combo/list selection,
                 sliders, focus rings. Without these, native controls keep Fluent's default blue accent
                 even in Sakura. Light1-3 = progressively lighter, Dark1-3 = darker, around the #E0218A
                 base; Fluent picks the right shade per state/variant. -->
            <Color x:Key="SystemAccentColor">#E0218A</Color>
            <Color x:Key="SystemAccentColorLight1">#E73E9C</Color>
            <Color x:Key="SystemAccentColorLight2">#EE5EAE</Color>
            <Color x:Key="SystemAccentColorLight3">#F488C4</Color>
            <Color x:Key="SystemAccentColorDark1">#C41C79</Color>
            <Color x:Key="SystemAccentColorDark2">#A41667</Color>
            <Color x:Key="SystemAccentColorDark3">#81104F</Color>

            <!-- Fluent's RadioButton checked fill uses its own keys (not SystemAccentColor), so without
                 these the selected radio stays Fluent-blue even in Sakura. Point them at the pink accent. -->
            <SolidColorBrush x:Key="RadioButtonOuterEllipseCheckedFill" Color="{StaticResource Accent}" />
            <SolidColorBrush x:Key="RadioButtonOuterEllipseCheckedFillPointerOver" Color="{StaticResource SystemAccentColorLight1}" />
            <SolidColorBrush x:Key="RadioButtonOuterEllipseCheckedFillPressed" Color="{StaticResource SystemAccentColorDark1}" />
            <SolidColorBrush x:Key="RadioButtonOuterEllipseCheckedStroke" Color="{StaticResource Accent}" />
            <SolidColorBrush x:Key="RadioButtonOuterEllipseCheckedStrokePointerOver" Color="{StaticResource SystemAccentColorLight1}" />
            <SolidColorBrush x:Key="RadioButtonOuterEllipseCheckedStrokePressed" Color="{StaticResource SystemAccentColorDark1}" />

            <Color x:Key="BgBase">#FCE3EE</Color>
            <Color x:Key="BgElevated">#FFF1F7</Color>
            <Color x:Key="BgSurface">#FFFFFF</Color>
            <!-- Translucent pink-white so the sakura backdrop shows through the cards (still opaque
                 enough to keep text legible). -->
            <Color x:Key="GlassBg">#CCFDF1F7</Color>
            <Color x:Key="GlassBgHover">#E6FEF7FB</Color>
            <Color x:Key="GlassBorder">#33E0218A</Color>
            <Color x:Key="TextPrimary">#F03A0E26</Color>
            <Color x:Key="TextSecondary">#C43A0E26</Color>
            <Color x:Key="TextMuted">#8A3A0E26</Color>
            <Color x:Key="Divider">#22E0218A</Color>

            <SolidColorBrush x:Key="BgBaseBrush" Color="{StaticResource BgBase}" />
            <SolidColorBrush x:Key="BgElevatedBrush" Color="{StaticResource BgElevated}" />
            <SolidColorBrush x:Key="BgSurfaceBrush" Color="{StaticResource BgSurface}" />
            <SolidColorBrush x:Key="GlassBgBrush" Color="{StaticResource GlassBg}" />
            <SolidColorBrush x:Key="GlassBgHoverBrush" Color="{StaticResource GlassBgHover}" />
            <SolidColorBrush x:Key="GlassBorderBrush" Color="{StaticResource GlassBorder}" />
            <!-- Unified with the nav-bar text colour (TextSecondary): all general body text uses one value;
                 only specially-coloured text (Success/Accent/Warning) differs. -->
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextSecondary}" />
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
            <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextSecondary}" />
            <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource Divider}" />

            <!-- Themed sidebar: a soft pink translucent vertical gradient (deeper rose at the bottom)
                 so the panel reads as part of the skin and the backdrop still glows through. -->
            <LinearGradientBrush x:Key="SidebarBgBrush" StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Offset="0" Color="#D9FCDCEC" />
                <GradientStop Offset="1" Color="#D9F7C2DC" />
            </LinearGradientBrush>

            <!-- Accent buttons: a filled pink→rose gradient with white text (vs. the tinted/outline
                 look of the flat themes). The hover gradient lifts a touch brighter. -->
            <LinearGradientBrush x:Key="AccentButtonFillBrush" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Offset="0" Color="#FF7EC4" />
                <GradientStop Offset="1" Color="#E0218A" />
            </LinearGradientBrush>
            <SolidColorBrush x:Key="AccentButtonForegroundBrush" Color="#FFFFFF" />
            <LinearGradientBrush x:Key="AccentButtonFillHoverBrush" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Offset="0" Color="#FF93CF" />
                <GradientStop Offset="1" Color="#EC3A9B" />
            </LinearGradientBrush>
            <SolidColorBrush x:Key="AccentButtonForegroundHoverBrush" Color="#FFFFFF" />

            <!-- Softer, glowier cards: rounder corners and a diffuse pink glow instead of a grey drop.
                 Blur kept ≤16 so the glow's rendered extent fits inside the content padding and isn't
                 clipped by the scroll viewport on the left/right; alpha bumped to keep it prominent. -->
            <CornerRadius x:Key="CardCornerRadius">12</CornerRadius>
            <BoxShadows x:Key="CardShadow">0 4 16 0 #40E0218A</BoxShadows>

            <!-- The sakura backdrop. UniformToFill so it covers the window at any size. -->
            <ImageBrush x:Key="AppBackdropBrush" Stretch="UniformToFill" AlignmentX="Center" AlignmentY="Center"
                        Source="avares://OpenTabletArtist/Assets/anime-bg.png" />

            <Color x:Key="PenDiagramFill">#F7CFD8</Color>
            <Color x:Key="PenDiagramButtonFill">#EEB6C6</Color>
            <Color x:Key="PenDiagramStroke">#CF5E86</Color>
            <SolidColorBrush x:Key="PenDiagramFillBrush" Color="{StaticResource PenDiagramFill}" />
            <SolidColorBrush x:Key="PenDiagramButtonFillBrush" Color="{StaticResource PenDiagramButtonFill}" />
            <SolidColorBrush x:Key="PenDiagramStrokeBrush" Color="{StaticResource PenDiagramStroke}" />
        </ResourceDictionary>

        <!-- ===== Dark Sakura (#241) =====
             The pink Sakura accent + falling petals over a DARK scheme. Keyed by DarkSakuraVariant, which
             inherits Dark so surfaces + Fluent control resources resolve dark and text stays light. The
             same cherry-blossom backdrop as Sakura, dimmed by a dark scrim so it reads moody instead of
             bright behind the dark glass panels. -->
        <ResourceDictionary x:Key="{x:Static svc:ThemeService.DarkSakuraVariant}">
            <!-- Pink accent (same as Sakura). -->
            <Color x:Key="Accent">#E0218A</Color>
            <Color x:Key="AccentMuted">#2EE0218A</Color>
            <Color x:Key="NavActive">#3AE0218A</Color>
            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}" />
            <SolidColorBrush x:Key="AccentMutedBrush" Color="{StaticResource AccentMuted}" />
            <SolidColorBrush x:Key="NavActiveBrush" Color="{StaticResource NavActive}" />

            <!-- Fluent's native-control accent ramp (toggles, checkboxes, selection, sliders, focus). -->
            <Color x:Key="SystemAccentColor">#E0218A</Color>
            <Color x:Key="SystemAccentColorLight1">#E73E9C</Color>
            <Color x:Key="SystemAccentColorLight2">#EE5EAE</Color>
            <Color x:Key="SystemAccentColorLight3">#F488C4</Color>
            <Color x:Key="SystemAccentColorDark1">#C41C79</Color>
            <Color x:Key="SystemAccentColorDark2">#A41667</Color>
            <Color x:Key="SystemAccentColorDark3">#81104F</Color>

            <!-- Fluent's RadioButton checked fill uses its own keys, not SystemAccentColor. -->
            <SolidColorBrush x:Key="RadioButtonOuterEllipseCheckedFill" Color="{StaticResource Accent}" />
            <SolidColorBrush x:Key="RadioButtonOuterEllipseCheckedFillPointerOver" Color="{StaticResource SystemAccentColorLight1}" />
            <SolidColorBrush x:Key="RadioButtonOuterEllipseCheckedFillPressed" Color="{StaticResource SystemAccentColorDark1}" />
            <SolidColorBrush x:Key="RadioButtonOuterEllipseCheckedStroke" Color="{StaticResource Accent}" />
            <SolidColorBrush x:Key="RadioButtonOuterEllipseCheckedStrokePointerOver" Color="{StaticResource SystemAccentColorLight1}" />
            <SolidColorBrush x:Key="RadioButtonOuterEllipseCheckedStrokePressed" Color="{StaticResource SystemAccentColorDark1}" />

            <!-- Dark plum-tinted surfaces. -->
            <Color x:Key="BgBase">#17111C</Color>
            <Color x:Key="BgElevated">#201826</Color>
            <Color x:Key="BgSurface">#291F31</Color>
            <!-- Dark translucent plum glass so the dimmed backdrop glows through the panels. -->
            <Color x:Key="GlassBg">#59261C30</Color>
            <Color x:Key="GlassBgHover">#73302438</Color>
            <Color x:Key="GlassBorder">#33E0218A</Color>
            <Color x:Key="TextPrimary">#F2FFFFFF</Color>
            <Color x:Key="TextSecondary">#C8FFFFFF</Color>
            <Color x:Key="TextMuted">#8CFFFFFF</Color>
            <Color x:Key="Divider">#26E0218A</Color>

            <SolidColorBrush x:Key="BgBaseBrush" Color="{StaticResource BgBase}" />
            <SolidColorBrush x:Key="BgElevatedBrush" Color="{StaticResource BgElevated}" />
            <SolidColorBrush x:Key="BgSurfaceBrush" Color="{StaticResource BgSurface}" />
            <SolidColorBrush x:Key="GlassBgBrush" Color="{StaticResource GlassBg}" />
            <SolidColorBrush x:Key="GlassBgHoverBrush" Color="{StaticResource GlassBgHover}" />
            <SolidColorBrush x:Key="GlassBorderBrush" Color="{StaticResource GlassBorder}" />
            <!-- Unified with the nav-bar text colour (TextSecondary): all general body text uses one value;
                 only specially-coloured text (Success/Accent/Warning) differs. -->
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextSecondary}" />
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
            <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextSecondary}" />
            <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource Divider}" />

            <!-- Dark plum translucent sidebar so the backdrop glows through. -->
            <LinearGradientBrush x:Key="SidebarBgBrush" StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Offset="0" Color="#8C2A1420" />
                <GradientStop Offset="1" Color="#8C200E18" />
            </LinearGradientBrush>

            <!-- Accent buttons: the same pink→rose gradient as Sakura. -->
            <LinearGradientBrush x:Key="AccentButtonFillBrush" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Offset="0" Color="#FF7EC4" />
                <GradientStop Offset="1" Color="#E0218A" />
            </LinearGradientBrush>
            <SolidColorBrush x:Key="AccentButtonForegroundBrush" Color="#FFFFFF" />
            <LinearGradientBrush x:Key="AccentButtonFillHoverBrush" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Offset="0" Color="#FF93CF" />
                <GradientStop Offset="1" Color="#EC3A9B" />
            </LinearGradientBrush>
            <SolidColorBrush x:Key="AccentButtonForegroundHoverBrush" Color="#FFFFFF" />

            <CornerRadius x:Key="CardCornerRadius">12</CornerRadius>
            <BoxShadows x:Key="CardShadow">0 4 16 0 #40E0218A</BoxShadows>

            <!-- The sakura backdrop, dimmed by a dark plum scrim (below) so it reads dark. -->
            <ImageBrush x:Key="AppBackdropBrush" Stretch="UniformToFill" AlignmentX="Center" AlignmentY="Center"
                        Source="avares://OpenTabletArtist/Assets/anime-bg.png" />
            <SolidColorBrush x:Key="BackdropScrimBrush" Color="#C4160910" />

            <Color x:Key="PenDiagramFill">#3A2A34</Color>
            <Color x:Key="PenDiagramButtonFill">#4A3644</Color>
            <Color x:Key="PenDiagramStroke">#E0218A</Color>
            <SolidColorBrush x:Key="PenDiagramFillBrush" Color="{StaticResource PenDiagramFill}" />
            <SolidColorBrush x:Key="PenDiagramButtonFillBrush" Color="{StaticResource PenDiagramButtonFill}" />
            <SolidColorBrush x:Key="PenDiagramStrokeBrush" Color="{StaticResource PenDiagramStroke}" />
        </ResourceDictionary>

        <!-- ===== Custom (user-tunable skin) =====
             A dark translucent skin the user drives from the Theme page: one accent colour derives the
             whole scheme, and an optional background image fills the window behind the glass panels (with
             a dimming scrim for legibility). The values here are DEFAULTS — ThemeViewModel.ApplyCustom
             overrides the accent-derived brushes + backdrop live via app.Resources. Keyed by the custom
             CustomVariant, which inherits Dark so anything not overridden (incl. Fluent control resources)
             resolves dark and text stays light over a photo. Panels stay translucent so the backdrop
             shows through. -->
        <ResourceDictionary x:Key="{x:Static svc:ThemeService.CustomVariant}">
            <!-- Default accent (the app's shared indigo); replaced live when the user picks a colour. -->
            <Color x:Key="Accent">#6366F1</Color>
            <Color x:Key="AccentMuted">#1F6366F1</Color>
            <Color x:Key="NavActive">#306366F1</Color>
            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}" />
            <SolidColorBrush x:Key="AccentMutedBrush" Color="{StaticResource AccentMuted}" />
            <SolidColorBrush x:Key="NavActiveBrush" Color="{StaticResource NavActive}" />

            <!-- Fluent's native-control accent ramp (toggles, checkboxes, selection, sliders, focus). -->
            <Color x:Key="SystemAccentColor">#6366F1</Color>
            <Color x:Key="SystemAccentColorLight1">#7C7EF4</Color>
            <Color x:Key="SystemAccentColorLight2">#9698F7</Color>
            <Color x:Key="SystemAccentColorLight3">#B6B7FA</Color>
            <Color x:Key="SystemAccentColorDark1">#4F52D4</Color>
            <Color x:Key="SystemAccentColorDark2">#4043A8</Color>
            <Color x:Key="SystemAccentColorDark3">#303281</Color>

            <!-- Fluent's RadioButton checked fill uses its own keys, not SystemAccentColor. -->
            <SolidColorBrush x:Key="RadioButtonOuterEllipseCheckedFill" Color="{StaticResource Accent}" />
            <SolidColorBrush x:Key="RadioButtonOuterEllipseCheckedFillPointerOver" Color="{StaticResource SystemAccentColorLight1}" />
            <SolidColorBrush x:Key="RadioButtonOuterEllipseCheckedFillPressed" Color="{StaticResource SystemAccentColorDark1}" />
            <SolidColorBrush x:Key="RadioButtonOuterEllipseCheckedStroke" Color="{StaticResource Accent}" />
            <SolidColorBrush x:Key="RadioButtonOuterEllipseCheckedStrokePointerOver" Color="{StaticResource SystemAccentColorLight1}" />
            <SolidColorBrush x:Key="RadioButtonOuterEllipseCheckedStrokePressed" Color="{StaticResource SystemAccentColorDark1}" />

            <Color x:Key="BgBase">#13131C</Color>
            <Color x:Key="BgElevated">#1B1B28</Color>
            <Color x:Key="BgSurface">#232336</Color>
            <!-- Dark translucent glass so a background image shows through the panels. -->
            <Color x:Key="GlassBg">#59202430</Color>
            <Color x:Key="GlassBgHover">#73262A38</Color>
            <Color x:Key="GlassBorder">#26FFFFFF</Color>
            <Color x:Key="TextPrimary">#F2FFFFFF</Color>
            <Color x:Key="TextSecondary">#C8FFFFFF</Color>
            <Color x:Key="TextMuted">#8CFFFFFF</Color>
            <Color x:Key="Divider">#22FFFFFF</Color>

            <SolidColorBrush x:Key="BgBaseBrush" Color="{StaticResource BgBase}" />
            <SolidColorBrush x:Key="BgElevatedBrush" Color="{StaticResource BgElevated}" />
            <SolidColorBrush x:Key="BgSurfaceBrush" Color="{StaticResource BgSurface}" />
            <SolidColorBrush x:Key="GlassBgBrush" Color="{StaticResource GlassBg}" />
            <SolidColorBrush x:Key="GlassBgHoverBrush" Color="{StaticResource GlassBgHover}" />
            <SolidColorBrush x:Key="GlassBorderBrush" Color="{StaticResource GlassBorder}" />
            <!-- Unified with the nav-bar text colour (TextSecondary): all general body text uses one value;
                 only specially-coloured text (Success/Accent/Warning) differs. -->
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextSecondary}" />
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
            <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextSecondary}" />
            <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource Divider}" />

            <!-- Dark translucent sidebar so the backdrop glows through. -->
            <LinearGradientBrush x:Key="SidebarBgBrush" StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Offset="0" Color="#73181820" />
                <GradientStop Offset="1" Color="#73101018" />
            </LinearGradientBrush>

            <!-- Accent buttons: filled indigo gradient with white text (overridden live to the accent). -->
            <LinearGradientBrush x:Key="AccentButtonFillBrush" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Offset="0" Color="#7C7EF4" />
                <GradientStop Offset="1" Color="#6366F1" />
            </LinearGradientBrush>
            <SolidColorBrush x:Key="AccentButtonForegroundBrush" Color="#FFFFFF" />
            <LinearGradientBrush x:Key="AccentButtonFillHoverBrush" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Offset="0" Color="#9092F7" />
                <GradientStop Offset="1" Color="#787BF4" />
            </LinearGradientBrush>
            <SolidColorBrush x:Key="AccentButtonForegroundHoverBrush" Color="#FFFFFF" />

            <CornerRadius x:Key="CardCornerRadius">12</CornerRadius>
            <BoxShadows x:Key="CardShadow">0 4 16 0 #40000000</BoxShadows>

            <!-- No image by default → a transparent backdrop (the window's BgBase shows). ApplyCustom
                 swaps in the user's image + a scrim when one is chosen. -->
            <SolidColorBrush x:Key="AppBackdropBrush" Color="Transparent" />

            <Color x:Key="PenDiagramFill">#3A3A50</Color>
            <Color x:Key="PenDiagramButtonFill">#4A4A64</Color>
            <Color x:Key="PenDiagramStroke">#6366F1</Color>
            <SolidColorBrush x:Key="PenDiagramFillBrush" Color="{StaticResource PenDiagramFill}" />
            <SolidColorBrush x:Key="PenDiagramButtonFillBrush" Color="{StaticResource PenDiagramButtonFill}" />
            <SolidColorBrush x:Key="PenDiagramStrokeBrush" Color="{StaticResource PenDiagramStroke}" />
        </ResourceDictionary>

    </ResourceDictionary.ThemeDictionaries>

</ResourceDictionary>
