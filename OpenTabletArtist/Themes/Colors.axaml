<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:svc="using:OpenTabletArtist.Services">

    <!-- ============================================================================
         Theming (#139): light + dark, switched by the app's ThemeVariant.
         - Variant-INDEPENDENT colors/brushes (accent + status) live at the top level.
         - Variant-SPECIFIC colors/brushes (backgrounds, text, glass, dividers) live in
           the Light/Dark theme dictionaries below; consumers bind with DynamicResource so
           they re-resolve when Application.RequestedThemeVariant changes.
         ============================================================================ -->

    <!-- Shared status colours (variant-independent). NOTE: the ACCENT (and its derived button/card
         resources) is intentionally NOT here — it lives in each theme dictionary instead, because a
         top-level resource shadows a same-key entry in the ThemeDictionaries, which would stop the
         Sakura skin from re-colouring the accent (#207). -->
    <Color x:Key="Success">#10B981</Color>
    <Color x:Key="SuccessMuted">#1A10B981</Color>
    <Color x:Key="Warning">#F59E0B</Color>
    <Color x:Key="WarningMuted">#1AF59E0B</Color>
    <Color x:Key="Error">#EF4444</Color>
    <Color x:Key="ErrorMuted">#1AEF4444</Color>
    <Color x:Key="TextInverse">#FFFFFF</Color>

    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Success}" />
    <SolidColorBrush x:Key="SuccessMutedBrush" Color="{StaticResource SuccessMuted}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Warning}" />
    <SolidColorBrush x:Key="WarningMutedBrush" Color="{StaticResource WarningMuted}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource Error}" />
    <SolidColorBrush x:Key="ErrorMutedBrush" Color="{StaticResource ErrorMuted}" />
    <SolidColorBrush x:Key="TextInverseBrush" Color="{StaticResource TextInverse}" />

    <ResourceDictionary.ThemeDictionaries>

        <!-- ===== Light ===== -->
        <ResourceDictionary x:Key="Light">
            <Color x:Key="BgBase">#F0F0F6</Color>
            <Color x:Key="BgElevated">#F7F7FC</Color>
            <Color x:Key="BgSurface">#FFFFFF</Color>
            <Color x:Key="GlassBg">#A6FFFFFF</Color>
            <Color x:Key="GlassBgHover">#BFFFFFFF</Color>
            <Color x:Key="GlassBorder">#33000000</Color>
            <Color x:Key="TextPrimary">#F0000000</Color>
            <Color x:Key="TextSecondary">#CC000000</Color>
            <Color x:Key="TextMuted">#99000000</Color>
            <Color x:Key="Divider">#1A000000</Color>

            <SolidColorBrush x:Key="BgBaseBrush" Color="{StaticResource BgBase}" />
            <SolidColorBrush x:Key="BgElevatedBrush" Color="{StaticResource BgElevated}" />
            <SolidColorBrush x:Key="BgSurfaceBrush" Color="{StaticResource BgSurface}" />
            <SolidColorBrush x:Key="GlassBgBrush" Color="{StaticResource GlassBg}" />
            <SolidColorBrush x:Key="GlassBgHoverBrush" Color="{StaticResource GlassBgHover}" />
            <SolidColorBrush x:Key="GlassBorderBrush" Color="{StaticResource GlassBorder}" />
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
            <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}" />
            <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource Divider}" />

            <!-- Sidebar fill — same as the card glass here; the Anime skin gives it its own look. -->
            <SolidColorBrush x:Key="SidebarBgBrush" Color="{StaticResource GlassBg}" />

            <!-- Accent + derived button/card resources. Per-theme (not top-level) so the Sakura skin
                 can override them — see the note at the top. Light + Dark share the indigo accent. -->
            <Color x:Key="Accent">#6366F1</Color>
            <Color x:Key="AccentMuted">#1A6366F1</Color>
            <Color x:Key="NavActive">#1A6366F1</Color>
            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}" />
            <SolidColorBrush x:Key="AccentMutedBrush" Color="{StaticResource AccentMuted}" />
            <SolidColorBrush x:Key="NavActiveBrush" Color="{StaticResource NavActive}" />
            <SolidColorBrush x:Key="AccentButtonFillBrush" Color="{StaticResource AccentMuted}" />
            <SolidColorBrush x:Key="AccentButtonForegroundBrush" Color="{StaticResource Accent}" />
            <SolidColorBrush x:Key="AccentButtonFillHoverBrush" Color="{StaticResource Accent}" />
            <SolidColorBrush x:Key="AccentButtonForegroundHoverBrush" Color="{StaticResource TextInverse}" />
            <CornerRadius x:Key="CardCornerRadius">16</CornerRadius>
            <BoxShadows x:Key="CardShadow">0 2 12 0 #14000000</BoxShadows>

            <!-- Full-window backdrop layer behind content; flat themes have none (see Anime). -->
            <SolidColorBrush x:Key="AppBackdropBrush" Color="Transparent" />
        </ResourceDictionary>

        <!-- ===== Dark ===== -->
        <ResourceDictionary x:Key="Dark">
            <Color x:Key="BgBase">#13131C</Color>
            <Color x:Key="BgElevated">#1B1B28</Color>
            <Color x:Key="BgSurface">#232336</Color>
            <Color x:Key="GlassBg">#1FFFFFFF</Color>
            <Color x:Key="GlassBgHover">#2EFFFFFF</Color>
            <Color x:Key="GlassBorder">#26FFFFFF</Color>
            <Color x:Key="TextPrimary">#F2FFFFFF</Color>
            <Color x:Key="TextSecondary">#CCFFFFFF</Color>
            <Color x:Key="TextMuted">#80FFFFFF</Color>
            <Color x:Key="Divider">#1AFFFFFF</Color>

            <SolidColorBrush x:Key="BgBaseBrush" Color="{StaticResource BgBase}" />
            <SolidColorBrush x:Key="BgElevatedBrush" Color="{StaticResource BgElevated}" />
            <SolidColorBrush x:Key="BgSurfaceBrush" Color="{StaticResource BgSurface}" />
            <SolidColorBrush x:Key="GlassBgBrush" Color="{StaticResource GlassBg}" />
            <SolidColorBrush x:Key="GlassBgHoverBrush" Color="{StaticResource GlassBgHover}" />
            <SolidColorBrush x:Key="GlassBorderBrush" Color="{StaticResource GlassBorder}" />
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
            <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}" />
            <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource Divider}" />

            <SolidColorBrush x:Key="SidebarBgBrush" Color="{StaticResource GlassBg}" />

            <!-- Accent + derived button/card resources (indigo; matches Light). Per-theme so Sakura
                 can override — see the note at the top. -->
            <Color x:Key="Accent">#6366F1</Color>
            <Color x:Key="AccentMuted">#1A6366F1</Color>
            <Color x:Key="NavActive">#1A6366F1</Color>
            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}" />
            <SolidColorBrush x:Key="AccentMutedBrush" Color="{StaticResource AccentMuted}" />
            <SolidColorBrush x:Key="NavActiveBrush" Color="{StaticResource NavActive}" />
            <SolidColorBrush x:Key="AccentButtonFillBrush" Color="{StaticResource AccentMuted}" />
            <SolidColorBrush x:Key="AccentButtonForegroundBrush" Color="{StaticResource Accent}" />
            <SolidColorBrush x:Key="AccentButtonFillHoverBrush" Color="{StaticResource Accent}" />
            <SolidColorBrush x:Key="AccentButtonForegroundHoverBrush" Color="{StaticResource TextInverse}" />
            <CornerRadius x:Key="CardCornerRadius">16</CornerRadius>
            <BoxShadows x:Key="CardShadow">0 2 12 0 #14000000</BoxShadows>

            <SolidColorBrush x:Key="AppBackdropBrush" Color="Transparent" />
        </ResourceDictionary>

        <!-- ===== Anime (experimental skin, #anime) =====
             A pink light-mode skin: re-skins app surfaces over a sakura backdrop image, leaning on
             the existing translucent "glass" panels so the image shows through. Keyed by the custom
             AnimeVariant, which inherits Light — so anything not overridden here (incl. all Fluent
             control resources) resolves from the Light theme. Cards stay translucent so the sakura
             backdrop shows through; the sidebar gets its own pink translucent gradient. -->
        <ResourceDictionary x:Key="{x:Static svc:ThemeService.AnimeVariant}">
            <!-- Pink accent (ties to the app's magenta mark) overriding the shared indigo. -->
            <Color x:Key="Accent">#E0218A</Color>
            <Color x:Key="AccentMuted">#1FE0218A</Color>
            <Color x:Key="NavActive">#24E0218A</Color>
            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}" />
            <SolidColorBrush x:Key="AccentMutedBrush" Color="{StaticResource AccentMuted}" />
            <SolidColorBrush x:Key="NavActiveBrush" Color="{StaticResource NavActive}" />

            <!-- Fluent's native-control accent ramp (#216): toggles, checkboxes, combo/list selection,
                 sliders, focus rings. Without these, native controls keep Fluent's default blue accent
                 even in Sakura. Light1-3 = progressively lighter, Dark1-3 = darker, around the #E0218A
                 base; Fluent picks the right shade per state/variant. -->
            <Color x:Key="SystemAccentColor">#E0218A</Color>
            <Color x:Key="SystemAccentColorLight1">#E73E9C</Color>
            <Color x:Key="SystemAccentColorLight2">#EE5EAE</Color>
            <Color x:Key="SystemAccentColorLight3">#F488C4</Color>
            <Color x:Key="SystemAccentColorDark1">#C41C79</Color>
            <Color x:Key="SystemAccentColorDark2">#A41667</Color>
            <Color x:Key="SystemAccentColorDark3">#81104F</Color>

            <Color x:Key="BgBase">#FCE3EE</Color>
            <Color x:Key="BgElevated">#FFF1F7</Color>
            <Color x:Key="BgSurface">#FFFFFF</Color>
            <!-- Translucent pink-white so the sakura backdrop shows through the cards (still opaque
                 enough to keep text legible). -->
            <Color x:Key="GlassBg">#CCFDF1F7</Color>
            <Color x:Key="GlassBgHover">#E6FEF7FB</Color>
            <Color x:Key="GlassBorder">#33E0218A</Color>
            <Color x:Key="TextPrimary">#F03A0E26</Color>
            <Color x:Key="TextSecondary">#C43A0E26</Color>
            <Color x:Key="TextMuted">#8A3A0E26</Color>
            <Color x:Key="Divider">#22E0218A</Color>

            <SolidColorBrush x:Key="BgBaseBrush" Color="{StaticResource BgBase}" />
            <SolidColorBrush x:Key="BgElevatedBrush" Color="{StaticResource BgElevated}" />
            <SolidColorBrush x:Key="BgSurfaceBrush" Color="{StaticResource BgSurface}" />
            <SolidColorBrush x:Key="GlassBgBrush" Color="{StaticResource GlassBg}" />
            <SolidColorBrush x:Key="GlassBgHoverBrush" Color="{StaticResource GlassBgHover}" />
            <SolidColorBrush x:Key="GlassBorderBrush" Color="{StaticResource GlassBorder}" />
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
            <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}" />
            <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource Divider}" />

            <!-- Themed sidebar: a soft pink translucent vertical gradient (deeper rose at the bottom)
                 so the panel reads as part of the skin and the backdrop still glows through. -->
            <LinearGradientBrush x:Key="SidebarBgBrush" StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Offset="0" Color="#D9FCDCEC" />
                <GradientStop Offset="1" Color="#D9F7C2DC" />
            </LinearGradientBrush>

            <!-- Accent buttons: a filled pink→rose gradient with white text (vs. the tinted/outline
                 look of the flat themes). The hover gradient lifts a touch brighter. -->
            <LinearGradientBrush x:Key="AccentButtonFillBrush" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Offset="0" Color="#FF7EC4" />
                <GradientStop Offset="1" Color="#E0218A" />
            </LinearGradientBrush>
            <SolidColorBrush x:Key="AccentButtonForegroundBrush" Color="#FFFFFF" />
            <LinearGradientBrush x:Key="AccentButtonFillHoverBrush" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Offset="0" Color="#FF93CF" />
                <GradientStop Offset="1" Color="#EC3A9B" />
            </LinearGradientBrush>
            <SolidColorBrush x:Key="AccentButtonForegroundHoverBrush" Color="#FFFFFF" />

            <!-- Softer, glowier cards: rounder corners and a diffuse pink glow instead of a grey drop. -->
            <CornerRadius x:Key="CardCornerRadius">22</CornerRadius>
            <BoxShadows x:Key="CardShadow">0 6 24 0 #33E0218A</BoxShadows>

            <!-- The sakura backdrop. UniformToFill so it covers the window at any size. -->
            <ImageBrush x:Key="AppBackdropBrush" Stretch="UniformToFill" AlignmentX="Center" AlignmentY="Center"
                        Source="avares://OpenTabletArtist/Assets/anime-bg.png" />
        </ResourceDictionary>

    </ResourceDictionary.ThemeDictionaries>

</ResourceDictionary>
