<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="using:OpenTabletArtist.Controls"
        xmlns:conv="using:OpenTabletArtist.Converters"
        xmlns:svc="using:OpenTabletArtist.Services">

    <Styles.Resources>
        <!-- Local converter instance so the ControlThemes below can hide empty title/description lines. -->
        <conv:NonEmptyToBoolConverter x:Key="NonEmpty" />

        <!-- ===== Reusable UX components (default ControlThemes) =====================================
             These back the TemplatedControls in OpenTabletArtist.Controls, consolidating settings-UI
             patterns that were hand-assembled across the views. -->

        <!-- ===== Card roles (#574) ==================================================================
             Section (grouping) · Alert (severity) · SelectableCard (pickable) replace the old shared
             Border.GlassPanel. Each shows a colour-coded role tag at its bottom-right when the developer
             "Show card-role tags" toggle is on (roleTag / roleTagText styles below). -->

        <!-- Section (grouping role): glass box + optional title/description header + content slot. Owns its
             border via template bindings (defaults here) so #573 can restyle it flush without a shared
             class. Was SettingCard. -->
        <ControlTheme x:Key="{x:Type c:Section}" TargetType="c:Section">
            <Setter Property="Background" Value="{DynamicResource GlassBgBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{DynamicResource CardCornerRadius}" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <Panel>
                            <StackPanel>
                                <TextBlock x:Name="PART_Title" Classes="SectionLabel"
                                           Text="{TemplateBinding Title, Converter={x:Static conv:UpperCaseConverter.Instance}}"
                                           Margin="0,0,0,12"
                                           IsVisible="{TemplateBinding Title, Converter={StaticResource NonEmpty}}" />
                                <TextBlock Text="{TemplateBinding Description}"
                                           Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"
                                           Margin="0,0,0,12"
                                           IsVisible="{TemplateBinding Description, Converter={StaticResource NonEmpty}}" />
                                <ContentPresenter Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}" />
                            </StackPanel>
                            <Border Classes="roleTag" Background="#2563EB"
                                    IsVisible="{Binding ShowCardRoleTags, Source={x:Static svc:DeveloperSettings.Instance}}">
                                <TextBlock Text="SECTION" Classes="roleTagText" />
                            </Border>
                        </Panel>
                    </Border>
                </ControlTemplate>
            </Setter>
            <!-- When there's a description, tighten the title→description gap (title no longer owns the
                 full header spacing). -->
            <Style Selector="^[HasDescription=True] /template/ TextBlock#PART_Title">
                <Setter Property="Margin" Value="0,0,0,4" />
            </Style>
        </ControlTheme>

        <!-- Alert (severity role): a tinted/bordered callout where the box IS the meaning. Per-severity
             background + border below (mirrors the old attentionCard.* tiers); keeps its chrome permanently. -->
        <ControlTheme x:Key="{x:Type c:Alert}" TargetType="c:Alert">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource NeutralBrush}" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="CornerRadius" Value="{DynamicResource CardCornerRadius}" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <Panel>
                            <ContentPresenter Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}" />
                            <Border Classes="roleTag" Background="#DC2626"
                                    IsVisible="{Binding ShowCardRoleTags, Source={x:Static svc:DeveloperSettings.Instance}}">
                                <TextBlock Text="ALERT" Classes="roleTagText" />
                            </Border>
                        </Panel>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^[Severity=Error]">
                <Setter Property="Background" Value="{DynamicResource ErrorMutedBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}" />
            </Style>
            <Style Selector="^[Severity=Warning]">
                <Setter Property="Background" Value="{DynamicResource WarningMutedBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource WarningBrush}" />
            </Style>
            <Style Selector="^[Severity=Neutral]">
                <Setter Property="Background" Value="{DynamicResource InfoMutedBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource InfoBrush}" />
            </Style>
        </ControlTheme>

        <!-- ComplexHeader: a tabbed page's header — a title (plain or custom) on the left + optional
             trailing actions/status on the right. See docs/design/ux-terminology.md. -->
        <ControlTheme x:Key="{x:Type c:ComplexHeader}" TargetType="c:ComplexHeader">
            <Setter Property="Margin" Value="0,0,0,20" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <!-- Title slot: custom TitleContent, else the plain Title in the PageTitle look. -->
                        <ContentControl Grid.Column="0" VerticalAlignment="Center"
                                        Content="{TemplateBinding TitleContent}"
                                        IsVisible="{TemplateBinding HasTitleContent}" />
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Classes="PageTitle" Margin="0"
                                   Text="{TemplateBinding Title}"
                                   IsVisible="{TemplateBinding HasTitleText}" />
                        <!-- Trailing actions / status. -->
                        <ContentPresenter Grid.Column="1" VerticalAlignment="Center"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}" />
                    </Grid>
                </ControlTemplate>
            </Setter>
        </ControlTheme>

        <!-- SelectableCard: a RadioButton rendered as a selectable option card (card-style pickers, e.g.
             Pen Behavior). The checked card is made obvious with an accent outline + a "Current mode"
             badge; hovering an unchecked card hints with a muted accent border. -->
        <ControlTheme x:Key="SelectableCard" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <ControlTemplate>
                    <!-- Glass look inlined (not via a shared grouping class) so the selectable role is
                         decoupled from the grouping default and can't be swept by #573. The :checked /
                         :pointerover selectors below override BorderBrush/Thickness on PART_Card. -->
                    <Border Name="PART_Card" Background="{DynamicResource GlassBgBrush}"
                            BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                            CornerRadius="{DynamicResource CardCornerRadius}" Padding="12">
                        <Panel>
                            <ContentPresenter Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              VerticalAlignment="Top" />
                            <Border Name="PART_Badge" Background="{DynamicResource AccentBrush}" CornerRadius="0"
                                    Padding="8,2" HorizontalAlignment="Right" VerticalAlignment="Top" IsVisible="False">
                                <TextBlock Text="Current mode" Foreground="White" FontWeight="SemiBold" />
                            </Border>
                            <Border Classes="roleTag" Background="#16A34A"
                                    IsVisible="{Binding ShowCardRoleTags, Source={x:Static svc:DeveloperSettings.Instance}}">
                                <TextBlock Text="SELECT" Classes="roleTagText" />
                            </Border>
                        </Panel>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover:not(:checked) /template/ Border#PART_Card">
                <Setter Property="BorderBrush" Value="{DynamicResource AccentMutedBrush}" />
            </Style>
            <Style Selector="^:checked /template/ Border#PART_Card">
                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                <Setter Property="BorderThickness" Value="2" />
            </Style>
            <Style Selector="^:checked /template/ Border#PART_Badge">
                <Setter Property="IsVisible" Value="True" />
            </Style>
        </ControlTheme>

        <!-- LabeledField: fixed-width caption column + an arbitrary control. -->
        <ControlTheme x:Key="{x:Type c:LabeledField}" TargetType="c:LabeledField">
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid ColumnDefinitions="Auto,*">
                        <TextBlock Grid.Column="0" Text="{TemplateBinding Label}"
                                   Width="{TemplateBinding LabelWidth}" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <ContentPresenter Grid.Column="1" Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          VerticalAlignment="Center" HorizontalAlignment="Left" />
                    </Grid>
                </ControlTemplate>
            </Setter>
        </ControlTheme>

        <!-- LabeledSlider: caption + slider + optional live numeric readout. -->
        <ControlTheme x:Key="{x:Type c:LabeledSlider}" TargetType="c:LabeledSlider">
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <TextBlock Grid.Column="0" Text="{TemplateBinding Label}"
                                   Width="{TemplateBinding LabelWidth}" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <Slider Grid.Column="1" x:Name="PART_Slider" VerticalAlignment="Center"
                                Minimum="{TemplateBinding Minimum}" Maximum="{TemplateBinding Maximum}"
                                TickFrequency="{TemplateBinding TickFrequency}"
                                IsSnapToTickEnabled="{TemplateBinding IsSnapToTickEnabled}"
                                TickPlacement="{TemplateBinding TickPlacement}"
                                Value="{Binding Value, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}" />
                        <TextBlock Grid.Column="2" x:Name="PART_Value" Text="{TemplateBinding ValueText}"
                                   Width="{TemplateBinding ValueWidth}" MinWidth="36"
                                   IsVisible="{TemplateBinding ShowValue}" TextAlignment="Right"
                                   VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" />
                    </Grid>
                </ControlTemplate>
            </Setter>
            <!-- Monospace readout (primary colour, fixed-width digits) for VM-formatted values. -->
            <Style Selector="^[Monospace=True] /template/ TextBlock#PART_Value">
                <Setter Property="FontFamily" Value="{DynamicResource MonoFontFamily}" />
                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            </Style>
        </ControlTheme>

        <!-- ToggleSetting: checkbox + optional muted description. The description sits on a line beneath
             by default, or inline after the label when InlineDescription is set (short one-line hints). -->
        <ControlTheme x:Key="{x:Type c:ToggleSetting}" TargetType="c:ToggleSetting">
            <Setter Property="Template">
                <ControlTemplate>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox Content="{TemplateBinding Label}"
                                      IsChecked="{Binding IsChecked, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}" />
                            <!-- Inline description: shown right after the label when InlineDescription=True. -->
                            <TextBlock x:Name="InlineDesc" Text="{TemplateBinding Description}"
                                       VerticalAlignment="Center" Margin="6,0,0,0" IsVisible="False"
                                       Foreground="{DynamicResource TextMutedBrush}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <!-- Below description: the default multi-line placement. -->
                        <TextBlock x:Name="BelowDesc" Text="{TemplateBinding Description}" Margin="28,2,0,0"
                                   Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"
                                   IsVisible="{TemplateBinding Description, Converter={StaticResource NonEmpty}}" />
                    </StackPanel>
                </ControlTemplate>
            </Setter>
            <!-- Inline mode: swap the below line for the inline one. -->
            <Style Selector="^[InlineDescription=True] /template/ TextBlock#InlineDesc">
                <Setter Property="IsVisible" Value="True" />
            </Style>
            <Style Selector="^[InlineDescription=True] /template/ TextBlock#BelowDesc">
                <Setter Property="IsVisible" Value="False" />
            </Style>
        </ControlTheme>

        <!-- StatusBadge: glyph + text, coloured by Kind. -->
        <ControlTheme x:Key="{x:Type c:StatusBadge}" TargetType="c:StatusBadge">
            <Setter Property="Template">
                <ControlTemplate>
                    <StackPanel Orientation="Horizontal">
                        <!-- PathIcon glyph, coloured + shaped per Kind by the selectors below (#551). -->
                        <PathIcon x:Name="PART_Glyph" Width="13" Height="13"
                                  VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock x:Name="PART_Text" Text="{TemplateBinding Text}" FontSize="{DynamicResource TypeCaptionSize}"
                                   VerticalAlignment="Center" TextWrapping="Wrap" />
                    </StackPanel>
                </ControlTemplate>
            </Setter>
            <Style Selector="^[Kind=Success] /template/ PathIcon#PART_Glyph">
                <Setter Property="Data" Value="{StaticResource IconCheckCircle}" />
                <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
            </Style>
            <Style Selector="^[Kind=Success] /template/ TextBlock#PART_Text">
                <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
            </Style>
            <Style Selector="^[Kind=Warning] /template/ PathIcon#PART_Glyph">
                <Setter Property="Data" Value="{StaticResource IconAlert}" />
                <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
            </Style>
            <Style Selector="^[Kind=Warning] /template/ TextBlock#PART_Text">
                <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
            </Style>
            <Style Selector="^[Kind=Error] /template/ PathIcon#PART_Glyph">
                <Setter Property="Data" Value="{StaticResource IconAlertCircle}" />
                <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}" />
            </Style>
            <Style Selector="^[Kind=Error] /template/ TextBlock#PART_Text">
                <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}" />
            </Style>
        </ControlTheme>

        <!-- Tablet status banner: shared detection/connection indicator (#128/#129/#130/#132).
             Green outline + text when detected; neutral gray otherwise (undetected isn't a warning, #489). -->
        <ControlTheme x:Key="{x:Type c:TabletStatusBanner}" TargetType="c:TabletStatusBanner">
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Template">
                <ControlTemplate>
                    <!-- Compact status pill: a status-colored outline + text. No translucent fill (the old
                         muted-tint band read oddly over the Sakura backdrop, #300). -->
                    <Border x:Name="PART_Pill" CornerRadius="0" Padding="12,7"
                            Background="Transparent"
                            BorderThickness="1.5" BorderBrush="{DynamicResource TextMutedBrush}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{TemplateBinding Text}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" TextWrapping="Wrap" />
                            <Border IsVisible="{TemplateBinding DynamicsOn}" VerticalAlignment="Center"
                                    Background="{DynamicResource AccentMutedBrush}"
                                    BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1"
                                    CornerRadius="0" Padding="6,1" Margin="10,0,0,0">
                                <TextBlock Text="Dynamics on" FontSize="{DynamicResource TypeCaptionSize}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentBrush}" />
                            </Border>
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter>
            <!-- Detected → success outline (default is the neutral gray outline above). -->
            <Style Selector="^[IsDetected=True] /template/ Border#PART_Pill">
                <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}" />
            </Style>
        </ControlTheme>

        <!-- WordmarkNav: the Zune top-bar wordmark (redesign Phase 1). Plain lowercase text — no pill, no
             underline; the active one is marked by accent colour + weight, matching the pivots (Metro
             signals state by brightness, not a rule). Content is already lowercased by the item template. -->
        <ControlTheme x:Key="WordmarkNav" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Panel>
                        <!-- Width reserver (#nav-no-reflow): the checked cue bumps the weight Light ->
                             Normal, and Normal is a few px wider per word. In the left-aligned WrapPanel
                             that meant clicking an item re-measured it and shoved every item to its right.
                             This invisible copy is always at the checked weight, so the Panel measures to
                             the widest state and the slot width never changes. Opacity=0 still lays out
                             (IsVisible=False would not). Keep every metric here in sync with Word below. -->
                        <TextBlock Text="{TemplateBinding Content}"
                                   FontFamily="{DynamicResource DisplayFontFamily}"
                                   FontSize="26" FontWeight="Normal" LetterSpacing="-0.2"
                                   Opacity="0" IsHitTestVisible="False" />
                        <TextBlock x:Name="Word" Text="{TemplateBinding Content}"
                                   FontFamily="{DynamicResource DisplayFontFamily}"
                                   FontSize="26" FontWeight="Light" LetterSpacing="-0.2"
                                   Foreground="{DynamicResource TextMutedBrush}" />
                    </Panel>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ TextBlock#Word">
                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            </Style>
            <Style Selector="^:checked /template/ TextBlock#Word">
                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                <Setter Property="FontWeight" Value="Normal" />
            </Style>
        </ControlTheme>

        <!-- PivotTab: the Zune subpage pivot (redesign Phase 2) — big lowercase Segoe UI Light headers
             that replace the vertical tab rail on tabbed pages. Same active cue as the wordmarks (accent +
             weight, no rule). Content is lowercased by the pivot item template. -->
        <ControlTheme x:Key="PivotTab" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Panel>
                        <!-- Width reserver — see WordmarkNav above (#nav-no-reflow). -->
                        <TextBlock Text="{TemplateBinding Content}"
                                   FontFamily="{DynamicResource DisplayFontFamily}"
                                   FontSize="18" FontWeight="Normal" LetterSpacing="-0.2"
                                   Opacity="0" IsHitTestVisible="False" />
                        <TextBlock x:Name="Word" Text="{TemplateBinding Content}"
                                   FontFamily="{DynamicResource DisplayFontFamily}"
                                   FontSize="18" FontWeight="Light" LetterSpacing="-0.2" />
                    </Panel>
                </ControlTemplate>
            </Setter>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Style Selector="^ /template/ TextBlock#Word">
                <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            </Style>
            <Style Selector="^:pointerover /template/ TextBlock#Word">
                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            </Style>
            <Style Selector="^:checked /template/ TextBlock#Word">
                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                <Setter Property="FontWeight" Value="Normal" />
            </Style>
        </ControlTheme>

        <!-- Accent Button -->
        <ControlTheme x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentButtonFillBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AccentButtonForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="FontFamily" Value="Segoe UI, Inter" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="0"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{Binding Content, RelativeSource={RelativeSource TemplatedParent}, Converter={x:Static conv:UpperCaseConverter.Instance}}"
                                          HorizontalContentAlignment="Center"
                                          VerticalContentAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="{DynamicResource AccentButtonFillHoverBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource AccentButtonForegroundHoverBrush}" />
            </Style>
        </ControlTheme>

        <!-- Ghost Button (subtle filled chip; legible on cards and the page backdrop, #249) -->
        <ControlTheme x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource GlassBgBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="FontFamily" Value="Segoe UI, Inter" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="0"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{Binding Content, RelativeSource={RelativeSource TemplatedParent}, Converter={x:Static conv:UpperCaseConverter.Instance}}"
                                          HorizontalContentAlignment="Center"
                                          VerticalContentAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="{DynamicResource GlassBgHoverBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            </Style>
        </ControlTheme>

        <!-- Tab RadioButton (for dialog tabs) -->
        <!-- Real-tab look: flat header with a 2px accent underline on the selected tab (sits on the
             tab strip's baseline), instead of a pill button. -->
        <!-- Vertical tab used by the tablet editor's left rail: a left accent bar + text,
             with a soft fill on hover/selected. Stretches to fill the rail width. -->
        <ControlTheme x:Key="TabRadioButton" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Template">
                <ControlTemplate>
                    <!-- Selected-item treatment: a rounded (12) highlight plus an inset, rounded 3px accent
                         indicator bar — so the current item reads the
                         same across both navigation levels. The indicator is always laid out (only its
                         colour changes when checked) so selecting can't shift the label. -->
                    <Border x:Name="Bd" Background="Transparent" CornerRadius="0" Padding="8,3.92">
                        <Grid ColumnDefinitions="Auto,8,*">
                            <Border x:Name="Indicator" Width="3" Height="20" CornerRadius="0"
                                    Background="Transparent" VerticalAlignment="Center"
                                    HorizontalAlignment="Left" Margin="-4,0,0,0" />
                            <TextBlock Grid.Column="2" x:Name="Label" Text="{TemplateBinding Content}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ TextBlock#Label">
                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            </Style>
            <Style Selector="^:pointerover /template/ Border#Bd">
                <Setter Property="Background" Value="{DynamicResource GlassBgHoverBrush}" />
            </Style>
            <Style Selector="^:checked /template/ Border#Bd">
                <Setter Property="Background" Value="{DynamicResource NavActiveBrush}" />
            </Style>
            <Style Selector="^:checked /template/ Border#Indicator">
                <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            </Style>
            <Style Selector="^:checked /template/ TextBlock#Label">
                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
            </Style>
        </ControlTheme>

        <!-- Delete Button (solid red — unmistakably destructive, #251) -->
        <ControlTheme x:Key="DeleteButton" TargetType="Button">
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="FontFamily" Value="Segoe UI, Inter" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="Bd" Background="{DynamicResource ErrorBrush}" CornerRadius="0"
                            Padding="{TemplateBinding Padding}"
                            BorderBrush="{DynamicResource ErrorBrush}" BorderThickness="1">
                        <ContentPresenter Content="{Binding Content, RelativeSource={RelativeSource TemplatedParent}, Converter={x:Static conv:UpperCaseConverter.Instance}}"
                                          HorizontalContentAlignment="Center"
                                          VerticalContentAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#Bd">
                <Setter Property="Opacity" Value="0.88" />
            </Style>
        </ControlTheme>
    </Styles.Resources>

    <!-- Settings auto-save indicator text (#321): secondary while saving/saved, warning when a save
         failed. Kept as classes (no local Foreground) so .failed wins by specificity in either theme. -->
    <Style Selector="TextBlock.saveStatus">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    </Style>
    <Style Selector="TextBlock.saveStatus.failed">
        <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <!-- App-wide default font. Every window/popup gets Segoe UI, and text inherits it, so unstyled
         content (labels, ComboBox/ToggleSwitch text, dropdown items) no longer falls back to the
         Fluent theme's default family. Any explicit FontFamily on a style or control still wins. -->
    <Style Selector=":is(TopLevel)">
        <Setter Property="FontFamily" Value="Segoe UI, Inter" />
    </Style>

    <!-- Card-role tag (#574): a small colour-coded label pinned to a card's bottom-right, shown only when
         the developer "Show card-role tags" toggle is on. The per-role colour + text are set at each use
         (SECTION #2563EB · ALERT #DC2626 · SELECT #16A34A). -->
    <Style Selector="Border.roleTag">
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="VerticalAlignment" Value="Bottom" />
        <Setter Property="Padding" Value="4,1" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="ZIndex" Value="1000" />
        <Setter Property="IsHitTestVisible" Value="False" />
    </Style>
    <Style Selector="TextBlock.roleTagText">
        <Setter Property="FontSize" Value="9" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="White" />
    </Style>

    <!-- (The old Border.GlassPanel escape-hatch style + CardPadding resource were removed with the
         card-roles refactor (#574): every card now declares a role — Section / Alert / SelectableCard —
         which own their glass look. A grep guard in CI keeps the escape-hatch class from coming back.) -->

    <!-- Base content text size (#fontstd): plain TextBlocks default to the one content size
         (ContentFontSize). Page titles (PageTitle), card titles (CardTitle), section labels
         (SectionLabel), status dots and the nav themes set their own size and win (classed selector or
         template-local value), so this only catches unclassed content text. -->
    <Style Selector="TextBlock">
        <Setter Property="FontSize" Value="{DynamicResource ContentFontSize}" />
    </Style>

    <!-- Page Title -->
    <Style Selector="TextBlock.PageTitle">
        <Setter Property="FontFamily" Value="{DynamicResource DisplayFontFamily}" />
        <Setter Property="FontSize" Value="{DynamicResource TypeDisplaySize}" />
        <Setter Property="FontWeight" Value="Light" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <!-- Header→content gap (previously carried by the now-removed PageSubtitle). -->
        <Setter Property="Margin" Value="0,0,0,20" />
    </Style>

    <!-- Card Title — a card's prominent content/identity title (tablet & profile names, warning titles,
         daemon status, option choices). At the content size but kept prominent by weight + primary colour,
         so it reads above body text and the muted all-caps SectionLabel headings. (#fontstd) -->
    <Style Selector="TextBlock.CardTitle">
        <Setter Property="FontFamily" Value="{DynamicResource DisplayFontFamily}" />
        <Setter Property="FontSize" Value="{DynamicResource ContentFontSize}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <!-- Section Label — the one descriptive card/section heading treatment (#fontstd): all-caps (text is
         written upper-case), SemiBold, muted, at the content size. Card content/identity titles (names,
         warnings, option choices) use the prominent CardTitle instead. -->
    <Style Selector="TextBlock.SectionLabel">
        <Setter Property="FontSize" Value="{DynamicResource ContentFontSize}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
    </Style>

    <!-- Size-bump modifier for SectionLabel: opt a specific label up to the tab-title size (TypeTitleSize)
         while keeping its all-caps / SemiBold / muted treatment. Add "largetitle" alongside "SectionLabel". -->
    <Style Selector="TextBlock.SectionLabel.largetitle">
        <Setter Property="FontSize" Value="{DynamicResource TypeTitleSize}" />
    </Style>

    <!-- Tab Title — the heading at the top of each tablet tab (matches the tab's rail label, #499). One
         place to restyle every tab heading: a step larger and in the primary text colour (the same colour
         as the tab-nav labels), so it reads as a page heading above the muted in-card SectionLabels. -->
    <Style Selector="TextBlock.TabTitle">
        <Setter Property="FontSize" Value="{DynamicResource TypeTitleSize}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="LetterSpacing" Value="0.3" />
    </Style>

    <!-- ===== Status marks ===========================================================
         A colored dot (U+25CF) in the normal UI font — no icon font. State is conveyed by colour:
           success → green   warning → amber   neutral → muted   error → red

         Two bool-driven base classes for the common "success vs not" indicator.
         Apply Classes.success="{Binding ...}" to toggle the success state:
           statusMark      → not-success shows the NEUTRAL (muted) dot  (off/idle is normal)
           statusMarkWarn  → not-success shows the WARNING (amber) dot   (off is a problem)

         For multi-state rows, use a literal class (success/warning/neutral/error). -->
    <Style Selector="TextBlock.statusMark, TextBlock.statusMarkWarn,
                     TextBlock.success, TextBlock.warning, TextBlock.neutral, TextBlock.error">
        <Setter Property="Text" Value="&#x25CF;" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,0,6,0" />
    </Style>

    <!-- Base appearance: neutral off-state -->
    <Style Selector="TextBlock.statusMark">
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
    </Style>
    <!-- Base appearance: warning off-state -->
    <Style Selector="TextBlock.statusMarkWarn">
        <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
    </Style>
    <!-- Success override for either base -->
    <Style Selector="TextBlock.statusMark.success, TextBlock.statusMarkWarn.success">
        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
    </Style>

    <!-- Literal single-state marks (for multi-state rows) -->
    <Style Selector="TextBlock.success">
        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
    </Style>
    <Style Selector="TextBlock.warning">
        <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
    </Style>
    <Style Selector="TextBlock.neutral">
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
    </Style>
    <Style Selector="TextBlock.error">
        <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}" />
    </Style>

    <!-- Prominent severity indicator for the "Needs attention" cards: a rounded colour bar down the
         card's left edge (reads at a glance, unlike the old tiny dot). Colour by severity via
         Classes.error/.warning/.neutral. -->
    <Style Selector="Border.severityBar">
        <Setter Property="Width" Value="40" />
        <Setter Property="MinHeight" Value="52" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Background" Value="{DynamicResource InfoBrush}" />
    </Style>
    <Style Selector="Border.severityBar.error">
        <Setter Property="Background" Value="{DynamicResource ErrorBrush}" />
    </Style>
    <Style Selector="Border.severityBar.warning">
        <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
    </Style>
    <Style Selector="Border.severityBar.neutral">
        <Setter Property="Background" Value="{DynamicResource InfoBrush}" />
    </Style>
    <!-- Information (#549): a calm grey — nothing's wrong, it's just an FYI, distinct from the blue
         Recommendation nudge. -->
    <Style Selector="Border.severityBar.information">
        <Setter Property="Background" Value="{DynamicResource NeutralBrush}" />
    </Style>

    <!-- (The Border.attentionCard.* health-card tints moved onto the Alert control's Severity tiers with
         the card-roles refactor (#574).) -->

    <!-- Always-visible, full-size scrollbars. The default Fluent scrollbars (a) auto-hide and
         (b) sit as a thin line until hovered (the thumb is scaled down by a RenderTransform in the
         collapsed state). Disable auto-hide AND clear the thumb's shrink transform so the bar is
         always the full, easy-to-grab width. -->
    <Style Selector="ScrollViewer">
        <Setter Property="AllowAutoHide" Value="False" />
    </Style>
    <Style Selector="ScrollBar">
        <Setter Property="AllowAutoHide" Value="False" />
    </Style>
    <Style Selector="ScrollBar /template/ Thumb">
        <Setter Property="RenderTransform" Value="none" />
    </Style>

    <!-- Slimmer slider thumb (#160). The Fluent thumb knob is ~20px; replace its template with a
         small accent dot so the size is fully under our control. -->
    <Style Selector="Slider /template/ Thumb">
        <Setter Property="Width" Value="12" />
        <Setter Property="Height" Value="12" />
        <Setter Property="Template">
            <ControlTemplate>
                <Ellipse Width="12" Height="12" Fill="{DynamicResource AccentBrush}" />
            </ControlTemplate>
        </Setter>
    </Style>

    <!-- CheckBox: the checked box uses the theme accent (Fluent's default is an off-theme accent that
         reads green in the Sakura skin). Covers the rest/hover/pressed checked states. -->
    <Style Selector="CheckBox:checked /template/ Border#NormalRectangle">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>
    <Style Selector="CheckBox:checked:pointerover /template/ Border#NormalRectangle">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>
    <Style Selector="CheckBox:checked:pressed /template/ Border#NormalRectangle">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>

    <!-- ToggleSwitch: the "on" track uses the theme accent (Fluent's default reads blue, off-theme in
         the Sakura skin — e.g. the Output Mode "Absolute" switch, #297). -->
    <Style Selector="ToggleSwitch:checked /template/ Border#SwitchKnobBounds">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>
    <Style Selector="ToggleSwitch:checked:pointerover /template/ Border#SwitchKnobBounds">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>
    <Style Selector="ToggleSwitch:checked:pressed /template/ Border#SwitchKnobBounds">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>

</Styles>
