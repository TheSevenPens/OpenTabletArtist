<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        Dependency-free icon set. Each entry is a StreamGeometry (a single SVG path, 24×24 viewBox)
        that renders natively via Avalonia's Path/PathIcon — no NuGet package, theme-coloured, scalable.

        Path data is from Material Design Icons (https://pictogrammers.com/library/mdi/, Apache-2.0).
        To add an icon: copy its SVG path `d=""` here under a new x:Key. Keep them single-path.

        Usage:
            <PathIcon Data="{StaticResource IconClose}" Width="16" Height="16"
                      Foreground="{DynamicResource AccentBrush}" />
        or inside a fixed box:
            <Viewbox Width="16" Height="16">
                <Path Data="{StaticResource IconClose}" Fill="{DynamicResource TextPrimaryBrush}" />
            </Viewbox>
    -->

    <StreamGeometry x:Key="IconCamera">M4,4H7L9,2H15L17,4H20A2,2 0 0,1 22,6V18A2,2 0 0,1 20,20H4A2,2 0 0,1 2,18V6A2,2 0 0,1 4,4M12,7A5,5 0 0,0 7,12A5,5 0 0,0 12,17A5,5 0 0,0 17,12A5,5 0 0,0 12,7M12,9A3,3 0 0,1 15,12A3,3 0 0,1 12,15A3,3 0 0,1 9,12A3,3 0 0,1 12,9Z</StreamGeometry>

    <StreamGeometry x:Key="IconKeyboard">M4,5A2,2 0 0,0 2,7V17A2,2 0 0,0 4,19H20A2,2 0 0,0 22,17V7A2,2 0 0,0 20,5H4M4,7H20V17H4V7M5,8V10H7V8H5M8,8V10H10V8H8M11,8V10H13V8H11M14,8V10H16V8H14M17,8V10H19V8H17M5,11V13H7V11H5M8,11V13H10V11H8M11,11V13H13V11H11M14,11V13H16V11H14M17,11V13H19V11H17M8,14V16H16V14H8Z</StreamGeometry>

    <StreamGeometry x:Key="IconClose">M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z</StreamGeometry>

