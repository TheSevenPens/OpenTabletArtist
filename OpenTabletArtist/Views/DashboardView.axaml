<UserControl x:Class="OpenTabletArtist.Views.DashboardView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="using:OpenTabletArtist.Controls">

    <!-- DataContext is the DashboardViewModel, supplied by the typed-nav DataTemplate (#15). -->
    <StackPanel MaxWidth="900" HorizontalAlignment="Left">
        <!-- Page Header -->
        <TextBlock Classes="PageTitle" Text="HOME" />

        <StackPanel>
            <!-- (The embedded OTD version + OTD UX launcher moved to the Advanced → OTD page.) -->

            <!-- Conflicting-driver alert: shown only when the daemon flagged real conflicts (#245). -->
            <Border Classes="GlassPanel" Margin="0,0,0,12" Padding="16"
                    BorderBrush="{DynamicResource WarningBrush}" BorderThickness="1.5"
                    IsVisible="{Binding Conflicts.HasConflicts}">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <StackPanel Grid.Column="0" MinWidth="0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Classes="warning" VerticalAlignment="Center" />
                            <TextBlock Classes="CardTitle" Text="Conflicting tablet driver detected" FontSize="13"
                                       Foreground="{DynamicResource WarningBrush}" VerticalAlignment="Center"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <TextBlock Text="A manufacturer tablet driver can interfere with OpenTabletDriver. Review and remove it in Driver cleanup."
                                   FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,4,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="Driver cleanup" Command="{Binding OpenDriverCleanupCommand}"
                            Theme="{StaticResource AccentButton}" Padding="12,6" FontSize="12"
                            VerticalAlignment="Center" />
                </Grid>
            </Border>

            <!-- OTD Status -->
            <Border Classes="GlassPanel" Margin="0,0,0,12" Padding="16">
                <StackPanel>
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <StackPanel Grid.Column="0" MinWidth="0">
                            <TextBlock Classes="CardTitle" Text="OpenTabletDriver Daemon" FontSize="13"
                                       TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Classes="statusMarkWarn" Classes.success="{Binding IsConnected}" />
                                <TextBlock Text="{Binding DaemonStatusText}" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                                <!-- Version read off the connected daemon's binary (#296). -->
                                <TextBlock Text="{Binding DaemonVersion, StringFormat='v{0}'}" FontSize="11"
                                           Margin="6,0,0,0" IsVisible="{Binding HasDaemonVersion}"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           ToolTip.Tip="Version of the connected OpenTabletDriver daemon" />
                            </StackPanel>

                            <!-- Daemon ownership indicator (one of three states while connected) -->

                            <!-- App-owned: connected to this project's build -->
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                                        IsVisible="{Binding ShowAppOwnedDaemon}">
                                <TextBlock Classes="success" />
                                <TextBlock FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource SuccessBrush}"
                                           Text="App-owned daemon"
                                           ToolTip.Tip="{Binding DaemonSourcePath}" TextWrapping="Wrap" />
                            </StackPanel>

                            <!-- External: connected to an OTD instance that isn't this project's build -->
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                                        IsVisible="{Binding ShowForeignDaemonWarning}">
                                <TextBlock Classes="warning" />
                                <TextBlock FontSize="10" FontWeight="SemiBold" TextWrapping="Wrap"
                                           Foreground="{DynamicResource WarningBrush}"
                                           Text="External daemon (not app-owned) — click Restart to use this project's build"
                                           ToolTip.Tip="{Binding DaemonSourcePath}" />
                            </StackPanel>

                            <!-- Unknown: connected but couldn't read the daemon's exe path -->
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                                        IsVisible="{Binding ShowDaemonSourceUnknown}">
                                <TextBlock Classes="neutral" />
                                <TextBlock FontSize="10"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Text="Daemon source unknown" />
                            </StackPanel>
                    </StackPanel>

                    <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                        <!-- Refresh button -->
                        <Button Content="Refresh" Command="{Binding RefreshConnectionCommand}"
                                ToolTip.Tip="Check daemon status"
                                IsEnabled="{Binding !IsDaemonBusy}"
                                Theme="{StaticResource GhostButton}" Padding="12,6" FontSize="12" Margin="0,0,6,0" />
                        <!-- Start button: show when NOT connected and not mid-connect -->
                        <Button Content="Start" Theme="{StaticResource AccentButton}"
                                Command="{Binding StartDaemonCommand}"
                                IsVisible="{Binding ShowStartButton}"
                                IsEnabled="{Binding !IsDaemonBusy}"
                                Padding="12,6" FontSize="12" />
                        <!-- Restart button: show when connected -->
                        <Button Content="Restart" Theme="{StaticResource AccentButton}"
                                Command="{Binding RestartDaemonCommand}"
                                IsVisible="{Binding IsConnected}"
                                IsEnabled="{Binding !IsDaemonBusy}"
                                Padding="12,6" FontSize="12" />
                        <!-- Stop button: show when connected -->
                        <Button Content="Stop" Theme="{StaticResource DeleteButton}"
                                Command="{Binding StopDaemonCommand}"
                                IsVisible="{Binding IsConnected}"
                                IsEnabled="{Binding !IsDaemonBusy}"
                                Padding="12,6" FontSize="12" Margin="6,0,0,0" />
                    </WrapPanel>
                </Grid>

                <!-- Activity: indeterminate progress + phase text while a lifecycle op runs OR while
                     the initial connect is in flight (so startup shows "Connecting…" instead of a
                     bare "Not connected" with nothing happening). -->
                <StackPanel IsVisible="{Binding ShowDaemonActivity}" Margin="0,12,0,0">
                    <ProgressBar IsIndeterminate="True" Height="3" Margin="0,0,0,6"
                                 Foreground="{DynamicResource AccentBrush}" />
                    <TextBlock Text="{Binding DaemonActivityText}" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                </StackPanel>

                <!-- Error: shown when a lifecycle op times out or fails -->
                <StackPanel Orientation="Horizontal" Margin="0,12,0,0"
                            IsVisible="{Binding HasDaemonOperationError}">
                    <TextBlock Classes="warning" />
                    <TextBlock Text="{Binding DaemonOperationError}" FontSize="11" TextWrapping="Wrap"
                               Foreground="{DynamicResource WarningBrush}" />
                </StackPanel>

                <!-- Auto-connect ran past the timeout: it's still retrying in the background, so say
                     so (with an immediate Retry) rather than a silent "Not connected" (#296). -->
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" Margin="0,12,0,0"
                      IsVisible="{Binding ConnectStalled}">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Classes="warning" />
                        <TextBlock Text="Couldn't reach the daemon — still retrying in the background."
                                   FontSize="11" TextWrapping="Wrap"
                                   Foreground="{DynamicResource WarningBrush}" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="Retry" Command="{Binding RefreshConnectionCommand}"
                            Theme="{StaticResource AccentButton}" Padding="12,6" FontSize="12"
                            VerticalAlignment="Center" />
                </Grid>
                </StackPanel>
            </Border>

            <!-- Per-tablet status moved to the Tablets nav node (#247); Home no longer duplicates it. -->

            <!-- VMulti Status -->
            <Border Classes="GlassPanel" Margin="0,0,0,12" Padding="16">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <StackPanel Grid.Column="0" MinWidth="0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Classes="CardTitle" Text="VMulti Driver" FontSize="13" TextWrapping="Wrap" />
                            <Button Content="Refresh" Command="{Binding RefreshVmultiDetectionCommand}"
                                    ToolTip.Tip="Refresh VMulti status"
                                    Theme="{StaticResource GhostButton}" Padding="8,3" FontSize="11"
                                    Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Classes="statusMarkWarn" Classes.success="{Binding VmultiInstalled}" />
                            <TextBlock Text="{Binding VmultiMessage}" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </StackPanel>
                        <TextBlock FontSize="10" Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0">
                            <Run Text="Setup API: " /><Run Text="{Binding VmultiSetupApiStatus}" />
                        </TextBlock>
                        <TextBlock FontSize="10" Foreground="{DynamicResource TextMutedBrush}" Margin="0,2,0,0">
                            <Run Text="HID: " /><Run Text="{Binding VmultiHidStatus}" />
                        </TextBlock>
                        <!-- Install status text (shown during installation) -->
                        <TextBlock Text="{Binding VmultiInstallStatus}" FontSize="10"
                                   Foreground="{DynamicResource AccentBrush}" Margin="0,2,0,0"
                                   IsVisible="{Binding VmultiInstalling}" />
                        <TextBlock Text="Required for pressure &amp; tilt" FontSize="10"
                                   Foreground="{DynamicResource TextMutedBrush}" FontStyle="Italic"
                                   Margin="0,2,0,0"
                                   IsVisible="{Binding !VmultiInstalled}" />
                    </StackPanel>

                    <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                        <!-- Browse button -->
                        <Button Content="Browse" Theme="{StaticResource AccentButton}"
                                Command="{Binding OpenFolderCommand}"
                                CommandParameter="C:\Program Files\VMulti"
                                Padding="12,6" FontSize="12" Margin="0,0,8,4" />
                        <!-- Install button -->
                        <Button Content="Install" Theme="{StaticResource AccentButton}"
                                Command="{Binding InstallVmultiCommand}"
                                Padding="12,6" FontSize="12" Margin="0,0,8,4"
                                IsVisible="{Binding ShowInstallButton}" />
                        <!-- Uninstall button -->
                        <Button Content="Uninstall" Theme="{StaticResource AccentButton}"
                                Command="{Binding UninstallVmultiCommand}"
                                Padding="12,6" FontSize="12" Margin="0,0,8,4"
                                IsVisible="{Binding ShowUninstallButton}" />
                        <!-- Progress indicator -->
                        <TextBlock Text="{Binding VmultiInstallStatus}" FontSize="11"
                                   Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"
                                   Margin="0,0,0,4"
                                   IsVisible="{Binding VmultiInstalling}" />
                    </WrapPanel>
                </Grid>
            </Border>

            <!-- Windows Ink Status -->
            <Border Classes="GlassPanel" Margin="0,0,0,12" Padding="16">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <StackPanel Grid.Column="0" MinWidth="0" VerticalAlignment="Center">
                        <!-- Title -->
                        <TextBlock Classes="CardTitle" Text="Kuuube's Windows Ink plugin" FontSize="13"
                                   TextWrapping="Wrap" />

                        <!-- Install status (version folded into the text, e.g. "v0.5.2 installed") -->
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Classes="statusMarkWarn" Classes.success="{Binding WinInkInstalled}" />
                            <TextBlock Text="{Binding WinInkInstallStatusText}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </StackPanel>

                        <!-- Active status: whether the active profile actually uses Windows Ink output mode -->
                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0"
                                    IsVisible="{Binding WinInkInstalled}">
                            <TextBlock Classes="statusMarkWarn" Classes.success="{Binding HasWindowsInk}" />
                            <TextBlock Text="{Binding WindowsInkStatusText}" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </StackPanel>

                        <!-- Supported driver version vs running OTD version -->
                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0"
                                    IsVisible="{Binding WinInkInstalled}">
                            <TextBlock FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                                       Text="{Binding WinInkSupportedDriverVersion, StringFormat='Supported driver: v{0}'}" />
                            <TextBlock FontSize="10" Foreground="{DynamicResource TextMutedBrush}" Margin="8,0,0,0"
                                       Text="{Binding CurrentOtdVersion, StringFormat='· OTD: v{0}'}" />
                        </StackPanel>

                        <!-- Compatibility mismatch warning -->
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                                    IsVisible="{Binding WinInkVersionMismatch}">
                            <TextBlock Classes="warning" />
                            <TextBlock FontSize="10" FontWeight="SemiBold" TextWrapping="Wrap"
                                       Foreground="{DynamicResource WarningBrush}"
                                       Text="{Binding CurrentOtdVersion, StringFormat='May be incompatible with OpenTabletDriver v{0}'}" />
                        </StackPanel>

                        <!-- Not-installed hint -->
                        <TextBlock Text="Install to enable pressure &amp; tilt in drawing apps"
                                   FontSize="10" Foreground="{DynamicResource TextMutedBrush}" FontStyle="Italic"
                                   TextWrapping="Wrap" Margin="0,4,0,0"
                                   IsVisible="{Binding !WinInkInstalled}" />

                        <!-- Update-check result -->
                        <TextBlock Text="{Binding WinInkUpdateCheckStatus}" FontSize="10" FontStyle="Italic"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,6,0,0"
                                   IsVisible="{Binding HasWinInkUpdateCheckStatus}" />

                        <!-- Action buttons -->
                        <WrapPanel Margin="0,12,0,0">
                            <Button Content="Install" Theme="{StaticResource AccentButton}"
                                    Command="{Binding InstallWindowsInkCommand}"
                                    Padding="12,6" FontSize="12" Margin="0,0,8,4"
                                    IsVisible="{Binding ShowWinInkInstall}" />
                            <Button Content="Check for Update" Theme="{StaticResource GhostButton}"
                                    Command="{Binding CheckForWindowsInkUpdateCommand}"
                                    Padding="12,6" FontSize="12" Margin="0,0,8,4"
                                    IsVisible="{Binding ShowWinInkCheckUpdate}" />
                            <Button Content="{Binding WinInkLatestVersion, StringFormat='Install Update (v{0})'}"
                                    Theme="{StaticResource AccentButton}"
                                    Command="{Binding InstallWindowsInkUpdateCommand}"
                                    Padding="12,6" FontSize="12" Margin="0,0,8,4"
                                    IsVisible="{Binding ShowWinInkInstallUpdate}" />
                            <Button Content="Uninstall" Theme="{StaticResource DeleteButton}"
                                    Command="{Binding UninstallWindowsInkCommand}"
                                    Padding="12,6" FontSize="12" Margin="0,0,8,4"
                                    IsVisible="{Binding ShowWinInkUninstall}" />
                            <TextBlock Text="{Binding WinInkBusyStatus}" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                                       Margin="0,0,8,4"
                                       IsVisible="{Binding WinInkBusy}" />
                        </WrapPanel>
                    </StackPanel>

                    <!-- Refresh plugin info -->
                    <Button Grid.Column="1" VerticalAlignment="Top" Content="Refresh"
                            Command="{Binding RefreshWindowsInkCommand}"
                            IsVisible="{Binding ShowWinInkRefresh}"
                            ToolTip.Tip="Refresh plugin info"
                            Theme="{StaticResource GhostButton}" Padding="12,6" FontSize="12" />
                </Grid>
            </Border>

        </StackPanel>
    </StackPanel>
</UserControl>
