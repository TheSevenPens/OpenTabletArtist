<UserControl x:Class="OpenTabletArtist.Views.DashboardView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="using:OpenTabletArtist.Controls">

    <!-- DataContext is the DashboardViewModel, supplied by the typed-nav DataTemplate (#15). -->
    <StackPanel MaxWidth="900" HorizontalAlignment="Left">
        <!-- Page Header -->
        <TextBlock Classes="PageTitle" Text="HOME" />

        <StackPanel>
            <!-- (The embedded OTD version + OTD UX launcher moved to the Advanced → OTD page.) -->

            <!-- Needs attention (#317): the health-check catalog, worst severity first. Hidden entirely
                 when everything is healthy, so Home stays quiet when there's nothing to do. Each card's
                 Fix button runs the relevant action in place or jumps to where the setting lives. -->
            <StackPanel IsVisible="{Binding Health.HasIssues}" Margin="0,0,0,4">
                <TextBlock Text="NEEDS ATTENTION" Classes="SectionLabel" Margin="0,0,0,8" />
                <ItemsControl ItemsSource="{Binding Health.Issues}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Classes="GlassPanel" Margin="0,0,0,8" Padding="16"
                                    BorderBrush="{DynamicResource WarningBrush}" BorderThickness="1.5">
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                    <TextBlock Grid.Column="0" Classes="statusMark" VerticalAlignment="Center"
                                               Classes.error="{Binding Severity, Converter={StaticResource EnumEquals}, ConverterParameter=Broken}"
                                               Classes.warning="{Binding Severity, Converter={StaticResource EnumEquals}, ConverterParameter=Misconfigured}"
                                               Classes.neutral="{Binding Severity, Converter={StaticResource EnumEquals}, ConverterParameter=Recommendation}" />
                                    <StackPanel Grid.Column="1" MinWidth="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" Classes="CardTitle" FontSize="13" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding Detail}" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                                    </StackPanel>
                                    <Button Grid.Column="2" Content="{Binding Remediation.ActionLabel}"
                                            IsVisible="{Binding Remediation, Converter={StaticResource NotNull}}"
                                            Command="{Binding $parent[ItemsControl].DataContext.RemediateCommand}"
                                            CommandParameter="{Binding}"
                                            Theme="{StaticResource AccentButton}" Padding="12,6" FontSize="12"
                                            VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Conflicting-driver alert: shown only when the daemon flagged real conflicts (#245). -->
            <Border Classes="GlassPanel" Margin="0,0,0,12" Padding="16"
                    BorderBrush="{DynamicResource WarningBrush}" BorderThickness="1.5"
                    IsVisible="{Binding Conflicts.HasConflicts}">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <StackPanel Grid.Column="0" MinWidth="0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Classes="warning" VerticalAlignment="Center" />
                            <TextBlock Classes="CardTitle" Text="Conflicting tablet driver detected" FontSize="13"
                                       Foreground="{DynamicResource WarningBrush}" VerticalAlignment="Center"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <TextBlock Text="A manufacturer tablet driver can interfere with OpenTabletDriver. Review and remove it in Driver cleanup."
                                   FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,4,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="Driver cleanup" Command="{Binding OpenDriverCleanupCommand}"
                            Theme="{StaticResource AccentButton}" Padding="12,6" FontSize="12"
                            VerticalAlignment="Center" />
                </Grid>
            </Border>

            <!-- OTD Status -->
            <Border Classes="GlassPanel" Margin="0,0,0,12" Padding="16">
                <StackPanel>
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <StackPanel Grid.Column="0" MinWidth="0">
                            <TextBlock Classes="CardTitle" Text="OpenTabletDriver Daemon" FontSize="13"
                                       TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Classes="statusMarkWarn" Classes.success="{Binding IsConnected}" />
                                <TextBlock Text="{Binding DaemonStatusText}" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                                <!-- Version read off the connected daemon's binary (#296). -->
                                <TextBlock Text="{Binding DaemonVersion, StringFormat='v{0}'}" FontSize="11"
                                           Margin="6,0,0,0" IsVisible="{Binding HasDaemonVersion}"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           ToolTip.Tip="Version of the connected OpenTabletDriver daemon" />
                            </StackPanel>

                            <!-- Daemon ownership indicator (one of three states while connected) -->

                            <!-- App-owned: connected to this project's build -->
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                                        IsVisible="{Binding ShowAppOwnedDaemon}">
                                <TextBlock Classes="success" />
                                <TextBlock FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource SuccessBrush}"
                                           Text="App-owned daemon"
                                           ToolTip.Tip="{Binding DaemonSourcePath}" TextWrapping="Wrap" />
                            </StackPanel>

                            <!-- External: connected to an OTD instance that isn't this project's build -->
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                                        IsVisible="{Binding ShowForeignDaemonWarning}">
                                <TextBlock Classes="warning" />
                                <TextBlock FontSize="10" FontWeight="SemiBold" TextWrapping="Wrap"
                                           Foreground="{DynamicResource WarningBrush}"
                                           Text="External daemon (not app-owned) — click Restart to use this project's build"
                                           ToolTip.Tip="{Binding DaemonSourcePath}" />
                            </StackPanel>

                            <!-- Unknown: connected but couldn't read the daemon's exe path -->
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                                        IsVisible="{Binding ShowDaemonSourceUnknown}">
                                <TextBlock Classes="neutral" />
                                <TextBlock FontSize="10"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Text="Daemon source unknown" />
                            </StackPanel>
                    </StackPanel>

                    <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                        <!-- Refresh button -->
                        <Button Content="Refresh" Command="{Binding RefreshConnectionCommand}"
                                ToolTip.Tip="Check daemon status"
                                IsEnabled="{Binding !IsDaemonBusy}"
                                Theme="{StaticResource GhostButton}" Padding="12,6" FontSize="12" Margin="0,0,6,0" />
                        <!-- Start button: show when NOT connected and not mid-connect -->
                        <Button Content="Start" Theme="{StaticResource AccentButton}"
                                Command="{Binding StartDaemonCommand}"
                                IsVisible="{Binding ShowStartButton}"
                                IsEnabled="{Binding !IsDaemonBusy}"
                                Padding="12,6" FontSize="12" />
                        <!-- Restart button: show when connected -->
                        <Button Content="Restart" Theme="{StaticResource AccentButton}"
                                Command="{Binding RestartDaemonCommand}"
                                IsVisible="{Binding IsConnected}"
                                IsEnabled="{Binding !IsDaemonBusy}"
                                Padding="12,6" FontSize="12" />
                        <!-- Stop button: show when connected -->
                        <Button Content="Stop" Theme="{StaticResource DeleteButton}"
                                Command="{Binding StopDaemonCommand}"
                                IsVisible="{Binding IsConnected}"
                                IsEnabled="{Binding !IsDaemonBusy}"
                                Padding="12,6" FontSize="12" Margin="6,0,0,0" />
                    </WrapPanel>
                </Grid>

                <!-- Activity: indeterminate progress + phase text while a lifecycle op runs OR while
                     the initial connect is in flight (so startup shows "Connecting…" instead of a
                     bare "Not connected" with nothing happening). -->
                <StackPanel IsVisible="{Binding ShowDaemonActivity}" Margin="0,12,0,0">
                    <ProgressBar IsIndeterminate="True" Height="3" Margin="0,0,0,6"
                                 Foreground="{DynamicResource AccentBrush}" />
                    <TextBlock Text="{Binding DaemonActivityText}" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                </StackPanel>

                <!-- Error: shown when a lifecycle op times out or fails -->
                <StackPanel Orientation="Horizontal" Margin="0,12,0,0"
                            IsVisible="{Binding HasDaemonOperationError}">
                    <TextBlock Classes="warning" />
                    <TextBlock Text="{Binding DaemonOperationError}" FontSize="11" TextWrapping="Wrap"
                               Foreground="{DynamicResource WarningBrush}" />
                </StackPanel>

                <!-- Auto-connect ran past the timeout: it's still retrying in the background, so say
                     so (with an immediate Retry) rather than a silent "Not connected" (#296). -->
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" Margin="0,12,0,0"
                      IsVisible="{Binding ConnectStalled}">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Classes="warning" />
                        <TextBlock Text="Couldn't reach the daemon — still retrying in the background."
                                   FontSize="11" TextWrapping="Wrap"
                                   Foreground="{DynamicResource WarningBrush}" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="Retry" Command="{Binding RefreshConnectionCommand}"
                            Theme="{StaticResource AccentButton}" Padding="12,6" FontSize="12"
                            VerticalAlignment="Center" />
                </Grid>
                </StackPanel>
            </Border>

            <!-- YOUR TABLETS: the former standalone Tablets page, merged into Home (#317). The cards are
                 navigable (Settings) and mirror the sidebar's per-tablet children with detection timing
                 + specs. -->
            <TextBlock Text="YOUR TABLETS" Classes="SectionLabel" Margin="0,4,0,10" />
            <ItemsControl ItemsSource="{Binding TabletsOverview.Tablets}"
                          IsVisible="{Binding TabletsOverview.HasTablets}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Classes="GlassPanel" Margin="0,0,0,10" Padding="16">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <StackPanel Grid.Column="0" MinWidth="0" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Classes="statusMarkWarn" Classes.success="{Binding IsDetected}" />
                                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding StatusText}" FontSize="11" Margin="0,4,0,0"
                                               Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding SpecsText}" FontSize="11" Margin="0,2,0,0"
                                               IsVisible="{Binding HasSpecs}"
                                               Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding LastSeenDetail}" FontSize="11" Margin="0,2,0,0"
                                               IsVisible="{Binding HasLastSeenDetail}"
                                               Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                                <Button Grid.Column="1" Content="Settings" Command="{Binding OpenCommand}"
                                        Theme="{StaticResource AccentButton}" Padding="12,6" FontSize="12"
                                        VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- No tablets at all → explicit empty state. -->
            <Border Classes="GlassPanel" Padding="32" IsVisible="{Binding !TabletsOverview.HasTablets}">
                <StackPanel HorizontalAlignment="Center" Spacing="8">
                    <TextBlock Text="No tablets connected or remembered"
                               FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock Text="Connect a tablet and it will appear here."
                               FontSize="13" HorizontalAlignment="Center" TextAlignment="Center"
                               Foreground="{DynamicResource TextMutedBrush}" />
                </StackPanel>
            </Border>

            <!-- Link out to OTD's supported-tablets list (#307). -->
            <Border Classes="GlassPanel" Margin="0,10,0,0" Padding="16">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <StackPanel Grid.Column="0" MinWidth="0" VerticalAlignment="Center">
                        <TextBlock Classes="CardTitle" Text="Supported tablets" FontSize="13" />
                        <TextBlock Text="Browse the full list of tablets OpenTabletDriver supports on the OTD website."
                                   FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="View list"
                            Command="{Binding TabletsOverview.OpenSupportedTabletsCommand}"
                            ToolTip.Tip="Open opentabletdriver.net/Tablets in your browser"
                            Theme="{StaticResource GhostButton}" Padding="12,6" FontSize="12"
                            VerticalAlignment="Center" />
                </Grid>
            </Border>

        </StackPanel>
    </StackPanel>
</UserControl>
