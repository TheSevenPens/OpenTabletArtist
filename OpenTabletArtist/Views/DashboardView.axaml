<UserControl x:Class="OpenTabletArtist.Views.DashboardView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="using:OpenTabletArtist.Controls"
             xmlns:conv="using:OpenTabletArtist.Converters">

    <!-- DataContext is the DashboardViewModel, supplied by the typed-nav DataTemplate (#15). No page
         title — the highlighted "home" wordmark in the top bar names the section (Zune). Home stays
         quiet: content (Needs attention / Your tablets) leads directly. -->
    <!-- Two-column Home (#combine): the home content on the left, the folded-in About content on the
         right. Left-aligned block, capped so the two columns stay a comfortable reading width. -->
    <Grid ColumnDefinitions="*,32,*" MaxWidth="1360" HorizontalAlignment="Left">
        <!-- LEFT — health · tablets. -->
        <StackPanel Grid.Column="0">
            <!-- (The embedded OTD version + OTD UX launcher moved to the Advanced → OTD page.) -->

            <!-- Needs attention (#317): the health-check catalog, worst severity first. Hidden entirely
                 when everything is healthy, so Home stays quiet when there's nothing to do. Each card's
                 Fix button runs the relevant action in place or jumps to where the setting lives. -->
            <StackPanel IsVisible="{Binding Health.HasIssues}" Margin="0,0,0,4">
                <TextBlock Text="NEEDS ATTENTION" Classes="TabTitle" Margin="0,0,0,8" />
                <ItemsControl ItemsSource="{Binding Health.Issues}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Health cards get a tinted per-tier background + border (#509/#574) so they
                                 read distinctly from normal cards, and a per-tier icon in the severity box
                                 (#552). The Alert role owns the tint/border via its Severity tier. -->
                            <c:Alert Margin="0,0,0,8" Padding="14,11"
                                     Severity="{Binding Severity, Converter={x:Static conv:HealthSeverityToAlertSeverityConverter.Instance}}">
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                                    <Border Grid.Column="0" Classes="severityBar"
                                            Classes.error="{Binding Severity, Converter={StaticResource EnumEquals}, ConverterParameter=Broken}"
                                            Classes.warning="{Binding Severity, Converter={StaticResource EnumEquals}, ConverterParameter=Misconfigured}"
                                            Classes.neutral="{Binding Severity, Converter={StaticResource EnumEquals}, ConverterParameter=Recommendation}"
                                            Classes.information="{Binding Severity, Converter={StaticResource EnumEquals}, ConverterParameter=Information}">
                                        <Panel>
                                            <PathIcon Data="{StaticResource IconAlertCircle}" Width="22" Height="22" Foreground="White"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      IsVisible="{Binding Severity, Converter={StaticResource EnumEquals}, ConverterParameter=Broken}" />
                                            <PathIcon Data="{StaticResource IconAlert}" Width="22" Height="22" Foreground="White"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      IsVisible="{Binding Severity, Converter={StaticResource EnumEquals}, ConverterParameter=Misconfigured}" />
                                            <PathIcon Data="{StaticResource IconLightbulbOn}" Width="22" Height="22" Foreground="White"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      IsVisible="{Binding Severity, Converter={StaticResource EnumEquals}, ConverterParameter=Recommendation}" />
                                            <PathIcon Data="{StaticResource IconInformationOutline}" Width="22" Height="22" Foreground="White"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      IsVisible="{Binding Severity, Converter={StaticResource EnumEquals}, ConverterParameter=Information}" />
                                        </Panel>
                                    </Border>
                                    <StackPanel Grid.Column="1" MinWidth="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" Classes="CardTitle" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding Detail}" Margin="0,2,0,0" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                                    </StackPanel>
                                    <Button Grid.Column="2" Content="{Binding Remediation.ActionLabel}"
                                            IsVisible="{Binding Remediation, Converter={StaticResource NotNull}}"
                                            Command="{Binding $parent[ItemsControl].DataContext.RemediateCommand}"
                                            CommandParameter="{Binding}"
                                            Theme="{StaticResource AccentButton}" Padding="12,6"
                                            VerticalAlignment="Center" />
                                </Grid>
                            </c:Alert>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- (Conflicting-driver alert folded into the "Needs attention" health list above (#317).) -->

            <!-- Daemon problem card: the daemon is surfaced on Home only when there's a connection
                 problem or an op is in flight. It morphs to a "Connecting to daemon…" spinner while Fix
                 runs, then clears on success (or reverts to the error). The full status + controls +
                 version live on the Daemon page (Advanced → OpenTabletDriver). -->
            <c:Alert Severity="Warning" Background="{DynamicResource GlassBgBrush}" Margin="0,0,0,12"
                     IsVisible="{Binding Daemon.ShowDaemonProblem}">
                <Panel>
                    <!-- Connecting… (morph) -->
                    <StackPanel IsVisible="{Binding Daemon.ShowDaemonActivity}">
                        <TextBlock Text="{Binding Daemon.DaemonActivityText}" Classes="CardTitle" />
                        <ProgressBar IsIndeterminate="True" Height="3" Margin="0,10,0,0"
                                     Foreground="{DynamicResource AccentBrush}" />
                    </StackPanel>
                    <!-- Problem (not connecting): message + Fix + Open daemon page. -->
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12"
                          IsVisible="{Binding !Daemon.ShowDaemonActivity}">
                        <TextBlock Grid.Column="0" Classes="warning" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" MinWidth="0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Daemon.HomeProblemText}" Classes="CardTitle" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding Daemon.DaemonOperationError}" Margin="0,4,0,0" TextWrapping="Wrap"
                                       IsVisible="{Binding Daemon.HasDaemonOperationError}"
                                       Foreground="{DynamicResource WarningBrush}" />
                            <TextBlock Text="Open the daemon page to start it or see details." Margin="0,4,0,0" TextWrapping="Wrap"
                                       IsVisible="{Binding Daemon.IsDaemonExeMissing}"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </StackPanel>
                        <Button Grid.Column="2" Content="Fix" Command="{Binding Daemon.FixCommand}"
                                IsVisible="{Binding Daemon.CanStartDaemon}" IsEnabled="{Binding !Daemon.IsDaemonBusy}"
                                Theme="{StaticResource AccentButton}" Padding="12,6" VerticalAlignment="Center" />
                        <Button Grid.Column="3" Content="Open daemon page" Command="{Binding Daemon.OpenDaemonPageCommand}"
                                Theme="{StaticResource GhostButton}" Padding="12,6" VerticalAlignment="Center" />
                    </Grid>
                </Panel>
            </c:Alert>

            <!-- YOUR TABLETS: the former standalone Tablets page, merged into Home (#317). The cards are
                 navigable (Settings) and mirror the sidebar's per-tablet children with detection timing
                 + specs. -->
            <TextBlock Text="YOUR TABLETS" Classes="TabTitle" Margin="0,4,0,10" />
            <ItemsControl ItemsSource="{Binding TabletsOverview.Tablets}"
                          IsVisible="{Binding TabletsOverview.HasTablets}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <c:Entity Margin="0,0,0,10">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <StackPanel Grid.Column="0" MinWidth="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding StatusText}" Margin="0,4,0,0"
                                               Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding SpecsText}" Margin="0,2,0,0"
                                               IsVisible="{Binding HasSpecs}"
                                               Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding LastSeenDetail}" Margin="0,2,0,0"
                                               IsVisible="{Binding HasLastSeenDetail}"
                                               Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                                            VerticalAlignment="Center">
                                    <Button Content="Settings" Command="{Binding OpenCommand}"
                                            Theme="{StaticResource AccentButton}" Padding="12,6" />
                                    <!-- Forget (remove saved settings). Managing connections lives here on Home.
                                         Offered for every tablet (#575): removes a remembered one, or resets a
                                         connected one to defaults — the tooltip + confirm dialog say which. -->
                                    <Button Command="{Binding ForgetCommand}"
                                            Theme="{StaticResource GhostButton}" Padding="9,6"
                                            ToolTip.Tip="{Binding ForgetTooltip}"
                                            AutomationProperties.Name="{Binding ForgetTooltip}">
                                        <PathIcon Data="{StaticResource IconTrashCanOutline}" Width="16" Height="16"
                                                  Foreground="{Binding $parent[Button].Foreground}" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </c:Entity>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- No tablets at all → a quiet inline empty state (boxless, left-aligned to the section
                 rhythm — the full Zune hero lives on the TABLET page). -->
            <StackPanel Spacing="4" Margin="0,0,0,6" IsVisible="{Binding !TabletsOverview.HasTablets}">
                <TextBlock Text="No tablets connected or remembered"
                           FontSize="15" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                <TextBlock Text="Connect a tablet and it'll appear here."
                           Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" />
            </StackPanel>

            <!-- (The run-at-startup toggle moved to its own Advanced → Startup page.) -->

        </StackPanel>

        <!-- RIGHT — the folded-in About content (what-is · help · resources · version). Rendered from
             the AboutViewModel via the typed-nav DataTemplate, so the markup isn't duplicated. The
             supported-tablets link now lives in that card's RESOURCES list. -->
        <ContentControl Grid.Column="2" Content="{Binding About}" VerticalAlignment="Top" />
    </Grid>
</UserControl>
