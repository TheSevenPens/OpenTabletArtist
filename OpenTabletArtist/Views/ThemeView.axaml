<UserControl x:Class="OpenTabletArtist.Views.ThemeView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="using:OpenTabletArtist.Controls">

    <!-- DataContext is the ThemeViewModel, supplied by the typed-nav DataTemplate (#15). -->
    <StackPanel MaxWidth="900" HorizontalAlignment="Left">
        <c:SettingCard Title="Appearance">
            <StackPanel>
                <c:LabeledField Label="Theme">
                    <ComboBox HorizontalAlignment="Left" MinWidth="220"
                              ItemsSource="{Binding ThemeOptions}"
                              SelectedItem="{Binding SelectedTheme}"
                              ToolTip.Tip="Light, Dark, Sakura, Custom, or follow the system setting">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <!-- Colour swatch previewing the theme. -->
                                    <Border Width="18" Height="18" CornerRadius="5"
                                            Background="{Binding Swatch}"
                                            BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                                            VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Label}" VerticalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </c:LabeledField>
                <TextBlock Text="{Binding SelectedDescription}"
                           Foreground="{DynamicResource TextMutedBrush}"
                           TextWrapping="Wrap" Margin="0,8,0,0" />
                <TextBlock Text="Your choice is remembered across restarts."
                           Foreground="{DynamicResource TextMutedBrush}"
                           TextWrapping="Wrap" Margin="0,2,0,0" />

                <!-- Sakura + Custom: toggle the falling-petal animation (#207), plus its opacity. -->
                <c:ToggleSetting Label="Falling petals" IsChecked="{Binding PetalsEnabled}"
                                 IsVisible="{Binding ShowPetalsToggle}" Margin="0,12,0,0"
                                 ToolTip.Tip="Animate drifting petals over the backdrop" />
                <c:LabeledSlider Label="Petal opacity" LabelWidth="130"
                                 Minimum="0.1" Maximum="1" Value="{Binding PetalsOpacity}"
                                 ValueFormat="0%" Margin="0,8,0,0"
                                 IsVisible="{Binding ShowPetalsToggle}" IsEnabled="{Binding PetalsEnabled}"
                                 ToolTip.Tip="How opaque the falling petals are" />
            </StackPanel>
        </c:SettingCard>

        <!-- Custom-only: the accent colour that derives the whole scheme + an optional background image. -->
        <c:SettingCard Title="Custom look" Margin="0,12,0,0" IsVisible="{Binding ShowCustomControls}"
                       Description="Pick an accent colour — the whole scheme (buttons, highlights, controls) is derived from it — and a base colour for the background behind the panels. Add a background image to fill the window instead.">
            <StackPanel Spacing="12">
                <c:LabeledField Label="Accent colour">
                    <ColorPicker Color="{Binding AccentColor, Mode=TwoWay}"
                                 ToolTip.Tip="The colour the rest of the scheme is derived from" />
                </c:LabeledField>
                <c:LabeledField Label="Base colour">
                    <ColorPicker Color="{Binding BaseColor, Mode=TwoWay}"
                                 ToolTip.Tip="The background colour behind the panels and the left pane (when no image is set)" />
                </c:LabeledField>
                <c:LabeledField Label="Background image">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding BackgroundImageLabel}" MaxWidth="220"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource TextMutedBrush}" />
                        <Button Content="Choose image…" Click="OnChooseImage" />
                        <Button Content="Clear" Command="{Binding ClearBackgroundImageCommand}"
                                IsEnabled="{Binding HasBackgroundImage}" />
                    </StackPanel>
                </c:LabeledField>
            </StackPanel>
        </c:SettingCard>

        <!-- Sakura + Custom: card tint/opacity + left-pane opacity, and a reset. Each control drives a
             global brush, so the whole app (including this page) re-tints live as you change it. -->
        <c:SettingCard Title="Cards &amp; translucency" Margin="0,12,0,0" IsVisible="{Binding ShowFrostControls}"
                       Description="Pick the card tint colour and how opaque the cards and left pane are — lower opacity lets more of the backdrop show through. Applies live.">
            <StackPanel Spacing="12">
                <c:LabeledField Label="Card colour">
                    <!-- Alpha hidden + disabled: card transparency is set by the separate "Card opacity"
                         slider below; the tint's own alpha is ignored by FrostBrush, so exposing it here just
                         misled (#505). IsAlphaVisible removes the alpha slider; IsAlphaEnabled keeps it opaque. -->
                    <ColorPicker Color="{Binding CardColor, Mode=TwoWay}"
                                 IsAlphaVisible="False" IsAlphaEnabled="False"
                                 ToolTip.Tip="The tint colour of the frosted cards" />
                </c:LabeledField>
                <c:LabeledSlider Label="Card opacity" LabelWidth="130"
                                 Minimum="0.15" Maximum="1" Value="{Binding CardOpacity}" />
                <c:LabeledSlider Label="Left pane opacity" LabelWidth="130"
                                 Minimum="0.15" Maximum="1" Value="{Binding SidebarOpacity}" />
                <Button Content="Reset to defaults" Command="{Binding ResetToDefaultsCommand}"
                        HorizontalAlignment="Left" Margin="0,4,0,0"
                        ToolTip.Tip="Restore this theme's colours, opacity, and petals to their defaults" />
            </StackPanel>
        </c:SettingCard>
    </StackPanel>
</UserControl>
