<UserControl x:Class="OpenTabletArtist.Views.ThemeView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="using:OpenTabletArtist.Controls">

    <!-- DataContext is the ThemeViewModel, supplied by the typed-nav DataTemplate (#15). Two columns:
         appearance (+ custom look) on the left, colours & translucency on the right. -->
    <Grid ColumnDefinitions="*,24,*" MaxWidth="900" HorizontalAlignment="Left">
        <!-- LEFT — appearance + custom look. -->
        <StackPanel Grid.Column="0">
        <c:Section Title="Appearance">
            <StackPanel>
                <c:LabeledField Label="Theme">
                    <ComboBox HorizontalAlignment="Left" MinWidth="220"
                              ItemsSource="{Binding ThemeOptions}"
                              SelectedItem="{Binding SelectedTheme}"
                              ToolTip.Tip="Light, Dark, Sakura, Custom, or follow the system setting">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <!-- Colour swatch previewing the theme. -->
                                    <Border Width="18" Height="18" CornerRadius="0"
                                            Background="{Binding Swatch}"
                                            BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                                            VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Label}" VerticalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </c:LabeledField>
                <TextBlock Text="{Binding SelectedDescription}"
                           Foreground="{DynamicResource TextMutedBrush}"
                           TextWrapping="Wrap" Margin="0,8,0,0" />
                <TextBlock Text="Your choice is remembered across restarts."
                           Foreground="{DynamicResource TextMutedBrush}"
                           TextWrapping="Wrap" Margin="0,2,0,0" />

                <!-- Sakura + Custom: toggle the falling-petal animation (#207), plus its opacity. -->
                <c:ToggleSetting Label="Falling petals" IsChecked="{Binding PetalsEnabled}"
                                 IsVisible="{Binding ShowPetalsToggle}" Margin="0,12,0,0"
                                 ToolTip.Tip="Animate drifting petals over the backdrop" />
                <c:LabeledSlider Label="Petal opacity" LabelWidth="130"
                                 Minimum="0.1" Maximum="1" Value="{Binding PetalsOpacity}"
                                 ValueFormat="0%" Margin="0,8,0,0"
                                 IsVisible="{Binding ShowPetalsToggle}" IsEnabled="{Binding PetalsEnabled}"
                                 ToolTip.Tip="How opaque the falling petals are" />
            </StackPanel>
        </c:Section>

        <!-- Custom-only: the base colour behind the panels + an optional background image. (The accent/
             highlight colour lives in Colours & translucency below, since every skin can set it now.) -->
        <c:Section Title="Custom look" Margin="0,12,0,0" IsVisible="{Binding ShowCustomControls}"
                       Description="Pick a base colour for the background behind the panels, or add a background image to fill the window instead.">
            <StackPanel Spacing="12">
                <StackPanel Spacing="4">
                    <TextBlock Text="Base colour" Foreground="{DynamicResource TextSecondaryBrush}" />
                    <c:SwatchPicker Color="{Binding BaseColor, Mode=TwoWay}" />
                </StackPanel>
                <c:LabeledField Label="Background image">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding BackgroundImageLabel}" MaxWidth="220"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource TextMutedBrush}" />
                        <Button Content="Choose image…" Click="OnChooseImage" />
                        <Button Content="Clear" Command="{Binding ClearBackgroundImageCommand}"
                                IsEnabled="{Binding HasBackgroundImage}" />
                    </StackPanel>
                </c:LabeledField>
                <!-- Only meaningful with an image set: fades the image over the base colour. -->
                <c:LabeledSlider Label="Image opacity" LabelWidth="130"
                                 Minimum="0" Maximum="1" Value="{Binding BackgroundImageOpacity}"
                                 ValueFormat="0%" IsVisible="{Binding ShowBackgroundImageOpacity}"
                                 ToolTip.Tip="Lower opacity lets more of the base colour show through the image" />
            </StackPanel>
        </c:Section>
        </StackPanel>

        <!-- RIGHT — colours & translucency. -->
        <StackPanel Grid.Column="2">
        <!-- Every translucent skin: highlight/card/left-pane colours (from a fixed palette, #555/#563) +
             opacities + a reset. Each control drives a global brush, so the whole app re-tints live. -->
        <c:Section Title="Colors &amp; opacity" IsVisible="{Binding ShowFrostControls}"
                       Description="Pick colours from the palette and set how opaque the cards and left pane are — lower opacity lets more of the backdrop show through. Applies live.">
            <StackPanel Spacing="14">
                <!-- Highlight/accent colour — all skins (#557). Derives buttons, selected nav, toggles, radios. -->
                <StackPanel Spacing="4" IsVisible="{Binding ShowAccentControl}">
                    <TextBlock Text="Highlight colour" Foreground="{DynamicResource TextSecondaryBrush}" />
                    <c:SwatchPicker Color="{Binding AccentColor, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Spacing="4">
                    <TextBlock Text="Card colour" Foreground="{DynamicResource TextSecondaryBrush}" />
                    <c:SwatchPicker Color="{Binding CardColor, Mode=TwoWay}" />
                </StackPanel>
                <c:LabeledSlider Label="Card opacity" LabelWidth="130"
                                 Minimum="0.15" Maximum="1" Value="{Binding CardOpacity}" />
                <!-- Left-pane (sidebar) tint — Sakura / Dark Sakura only (#554). -->
                <StackPanel Spacing="4" IsVisible="{Binding ShowSidebarColor}">
                    <TextBlock Text="Left pane colour" Foreground="{DynamicResource TextSecondaryBrush}" />
                    <c:SwatchPicker Color="{Binding SidebarColor, Mode=TwoWay}" />
                </StackPanel>
                <c:LabeledSlider Label="Left pane opacity" LabelWidth="130"
                                 Minimum="0.15" Maximum="1" Value="{Binding SidebarOpacity}" />
                <Button Content="Reset to defaults" Command="{Binding ResetToDefaultsCommand}"
                        HorizontalAlignment="Left" Margin="0,4,0,0"
                        ToolTip.Tip="Restore this theme's colours, opacity, and petals to their defaults" />
            </StackPanel>
        </c:Section>
        </StackPanel>
    </Grid>
</UserControl>
