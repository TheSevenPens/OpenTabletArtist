<UserControl x:Class="OpenTabletArtist.Views.TestView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="using:OpenTabletArtist.Controls">

    <UserControl.Styles>
        <!-- Small accent pill listing an active dynamics aspect (#184), matching the banner's chip. -->
        <Style Selector="Border.DynChip">
            <Setter Property="Background" Value="{DynamicResource AccentMutedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="6,1" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Border.DynChip > TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        </Style>
        <!-- Each readout row pairs a proportional label with a monospace value; the two fonts have
             different line-box metrics, so center both to keep the value from sitting above its label. -->
        <Style Selector="UniformGrid > StackPanel > TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Styles>

    <!-- DataContext is the TestViewModel, supplied by the typed-nav DataTemplate (#15). -->
    <DockPanel LastChildFill="True">

        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Classes="PageTitle" Text="SCRIBBLE" />
            <!-- Tablet status (detected name / not detected). The "Dynamics on" pill now lives with the
                 "Affecting your pen" chips below, so it isn't shown on the banner. #128/#129/#130 -->
            <c:TabletStatusBanner Text="{Binding TabletStatusText}" IsDetected="{Binding TabletDetected}"
                                  Margin="0,8,0,0" />

            <!-- Active-tablet picker, only when more than one tablet is connected (#190 phase 3). -->
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0"
                        IsVisible="{Binding ShowTabletPicker}">
                <TextBlock Text="Tablet" FontSize="12" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
                <ComboBox ItemsSource="{Binding TabletNames}" SelectedItem="{Binding SelectedTablet}"
                          MinWidth="200" FontSize="13" />
            </StackPanel>

            <!-- Spell out which dynamics are actually altering the pen, so it's clear why the stroke
                 behaves as it does (#184). -->
            <WrapPanel Orientation="Horizontal" IsVisible="{Binding DynamicsActive}" Margin="0,6,0,0">
                <TextBlock Text="Affecting your pen:" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
                <!-- "Dynamics on" pill grouped with the specific-aspect chips (moved off the banner). -->
                <Border Classes="DynChip">
                    <TextBlock Text="Dynamics on" />
                </Border>
                <Border Classes="DynChip" IsVisible="{Binding CurveActive}">
                    <TextBlock Text="Pressure curve" />
                </Border>
                <Border Classes="DynChip" IsVisible="{Binding PressureSmoothingActive}">
                    <TextBlock Text="Pressure smoothing" />
                </Border>
                <Border Classes="DynChip" IsVisible="{Binding PositionSmoothingActive}">
                    <TextBlock Text="Position smoothing" />
                </Border>
                <TextBlock Text="No curve or smoothing — behaves linear" FontSize="12" VerticalAlignment="Center"
                           IsVisible="{Binding DynamicsNoOp}" Foreground="{DynamicResource TextMutedBrush}" />
            </WrapPanel>

            <!-- Pointer-only mode paints nothing, so active dynamics are invisible — warn (#183). -->
            <TextBlock Text="Pointer-only mode doesn't draw, so you won't see the dynamics above. Pick a pressure Mode to see them."
                       IsVisible="{Binding PointerOnlyWithDynamics}" Margin="0,6,0,0"
                       FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource WarningBrush}" />

            <!-- Controls + live readouts, grouped in one card so they read as a single panel instead
                 of floating text over the themed backdrop. -->
            <Border Classes="GlassPanel" Padding="16" Margin="0,12,0,0">
                <StackPanel>
                    <!-- Controls -->
                    <WrapPanel Orientation="Horizontal">
                        <ToggleSwitch OffContent="App input (Windows Ink)" OnContent="Driver input (OTD)"
                                      IsChecked="{Binding UseDriverInput}" FontSize="13"
                                      VerticalAlignment="Center" Margin="0,0,20,0" />
                        <TextBlock Text="Mode" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <ComboBox ItemsSource="{Binding BrushModes}" SelectedItem="{Binding BrushMode}"
                                  MinWidth="170" FontSize="13" VerticalAlignment="Center" Margin="0,0,20,0" />
                        <Button Content="Clear" Command="{Binding ClearCommand}"
                                Theme="{StaticResource GhostButton}" Padding="14,6" FontSize="13" />
                        <Button Content="Dynamics" Command="{Binding OpenDynamicsCommand}"
                                Theme="{StaticResource GhostButton}" Padding="14,6" FontSize="13" Margin="8,0,0,0"
                                ToolTip.Tip="Open this tablet's Dynamics settings (curve + smoothing) without leaving Test" />
                        <Button Content="Copy" Click="OnCopy"
                                Theme="{StaticResource GhostButton}" Padding="14,6" FontSize="13" Margin="8,0,0,0"
                                ToolTip.Tip="Copy the drawing to the clipboard as an image" />
                    </WrapPanel>

                    <!-- Live readouts. UniformGrid = equal-width cells, so values changing width can't
                         shift the row; monospace values keep the digits from jittering. -->
                    <UniformGrid Columns="5" Margin="0,14,0,0">
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock Text="Canvas X:" Width="62" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding CanvasXText}" FontFamily="{DynamicResource MonoFontFamily}" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock Text="Canvas Y:" Width="62" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding CanvasYText}" FontFamily="{DynamicResource MonoFontFamily}" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock Text="Pressure:" Width="62" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding PressureText}" FontFamily="{DynamicResource MonoFontFamily}" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock Text="Raw X:" Width="62" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding RawXText}" FontFamily="{DynamicResource MonoFontFamily}" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock Text="Raw Y:" Width="62" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding RawYText}" FontFamily="{DynamicResource MonoFontFamily}" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock Text="Twist:" Width="62" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding TwistText}" FontFamily="{DynamicResource MonoFontFamily}" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock Text="Tilt X:" Width="62" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding TiltXText}" FontFamily="{DynamicResource MonoFontFamily}" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock Text="Tilt Y:" Width="62" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding TiltYText}" FontFamily="{DynamicResource MonoFontFamily}" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock Text="Azimuth:" Width="62" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding AzimuthText}" FontFamily="{DynamicResource MonoFontFamily}" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock Text="Altitude:" Width="62" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding AltitudeText}" FontFamily="{DynamicResource MonoFontFamily}" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" />
                        </StackPanel>
                        <!-- Hover distance (0–255) — driver-reported. Always shown so the grid layout is stable;
                             blank ("—") in App input, numeric only in Driver input (#hover-readout). -->
                        <StackPanel Orientation="Horizontal" Margin="0,2"
                                    ToolTip.Tip="Driver-reported hover height (0–255) — shown in Driver input, for tablets that report proximity.">
                            <TextBlock Text="Hover:" Width="62" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding HoverText}" FontFamily="{DynamicResource MonoFontFamily}" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" />
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Paint surface fills the rest. Square corners (override the GlassPanel rounding). -->
        <Border Classes="GlassPanel" CornerRadius="0" Padding="0" ClipToBounds="True" MinHeight="320">
            <Grid>
                <c:PenTestCanvas x:Name="PaintCanvas"
                                 BrushMode="{Binding BrushMode}" />
                <!-- Driver-input painting needs an Absolute output mode; otherwise show why the
                     canvas is disabled (#95). -->
                <Border IsVisible="{Binding DriverCanvasDisabled}"
                        Background="#E6F5F5F0" Padding="32">
                    <TextBlock Text="{Binding DriverDisabledNote}"
                               FontSize="12" MaxWidth="420" TextWrapping="Wrap"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               TextAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                </Border>
            </Grid>
        </Border>
    </DockPanel>
</UserControl>
