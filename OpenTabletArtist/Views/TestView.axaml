<UserControl x:Class="OpenTabletArtist.Views.TestView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="using:OpenTabletArtist.Controls"
             xmlns:conv="using:OpenTabletArtist.Converters"
             xmlns:views="using:OpenTabletArtist.Views">

    <UserControl.Styles>
        <!-- Small accent chip listing an active dynamics aspect (#184), matching the banner's chip. -->
        <Style Selector="Border.DynChip">
            <Setter Property="Background" Value="{DynamicResource AccentMutedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Border.DynChip > TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource TypeCaptionSize}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        </Style>
        <!-- Each readout row pairs a proportional label with a monospace value. The two fonts have
             different metrics (Consolas rides higher than the label font), so pin both to the top and
             nudge the mono value down (via Margin on .ReadoutValue below) to align their baselines. -->
        <Style Selector="UniformGrid > StackPanel > TextBlock">
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>
        <!-- Fixed value width so the left-aligned, content-sized grid columns don't reflow (jump) as the
             numbers change digit count. Wide enough for a paired "x, y" reading (#scribble-readouts). -->
        <Style Selector="UniformGrid > StackPanel > TextBlock.ReadoutValue">
            <Setter Property="Margin" Value="0,3,0,0" />
            <Setter Property="Width" Value="104" />
        </Style>
    </UserControl.Styles>

    <!-- DataContext is the TestViewModel, supplied by the typed-nav DataTemplate (#15). -->
    <DockPanel LastChildFill="True">

        <StackPanel DockPanel.Dock="Top">
            <!-- No page title — the "scribble" wordmark names the section (Zune). -->
            <!-- One row: on the LEFT, the Dynamics button + the chips that spell out which dynamics are
                 actually altering the pen (#184) — always shown, so the button stays available when
                 dynamics are off; on the RIGHT, the active-tablet switcher (only when more than one tablet
                 is connected, #190 phase 3), matching where the Tablet/Pen pages place their switcher. -->
            <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                <WrapPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Dynamics" Command="{Binding OpenDynamicsCommand}"
                            Theme="{StaticResource GhostButton}" FontSize="{DynamicResource TypeCaptionSize}" Padding="8,3" MinHeight="0"
                            VerticalAlignment="Center" Margin="0,0,8,0"
                            ToolTip.Tip="Open this tablet's Dynamics settings (curve + smoothing) without leaving Scribble" />
                    <!-- "Dynamics on" pill grouped with the specific-aspect chips (moved off the banner). -->
                    <Border Classes="DynChip" IsVisible="{Binding DynamicsActive}">
                        <TextBlock Text="Dynamics on" />
                    </Border>
                    <Border Classes="DynChip" IsVisible="{Binding CurveActive}">
                        <TextBlock Text="Pressure curve" />
                    </Border>
                    <Border Classes="DynChip" IsVisible="{Binding PressureSmoothingActive}">
                        <TextBlock Text="Pressure smoothing" />
                    </Border>
                    <Border Classes="DynChip" IsVisible="{Binding PositionSmoothingActive}">
                        <TextBlock Text="Position smoothing" />
                    </Border>
                    <TextBlock Text="No curve or smoothing — behaves linear" VerticalAlignment="Center"
                               IsVisible="{Binding DynamicsNoOp}" Foreground="{DynamicResource TextMutedBrush}" />
                </WrapPanel>

                <!-- The same switcher dropdown the Tablet/Pen pages use (dropdown only — no refresh here),
                     at the far right of the row. Shown only when more than one tablet is connected. -->
                <views:TabletSwitcherBar Grid.Column="1" Margin="16,0,0,0"
                                         HorizontalAlignment="Right" VerticalAlignment="Center"
                                         IsVisible="{Binding ShowTabletPicker}"
                                         ShowRefresh="False"
                                         Tablets="{Binding Tablets}"
                                         SelectedTablet="{Binding SelectedTablet, Mode=TwoWay}" />
            </Grid>

            <!-- Pointer-only mode paints nothing, so active dynamics are invisible — warn (#183). -->
            <TextBlock Text="Pointer-only mode doesn't draw, so you won't see the dynamics above. Pick a pressure Mode to see them."
                       IsVisible="{Binding PointerOnlyWithDynamics}" Margin="0,6,0,0"
                       TextWrapping="Wrap" Foreground="{DynamicResource WarningBrush}" />

            <!-- Controls + live readouts, in a ControlPanel (ribbon-style control cluster) — bordered with
                 the Entity glass fill so it reads as a single panel over the themed backdrop. -->
            <c:ControlPanel Margin="0,12,0,0">
                <StackPanel>
                    <!-- Controls -->
                    <WrapPanel Orientation="Horizontal">
                        <ToggleSwitch OffContent="Windows Ink" OnContent="Raw input"
                                      IsChecked="{Binding UseDriverInput}"
                                      VerticalAlignment="Center" Margin="0,0,20,0" />
                        <TextBlock Text="Mode" VerticalAlignment="Center" Margin="0,0,6,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <ComboBox ItemsSource="{Binding BrushModes}" SelectedItem="{Binding BrushMode}"
                                  MinWidth="200" VerticalAlignment="Center" Margin="0,0,20,0">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={x:Static conv:PenBrushModeNameConverter.Instance}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Content="Clear" Command="{Binding ClearCommand}"
                                Theme="{StaticResource GhostButton}" Padding="14,6" />
                        <Button Content="Copy" Click="OnCopy"
                                Theme="{StaticResource GhostButton}" Padding="14,6" Margin="8,0,0,0"
                                ToolTip.Tip="Copy the drawing to the clipboard as an image" />
                    </WrapPanel>

                    <!-- Live readouts. X/Y pairs share a cell ("x, y") so the panel is 4×2 instead of a
                         taller 5-wide grid; left-aligned + content-sized columns keep it horizontally
                         compact on smaller desktops. Monospace values keep the digits from jittering. -->
                    <UniformGrid Columns="4" Margin="0,12,0,0" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal" Margin="0,2,20,2">
                            <TextBlock Text="Canvas:" Width="58" Foreground="{DynamicResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding CanvasText}" FontFamily="{DynamicResource MonoFontFamily}" Foreground="{DynamicResource TextPrimaryBrush}" Classes="ReadoutValue" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2,20,2">
                            <TextBlock Text="Raw:" Width="58" Foreground="{DynamicResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding RawText}" FontFamily="{DynamicResource MonoFontFamily}" Foreground="{DynamicResource TextPrimaryBrush}" Classes="ReadoutValue" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2,20,2">
                            <TextBlock Text="Tilt:" Width="58" Foreground="{DynamicResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding TiltText}" FontFamily="{DynamicResource MonoFontFamily}" Foreground="{DynamicResource TextPrimaryBrush}" Classes="ReadoutValue" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2,20,2">
                            <TextBlock Text="Pressure:" Width="58" Foreground="{DynamicResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding PressureText}" FontFamily="{DynamicResource MonoFontFamily}" Foreground="{DynamicResource TextPrimaryBrush}" Classes="ReadoutValue" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2,20,2">
                            <TextBlock Text="Twist:" Width="58" Foreground="{DynamicResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding TwistText}" FontFamily="{DynamicResource MonoFontFamily}" Foreground="{DynamicResource TextPrimaryBrush}" Classes="ReadoutValue" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2,20,2">
                            <TextBlock Text="Azimuth:" Width="58" Foreground="{DynamicResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding AzimuthText}" FontFamily="{DynamicResource MonoFontFamily}" Foreground="{DynamicResource TextPrimaryBrush}" Classes="ReadoutValue" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2,20,2">
                            <TextBlock Text="Altitude:" Width="58" Foreground="{DynamicResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding AltitudeText}" FontFamily="{DynamicResource MonoFontFamily}" Foreground="{DynamicResource TextPrimaryBrush}" Classes="ReadoutValue" />
                        </StackPanel>
                        <!-- Hover distance (0–255) — driver-reported. Always shown so the grid layout is stable;
                             blank ("—") in App input, numeric only in Driver input (#hover-readout). -->
                        <StackPanel Orientation="Horizontal" Margin="0,2,20,2"
                                    ToolTip.Tip="Driver-reported hover height (0–255) — shown in Driver input, for tablets that report proximity.">
                            <TextBlock Text="Hover:" Width="58" Foreground="{DynamicResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding HoverText}" FontFamily="{DynamicResource MonoFontFamily}" Foreground="{DynamicResource TextPrimaryBrush}" Classes="ReadoutValue" />
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>
            </c:ControlPanel>
        </StackPanel>

        <!-- Paint surface fills the rest. Square corners (override the default card rounding). -->
        <c:Canvas CornerRadius="0" Padding="0" ClipToBounds="True" MinHeight="320">
            <Grid>
                <c:PenTestCanvas x:Name="PaintCanvas"
                                 BrushMode="{Binding BrushMode}" />
                <!-- Driver-input painting needs an Absolute output mode; otherwise show why the
                     canvas is disabled (#95). -->
                <Border IsVisible="{Binding DriverCanvasDisabled}"
                        Background="#E6F5F5F0" Padding="32">
                    <TextBlock Text="{Binding DriverDisabledNote}"
                               MaxWidth="420" TextWrapping="Wrap"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               TextAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                </Border>
            </Grid>
        </c:Canvas>
    </DockPanel>
</UserControl>
