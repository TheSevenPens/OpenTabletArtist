<UserControl x:Class="OpenTabletArtist.Views.OtdView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- DataContext is the OtdViewModel, supplied by the typed-nav DataTemplate (#15). -->
    <StackPanel MaxWidth="900" HorizontalAlignment="Left">
        <TextBlock Classes="PageTitle" Text="DAEMON" />
        <TextBlock Classes="PageSubtitle" Text="Bundled OpenTabletDriver engine" />

        <!-- Embedded OpenTabletDriver Version (moved here from Home). -->
        <Border Classes="GlassPanel" Margin="0,0,0,12" Padding="16">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <StackPanel Grid.Column="0" MinWidth="0">
                    <TextBlock Classes="CardTitle" Text="Embedded OpenTabletDriver Version" FontSize="13"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding CurrentOtdVersion}" Margin="0,4,0,0" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                </StackPanel>

                <!-- Launch OTD's own UX -->
                <Button Grid.Column="1" Content="OTD UX" Theme="{StaticResource GhostButton}"
                        Command="{Binding LaunchOtdUxCommand}"
                        VerticalAlignment="Center"
                        Padding="12,6" FontSize="12" />
            </Grid>
        </Border>
    </StackPanel>
</UserControl>
