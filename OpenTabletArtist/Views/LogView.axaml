<UserControl x:Class="OpenTabletArtist.Views.LogView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- DataContext is the LogViewModel, supplied by the typed-nav DataTemplate (#15). -->
    <StackPanel HorizontalAlignment="Stretch">
        <!-- Toolbar: level filter, search, auto-scroll, copy/clear -->
        <Border Classes="GlassPanel" Margin="0,0,0,12">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto" ColumnSpacing="14" VerticalAlignment="Center">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="Level" FontSize="12" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                    <ComboBox ItemsSource="{Binding Levels}" SelectedItem="{Binding MinLevel}" MinWidth="120"
                              ToolTip.Tip="Hide messages below this severity" />
                </StackPanel>
                <CheckBox Grid.Column="1" Content="Auto-scroll" IsChecked="{Binding AutoScroll}"
                          FontSize="12" VerticalAlignment="Center" />
                <TextBox Grid.Column="2" Text="{Binding SearchText}" MinWidth="160"
                         PlaceholderText="Filter messages…" FontSize="12"
                         ToolTip.Tip="Show only log lines whose message contains this text (case-insensitive)" />
                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="{Binding FilterSummary}" FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"
                               IsVisible="{Binding ShowFilterSummary}" />
                    <TextBlock Text="Daemon not connected." FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"
                               IsVisible="{Binding !IsConnected}" />
                </StackPanel>
                <Button Grid.Column="4" Content="Copy ▾"
                        Theme="{StaticResource GhostButton}" Padding="12,6" FontSize="12"
                        IsEnabled="{Binding HasEntries}"
                        ToolTip.Tip="Copy the visible log to the clipboard">
                    <Button.Flyout>
                        <MenuFlyout>
                            <MenuItem Header="Copy as text" Click="CopyText_Click" />
                            <MenuItem Header="Copy as Markdown" Click="CopyMarkdown_Click" />
                            <MenuItem Header="Copy as HTML" Click="CopyHtml_Click" />
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
                <Button Grid.Column="5" Content="Clear" Command="{Binding ClearCommand}"
                        Theme="{StaticResource GhostButton}" Padding="12,6" FontSize="12"
                        IsEnabled="{Binding HasEntries}" />
            </Grid>
        </Border>

        <!-- Log -->
        <Border Classes="GlassPanel" Padding="0" ClipToBounds="True">
            <Panel>
                <ListBox x:Name="LogList" ItemsSource="{Binding Entries}"
                         Height="560" Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="12,2" />
                            <Setter Property="MinHeight" Value="0" />
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="Auto,52,Auto,*" ColumnSpacing="10">
                                <TextBlock Grid.Column="0" Text="{Binding Time}"
                                           FontFamily="{DynamicResource MonoFontFamily}" FontSize="12"
                                           Foreground="{DynamicResource TextMutedBrush}" />
                                <TextBlock Grid.Column="1" Text="{Binding Level}"
                                           FontFamily="{DynamicResource MonoFontFamily}" FontSize="12"
                                           FontWeight="SemiBold" Foreground="{Binding LevelBrush}" />
                                <TextBlock Grid.Column="2" Text="{Binding Group}"
                                           FontFamily="{DynamicResource MonoFontFamily}" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                <TextBlock Grid.Column="3" Text="{Binding Message}"
                                           FontFamily="{DynamicResource MonoFontFamily}" FontSize="12"
                                           Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Empty / no-matches state -->
                <TextBlock Text="{Binding EmptyStateText}" FontSize="12"
                           Foreground="{DynamicResource TextMutedBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           IsHitTestVisible="False"
                           IsVisible="{Binding ShowEmptyState}" />
            </Panel>
        </Border>
    </StackPanel>
</UserControl>
