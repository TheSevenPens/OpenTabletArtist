<UserControl x:Class="OpenTabletArtist.Views.LogView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="using:OpenTabletArtist.Controls">

    <!-- DataContext is the LogViewModel, supplied by the typed-nav DataTemplate (#15). The page fills the
         viewport (the shell disables the outer scroll for the Console tab): the toolbar is pinned at the
         top and only the log list scrolls, so there's never a second, outer scrollbar. -->
    <Grid RowDefinitions="Auto,*">
        <!-- Toolbar: level filter, search, auto-scroll, copy/clear -->
        <c:Section Grid.Row="0" Margin="0,0,0,12">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto" ColumnSpacing="14" VerticalAlignment="Center">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="Level" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                    <ComboBox ItemsSource="{Binding Levels}" SelectedItem="{Binding MinLevel}" MinWidth="120"
                              ToolTip.Tip="Hide messages below this severity" />
                </StackPanel>
                <CheckBox Grid.Column="1" Content="Auto-scroll" IsChecked="{Binding AutoScroll}"
                          VerticalAlignment="Center" />
                <TextBox Grid.Column="2" Text="{Binding SearchText}" MinWidth="160"
                         PlaceholderText="Filter messages…"
                         ToolTip.Tip="Show only log lines whose message contains this text (case-insensitive)" />
                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="{Binding FilterSummary}"
                               Foreground="{DynamicResource TextMutedBrush}"
                               IsVisible="{Binding ShowFilterSummary}" />
                    <TextBlock Text="Daemon not connected."
                               Foreground="{DynamicResource TextMutedBrush}"
                               IsVisible="{Binding !IsConnected}" />
                </StackPanel>
                <Button Grid.Column="4"
                        Theme="{StaticResource GhostButton}" Padding="12,6"
                        IsEnabled="{Binding HasEntries}"
                        ToolTip.Tip="Copy the visible log to the clipboard">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Copy" VerticalAlignment="Center" />
                        <PathIcon Data="{StaticResource IconChevronDown}" Width="10" Height="10"
                                  VerticalAlignment="Center" />
                    </StackPanel>
                    <Button.Flyout>
                        <MenuFlyout>
                            <MenuItem Header="Copy as text" Click="CopyText_Click" />
                            <MenuItem Header="Copy as Markdown" Click="CopyMarkdown_Click" />
                            <MenuItem Header="Copy as HTML" Click="CopyHtml_Click" />
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
                <Button Grid.Column="5" Content="Clear" Command="{Binding ClearCommand}"
                        Theme="{StaticResource GhostButton}" Padding="12,6"
                        IsEnabled="{Binding HasEntries}" />
            </Grid>
        </c:Section>

        <!-- Log — fills the remaining height; the ListBox scrolls internally. A plain Panel (not c:Section,
             whose template stacks its content and would let the ListBox size to all its rows) so the list
             is bounded to the row and its own scrollbar engages. -->
        <Panel Grid.Row="1" ClipToBounds="True">
                <ListBox x:Name="LogList" ItemsSource="{Binding Entries}"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="12,2" />
                            <Setter Property="MinHeight" Value="0" />
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="Auto,52,Auto,*" ColumnSpacing="10">
                                <TextBlock Grid.Column="0" Text="{Binding Time}"
                                           FontFamily="{DynamicResource MonoFontFamily}"
                                           Foreground="{DynamicResource TextMutedBrush}" />
                                <TextBlock Grid.Column="1" Text="{Binding Level}"
                                           FontFamily="{DynamicResource MonoFontFamily}"
                                           FontWeight="SemiBold" Foreground="{Binding LevelBrush}" />
                                <TextBlock Grid.Column="2" Text="{Binding Group}"
                                           FontFamily="{DynamicResource MonoFontFamily}"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                <TextBlock Grid.Column="3" Text="{Binding Message}"
                                           FontFamily="{DynamicResource MonoFontFamily}"
                                           Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Empty / no-matches state -->
                <TextBlock Text="{Binding EmptyStateText}"
                           Foreground="{DynamicResource TextMutedBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           IsHitTestVisible="False"
                           IsVisible="{Binding ShowEmptyState}" />
        </Panel>
    </Grid>
</UserControl>
