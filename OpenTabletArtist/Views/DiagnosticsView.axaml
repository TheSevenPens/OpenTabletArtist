<UserControl x:Class="OpenTabletArtist.Views.DiagnosticsView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="using:OpenTabletArtist.Controls"
>

    <!-- DataContext is the DiagnosticsViewModel, supplied by the typed-nav DataTemplate (#15). -->
    <StackPanel MaxWidth="900" HorizontalAlignment="Left">
        <!-- Controls -->
        <c:Section Margin="0,0,0,12">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <StackPanel Grid.Column="0" VerticalAlignment="Center" MinWidth="0">
                    <TextBlock Classes="SectionLabel" Text="CURRENT TABLET" />
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="{Binding DebugTabletName, FallbackValue='No tablet'}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" />
                        <TextBlock Text=" | " Foreground="{DynamicResource TextMutedBrush}"
                                   IsVisible="{Binding IsDebugging}" />
                        <TextBlock Text="{Binding DebugReportRate}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   IsVisible="{Binding IsDebugging}" />
                        <TextBlock Text=" | " Foreground="{DynamicResource TextMutedBrush}"
                                   IsVisible="{Binding IsDebugging}" />
                        <TextBlock Text="{Binding ReportCount, StringFormat='Reports: {0}'}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   IsVisible="{Binding IsDebugging}" />
                    </StackPanel>

                    <!-- Active-tablet picker, only when more than one tablet is connected (#190 phase 3). -->
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0"
                                IsVisible="{Binding ShowTabletPicker}">
                        <TextBlock Text="Show" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <ComboBox ItemsSource="{Binding TabletNames}" SelectedItem="{Binding SelectedTablet}"
                                  MinWidth="200" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Start" Command="{Binding ToggleDebuggingCommand}"
                            IsEnabled="{Binding IsConnected}"
                            IsVisible="{Binding !IsDebugging}"
                            Theme="{StaticResource AccentButton}"
                            Padding="12,6" />
                    <Button Content="Stop" Command="{Binding ToggleDebuggingCommand}"
                            IsVisible="{Binding IsDebugging}"
                            Theme="{StaticResource DeleteButton}"
                            Padding="12,6" />
                </StackPanel>
            </Grid>
        </c:Section>

        <!-- Content -->
        <StackPanel>
            <!-- Tablet Visualizer -->
            <c:Section Margin="0,0,0,12" Padding="8"
                    IsVisible="{Binding IsDebugging}">
                <c:TabletVisualizer Height="200"
                                    PenX="{Binding DebugPenX}"
                                    PenY="{Binding DebugPenY}"
                                    MaxX="{Binding DebugMaxX}"
                                    MaxY="{Binding DebugMaxY}"
                                    DigitizerWidth="{Binding DebugDigitizerWidth}"
                                    DigitizerHeight="{Binding DebugDigitizerHeight}"
                                    Pressure="{Binding DebugPenPressure}"
                                    MaxPressure="{Binding DebugMaxPressure}"
                                    HasPosition="{Binding DebugHasPosition}" />
            </c:Section>

            <!-- Stylus Info -->
            <c:Section Margin="0,0,0,12"
                    IsVisible="{Binding IsDebugging}">
                <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto">
                    <!-- Position -->
                    <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,12,0">
                        <TextBlock Text="POSITION" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4" />
                        <TextBlock Text="{Binding DebugPenX, StringFormat='X: {0:F1}'}"
                                   FontFamily="{DynamicResource MonoFontFamily}"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <TextBlock Text="{Binding DebugPenY, StringFormat='Y: {0:F1}'}"
                                   FontFamily="{DynamicResource MonoFontFamily}"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0" />
                    </StackPanel>
                    <!-- Pressure -->
                    <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,12,0">
                        <TextBlock Text="PRESSURE" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4" />
                        <TextBlock Text="{Binding DebugPressurePercent, StringFormat='{}{0:F1}%'}"
                                   FontFamily="{DynamicResource MonoFontFamily}"
                                   Foreground="{DynamicResource AccentBrush}" />
                        <!-- Pressure bar -->
                        <Border Height="6" CornerRadius="0" Margin="0,4,0,0"
                                Background="{DynamicResource GlassBgBrush}" ClipToBounds="True">
                            <Border CornerRadius="0" HorizontalAlignment="Left"
                                    Background="{DynamicResource AccentBrush}">
                                <Border.Width>
                                    <MultiBinding>
                                        <MultiBinding.Converter>
                                            <c:PercentToWidthConverter />
                                        </MultiBinding.Converter>
                                        <Binding Path="DebugPressurePercent" />
                                        <Binding Path="$parent[Border].Bounds.Width" />
                                    </MultiBinding>
                                </Border.Width>
                            </Border>
                        </Border>
                        <TextBlock Text="{Binding DebugPenPressure, StringFormat='{}{0:F0}'}"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                    <!-- Tilt -->
                    <StackPanel Grid.Column="2" Grid.Row="0">
                        <TextBlock Text="TILT" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4" />
                        <TextBlock Text="{Binding DebugTiltX, StringFormat='X: {0:F1}°'}"
                                   FontFamily="{DynamicResource MonoFontFamily}"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <TextBlock Text="{Binding DebugTiltY, StringFormat='Y: {0:F1}°'}"
                                   FontFamily="{DynamicResource MonoFontFamily}"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0" />
                        <TextBlock Text="{Binding DebugTiltAzimuth, StringFormat='Az: {0:F1}°'}"
                                   FontFamily="{DynamicResource MonoFontFamily}"
                                   Foreground="{DynamicResource AccentBrush}" Margin="0,4,0,0" />
                        <TextBlock Text="{Binding DebugTiltAltitude, StringFormat='Alt: {0:F1}°'}"
                                   FontFamily="{DynamicResource MonoFontFamily}"
                                   Foreground="{DynamicResource AccentBrush}" Margin="0,2,0,0" />
                    </StackPanel>
                    <!-- Proximity -->
                    <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,12,12,0">
                        <TextBlock Text="PROXIMITY" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4" />
                        <TextBlock Text="{Binding DebugNearProximity}"
                                   FontFamily="{DynamicResource MonoFontFamily}"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>
                    <!-- Hover Distance -->
                    <StackPanel Grid.Column="1" Grid.Row="1" Margin="0,12,12,0">
                        <TextBlock Text="HOVER DISTANCE" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4" />
                        <TextBlock Text="{Binding DebugHoverDistance}"
                                   FontFamily="{DynamicResource MonoFontFamily}"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>
                    <!-- Buttons -->
                    <StackPanel Grid.Column="2" Grid.Row="1" Margin="0,12,0,0">
                        <TextBlock Text="PEN BUTTONS" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4" />
                        <TextBlock Text="{Binding DebugPenButtons}"
                                   FontFamily="{DynamicResource MonoFontFamily}"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>
                </Grid>
            </c:Section>
        </StackPanel>

        <!-- Not connected warning -->
        <c:Section
                IsVisible="{Binding !IsConnected}">
            <TextBlock Text="Daemon not connected. Connect first from Home."
                       Foreground="{DynamicResource TextMutedBrush}"
                       HorizontalAlignment="Center" />
        </c:Section>
    </StackPanel>
</UserControl>
