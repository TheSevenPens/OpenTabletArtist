<UserControl x:Class="OpenTabletArtist.Views.PerAppView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- DataContext is the PerAppViewModel, supplied by the typed-nav DataTemplate (#15). -->
    <StackPanel MaxWidth="860" HorizontalAlignment="Left">
        <TextBlock Classes="PageTitle" Text="PER-APP PROFILES" />

        <TextBlock Text="Automatically switch to a saved profile when you change apps — like Wacom/XP-Pen/Huion drivers. Switches are temporary (your saved default is never overwritten) and only happen while OpenTabletArtist is running."
                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                   TextWrapping="Wrap" Margin="0,0,0,18" />

        <!-- Foreign-daemon guard: this feature writes to whatever daemon is connected; snapshots only
             match the app-owned daemon (#167). -->
        <Border Background="{DynamicResource WarningMutedBrush}" BorderBrush="{DynamicResource WarningBrush}"
                BorderThickness="1" CornerRadius="8" Padding="14,10" Margin="0,0,0,18"
                IsVisible="{Binding IsForeignDaemon}">
            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource WarningBrush}"
                       Text="Per-app switching is unavailable while a daemon that OpenTabletArtist didn't start is running — its settings and profile files may not match yours. Stop that daemon (or let OpenTabletArtist manage it) to use this feature." />
        </Border>

        <!-- Need snapshots first -->
        <Border Classes="GlassPanel" Padding="24"
                IsVisible="{Binding !HasEnoughSnapshots}" IsEnabled="{Binding CanUse}">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="Save a profile first" FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="Per-app switching maps applications to saved profiles. Create at least one on the Profiles page, then come back."
                           FontSize="12" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"
                           HorizontalAlignment="Center" TextAlignment="Center" MaxWidth="460" Margin="0,6,0,0" />
            </StackPanel>
        </Border>

        <StackPanel IsVisible="{Binding HasEnoughSnapshots}" IsEnabled="{Binding CanUse}" Spacing="14">
            <!-- Master controls -->
            <Border Classes="GlassPanel" Padding="18">
                <StackPanel Spacing="14">
                    <CheckBox Content="Enable per-app profile switching" IsChecked="{Binding Enabled}"
                              FontWeight="SemiBold" />
                </StackPanel>
            </Border>

            <!-- Catch-all card: what any app that isn't mapped below should use. Same dropdown (Current
                 settings + saved profiles) as every app card — one consistent way to target the live
                 config or a profile, even for unmapped apps. -->
            <Border Classes="GlassPanel" Padding="16">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" MinWidth="0">
                        <TextBlock Classes="CardTitle" Text="Default for apps" />
                        <TextBlock Text="Used whenever the focused app isn't one of the mapped apps below."
                                   FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="0,2,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                    <ComboBox Grid.Column="1" VerticalAlignment="Center" MinWidth="170"
                              ItemsSource="{Binding TargetOptions}" SelectedItem="{Binding UnmappedTarget}" />
                </Grid>
            </Border>

            <!-- Mappings -->
            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                <TextBlock Grid.Column="0" Text="APP MAPPINGS" FontSize="11" FontWeight="SemiBold"
                           LetterSpacing="0.5" Foreground="{DynamicResource TextMutedBrush}"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Add app…" Theme="{StaticResource AccentButton}"
                        Padding="14,7" FontSize="12" Command="{Binding AddAppCommand}" />
            </Grid>

            <ItemsControl ItemsSource="{Binding Mappings}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Classes="GlassPanel" Margin="0,0,0,10" Padding="16">
                            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" MinWidth="0">
                                    <TextBlock Classes="CardTitle" Text="{Binding ExeName}" />
                                    <TextBlock Text="{Binding PathDisplay}" FontSize="11"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                                    <TextBlock Text="⚠ profile missing" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource WarningBrush}" Margin="0,3,0,0"
                                               IsVisible="{Binding IsMissing}" />
                                </StackPanel>

                                <ComboBox Grid.Column="1" VerticalAlignment="Center" MinWidth="170"
                                          ItemsSource="{Binding SnapshotOptions}"
                                          SelectedItem="{Binding SelectedSnapshot}" />

                                <Button Grid.Column="2" Content="Remove" Theme="{StaticResource DeleteButton}"
                                        VerticalAlignment="Center" Padding="12,6" FontSize="12"
                                        Command="{Binding RemoveCommand}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Classes="GlassPanel" Padding="24" IsVisible="{Binding !HasMappings}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="No apps mapped yet" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="Add an app and pick which profile it should use."
                               FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                               HorizontalAlignment="Center" Margin="0,6,0,0" />
                </StackPanel>
            </Border>
        </StackPanel>
    </StackPanel>
</UserControl>
