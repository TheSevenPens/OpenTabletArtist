<UserControl x:Class="OpenTabletArtist.Views.PerAppView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="using:OpenTabletArtist.Controls">

    <!-- DataContext is the PerAppViewModel, supplied by the typed-nav DataTemplate (#15). Hosted as a
         SETTINGS tab (#571), so the page title is the Settings tab title — no PageTitle here. -->
    <StackPanel MaxWidth="860" HorizontalAlignment="Left">
        <TextBlock Text="Automatically switch to a saved preset when you change apps — like Wacom/XP-Pen/Huion drivers. Switches are temporary (your saved default is never overwritten) and only happen while OpenTabletArtist is running."
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   TextWrapping="Wrap" Margin="0,0,0,18" />

        <!-- Foreign-daemon guard: this feature writes to whatever daemon is connected; snapshots only
             match the app-owned daemon (#167). -->
        <Border Background="{DynamicResource WarningMutedBrush}" BorderBrush="{DynamicResource WarningBrush}"
                BorderThickness="1" CornerRadius="0" Padding="14,10" Margin="0,0,0,18"
                IsVisible="{Binding IsForeignDaemon}">
            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource WarningBrush}"
                       Text="Per-app switching is unavailable while a daemon that OpenTabletArtist didn't start is running — its settings and preset files may not match yours. Stop that daemon (or let OpenTabletArtist manage it) to use this feature." />
        </Border>

        <!-- Need snapshots first -->
        <c:Section Padding="24"
                IsVisible="{Binding !HasEnoughSnapshots}" IsEnabled="{Binding CanUse}">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="Save a preset first" FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="Per-app switching maps applications to saved presets. Create at least one on the Presets page, then come back."
                           Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"
                           HorizontalAlignment="Center" TextAlignment="Center" MaxWidth="460" Margin="0,6,0,0" />
            </StackPanel>
        </c:Section>

        <StackPanel IsVisible="{Binding HasEnoughSnapshots}" IsEnabled="{Binding CanUse}" Spacing="14">
            <!-- No explicit on/off: switching turns on by itself as soon as an app below is mapped to a
                 saved profile (a mapping to "Current settings" is a no-op and doesn't arm it). -->

            <!-- Catch-all card: what any app that isn't mapped below should use. Same dropdown (Current
                 settings + saved profiles) as every app card — one consistent way to target the live
                 config or a profile, even for unmapped apps. -->
            <c:Section>
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" MinWidth="0">
                        <TextBlock Classes="SectionLabel" Text="DEFAULT FOR APPS" />
                        <TextBlock Text="Used whenever the focused app isn't one of the mapped apps below."
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="0,2,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                    <ComboBox Grid.Column="1" VerticalAlignment="Center" MinWidth="170"
                              ItemsSource="{Binding TargetOptions}" SelectedItem="{Binding UnmappedTarget}" />
                </Grid>
            </c:Section>

            <!-- Mappings -->
            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                <TextBlock Grid.Column="0" Text="APP MAPPINGS" FontWeight="SemiBold"
                           LetterSpacing="0.5" Foreground="{DynamicResource TextMutedBrush}"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Add app…" Theme="{StaticResource AccentButton}"
                        Padding="14,7" Command="{Binding AddAppCommand}" />
            </Grid>

            <ItemsControl ItemsSource="{Binding Mappings}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <c:Section Margin="0,0,0,10">
                            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" MinWidth="0">
                                    <TextBlock Classes="CardTitle" Text="{Binding ExeName}" />
                                    <TextBlock Text="{Binding PathDisplay}"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                                    <StackPanel Orientation="Horizontal" Spacing="5" Margin="0,3,0,0"
                                                IsVisible="{Binding IsMissing}">
                                        <PathIcon Data="{StaticResource IconAlert}" Width="13" Height="13"
                                                  VerticalAlignment="Center"
                                                  Foreground="{DynamicResource WarningBrush}" />
                                        <TextBlock Text="preset missing" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource WarningBrush}" />
                                    </StackPanel>
                                </StackPanel>

                                <ComboBox Grid.Column="1" VerticalAlignment="Center" MinWidth="170"
                                          ItemsSource="{Binding SnapshotOptions}"
                                          SelectedItem="{Binding SelectedSnapshot}" />

                                <Button Grid.Column="2" Content="Remove" Theme="{StaticResource DeleteButton}"
                                        VerticalAlignment="Center" Padding="12,6"
                                        Command="{Binding RemoveCommand}" />
                            </Grid>
                        </c:Section>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <c:Section Padding="24" IsVisible="{Binding !HasMappings}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="No apps mapped yet" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="Map an app to a saved preset to start automatic switching — there's no separate on/off."
                               Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"
                               HorizontalAlignment="Center" TextAlignment="Center" MaxWidth="460" Margin="0,6,0,0" />
                </StackPanel>
            </c:Section>
        </StackPanel>
    </StackPanel>
</UserControl>
