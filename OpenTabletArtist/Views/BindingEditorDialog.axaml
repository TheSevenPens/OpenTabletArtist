<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="using:OpenTabletArtist.Converters"
        x:Class="OpenTabletArtist.Views.BindingEditorDialog"
        Title="{Binding Title}"
        Width="820" Height="580"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBaseBrush}">

    <Window.Resources>
        <!-- One keycap: a fixed-width footprint (so rows of equal total units align regardless of key
             count) with the visible key inset by a small margin. Spacers render as empty footprint. -->
        <DataTemplate x:Key="KeyCapTemplate">
            <Border Width="{Binding Width}" Height="34">
                <Button Theme="{StaticResource BindingModePill}" Classes.selected="{Binding IsSelected}"
                        Command="{Binding PickCommand}" CommandParameter="{Binding}"
                        Content="{Binding Display}" IsVisible="{Binding !IsSpacer}"
                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                        Margin="1.5" Padding="0" FontSize="11" />
            </Border>
        </DataTemplate>
        <!-- One keyboard row. -->
        <DataTemplate x:Key="KeyRowTemplate">
            <ItemsControl ItemsSource="{Binding}" Margin="0,0,0,3"
                          ItemTemplate="{StaticResource KeyCapTemplate}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </DataTemplate>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="RadioButton.tab">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="Bd" Background="Transparent" Padding="16,9"
                            BorderThickness="0,0,0,2" BorderBrush="Transparent">
                        <TextBlock x:Name="Lbl" Text="{TemplateBinding Content}"
                                   FontSize="12" FontWeight="SemiBold" LetterSpacing="0.5"
                                   Foreground="{DynamicResource TextMutedBrush}" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="RadioButton.tab:pointerover /template/ TextBlock#Lbl">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>
        <Style Selector="RadioButton.tab:checked /template/ Border#Bd">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        </Style>
        <Style Selector="RadioButton.tab:checked /template/ TextBlock#Lbl">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        </Style>

        <Style Selector="TextBlock.caption">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="LetterSpacing" Value="0.5" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        </Style>
    </Window.Styles>

    <DockPanel Margin="24">
        <!-- Heading -->
        <StackPanel DockPanel.Dock="Top" Spacing="3" Margin="0,0,0,14">
            <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
            <TextBlock Text="Pick a type, set it, then Save. Clear removes the binding."
                       FontSize="12" Foreground="{DynamicResource TextMutedBrush}" />
        </StackPanel>

        <!-- Footer -->
        <StackPanel DockPanel.Dock="Bottom">
            <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="0,16,0,0" />
            <Grid ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,14,0,0">
                <Button Grid.Column="0" Content="Clear" Command="{Binding ClearCommand}"
                        Theme="{StaticResource GhostButton}" Padding="16,8" FontSize="12"
                        ToolTip.Tip="Remove this binding (unbind)" />
                <Button Grid.Column="2" Content="Cancel" Command="{Binding CancelDialogCommand}"
                        Theme="{StaticResource GhostButton}" Padding="16,8" FontSize="12" Margin="0,0,8,0" />
                <Button Grid.Column="3" Content="Save" Command="{Binding SaveCommand}"
                        Theme="{StaticResource AccentButton}" Padding="22,8" FontSize="12" />
            </Grid>
        </StackPanel>

        <!-- Tab strip -->
        <Border DockPanel.Dock="Top" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource DividerBrush}">
            <StackPanel Orientation="Horizontal">
                <RadioButton Classes="tab" Content="KEYBOARD" GroupName="type"
                             IsChecked="{Binding IsKeyboardTab, Mode=TwoWay}" />
                <RadioButton Classes="tab" Content="MOUSE" GroupName="type"
                             IsChecked="{Binding IsMouseTab, Mode=TwoWay}" />
                <RadioButton Classes="tab" Content="SCROLL" GroupName="type"
                             IsChecked="{Binding IsScrollTab, Mode=TwoWay}" />
            </StackPanel>
        </Border>

        <Panel Margin="0,16,0,0">
            <!-- Keyboard -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" IsVisible="{Binding IsKeyboardTab}">
                <StackPanel Spacing="14">
                    <!-- Three aligned sections: main block · nav cluster · numpad. -->
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <ItemsControl ItemsSource="{Binding MainRows}" ItemTemplate="{StaticResource KeyRowTemplate}"
                                      VerticalAlignment="Top" />
                        <ItemsControl ItemsSource="{Binding NavRows}" ItemTemplate="{StaticResource KeyRowTemplate}"
                                      VerticalAlignment="Top" />
                        <ItemsControl ItemsSource="{Binding NumpadRows}" ItemTemplate="{StaticResource KeyRowTemplate}"
                                      VerticalAlignment="Top" />
                    </StackPanel>

                    <TextBlock Text="Ctrl, Shift and Alt are held modifiers — tap to toggle, then pick a key."
                               FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />

                    <StackPanel Spacing="7">
                        <TextBlock Text="MORE KEYS" Classes="caption" />
                        <ItemsControl ItemsSource="{Binding MoreKeys}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Theme="{StaticResource BindingModePill}"
                                            Classes.selected="{Binding IsSelected}"
                                            Command="{Binding PickCommand}" CommandParameter="{Binding}"
                                            Content="{Binding Display}" Height="30" MinWidth="42"
                                            Margin="0,0,4,4" Padding="8,0" FontSize="11" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Mouse -->
            <StackPanel Spacing="7" IsVisible="{Binding IsMouseTab}">
                <TextBlock Text="BUTTON" Classes="caption" />
                <StackPanel Spacing="6">
                    <RadioButton Content="Left click" GroupName="mb"
                                 IsChecked="{Binding SelectedMouseButton, Converter={x:Static conv:EqualityConverter.Instance}, ConverterParameter=Left}" />
                    <RadioButton Content="Right click" GroupName="mb"
                                 IsChecked="{Binding SelectedMouseButton, Converter={x:Static conv:EqualityConverter.Instance}, ConverterParameter=Right}" />
                    <RadioButton Content="Middle click" GroupName="mb"
                                 IsChecked="{Binding SelectedMouseButton, Converter={x:Static conv:EqualityConverter.Instance}, ConverterParameter=Middle}" />
                    <RadioButton Content="Back button" GroupName="mb"
                                 IsChecked="{Binding SelectedMouseButton, Converter={x:Static conv:EqualityConverter.Instance}, ConverterParameter=Backward}" />
                    <RadioButton Content="Forward button" GroupName="mb"
                                 IsChecked="{Binding SelectedMouseButton, Converter={x:Static conv:EqualityConverter.Instance}, ConverterParameter=Forward}" />
                </StackPanel>
            </StackPanel>

            <!-- Scroll -->
            <StackPanel Spacing="7" IsVisible="{Binding IsScrollTab}">
                <TextBlock Text="DIRECTION" Classes="caption" />
                <StackPanel Spacing="6">
                    <RadioButton Content="Scroll up" GroupName="sc"
                                 IsChecked="{Binding SelectedScroll, Converter={x:Static conv:EqualityConverter.Instance}, ConverterParameter=Up}" />
                    <RadioButton Content="Scroll down" GroupName="sc"
                                 IsChecked="{Binding SelectedScroll, Converter={x:Static conv:EqualityConverter.Instance}, ConverterParameter=Down}" />
                    <RadioButton Content="Scroll left" GroupName="sc"
                                 IsChecked="{Binding SelectedScroll, Converter={x:Static conv:EqualityConverter.Instance}, ConverterParameter=Left}" />
                    <RadioButton Content="Scroll right" GroupName="sc"
                                 IsChecked="{Binding SelectedScroll, Converter={x:Static conv:EqualityConverter.Instance}, ConverterParameter=Right}" />
                </StackPanel>
            </StackPanel>
        </Panel>
    </DockPanel>
</Window>
