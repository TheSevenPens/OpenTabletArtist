<UserControl x:Class="OpenTabletArtist.Views.PresetsView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="using:OpenTabletArtist.Controls">

    <!-- DataContext is the PresetsViewModel, supplied by the typed-nav DataTemplate (#15). Hosted as a
         SETTINGS tab (#571), so the page title is the Settings tab title — no PageTitle here. -->
    <StackPanel MaxWidth="900" HorizontalAlignment="Left">
        <!-- The live config (settings.json), made visible: it's what per-app / hotkey switches revert to,
             and every profile below is a saved copy of it. Accent-outlined to set it apart. -->
        <!-- Accent-outlined emphasis card (the live config). Alert role with a glass bg + accent border
             override so it looks identical to the old GlassPanel + accent-border card (#574). -->
        <c:Alert Background="{DynamicResource GlassBgBrush}" BorderBrush="{DynamicResource AccentBrush}"
                 BorderThickness="1.5" Margin="0,0,0,18">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Classes="SectionLabel" Text="CURRENT SETTINGS" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource AccentMutedBrush}" CornerRadius="0" Padding="8,2"
                            VerticalAlignment="Center">
                        <TextBlock Text="In use now" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBrush}" />
                    </Border>
                </StackPanel>
                <TextBlock Text="The configuration your tablet is using right now. It saves automatically as you edit it on the Tablet pages — everything below is a saved copy you can switch back to."
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap" Margin="0,6,0,12" />
                <Button Content="Save as preset" Theme="{StaticResource AccentButton}"
                        HorizontalAlignment="Left"
                        Padding="14,7" Command="{Binding SavePresetCommand}" />
            </StackPanel>
        </c:Alert>

        <!-- Header row: section label + Browse (opens the folder where profiles are stored). -->
        <Grid ColumnDefinitions="*,Auto" Margin="2,0,0,8" IsVisible="{Binding HasPresets}">
            <TextBlock Grid.Column="0" Text="SAVED PRESETS" FontWeight="SemiBold"
                       LetterSpacing="0.5" Foreground="{DynamicResource TextMutedBrush}"
                       VerticalAlignment="Center" />
            <Button Grid.Column="1" Theme="{StaticResource GhostButton}"
                    Width="34" Height="30" Padding="0" VerticalAlignment="Center"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                    ToolTip.Tip="Open the folder where presets are stored"
                    AutomationProperties.Name="Open the folder where presets are stored"
                    Command="{Binding OpenFolderCommand}"
                    CommandParameter="{Binding PresetDirectory}">
                <PathIcon Data="{StaticResource IconFolderOutline}" Width="16" Height="16"
                          Foreground="{Binding $parent[Button].Foreground}" />
            </Button>
        </Grid>

        <ItemsControl ItemsSource="{Binding Presets}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <c:Section Margin="0,0,0,12">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" MinWidth="0">
                                <TextBlock Classes="CardTitle" Text="{Binding Name}" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding LastModified}"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="0,2,0,0" />
                            </StackPanel>

                            <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                                <Button Content="Load" Theme="{StaticResource AccentButton}"
                                        Command="{Binding $parent[ItemsControl].DataContext.LoadPresetCommand}"
                                        CommandParameter="{Binding Name}"
                                        Margin="0,0,6,0" Padding="12,6" />
                                <Button Content="Update" Theme="{StaticResource GhostButton}"
                                        Command="{Binding $parent[ItemsControl].DataContext.UpdatePresetCommand}"
                                        CommandParameter="{Binding Name}"
                                        Margin="0,0,6,0" Padding="12,6" />
                                <Button Content="Duplicate" Theme="{StaticResource GhostButton}"
                                        Command="{Binding $parent[ItemsControl].DataContext.DuplicatePresetCommand}"
                                        CommandParameter="{Binding Name}"
                                        ToolTip.Tip="Save a copy of this preset"
                                        Margin="0,0,6,0" Padding="12,6" />
                                <Button Content="Rename" Theme="{StaticResource GhostButton}"
                                        Command="{Binding $parent[ItemsControl].DataContext.RenamePresetCommand}"
                                        CommandParameter="{Binding Name}"
                                        Margin="0,0,6,0" Padding="12,6" />
                                <Button Content="Delete" Padding="12,6"
                                        Theme="{StaticResource DeleteButton}"
                                        Command="{Binding $parent[ItemsControl].DataContext.DeletePresetCommand}"
                                        CommandParameter="{Binding Name}" Margin="0,0,0,4" />
                            </WrapPanel>
                        </Grid>
                    </c:Section>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <c:Section Padding="24" IsVisible="{Binding !HasPresets}">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="No presets yet" FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="Save a named backup of your current settings to restore later."
                           Foreground="{DynamicResource TextMutedBrush}"
                           HorizontalAlignment="Center" TextAlignment="Center" Margin="0,8,0,0" />
            </StackPanel>
        </c:Section>
    </StackPanel>
</UserControl>
