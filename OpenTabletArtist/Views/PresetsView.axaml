<UserControl x:Class="OpenTabletArtist.Views.PresetsView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- DataContext is the PresetsViewModel, supplied by the typed-nav DataTemplate (#15). -->
    <StackPanel MaxWidth="900" HorizontalAlignment="Left">
        <TextBlock Classes="PageTitle" Text="PROFILES" />

        <!-- The live config (settings.json), made visible: it's what per-app / hotkey switches revert to,
             and every profile below is a saved copy of it. Accent-outlined to set it apart. -->
        <Border Classes="GlassPanel" Margin="0,0,0,18" Padding="16"
                BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1.5">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Classes="CardTitle" Text="Current settings" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource AccentMutedBrush}" CornerRadius="10" Padding="8,2"
                            VerticalAlignment="Center">
                        <TextBlock Text="In use now" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBrush}" />
                    </Border>
                </StackPanel>
                <TextBlock Text="The configuration your tablet is using right now. It saves automatically as you edit it on the Tablet pages — everything below is a saved copy you can switch back to (or use as a per-app profile)."
                           FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap" Margin="0,6,0,12" />
                <StackPanel Orientation="Horizontal">
                    <Button Content="Save as profile" Theme="{StaticResource AccentButton}"
                            Padding="14,7" FontSize="13" Command="{Binding SavePresetCommand}" />
                    <Button Content="Browse" Theme="{StaticResource GhostButton}"
                            Padding="14,7" FontSize="13" Margin="8,0,0,0"
                            Command="{Binding OpenFolderCommand}"
                            CommandParameter="{Binding PresetDirectory}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <TextBlock Text="SAVED PROFILES" FontSize="11" FontWeight="SemiBold" LetterSpacing="0.5"
                   Foreground="{DynamicResource TextMutedBrush}" Margin="2,0,0,8"
                   IsVisible="{Binding HasPresets}" />

        <ItemsControl ItemsSource="{Binding Presets}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Classes="GlassPanel" Margin="0,0,0,12" Padding="16">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" MinWidth="0">
                                <TextBlock Classes="CardTitle" Text="{Binding Name}" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding LastModified}" FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="0,2,0,0" />
                            </StackPanel>

                            <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                                <Button Content="Load" Theme="{StaticResource AccentButton}"
                                        Command="{Binding $parent[ItemsControl].DataContext.LoadPresetCommand}"
                                        CommandParameter="{Binding Name}"
                                        Margin="0,0,6,0" Padding="12,6" FontSize="12" />
                                <Button Content="Update" Theme="{StaticResource GhostButton}"
                                        Command="{Binding $parent[ItemsControl].DataContext.UpdatePresetCommand}"
                                        CommandParameter="{Binding Name}"
                                        Margin="0,0,6,0" Padding="12,6" FontSize="12" />
                                <Button Content="Rename" Theme="{StaticResource GhostButton}"
                                        Command="{Binding $parent[ItemsControl].DataContext.RenamePresetCommand}"
                                        CommandParameter="{Binding Name}"
                                        Margin="0,0,6,0" Padding="12,6" FontSize="12" />
                                <Button Content="Delete" Padding="12,6" FontSize="12"
                                        Theme="{StaticResource DeleteButton}"
                                        Command="{Binding $parent[ItemsControl].DataContext.DeletePresetCommand}"
                                        CommandParameter="{Binding Name}" Margin="0,0,0,4" />
                            </WrapPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Border Classes="GlassPanel" Padding="32"
                IsVisible="{Binding !HasPresets}">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="No profiles yet" FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="Save a named backup of your current settings to restore later."
                           FontSize="13" Foreground="{DynamicResource TextMutedBrush}"
                           HorizontalAlignment="Center" TextAlignment="Center" Margin="0,8,0,0" />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
