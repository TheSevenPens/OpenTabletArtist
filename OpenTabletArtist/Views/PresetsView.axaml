<UserControl x:Class="OpenTabletArtist.Views.PresetsView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- DataContext is the PresetsViewModel, supplied by the typed-nav DataTemplate (#15). -->
    <StackPanel MaxWidth="900" HorizontalAlignment="Left">
        <TextBlock Classes="PageTitle" Text="SAVED SETTINGS" />

        <!-- Clarify the two persistence models so snapshots don't read as "the Save button" (#321). -->
        <TextBlock Text="Your settings save automatically as you change them — there's no Save button. Snapshots are named backups of all your settings: save one now and restore it later (handy before experimenting)."
                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                   TextWrapping="Wrap" Margin="0,0,0,16" />

        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <Button Content="Save Snapshot" Theme="{StaticResource AccentButton}"
                    Padding="14,7" FontSize="13"
                    Command="{Binding SavePresetCommand}" />
            <Button Content="Browse" Theme="{StaticResource GhostButton}"
                    Padding="14,7" FontSize="13" Margin="8,0,0,0"
                    Command="{Binding OpenFolderCommand}"
                    CommandParameter="{Binding PresetDirectory}" />
        </StackPanel>

        <ItemsControl ItemsSource="{Binding Presets}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Classes="GlassPanel" Margin="0,0,0,12" Padding="16">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" MinWidth="0">
                                <TextBlock Classes="CardTitle" Text="{Binding Name}" FontSize="14" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding LastModified}" FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="0,2,0,0" />
                                <!-- Assigned global hotkey (#320), with an inline clear. -->
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0"
                                            IsVisible="{Binding HasHotkey}">
                                    <TextBlock Text="{Binding HotkeyDisplay, StringFormat='⌨ {0}'}" FontSize="11"
                                               FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}"
                                               VerticalAlignment="Center" />
                                    <Button Content="✕" ToolTip.Tip="Clear hotkey"
                                            Command="{Binding $parent[ItemsControl].DataContext.ClearHotkeyCommand}"
                                            CommandParameter="{Binding Name}"
                                            Theme="{StaticResource GhostButton}" Padding="6,1" FontSize="10"
                                            VerticalAlignment="Center" />
                                </StackPanel>
                            </StackPanel>

                            <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                                <Button Content="Load" Theme="{StaticResource AccentButton}"
                                        Command="{Binding $parent[ItemsControl].DataContext.LoadPresetCommand}"
                                        CommandParameter="{Binding Name}"
                                        Margin="0,0,6,0" Padding="12,6" FontSize="12" />
                                <Button Content="Update" Theme="{StaticResource GhostButton}"
                                        Command="{Binding $parent[ItemsControl].DataContext.UpdatePresetCommand}"
                                        CommandParameter="{Binding Name}"
                                        Margin="0,0,6,0" Padding="12,6" FontSize="12" />
                                <Button Content="Hotkey…" Theme="{StaticResource GhostButton}"
                                        ToolTip.Tip="Assign a global keyboard shortcut that switches to this snapshot"
                                        Command="{Binding $parent[ItemsControl].DataContext.AssignHotkeyCommand}"
                                        CommandParameter="{Binding Name}"
                                        Margin="0,0,6,0" Padding="12,6" FontSize="12" />
                                <Button Content="Rename" Theme="{StaticResource GhostButton}"
                                        Command="{Binding $parent[ItemsControl].DataContext.RenamePresetCommand}"
                                        CommandParameter="{Binding Name}"
                                        Margin="0,0,6,0" Padding="12,6" FontSize="12" />
                                <Button Content="Delete" Padding="12,6" FontSize="12"
                                        Theme="{StaticResource DeleteButton}"
                                        Command="{Binding $parent[ItemsControl].DataContext.DeletePresetCommand}"
                                        CommandParameter="{Binding Name}" Margin="0,0,0,4" />
                            </WrapPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Border Classes="GlassPanel" Padding="32"
                IsVisible="{Binding !HasPresets}">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="No snapshots yet" FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="Save a named backup of your current settings to restore later."
                           FontSize="13" Foreground="{DynamicResource TextMutedBrush}"
                           HorizontalAlignment="Center" TextAlignment="Center" Margin="0,8,0,0" />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
