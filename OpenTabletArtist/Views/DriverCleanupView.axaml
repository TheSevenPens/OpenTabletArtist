<UserControl x:Class="OpenTabletArtist.Views.DriverCleanupView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="using:OpenTabletArtist.Controls">

    <!-- DataContext is the DriverCleanupViewModel, supplied by the typed-nav DataTemplate (#15). -->
    <StackPanel MaxWidth="900" HorizontalAlignment="Left">
        <!-- Detected conflicting drivers — one card each, with the full daemon message (#245). -->
        <StackPanel IsVisible="{Binding Conflicts.HasConflicts}" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <TextBlock Text="CONFLICTING DRIVERS DETECTED" Classes="SectionLabel"
                       Foreground="{DynamicResource WarningBrush}" VerticalAlignment="Center" />
        </StackPanel>
        <ItemsControl ItemsSource="{Binding Conflicts.Drivers}" IsVisible="{Binding Conflicts.HasConflicts}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <c:Alert Severity="Warning" Background="{DynamicResource GlassBgBrush}" Margin="0,0,0,12">
                        <StackPanel Spacing="6">
                            <TextBlock Text="{Binding Name}" Classes="CardTitle" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding Impact}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource WarningBrush}" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding ProcessesText}" IsVisible="{Binding HasProcesses}"
                                       Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                            <!-- Full daemon message — selectable so it can be copied for troubleshooting. -->
                            <SelectableTextBlock Text="{Binding Detail}"
                                                 Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"
                                                 Margin="0,2,0,0" />
                            <Button Content="Open OpenTabletDriver FAQ" IsVisible="{Binding HasWiki}"
                                    Command="{Binding $parent[ItemsControl].DataContext.OpenUrlCommand}"
                                    CommandParameter="{Binding WikiUrl}"
                                    Theme="{StaticResource GhostButton}" Padding="12,6"
                                    HorizontalAlignment="Left" Margin="0,4,0,0" />
                        </StackPanel>
                    </c:Alert>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- TabletDriverCleanup -->
        <c:Section Margin="0,0,0,12">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <StackPanel Grid.Column="0" VerticalAlignment="Center" MinWidth="0">
                    <TextBlock Classes="CardTitle" Text="TabletDriverCleanup" />
                    <TextBlock Text="Removes leftover bits from previous tablet drivers"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,4,0,0" TextWrapping="Wrap"
                               IsVisible="{Binding !CleanupInstalled}" />
                    <TextBlock Text="{Binding CleanupInstallPath}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,4,0,0" TextWrapping="Wrap"
                               IsVisible="{Binding CleanupInstalled}" />
                    <TextBlock Text="{Binding CleanupStatus}"
                               Foreground="{DynamicResource AccentBrush}" Margin="0,4,0,0"
                               IsVisible="{Binding CleanupBusy}" />
                </StackPanel>

                <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                    <!-- When not installed: just an Install button -->
                    <Button Content="Install" Theme="{StaticResource AccentButton}"
                            Command="{Binding InstallCleanupCommand}"
                            Padding="12,6" Margin="0,0,8,4"
                            IsEnabled="{Binding !CleanupBusy}"
                            IsVisible="{Binding !CleanupInstalled}" />

                    <!-- When installed: Browse, Run, Uninstall -->
                    <Button Theme="{StaticResource AccentButton}"
                            Command="{Binding OpenFolderCommand}"
                            CommandParameter="{Binding CleanupInstallPath}"
                            ToolTip.Tip="Open the install folder in File Explorer"
                            AutomationProperties.Name="Open the install folder in File Explorer"
                            Width="34" Height="30" Padding="0" Margin="0,0,8,4"
                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                            IsVisible="{Binding CleanupInstalled}">
                        <PathIcon Data="{StaticResource IconFolderOutline}" Width="16" Height="16"
                                  Foreground="{Binding $parent[Button].Foreground}" />
                    </Button>
                    <Button Content="Run" Theme="{StaticResource AccentButton}"
                            Command="{Binding RunCleanupCommand}"
                            Padding="12,6" Margin="0,0,8,4"
                            IsEnabled="{Binding !CleanupBusy}"
                            IsVisible="{Binding CleanupInstalled}" />
                    <Button Content="Uninstall" Theme="{StaticResource AccentButton}"
                            Command="{Binding UninstallCleanupCommand}"
                            Padding="12,6" Margin="0,0,0,4"
                            IsEnabled="{Binding !CleanupBusy}"
                            IsVisible="{Binding CleanupInstalled}" />
                </WrapPanel>
            </Grid>
        </c:Section>
    </StackPanel>
</UserControl>
