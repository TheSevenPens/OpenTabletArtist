<UserControl x:Class="OpenTabletArtist.Views.TabletDetailView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="using:OpenTabletArtist.Controls"
             xmlns:conv="using:Avalonia.Data.Converters"
             xmlns:otac="using:OpenTabletArtist.Converters"
             xmlns:views="using:OpenTabletArtist.Views">

    <UserControl.Styles>
        <!-- Express-key card lights up while its physical button is held. Only the border/background
             change (thickness stays 1) so the highlight doesn't nudge the layout. -->
        <Style Selector="Border.expressCard.pressed">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Background" Value="{DynamicResource AccentMutedBrush}" />
        </Style>
    </UserControl.Styles>

    <UserControl.Resources>
        <!-- Shared binding card: a label + the current binding as text + an Edit button that opens the
             modal type-tabbed editor (BindingEditorDialog). Used by both the ExpressKeys tab (auxiliary
             buttons) and the Wheel tab (rotation directions + wheel button) — both bind a ButtonBinding. -->
        <DataTemplate x:Key="ButtonBindingCard">
            <Border Classes="GlassPanel expressCard" Classes.pressed="{Binding IsPressed}"
                    Padding="16,12" Margin="0,0,0,10">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Label}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Summary}" FontSize="12" TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="Edit" Command="{Binding EditCommand}"
                            IsEnabled="{Binding CanEdit}" VerticalAlignment="Center"
                            Theme="{StaticResource GhostButton}" Padding="16,7" FontSize="12"
                            ToolTip.Tip="Change this binding" />
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <!-- A single tablet's settings: the tabbed editor. Hosted as the in-app Tablets page, and by the
         tray's focused Pen Dynamics dialog. DataContext is a TabletDetailViewModel. -->
    <Grid RowDefinitions="Auto,*" ColumnDefinitions="Auto,*">
        <!-- Header: tablet name, connection status, Refresh + Forget on one row. -->
        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Spacing="8" Margin="0,0,0,16">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12">
                <!-- Header title: brand (first word) small, over the model (rest) large — matches the
                     PageTitle look (Segoe UI Light, uppercase) but split across two lines. -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" MaxWidth="360">
                    <TextBlock Text="{Binding TabletBrand, Converter={x:Static otac:UpperCaseConverter.Instance}}"
                               IsVisible="{Binding HasTabletBrand}"
                               FontFamily="Segoe UI, Inter" FontSize="18" FontWeight="Light"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock Text="{Binding TabletModel, Converter={x:Static otac:UpperCaseConverter.Instance}}"
                               FontFamily="Segoe UI, Inter" FontSize="30" FontWeight="Light"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               TextWrapping="Wrap" Margin="0,-2,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" MinWidth="0">
                    <TextBlock Classes="statusMarkWarn" Classes.success="{Binding IsTabletDetected}" />
                    <TextBlock Text="{Binding DetectionText}" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" TextWrapping="Wrap" MinWidth="0" />
                </StackPanel>
                <Button Grid.Column="2" Content="Refresh" Command="{Binding RefreshCommand}"
                        ToolTip.Tip="Reload settings from daemon"
                        Theme="{StaticResource GhostButton}" Padding="12,6" FontSize="12"
                        VerticalAlignment="Center" />
                <!-- Forget the tablet's saved profile. Hidden in the focused Pen Dynamics dialog. -->
                <Button Grid.Column="3" Content="Forget" Command="{Binding ForgetCommand}"
                        IsVisible="{Binding ShowForget}"
                        ToolTip.Tip="Remove this tablet's saved settings"
                        Theme="{StaticResource DeleteButton}" Padding="12,6" FontSize="12"
                        VerticalAlignment="Center" />
            </Grid>
            <TextBlock Text="{Binding RefreshWarning}" FontSize="11" FontStyle="Italic"
                       Foreground="#e87930" TextWrapping="Wrap"
                       IsVisible="{Binding RefreshWarning, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}}" />
        </StackPanel>

        <!-- Tab rail — vertical, to the left of the content (hidden in the focused Pen Dynamics view, #133) -->
        <Border Grid.Row="1" Grid.Column="0" Margin="0,0,16,0" BorderThickness="0,0,1,0"
                BorderBrush="{DynamicResource DividerBrush}"
                IsVisible="{Binding !DynamicsOnly}">
            <StackPanel Width="150" Spacing="2">
                <RadioButton Content="PEN BEHAVIOR" IsChecked="True" x:Name="OutputModeTab"
                             Theme="{StaticResource TabRadioButton}" />
                <RadioButton Content="DISPLAY MAPPING" x:Name="DisplayMappingTab"
                             Theme="{StaticResource TabRadioButton}"
                             IsVisible="{Binding HasAreaMapping}" />
                <RadioButton Content="ACTIVE AREA" x:Name="ActiveAreaTab"
                             Theme="{StaticResource TabRadioButton}"
                             IsVisible="{Binding HasAreaMapping}" />
                <RadioButton Content="CALIBRATION" x:Name="CalibrationTab"
                             Theme="{StaticResource TabRadioButton}"
                             IsVisible="{Binding HasAreaMapping}" />
                <RadioButton Content="PEN SWITCHES" x:Name="PenTipTab"
                             Theme="{StaticResource TabRadioButton}" />
                <RadioButton Content="EXPRESSKEYS" x:Name="PenButtonsTab"
                             Theme="{StaticResource TabRadioButton}" />
                <RadioButton Content="WHEEL" x:Name="WheelTab"
                             Theme="{StaticResource TabRadioButton}"
                             IsVisible="{Binding HasWheels}" />
                <RadioButton Content="DYNAMICS" x:Name="DynamicsTab"
                             Theme="{StaticResource TabRadioButton}" />
                <!-- #318: Hover-limit feature hidden temporarily while its behavior is validated. The
                     tab (and its still-present content below) is unreachable while IsVisible=False, and
                     the HoverFilter plugin is neutered so it has no effect. Set IsVisible back to True
                     (and flip HoverFilter.LimiterEnabled) to restore. -->
                <RadioButton Content="HOVER" x:Name="HoverTab" IsVisible="False"
                             Theme="{StaticResource TabRadioButton}" />
                <RadioButton Content="FILTERS" x:Name="FiltersTab"
                             Theme="{StaticResource TabRadioButton}" />
                <RadioButton Content="JSON" x:Name="JsonTab"
                             Theme="{StaticResource TabRadioButton}" />
            </StackPanel>
        </Border>

        <!-- Output Mode tab content -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto"
                      IsVisible="{Binding #OutputModeTab.IsChecked}">
            <StackPanel>
                <!-- Movement: a plain-language Absolute vs Relative choice (both are Windows Ink modes). -->
                <Border Classes="GlassPanel" Padding="16">
                    <StackPanel>
                        <TextBlock Text="MOVEMENT" Classes="SectionLabel" />
                        <StackPanel Margin="0,10,0,0" Spacing="8">
                            <RadioButton GroupName="Movement" FontSize="13"
                                         IsChecked="{Binding IsAbsoluteMode, Mode=TwoWay}">
                                <TextBlock TextWrapping="Wrap"><Run Text="Normal pen movement (aka " /><Run Text="ABSOLUTE" FontWeight="Bold" /><Run Text=" mode) — good for artists" /></TextBlock>
                            </RadioButton>
                            <RadioButton GroupName="Movement" FontSize="13"
                                         IsChecked="{Binding IsAbsoluteMode, Converter={StaticResource InvBool}, Mode=TwoWay}">
                                <TextBlock TextWrapping="Wrap"><Run Text="Mouse-like movement (aka " /><Run Text="RELATIVE" FontWeight="Bold" /><Run Text=" mode) — often used with games" /></TextBlock>
                            </RadioButton>
                        </StackPanel>

                        <!-- Only when the current mode isn't Windows Ink: pressure/tilt won't work; offer a fix. -->
                        <TextBlock Text="Output mode needs to use Windows Ink for pressure and tilt to work"
                                   FontSize="10" Foreground="#e87930" FontStyle="Italic" Margin="0,12,0,0"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding CanFixOutputMode}" />
                        <Button Content="Fix" Theme="{StaticResource AccentButton}"
                                Command="{Binding FixOutputModeCommand}"
                                Padding="12,6" FontSize="11" Margin="0,6,0,0"
                                HorizontalAlignment="Left"
                                IsVisible="{Binding CanFixOutputMode}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Display Mapping tab content: pick a display + see the tablet's active area and the live
             pen, all in one diagram (#250/#252). -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto"
                      IsVisible="{Binding #DisplayMappingTab.IsChecked}">
            <StackPanel>
                <Border Classes="GlassPanel" Padding="16"
                        IsVisible="{Binding HasAreaMapping}">
                    <StackPanel>
                        <Grid RowDefinitions="Auto,Auto" ColumnSpacing="12">
                            <TextBlock Grid.Row="0" Text="DISPLAY MAPPING" Classes="SectionLabel"
                                       VerticalAlignment="Center" />
                            <WrapPanel Grid.Row="1" Orientation="Horizontal">
                                <Button Content="Refresh" Command="{Binding RefreshDisplaysCommand}"
                                        ToolTip.Tip="Refresh displays from Windows"
                                        Theme="{StaticResource GhostButton}" Padding="10,5" FontSize="11" Margin="0,0,6,4" />
                                <Button Content="Display Settings"
                                        Command="{Binding OpenDisplaySettingsCommand}"
                                        ToolTip.Tip="Open Windows Display Settings"
                                        Theme="{StaticResource GhostButton}" Padding="10,5" FontSize="11" Margin="0,0,0,4" />
                            </WrapPanel>
                        </Grid>
                        <TextBlock Text="Click a display to map the tablet to it, then Apply."
                                   FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,6,0,8"
                                   TextWrapping="Wrap" />
                        <ctrl:ScreenMappingDiagram Displays="{Binding Displays}"
                                                   SelectedNumber="{Binding SelectedDisplayNumber, Mode=TwoWay}"
                                                   Area="{Binding TabletArea}"
                                                   AccentBrush="{DynamicResource AccentBrush}"
                                                   Height="320" />
                        <Button Content="Apply mapping" Command="{Binding ApplyDisplayCommand}"
                                Theme="{StaticResource AccentButton}" Padding="14,7" FontSize="12"
                                HorizontalAlignment="Left" Margin="0,10,0,0" />
                        <!-- Make it obvious a changed display selection isn't live until applied (#179 follow-up). -->
                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,8,0,0"
                                    IsVisible="{Binding MappingChangePending}">
                            <TextBlock Text="●" FontSize="11" VerticalAlignment="Center"
                                       Foreground="{DynamicResource AccentBrush}" />
                            <TextBlock Text="Display selection changed — click Apply mapping to save it."
                                       FontSize="11" FontWeight="SemiBold" TextWrapping="Wrap"
                                       Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- Per-display hardware: which connector/port and GPU drives each monitor. -->
                        <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="0,14,0,12" />
                        <ItemsControl ItemsSource="{Binding Displays}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" Margin="0,0,0,8">
                                        <Border Grid.Column="0" Width="24" Height="24" CornerRadius="5"
                                                Background="{DynamicResource AccentMutedBrush}" VerticalAlignment="Top">
                                            <TextBlock Text="{Binding Number}" FontSize="12" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource AccentBrush}" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Spacing="1">
                                            <TextBlock Text="{Binding DisplayTitle}" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding DetailSubLine}" FontSize="11"
                                                       Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Active Area tab content: the tablet's full area with the effective (used) area drawn to
             scale. Read-only for now — a later iteration will let the user resize/align it here. -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto"
                      IsVisible="{Binding #ActiveAreaTab.IsChecked}">
            <StackPanel>
                <Border Classes="GlassPanel" Padding="16" IsVisible="{Binding HasAreaMapping}">
                    <StackPanel>
                        <TextBlock Text="ACTIVE AREA" Classes="SectionLabel" />
                        <TextBlock Text="The highlighted region is the part of your tablet that's currently mapped to the screen. It's sized automatically to match the selected display's proportions, so pen movement isn't stretched or squashed."
                                   FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="0,6,0,10" TextWrapping="Wrap" />

                        <!-- Diagram + stats when we have digitizer specs. -->
                        <StackPanel IsVisible="{Binding TabletArea, Converter={x:Static conv:ObjectConverters.IsNotNull}}">
                            <ctrl:ActiveAreaDiagram Area="{Binding TabletArea}"
                                                    AccentBrush="{DynamicResource AccentBrush}"
                                                    Height="320" />
                            <Grid ColumnDefinitions="*,*,*,*" Margin="0,12,0,0">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="{Binding ActiveAreaUsagePercentText}" FontSize="20" FontWeight="Bold"
                                               Foreground="{DynamicResource AccentBrush}" />
                                    <TextBlock Text="of tablet area used" FontSize="10" TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextMutedBrush}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="{Binding ActiveAreaDimsPercentText}" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <TextBlock Text="width × height" FontSize="10" TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextMutedBrush}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="2">
                                    <TextBlock Text="{Binding ActiveAreaUsedText}" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <TextBlock Text="active area" FontSize="10" TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextMutedBrush}" />
                                </StackPanel>
                                <StackPanel Grid.Column="3" Spacing="2">
                                    <TextBlock Text="{Binding ActiveAreaFullText}" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <TextBlock Text="full tablet area" FontSize="10" TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextMutedBrush}" />
                                </StackPanel>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,12,0,0">
                                <TextBlock Text="Diagonal:" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                <TextBlock Text="{Binding ActiveAreaDiagonalText}" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                            </StackPanel>
                            <TextBlock Text="You'll be able to shrink or realign this area in a future update."
                                       FontSize="10" FontStyle="Italic" Margin="0,12,0,0" TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextMutedBrush}" />
                        </StackPanel>

                        <!-- No digitizer specs for this tablet — nothing to draw. -->
                        <TextBlock Text="Active-area details aren't available for this tablet."
                                   FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   IsVisible="{Binding TabletArea, Converter={x:Static conv:ObjectConverters.IsNull}}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Calibration tab content (#252). -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto"
                      IsVisible="{Binding #CalibrationTab.IsChecked}">
            <StackPanel>
                <Border Classes="GlassPanel" Padding="16"
                        IsVisible="{Binding HasAreaMapping}">
                    <StackPanel>
                        <TextBlock Text="CALIBRATION" Classes="SectionLabel" />
                        <TextBlock Text="Correct where the pen lands vs. where you see it (Absolute mode only)."
                                   FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="0,6,0,8" TextWrapping="Wrap" />
                        <StackPanel Spacing="10">
                            <!-- Capture density: quick corner method or a finer grid. Radio buttons so
                                 all options are visible at a glance (replaces the old dropdown). -->
                            <StackPanel Spacing="6" IsVisible="{Binding CanCalibrate}">
                                <RadioButton GroupName="CalibrationMode" Content="4 point" FontSize="11"
                                             IsChecked="{Binding IsCalibration4Point, Mode=TwoWay}"
                                             ToolTip.Tip="Quick — tap the four corners; corrects perspective (homography)" />
                                <RadioButton GroupName="CalibrationMode" Content="9 point" FontSize="11"
                                             IsChecked="{Binding IsCalibration9Point, Mode=TwoWay}"
                                             ToolTip.Tip="A 3×3 grid; corrects localized distortion across the screen" />
                                <RadioButton GroupName="CalibrationMode" Content="25 point" FontSize="11"
                                             IsChecked="{Binding IsCalibration25Point, Mode=TwoWay}"
                                             ToolTip.Tip="A 5×5 grid; the finest correction across the screen" />
                            </StackPanel>
                            <Button Content="Calibrate…" Command="{Binding CalibrateCommand}"
                                    IsEnabled="{Binding CanRunCalibration}" HorizontalAlignment="Left"
                                    Theme="{StaticResource AccentButton}" Padding="14,7" FontSize="12"
                                    ToolTip.Tip="Tap the targets to correct where the pen lands vs. where you see it (Absolute mode only)" />
                        </StackPanel>
                        <TextBlock Text="Calibration is available in Absolute mode."
                                   FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="0,8,0,0" IsVisible="{Binding !CanCalibrate}" />
                        <!-- Absolute mode, but the tablet isn't connected — calibration needs live pen taps (#177). -->
                        <TextBlock Text="Connect this tablet to calibrate."
                                   FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="0,8,0,0" IsVisible="{Binding ShowConnectToCalibrateHint}" />
                        <!-- Calibration state: whether it's active, which mode, and a way to clear it. -->
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,10,0,0"
                                    IsVisible="{Binding CanCalibrate}">
                            <TextBlock Classes="statusMark" Classes.success="{Binding IsCalibrated}"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding CalibrationStatusText}" FontSize="11" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                            <Button Content="Clear calibration" Command="{Binding ClearCalibrationCommand}"
                                    IsVisible="{Binding CanClearCalibration}"
                                    Theme="{StaticResource GhostButton}" Padding="10,4" FontSize="11"
                                    VerticalAlignment="Center"
                                    ToolTip.Tip="Remove the calibration and return the pointer to its uncorrected default" />
                        </StackPanel>
                        <TextBlock Text="This tablet's calibration was made for a different display mapping — recalibrate to keep it accurate."
                                   FontSize="10" Foreground="{DynamicResource WarningBrush}" TextWrapping="Wrap"
                                   Margin="0,4,0,0" IsVisible="{Binding CalibrationStale}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Pen Switches tab: reflowing rows — pen tip + eraser · a horizontal pen (tip to the left) ·
             the buttons. Cards wrap when the window is narrow, so the layout survives resizing.
             Data-driven: only the buttons this pen actually has appear (in the graphic and as cards). -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto"
                      IsVisible="{Binding #PenTipTab.IsChecked}" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="16" HorizontalAlignment="Center" Margin="0,4,0,0">
                    <!-- Row 1: pen tip + eraser -->
                    <WrapPanel HorizontalAlignment="Center">
                        <views:PenSwitchCard Margin="6" DataContext="{Binding PenTipRow}" />
                        <views:PenSwitchCard Margin="6" DataContext="{Binding PenEraserRow}" />
                    </WrapPanel>

                    <!-- Row 2: horizontal pen (tip left → eraser right). Decorative; no connectors. -->
                    <Viewbox MaxWidth="440" MaxHeight="86" HorizontalAlignment="Center">
                        <Canvas Width="400" Height="80">
                            <!-- tip nib (far left, under the cone) -->
                            <Rectangle Canvas.Left="8" Canvas.Top="36" Width="20" Height="8" RadiusX="4" RadiusY="4"
                                       Fill="#F7CFD8" Stroke="#CF5E86" StrokeThickness="2.5" />
                            <!-- tip cone (pointing left) -->
                            <Polygon Points="72,28 72,52 26,45 26,35" Fill="#F7CFD8"
                                     Stroke="#CF5E86" StrokeThickness="2.5" StrokeJoin="Round" />
                            <!-- barrel -->
                            <Rectangle Canvas.Left="70" Canvas.Top="28" Width="272" Height="24"
                                       Fill="#F7CFD8" Stroke="#CF5E86" StrokeThickness="2.5" />
                            <!-- eraser nub (right) -->
                            <Rectangle Canvas.Left="342" Canvas.Top="31" Width="26" Height="18" RadiusX="6" RadiusY="6"
                                       Fill="#F7CFD8" Stroke="#CF5E86" StrokeThickness="2.5" />
                            <!-- side buttons, clustered toward the tip (left) -->
                            <Rectangle Canvas.Left="104" Canvas.Top="32" Width="34" Height="16" RadiusX="6" RadiusY="6"
                                       Fill="#EEB6C6" Stroke="#CF5E86" StrokeThickness="2"
                                       IsVisible="{Binding PenButton1Row, Converter={x:Static conv:ObjectConverters.IsNotNull}}" />
                            <Rectangle Canvas.Left="148" Canvas.Top="32" Width="34" Height="16" RadiusX="6" RadiusY="6"
                                       Fill="#EEB6C6" Stroke="#CF5E86" StrokeThickness="2"
                                       IsVisible="{Binding PenButton2Row, Converter={x:Static conv:ObjectConverters.IsNotNull}}" />
                            <Rectangle Canvas.Left="192" Canvas.Top="32" Width="34" Height="16" RadiusX="6" RadiusY="6"
                                       Fill="#EEB6C6" Stroke="#CF5E86" StrokeThickness="2"
                                       IsVisible="{Binding PenButton3Row, Converter={x:Static conv:ObjectConverters.IsNotNull}}" />
                        </Canvas>
                    </Viewbox>

                    <!-- Row 3: buttons (only those the pen has) -->
                    <WrapPanel HorizontalAlignment="Center">
                        <views:PenSwitchCard Margin="6" DataContext="{Binding PenButton1Row}"
                                             IsVisible="{Binding $parent[WrapPanel].DataContext.PenButton1Row, Converter={x:Static conv:ObjectConverters.IsNotNull}}" />
                        <views:PenSwitchCard Margin="6" DataContext="{Binding PenButton2Row}"
                                             IsVisible="{Binding $parent[WrapPanel].DataContext.PenButton2Row, Converter={x:Static conv:ObjectConverters.IsNotNull}}" />
                        <views:PenSwitchCard Margin="6" DataContext="{Binding PenButton3Row}"
                                             IsVisible="{Binding $parent[WrapPanel].DataContext.PenButton3Row, Converter={x:Static conv:ObjectConverters.IsNotNull}}" />
                    </WrapPanel>
                </StackPanel>
        </ScrollViewer>

        <!-- ExpressKeys tab content: one card per auxiliary button. -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto"
                      IsVisible="{Binding #PenButtonsTab.IsChecked}">
            <StackPanel>
                <!-- Header: master enable toggle and clear-all (when there are buttons). -->
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12" Margin="0,0,0,8">
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                                VerticalAlignment="Center" IsVisible="{Binding ShowAuxControls}">
                        <TextBlock Text="Buttons enabled" FontSize="12" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <ToggleSwitch IsChecked="{Binding AuxButtonsEnabled}" OnContent="" OffContent=""
                                      MinWidth="0" VerticalAlignment="Center"
                                      ToolTip.Tip="Turn all express keys on or off. Your mappings are kept and restored when you turn them back on." />
                    </StackPanel>
                    <Button Grid.Column="2" Content="Clear all" Command="{Binding ClearAuxButtonsCommand}"
                            IsVisible="{Binding ShowAuxControls}"
                            ToolTip.Tip="Remove every express-key mapping"
                            Theme="{StaticResource GhostButton}" Padding="12,6" FontSize="12"
                            VerticalAlignment="Center" />
                </Grid>

                <ItemsControl ItemsSource="{Binding AuxButtons}" IsVisible="{Binding !NoAuxButtons}"
                              ItemTemplate="{StaticResource ButtonBindingCard}" />

                <!-- Empty state when the tablet has no auxiliary buttons. -->
                <Border Classes="GlassPanel" Padding="16" IsVisible="{Binding NoAuxButtons}">
                    <TextBlock Text="No auxiliary buttons configured" FontSize="12"
                               Foreground="{DynamicResource TextMutedBrush}" />
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Wheel tab content: per-wheel rotation bindings (CW/CCW) + sensitivity, wheel buttons, and a
             master enable / clear-all. Reuses the ExpressKeys binding-editor card. Only shown when the
             tablet reports a wheel. -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto"
                      IsVisible="{Binding #WheelTab.IsChecked}">
            <StackPanel>
                <!-- Header: label + master enable toggle + clear-all (parity with ExpressKeys). -->
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12" Margin="0,0,0,8">
                    <TextBlock Grid.Column="0" Text="WHEEL" Classes="SectionLabel" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                                VerticalAlignment="Center" IsVisible="{Binding ShowWheelControls}">
                        <TextBlock Text="Wheel enabled" FontSize="12" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <ToggleSwitch IsChecked="{Binding WheelEnabled}" OnContent="" OffContent=""
                                      MinWidth="0" VerticalAlignment="Center"
                                      ToolTip.Tip="Turn all wheel bindings on or off. Your mappings are kept and restored when you turn them back on." />
                    </StackPanel>
                    <Button Grid.Column="2" Content="Clear all" Command="{Binding ClearWheelBindingsCommand}"
                            IsVisible="{Binding ShowWheelControls}"
                            ToolTip.Tip="Remove every wheel binding"
                            Theme="{StaticResource GhostButton}" Padding="12,6" FontSize="12"
                            VerticalAlignment="Center" />
                </Grid>

                <TextBlock Text="Bind an action to each direction the wheel turns, plus its button. Sensitivity sets how far you turn before the action repeats."
                           FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                           Margin="0,0,0,10" TextWrapping="Wrap" />

                <!-- One card per wheel: the live gauge on the left, and every mapping for that wheel
                     (clockwise + counter-clockwise actions with sensitivity, and the wheel button)
                     grouped on the right — so a wheel is a single self-contained unit (#310). -->
                <ItemsControl ItemsSource="{Binding Wheels}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Classes="GlassPanel" Margin="0,0,0,10" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}" Classes="SectionLabel"
                                               IsVisible="{Binding ShowTitle}" Margin="0,0,0,10" />

                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="18">
                                        <!-- Live gauge: marker + fading trail + current angle. -->
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <ctrl:WheelGauge Position="{Binding LivePosition}"
                                                             TurningClockwise="{Binding TurningClockwise}"
                                                             TurningCounterClockwise="{Binding TurningCounterClockwise}"
                                                             AccentBrush="{DynamicResource AccentBrush}"
                                                             Width="132" Height="132" HorizontalAlignment="Center" />
                                            <TextBlock Text="{Binding StepInfo}" FontSize="10"
                                                       IsVisible="{Binding HasStepInfo}"
                                                       HorizontalAlignment="Center" TextAlignment="Center"
                                                       MaxWidth="150" TextWrapping="Wrap"
                                                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0" />
                                        </StackPanel>

                                        <!-- All mappings for this wheel. -->
                                        <StackPanel Grid.Column="1" MinWidth="0">
                                            <!-- Clockwise: binding card + sensitivity. -->
                                            <ContentControl Content="{Binding Clockwise}"
                                                            ContentTemplate="{StaticResource ButtonBindingCard}" />
                                            <ctrl:LabeledSlider Label="Sensitivity" LabelWidth="72" Margin="12,0,2,10"
                                                                Minimum="{Binding ThresholdMin}" Maximum="{Binding ThresholdMax}"
                                                                TickFrequency="{Binding ThresholdTick}" IsSnapToTickEnabled="True"
                                                                IsEnabled="{Binding CanEdit}"
                                                                Value="{Binding ClockwiseThreshold}"
                                                                ValueTextOverride="{Binding ClockwiseThresholdText}"
                                                                Monospace="True" ValueWidth="130" />

                                            <!-- Counter-clockwise: binding card + sensitivity. -->
                                            <ContentControl Content="{Binding CounterClockwise}"
                                                            ContentTemplate="{StaticResource ButtonBindingCard}" />
                                            <ctrl:LabeledSlider Label="Sensitivity" LabelWidth="72" Margin="12,0,2,10"
                                                                Minimum="{Binding ThresholdMin}" Maximum="{Binding ThresholdMax}"
                                                                TickFrequency="{Binding ThresholdTick}" IsSnapToTickEnabled="True"
                                                                IsEnabled="{Binding CanEdit}"
                                                                Value="{Binding CounterClockwiseThreshold}"
                                                                ValueTextOverride="{Binding CounterClockwiseThresholdText}"
                                                                Monospace="True" ValueWidth="130" />

                                            <!-- Wheel button(s). -->
                                            <ItemsControl ItemsSource="{Binding Buttons}" IsVisible="{Binding HasButtons}"
                                                          ItemTemplate="{StaticResource ButtonBindingCard}" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Dynamics tab content -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto"
                      IsVisible="{Binding #DynamicsTab.IsChecked}">
            <StackPanel IsEnabled="{Binding CanEditPressure}">
                <!-- Master On/Off as a header row (not a card), plus a reset-everything action. -->
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12" Margin="2,2,2,10">
                    <TextBlock Grid.Column="0" Text="PEN DYNAMICS" Classes="SectionLabel" VerticalAlignment="Center" />
                    <Button Grid.Column="1" Content="Reset all" Command="{Binding ResetAllDynamicsCommand}"
                            Theme="{StaticResource GhostButton}" Padding="12,5" FontSize="11" VerticalAlignment="Center"
                            ToolTip.Tip="Reset the curve, smoothing, and order back to their defaults" />
                    <ToggleSwitch Grid.Column="2" VerticalAlignment="Center"
                                  OnContent="On" OffContent="Off"
                                  IsChecked="{Binding PressureCurveEnabled}" />
                </Grid>

                <!-- Curve + smoothing only apply when Pen Dynamics is On — disable AND dim them when
                     it's Off (IsEnabled barely greys the read-outs, and the custom curve chart ignores
                     IsEnabled, so the opacity is what actually makes "Off" read as inactive). -->
                <StackPanel IsEnabled="{Binding PressureCurveEnabled}"
                            Opacity="{Binding DynamicsControlsOpacity}">

                    <!-- Pressure curve: chart + presets + softness + dead zone + node read-outs -->
                    <Border Classes="GlassPanel" Padding="14" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="PRESSURE CURVE" Classes="SectionLabel" />

                            <!-- Two columns: compact chart on the left, controls on the right. -->
                            <Grid ColumnDefinitions="Auto,*" Margin="0,8,0,0">
                                <!-- Compact 1:1 chart; the green dot tracks live pen pressure (#102). -->
                                <ctrl:PressureCurveChart Grid.Column="0" Curve="{Binding Curve, Mode=TwoWay}"
                                                         LivePressure="{Binding LivePressure}"
                                                         Width="180" Height="180"
                                                         VerticalAlignment="Top" Margin="0,0,16,0" />

                                <StackPanel Grid.Column="1">
                                    <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,8">
                                        <TextBlock Grid.Column="0" Text="Presets" FontSize="12" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" Width="70" />
                                        <WrapPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Content="Linear" Command="{Binding ApplyPresetCommand}" CommandParameter="linear"
                                                    Theme="{StaticResource GhostButton}" Padding="12,5" FontSize="11" Margin="0,0,6,4" />
                                            <Button Content="Soft" Command="{Binding ApplyPresetCommand}" CommandParameter="soft"
                                                    Theme="{StaticResource GhostButton}" Padding="12,5" FontSize="11" Margin="0,0,6,4" />
                                            <Button Content="Firm" Command="{Binding ApplyPresetCommand}" CommandParameter="firm"
                                                    Theme="{StaticResource GhostButton}" Padding="12,5" FontSize="11" Margin="0,0,6,4" />
                                            <Button Content="Reset" Command="{Binding ResetCurveCommand}"
                                                    Theme="{StaticResource GhostButton}" Padding="12,5" FontSize="11" Margin="0,0,0,4"
                                                    ToolTip.Tip="Reset the curve to the linear default" />
                                        </WrapPanel>
                                    </Grid>

                                    <!-- Capped at ±0.95 (±1.0 is mathematically degenerate); the end ticks
                                         sit at the slider ends so the marks read as -1/-0.5/0/0.5/1. -->
                                    <ctrl:LabeledSlider Label="Softness" LabelWidth="70" Margin="0,0,0,8"
                                                        Minimum="-0.95" Maximum="0.95"
                                                        Ticks="-0.95,-0.5,0,0.5,0.95" TickPlacement="BottomRight"
                                                        Value="{Binding Softness}" ValueTextOverride="{Binding SoftnessText}"
                                                        Monospace="True" ValueWidth="40"
                                                        ToolTip.Tip="Positive = lighter touch (concave) · Negative = firmer (convex)" />

                                    <CheckBox Content="Cut below input minimum (dead zone)"
                                              IsChecked="{Binding CutBelowMinimum}" FontSize="12" Margin="0,0,0,8"
                                              Foreground="{DynamicResource TextSecondaryBrush}"
                                              ToolTip.Tip="Below the input minimum, produce zero output (a dead zone) instead of holding at the output minimum." />

                                    <Grid ColumnDefinitions="Auto,*,*" RowDefinitions="Auto,Auto,Auto">
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Input" Classes="SectionLabel"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Output" Classes="SectionLabel"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Min node" FontSize="12" Width="70"
                                                   VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding InputMinimumText}" FontSize="12"
                                                   FontFamily="{DynamicResource MonoFontFamily}" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" />
                                        <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding OutputMinimumText}" FontSize="12"
                                                   FontFamily="{DynamicResource MonoFontFamily}" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" />
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Max node" FontSize="12" Width="70"
                                                   VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding InputMaximumText}" FontSize="12"
                                                   FontFamily="{DynamicResource MonoFontFamily}" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" />
                                        <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding OutputMaximumText}" FontSize="12"
                                                   FontFamily="{DynamicResource MonoFontFamily}" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" />
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Smoothing -->
                    <Border Classes="GlassPanel" Padding="14" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="SMOOTHING (JITTER REDUCTION)" Classes="SectionLabel"
                                       ToolTip.Tip="EMA smoothing trades a little lag for steadier output. Position steadies wobbly lines; pressure evens out pressure jitter." />
                            <ctrl:LabeledSlider Label="Position" LabelWidth="80" Margin="0,8,0,4"
                                                Minimum="0" Maximum="1"
                                                Ticks="0,0.25,0.5,0.75,0.9,1" TickPlacement="BottomRight"
                                                Value="{Binding PositionSmoothing}"
                                                ValueTextOverride="{Binding PositionSmoothingText}"
                                                Monospace="True" ValueWidth="44" />
                            <ctrl:LabeledSlider Label="Pressure" LabelWidth="80"
                                                Minimum="0" Maximum="1"
                                                Ticks="0,0.25,0.5,0.75,0.9,1" TickPlacement="BottomRight"
                                                Value="{Binding PressureSmoothing}"
                                                ValueTextOverride="{Binding PressureSmoothingText}"
                                                Monospace="True" ValueWidth="44" />
                        </StackPanel>
                    </Border>

                    <!-- Order (compact one-row card) -->
                    <Border Classes="GlassPanel" Padding="14" Margin="0,0,0,10">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <TextBlock Grid.Column="0" Text="ORDER" Classes="SectionLabel" VerticalAlignment="Center"
                                       ToolTip.Tip="Whether smoothing runs after the curve (default) or before it." />
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding SmoothAfterCurve}"
                                          OnContent="Curve → Smooth" OffContent="Smooth → Curve" VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Hover tab content (#188) -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto"
                      IsVisible="{Binding #HoverTab.IsChecked}">
            <StackPanel IsEnabled="{Binding CanEditHover}">
                <!-- Master On/Off header row. -->
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" Margin="2,2,2,10">
                    <TextBlock Grid.Column="0" Text="HOVER LIMIT" Classes="SectionLabel" VerticalAlignment="Center" />
                    <ToggleSwitch Grid.Column="1" VerticalAlignment="Center"
                                  OnContent="On" OffContent="Off"
                                  IsChecked="{Binding HoverLimitEnabled}" />
                </Grid>

                <Border Classes="GlassPanel" Padding="14" Margin="0,0,0,10"
                        IsEnabled="{Binding HoverLimitEnabled}" Opacity="{Binding HoverControlsOpacity}">
                    <StackPanel>
                        <TextBlock Text="Stops the cursor tracking once the pen lifts past this distance — useful to keep a raised pen from dragging the cursor. Drawing is unaffected."
                                   FontSize="12" TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,10" />
                        <ctrl:LabeledSlider Label="Max hover" LabelWidth="80"
                                            Minimum="1" Maximum="{Binding HoverDistanceMax}"
                                            Value="{Binding MaxHoverDistance}"
                                            ValueTextOverride="{Binding MaxHoverDistanceText}"
                                            Monospace="True" ValueWidth="40"
                                            ToolTip.Tip="Lower = the cursor stops sooner as you lift the pen. Higher = allow more hover (255 = no limit)." />
                        <TextBlock Text="Hover distance is 0–255. Not all tablets report it — check the Diagnostics page for your tablet's live hover values to pick a limit."
                                   FontSize="10" TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,10,0,0" />

                        <!-- Near-proximity gate (#311): track only in the tablet's close band (Wacom default). -->
                        <Border Height="1" Background="{DynamicResource GlassBorderBrush}" Margin="0,14,0,12" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Near proximity only" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                <TextBlock Text="Only track while the pen is close to the surface — matches Wacom's default hover range. Needs a tablet that reports proximity."
                                           FontSize="10" TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextMutedBrush}" Margin="0,2,0,0" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" VerticalAlignment="Center" MinWidth="0"
                                          OnContent="" OffContent=""
                                          IsChecked="{Binding NearProximityOnly}" />
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Filters tab content: one card per filter on the profile. -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto"
                      IsVisible="{Binding #FiltersTab.IsChecked}">
            <StackPanel>
                <TextBlock Text="FILTERS" Classes="SectionLabel" Margin="0,0,0,8" />

                <ItemsControl ItemsSource="{Binding Filters}" IsVisible="{Binding HasFilters}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Classes="GlassPanel" Padding="16,12" Margin="0,0,0,10">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       TextWrapping="Wrap" VerticalAlignment="Center" />
                                            <!-- Stale leftover from an older app/plugin name: inert, should be cleaned. -->
                                            <Border IsVisible="{Binding IsLegacy}"
                                                    Background="#33e87930" BorderBrush="#e87930" BorderThickness="1"
                                                    CornerRadius="4" Padding="6,1" VerticalAlignment="Center"
                                                    ToolTip.Tip="Left over from an older version. The driver has no plugin for this type, so it does nothing — it will be removed automatically.">
                                                <TextBlock Text="Legacy" FontSize="10" FontWeight="SemiBold"
                                                           Foreground="#e87930" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding FullPath}" FontSize="11"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <TextBlock Classes="statusMark" Classes.success="{Binding Enabled}" />
                                        <TextBlock Text="{Binding StatusText}" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty state when the profile has no filters. -->
                <Border Classes="GlassPanel" Padding="16" IsVisible="{Binding !HasFilters}">
                    <TextBlock Text="No filters configured" FontSize="12"
                               Foreground="{DynamicResource TextMutedBrush}" />
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- JSON tab content -->
        <Border Grid.Row="1" Grid.Column="1" Classes="GlassPanel" Padding="16"
                IsVisible="{Binding #JsonTab.IsChecked}">
            <TextBox Text="{Binding RawJson, Mode=OneWay}" IsReadOnly="True"
                     FontFamily="{DynamicResource MonoFontFamily}" FontSize="11"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     Background="Transparent" BorderThickness="0"
                     TextWrapping="NoWrap"
                     AcceptsReturn="True" />
        </Border>
    </Grid>
</UserControl>
