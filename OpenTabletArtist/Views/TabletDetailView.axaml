<UserControl x:Class="OpenTabletArtist.Views.TabletDetailView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="using:OpenTabletArtist.Controls"
             xmlns:conv="using:Avalonia.Data.Converters"
             xmlns:otac="using:OpenTabletArtist.Converters"
             xmlns:views="using:OpenTabletArtist.Views">

    <UserControl.Styles>
        <!-- Express-key card lights up while its physical button is held. Only the border/background
             change (thickness stays 1) so the highlight doesn't nudge the layout. -->
        <Style Selector="Border.expressCard.pressed">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Background" Value="{DynamicResource AccentMutedBrush}" />
        </Style>
        <!-- Calibration card that's currently in use: accent outline (overrides the GlassPanel border). -->
        <Style Selector="Border.GlassPanel.calCurrent">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
        <!-- "In use" pill shown on the current calibration card. -->
        <Style Selector="Border.calBadge">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Border.calBadge > TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <!-- Connection status bar across the top of the tablet header: full-width, solid colour by
             state — orange when the tablet isn't detected, green when it is. -->
        <Style Selector="Border.tabletStatusBar">
            <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
        <Style Selector="Border.tabletStatusBar.connected">
            <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
        </Style>
    </UserControl.Styles>

    <UserControl.Resources>
        <!-- Shared binding card: a label + the current binding as text + an Edit button that opens the
             modal type-tabbed editor (BindingEditorDialog). Used by both the ExpressKeys tab (auxiliary
             buttons) and the Wheel tab (rotation directions + wheel button) — both bind a ButtonBinding. -->
        <DataTemplate x:Key="ButtonBindingCard">
            <Border Classes="GlassPanel expressCard" Classes.pressed="{Binding IsPressed}"
                    Padding="16,12" Margin="0,0,0,10">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Label}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Summary}" TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="Edit" Command="{Binding EditCommand}"
                            IsEnabled="{Binding CanEdit}" VerticalAlignment="Center"
                            Theme="{StaticResource GhostButton}" Padding="16,7"
                            ToolTip.Tip="Change this binding" />
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <!-- A single tablet's settings: the tabbed editor. Hosted as the in-app Tablets page, and by the
         tray's focused Pen Dynamics dialog. DataContext is a TabletDetailViewModel. -->
    <Grid RowDefinitions="Auto,*" ColumnDefinitions="Auto,*">
        <!-- Complex header (see docs/design/ux-terminology.md): a full-width connection-status bar,
             then the tablet name (brand/model) + Refresh/Forget, then an optional refresh-warning line. -->
        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Spacing="8" Margin="0,0,0,16">
            <!-- Connection status bar spanning the header — solid green when detected, orange when not. -->
            <Border Classes="tabletStatusBar" Classes.connected="{Binding IsTabletDetected}">
                <TextBlock Text="{Binding DetectionText}" FontWeight="SemiBold"
                           Foreground="White" VerticalAlignment="Center" TextWrapping="Wrap" />
            </Border>
            <ctrl:ComplexHeader Margin="0">
                <ctrl:ComplexHeader.TitleContent>
                    <!-- brand (first word) small, over the model (rest) large — the PageTitle look
                         (Segoe UI Light, uppercase) split across two lines. -->
                    <StackPanel VerticalAlignment="Center" MaxWidth="360">
                        <TextBlock Text="{Binding TabletBrand, Converter={x:Static otac:UpperCaseConverter.Instance}}"
                                   IsVisible="{Binding HasTabletBrand}"
                                   FontFamily="Segoe UI, Inter" FontSize="18" FontWeight="Light"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Text="{Binding TabletModel, Converter={x:Static otac:UpperCaseConverter.Instance}}"
                                   FontFamily="Segoe UI, Inter" FontSize="30" FontWeight="Light"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   TextWrapping="Wrap" Margin="0,-2,0,0" />
                    </StackPanel>
                </ctrl:ComplexHeader.TitleContent>
                <!-- Trailing: Refresh + Forget (connection status moved to the bar above). -->
                <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Content="Refresh" Command="{Binding RefreshCommand}"
                            ToolTip.Tip="Reload settings from daemon"
                            Theme="{StaticResource GhostButton}" Padding="12,6" />
                    <!-- Forget the tablet's saved profile. Hidden in the focused Pen Dynamics dialog. -->
                    <Button Content="Forget" Command="{Binding ForgetCommand}"
                            IsVisible="{Binding ShowForget}"
                            ToolTip.Tip="Remove this tablet's saved settings"
                            Theme="{StaticResource DeleteButton}" Padding="12,6" />
                </StackPanel>
            </ctrl:ComplexHeader>
            <TextBlock Text="{Binding RefreshWarning}" FontStyle="Italic"
                       Foreground="{DynamicResource WarningBrush}" TextWrapping="Wrap"
                       IsVisible="{Binding RefreshWarning, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}}" />
            <!-- Settings changed outside OTA (e.g. the OTD UX) while the user had an unsaved edit here.
                 Non-destructive: Reload adopts the external values; otherwise it's picked up silently. -->
            <Border IsVisible="{Binding HasExternalChange}"
                    Background="{DynamicResource GlassBgBrush}"
                    BorderBrush="{DynamicResource WarningBrush}" BorderThickness="1"
                    CornerRadius="6" Padding="12,8" Margin="0,4,0,0">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="{Binding ExternalChangeText}"
                               Foreground="{DynamicResource WarningBrush}"
                               TextWrapping="Wrap" VerticalAlignment="Center" />
                    <Button Grid.Column="1" Content="Reload"
                            Command="{Binding ReloadExternalChangeCommand}"
                            ToolTip.Tip="Discard your unsaved change and load the current settings"
                            Theme="{StaticResource GhostButton}" Padding="12,6"
                            Margin="12,0,0,0" VerticalAlignment="Center" />
                </Grid>
            </Border>
        </StackPanel>

        <!-- Tab rail — vertical, to the left of the content (hidden in the focused Pen Dynamics view, #133) -->
        <Border Grid.Row="1" Grid.Column="0" Margin="0,0,16,0" BorderThickness="0,0,1,0"
                BorderBrush="{DynamicResource DividerBrush}"
                IsVisible="{Binding !DynamicsOnly}">
            <StackPanel Width="150" Spacing="2" x:Name="TabRail">
                <RadioButton Content="ABOUT" IsChecked="True" x:Name="AboutTab"
                             Theme="{StaticResource TabRadioButton}" />
                <RadioButton Content="PEN BEHAVIOR" x:Name="OutputModeTab"
                             Theme="{StaticResource TabRadioButton}" />
                <RadioButton Content="PEN INPUTS" x:Name="PenTipTab"
                             Theme="{StaticResource TabRadioButton}" />
                <RadioButton Content="PEN BUTTONS" x:Name="PenBarrelTab"
                             Theme="{StaticResource TabRadioButton}"
                             IsVisible="{Binding HasPenButtons}" />
                <RadioButton Content="PRESSURE DYNAMICS" x:Name="PressureDynamicsTab"
                             Theme="{StaticResource TabRadioButton}" />
                <RadioButton Content="POSITION DYNAMICS" x:Name="PositionDynamicsTab"
                             Theme="{StaticResource TabRadioButton}" />
                <RadioButton Content="TILT DYNAMICS" x:Name="TiltDynamicsTab"
                             Theme="{StaticResource TabRadioButton}" />
                <RadioButton Content="DISPLAY MAPPING" x:Name="DisplayMappingTab"
                             Theme="{StaticResource TabRadioButton}"
                             IsVisible="{Binding HasAreaMapping}" />
                <RadioButton Content="ACTIVE AREA" x:Name="ActiveAreaTab"
                             Theme="{StaticResource TabRadioButton}"
                             IsVisible="{Binding HasAreaMapping}" />
                <RadioButton Content="CALIBRATION" x:Name="CalibrationTab"
                             Theme="{StaticResource TabRadioButton}"
                             IsVisible="{Binding HasAreaMapping}" />
                <!-- Tablet-body express keys. x:Name kept as PenButtonsTab (referenced in code-behind for
                     the live aux-button highlight); labelled TABLET BUTTONS to disambiguate from the pen's
                     own PEN BUTTONS tab (#494). -->
                <RadioButton Content="TABLET BUTTONS" x:Name="PenButtonsTab"
                             Theme="{StaticResource TabRadioButton}" />
                <RadioButton Content="WHEELS" x:Name="WheelTab"
                             Theme="{StaticResource TabRadioButton}"
                             IsVisible="{Binding HasWheels}" />
                <!-- #318: Hover-limit feature hidden temporarily while its behavior is validated. The
                     tab (and its still-present content below) is unreachable while IsVisible=False, and
                     the HoverFilter plugin is neutered so it has no effect. Set IsVisible back to True
                     (and flip HoverFilter.LimiterEnabled) to restore. -->
                <RadioButton Content="HOVER" x:Name="HoverTab" IsVisible="False"
                             Theme="{StaticResource TabRadioButton}" />
                <!-- Filters/JSON are developer-only views, hidden unless enabled on Advanced → Developer. -->
                <RadioButton Content="FILTERS" x:Name="FiltersTab"
                             Theme="{StaticResource TabRadioButton}"
                             IsVisible="{Binding ShowFiltersTab}" />
                <RadioButton Content="JSON" x:Name="JsonTab"
                             Theme="{StaticResource TabRadioButton}"
                             IsVisible="{Binding ShowJsonTab}" />
            </StackPanel>
        </Border>

        <!-- About tab content: a clean read-out of the tablet's specs, plus a Resources area that will
             hold documentation / compatible-pen links over time. First tab, shown by default. -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto"
                      IsVisible="{Binding #AboutTab.IsChecked}">
            <StackPanel>
                <TextBlock Text="ABOUT" Classes="TabTitle" Margin="0,0,0,12" />
                <Border Classes="GlassPanel">
                    <StackPanel>
                        <TextBlock Text="SPECIFICATIONS" Classes="SectionLabel" />
                        <!-- Spec rows; each is included by the VM only when the value is known. -->
                        <ItemsControl ItemsSource="{Binding TabletFacts}" Margin="0,10,0,0"
                                      IsVisible="{Binding HasTabletFacts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="150,*" Margin="0,0,0,9">
                                        <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                   Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" />
                                        <TextBlock Grid.Column="1" Text="{Binding Value}" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <!-- Specs only exist while the tablet is detected. -->
                        <TextBlock Text="Connect this tablet to see its specifications."
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="0,10,0,0" TextWrapping="Wrap"
                                   IsVisible="{Binding !HasTabletFacts}" />
                    </StackPanel>
                </Border>

                <!-- #467: mirror the Home "using a custom config" card here, so the use of a config that
                     overrides OTD's vetted built-in is obvious right where the tablet is inspected. -->
                <Border Classes="GlassPanel" Margin="0,12,0,0"
                        BorderBrush="{DynamicResource WarningBrush}" BorderThickness="1.5"
                        IsVisible="{Binding IsConfigOverride}">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                        <Border Grid.Column="0" Classes="severityBar neutral" />
                        <StackPanel Grid.Column="1" MinWidth="0" VerticalAlignment="Center">
                            <TextBlock Text="Using a custom tablet config" Classes="CardTitle" TextWrapping="Wrap" />
                            <TextBlock Margin="0,4,0,0" TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Text="This tablet is driven by a custom configuration file that replaces OpenTabletDriver's built-in, vetted config of the same name. That's fine if you did it on purpose, but if the pen behaves oddly, removing the override to restore the built-in is worth trying." />
                        </StackPanel>
                        <Button Grid.Column="2" Content="Review"
                                Command="{Binding ReviewConfigCommand}"
                                Theme="{StaticResource AccentButton}" Padding="12,6"
                                VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <Border Classes="GlassPanel" Margin="0,12,0,0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="RESOURCES" Classes="SectionLabel" />
                        <Button Content="View supported tablets"
                                Command="{Binding OpenSupportedTabletsPageCommand}"
                                Theme="{StaticResource GhostButton}" Padding="10,6"
                                HorizontalAlignment="Left"
                                ToolTip.Tip="Show the tablets OpenTabletDriver supports (this one highlighted)" />
                        <TextBlock Text="Documentation and compatible-pen details will appear here in a future update."
                                   Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Output Mode tab content -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto"
                      IsVisible="{Binding #OutputModeTab.IsChecked}">
            <StackPanel>
                <!-- Movement: pick Absolute vs Relative as cards (both are Windows Ink modes). The card of
                     the mode in use is made obvious by the SelectableCard theme (accent outline + badge). -->
                <TextBlock Text="PEN BEHAVIOR" Classes="TabTitle" />
                <TextBlock Text="How the pen maps to the screen." Margin="0,4,0,0"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
                <!-- IsChecked is OneWay (display only); the mode change is driven by the Command on click.
                     A TwoWay IsChecked here made the two grouped radios fight into an apply↔reload loop. -->
                <UniformGrid Columns="2" Margin="0,12,0,0">
                    <RadioButton GroupName="Movement" Theme="{StaticResource SelectableCard}" Margin="0,0,12,0"
                                 IsChecked="{Binding IsAbsoluteMode, Mode=OneWay}"
                                 Command="{Binding SelectMovementCommand}" CommandParameter="absolute">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Normal (Absolute)" Classes="CardTitle" />
                            <TextBlock Text="The pen maps 1:1 to the screen — good for artists."
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton GroupName="Movement" Theme="{StaticResource SelectableCard}"
                                 IsChecked="{Binding IsAbsoluteMode, Converter={StaticResource InvBool}, Mode=OneWay}"
                                 Command="{Binding SelectMovementCommand}" CommandParameter="relative">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Mouse-like (Relative)" Classes="CardTitle" />
                            <TextBlock Text="The pen moves the cursor like a mouse — often used with games."
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </StackPanel>
                    </RadioButton>
                </UniformGrid>

                <!-- Only when the current mode isn't Windows Ink: pressure/tilt won't work; offer a fix. -->
                <TextBlock Text="Output mode needs to use Windows Ink for pressure and tilt to work"
                           Foreground="{DynamicResource WarningBrush}" FontStyle="Italic" Margin="0,12,0,0"
                           TextWrapping="Wrap"
                           IsVisible="{Binding CanFixOutputMode}" />
                <Button Content="Fix" Theme="{StaticResource AccentButton}"
                        Command="{Binding FixOutputModeCommand}"
                        Padding="12,6" Margin="0,6,0,0"
                        HorizontalAlignment="Left"
                        IsVisible="{Binding CanFixOutputMode}" />
            </StackPanel>
        </ScrollViewer>

        <!-- Display Mapping tab content: pick a display + see the tablet's active area and the live
             pen, all in one diagram (#250/#252). -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto"
                      IsVisible="{Binding #DisplayMappingTab.IsChecked}">
            <StackPanel>
                <TextBlock Text="DISPLAY MAPPING" Classes="TabTitle" Margin="0,0,0,12" />
                <Border Classes="GlassPanel"
                        IsVisible="{Binding HasAreaMapping}">
                    <StackPanel>
                        <!-- Flags a mapping that isn't a clean single-monitor one (#displaymap): an off-screen
                             area is a warning (the pen hits dead zones); a custom/multi-display area is an
                             informational note. Apply mapping below is the one-click fix for both. -->
                        <Border IsVisible="{Binding ShowMappingOffScreen}" CornerRadius="8" Padding="12,10"
                                Margin="0,0,0,12" Background="Transparent"
                                BorderThickness="1.5" BorderBrush="{DynamicResource WarningBrush}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="⚠" VerticalAlignment="Top"
                                           Foreground="{DynamicResource WarningBrush}" />
                                <TextBlock Text="{Binding MappingValidityText}" FontWeight="SemiBold"
                                           TextWrapping="Wrap" MaxWidth="360"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                            </StackPanel>
                        </Border>
                        <Border IsVisible="{Binding ShowMappingCustom}" CornerRadius="8" Padding="12,10"
                                Margin="0,0,0,12" Background="Transparent"
                                BorderThickness="1" BorderBrush="{DynamicResource DividerBrush}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="ⓘ" VerticalAlignment="Top"
                                           Foreground="{DynamicResource TextMutedBrush}" />
                                <TextBlock Text="{Binding MappingValidityText}"
                                           TextWrapping="Wrap" MaxWidth="360"
                                           Foreground="{DynamicResource TextMutedBrush}" />
                            </StackPanel>
                        </Border>
                        <Grid RowDefinitions="Auto,Auto" ColumnSpacing="12">
                            <TextBlock Grid.Row="0" Text="DISPLAY MAPPING" Classes="SectionLabel"
                                       VerticalAlignment="Center" />
                            <!-- Apply mapping leads the row (primary action), then the display helpers. -->
                            <WrapPanel Grid.Row="1" Orientation="Horizontal">
                                <Button Content="Apply mapping" Command="{Binding ApplyDisplayCommand}"
                                        ToolTip.Tip="Map the tablet to the selected display"
                                        Theme="{StaticResource AccentButton}" Padding="10,5" Margin="0,0,6,4" />
                                <Button Content="Refresh Display Settings" Command="{Binding RefreshDisplaysCommand}"
                                        ToolTip.Tip="Refresh displays from Windows"
                                        Theme="{StaticResource GhostButton}" Padding="10,5" Margin="0,0,6,4" />
                                <Button Content="Display Settings"
                                        Command="{Binding OpenDisplaySettingsCommand}"
                                        ToolTip.Tip="Open Windows Display Settings"
                                        Theme="{StaticResource GhostButton}" Padding="10,5" Margin="0,0,0,4" />
                            </WrapPanel>
                        </Grid>
                        <!-- A changed display selection isn't live until Apply mapping (#179 follow-up);
                             sits directly under the button row. -->
                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,6,0,0"
                                    IsVisible="{Binding MappingChangePending}">
                            <TextBlock Text="●" VerticalAlignment="Center"
                                       Foreground="{DynamicResource AccentBrush}" />
                            <TextBlock Text="Display selection changed — click Apply mapping to save it."
                                       FontWeight="SemiBold" TextWrapping="Wrap"
                                       Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="Click a display to map the tablet to it, then Apply."
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,6,0,8"
                                   TextWrapping="Wrap" />
                        <ctrl:ScreenMappingDiagram Displays="{Binding Displays}"
                                                   SelectedNumber="{Binding SelectedDisplayNumber, Mode=TwoWay}"
                                                   Area="{Binding TabletArea}"
                                                   AccentBrush="{DynamicResource AccentBrush}"
                                                   Height="320" />

                        <!-- Per-display hardware: which connector/port and GPU drives each monitor. -->
                        <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="0,14,0,12" />
                        <ItemsControl ItemsSource="{Binding Displays}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" Margin="0,0,0,8">
                                        <Border Grid.Column="0" Width="24" Height="24" CornerRadius="5"
                                                Background="{DynamicResource AccentMutedBrush}" VerticalAlignment="Top">
                                            <TextBlock Text="{Binding Number}" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource AccentBrush}" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Spacing="1">
                                            <TextBlock Text="{Binding DisplayTitle}" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding DetailSubLine}"
                                                       Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Active Area tab content: the tablet's full area with the effective (used) area drawn to
             scale. Read-only for now — a later iteration will let the user resize/align it here. -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto"
                      IsVisible="{Binding #ActiveAreaTab.IsChecked}">
            <StackPanel>
                <Border Classes="GlassPanel" IsVisible="{Binding HasAreaMapping}">
                    <StackPanel>
                        <TextBlock Text="ACTIVE AREA" Classes="TabTitle" />
                        <TextBlock Text="The highlighted region is the part of your tablet that's currently mapped to the screen. It's sized automatically to match the selected display's proportions, so pen movement isn't stretched or squashed."
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="0,6,0,10" TextWrapping="Wrap" />

                        <!-- Diagram + stats when we have digitizer specs. -->
                        <StackPanel IsVisible="{Binding TabletArea, Converter={x:Static conv:ObjectConverters.IsNotNull}}">
                            <!-- Unit toggle for the length read-outs below (display-only; OTD works in mm). -->
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right"
                                        Margin="0,0,0,6" VerticalAlignment="Center">
                                <TextBlock Text="Units:" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextMutedBrush}" />
                                <ToggleSwitch IsChecked="{Binding UseImperialUnits}" MinWidth="0"
                                              OnContent="Inches" OffContent="Millimeters"
                                              ToolTip.Tip="Switch the active-area measurements between metric and imperial"
                                              VerticalAlignment="Center" />
                            </StackPanel>
                            <ctrl:ActiveAreaDiagram x:Name="ActiveAreaDiagramControl"
                                                    Area="{Binding TabletArea}"
                                                    AccentBrush="{DynamicResource AccentBrush}"
                                                    UseImperialUnits="{Binding UseImperialUnits}"
                                                    Editable="True" Height="320" />

                            <!-- Proportional resize + maximize (#199). Drag the area / a corner on the
                                 diagram above; this slider is the same size control, for precision. -->
                            <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12" Margin="0,10,0,0">
                                <TextBlock Grid.Column="0" Text="Size" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextMutedBrush}" />
                                <Slider Grid.Column="1" Minimum="10" Maximum="100"
                                        Value="{Binding ActiveAreaSizePercent}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" Text="{Binding ActiveAreaSizePercent, StringFormat={}{0:0}%}"
                                           MinWidth="38" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                <Button Grid.Column="3" Content="Maximize"
                                        Command="{Binding MaximizeActiveAreaCommand}"
                                        Theme="{StaticResource GhostButton}" Padding="12,6" />
                            </Grid>
                            <TextBlock Text="Drag the highlighted area to move it, or drag a corner to resize — the shape stays locked to your display."
                                       Margin="0,8,0,0" TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextMutedBrush}" />

                            <Grid ColumnDefinitions="*,*,*,*" Margin="0,12,0,0">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="{Binding ActiveAreaUsagePercentText}" FontSize="20" FontWeight="Bold"
                                               Foreground="{DynamicResource AccentBrush}" />
                                    <TextBlock Text="of tablet area used" TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextMutedBrush}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="{Binding ActiveAreaDimsPercentText}" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <TextBlock Text="width × height" TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextMutedBrush}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="2">
                                    <TextBlock Text="{Binding ActiveAreaUsedText}" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <TextBlock Text="active area" TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextMutedBrush}" />
                                </StackPanel>
                                <StackPanel Grid.Column="3" Spacing="2">
                                    <TextBlock Text="{Binding ActiveAreaFullText}" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <TextBlock Text="full tablet area" TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextMutedBrush}" />
                                </StackPanel>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,12,0,0">
                                <TextBlock Text="Diagonal:" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                <TextBlock Text="{Binding ActiveAreaDiagonalText}"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>

                        <!-- No digitizer specs for this tablet — nothing to draw. -->
                        <TextBlock Text="Active-area details aren't available for this tablet."
                                   Margin="0,4,0,0" TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   IsVisible="{Binding TabletArea, Converter={x:Static conv:ObjectConverters.IsNull}}" />
                    </StackPanel>
                </Border>

                <!-- Rotation (#199): rotate the active area to match physically turning the tablet.
                     180° = buttons on the other side; 90°/270° = portrait, which shrinks the active area
                     to the largest that fits the tablet once rotated (keeps the display filled, undistorted).
                     IsChecked is OneWay — the change is driven by the Command. -->
                <Border Classes="GlassPanel" Margin="0,12,0,0" IsVisible="{Binding HasAreaMapping}">
                    <StackPanel>
                        <TextBlock Text="ROTATION" Classes="SectionLabel" />
                        <TextBlock Text="Rotate the active area to match how you physically turn the tablet — 180° to put the express keys on the opposite side, or 90°/270° for portrait. The display stays filled and undistorted; for portrait the active area shrinks to fit the tablet once rotated."
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="0,6,0,10" TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Spacing="18">
                            <RadioButton GroupName="AreaRotation" Content="None"
                                         IsChecked="{Binding IsRotation0, Mode=OneWay}"
                                         Command="{Binding SetRotationCommand}" CommandParameter="0" />
                            <RadioButton GroupName="AreaRotation" Content="90°"
                                         IsChecked="{Binding IsRotation90, Mode=OneWay}"
                                         Command="{Binding SetRotationCommand}" CommandParameter="90" />
                            <RadioButton GroupName="AreaRotation" Content="180°"
                                         IsChecked="{Binding IsRotation180, Mode=OneWay}"
                                         Command="{Binding SetRotationCommand}" CommandParameter="180" />
                            <RadioButton GroupName="AreaRotation" Content="270°"
                                         IsChecked="{Binding IsRotation270, Mode=OneWay}"
                                         Command="{Binding SetRotationCommand}" CommandParameter="270" />
                        </StackPanel>
                        <TextBlock Text="After rotating, re-run calibration if you use it — the mapping changed."
                                   FontStyle="Italic" Margin="0,10,0,0" TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextMutedBrush}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Calibration tab content (#252). -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto"
                      IsVisible="{Binding #CalibrationTab.IsChecked}">
            <StackPanel MaxWidth="900" HorizontalAlignment="Left" IsVisible="{Binding HasAreaMapping}">
                <TextBlock Text="CALIBRATION" Classes="TabTitle" />
                <TextBlock Text="Correct where the pen lands vs. where you see it (Absolute mode only). Choose a density, then tap the targets on screen."
                           Foreground="{DynamicResource TextMutedBrush}"
                           Margin="0,6,0,12" TextWrapping="Wrap" />

                <!-- Current calibration status card — sits before the density options so the user sees
                     the current state (and can clear it) first. Leads with which display the calibration
                     overlay pops up on (the tablet's mapped display), so the user knows where to look;
                     this line used to be a separate accent box above the card (folded in, #500). -->
                <Border Classes="GlassPanel" Margin="0,0,0,12" IsVisible="{Binding CanCalibrate}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="{Binding CalibrationDisplayText}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBrush}" TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="{Binding CalibrationStatusText}" FontWeight="SemiBold"
                                       VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <ToggleSwitch IsChecked="{Binding CalibrationEnabled}" IsVisible="{Binding HasCalibration}"
                                          OnContent="On" OffContent="Off" VerticalAlignment="Center" MinWidth="0"
                                          ToolTip.Tip="Turn the calibration correction on or off without clearing it — to compare with and without." />
                            <Button Content="View report" Click="OnViewCalibrationReport" IsVisible="{Binding HasCalibrationReport}"
                                    Theme="{StaticResource GhostButton}" Padding="10,4" VerticalAlignment="Center"
                                    ToolTip.Tip="See the recorded points, fit quality and natural tilt from the last calibration" />
                            <Button Content="Clear calibration" Command="{Binding ClearCalibrationCommand}" IsVisible="{Binding CanClearCalibration}"
                                    Theme="{StaticResource GhostButton}" Padding="10,4" VerticalAlignment="Center"
                                    ToolTip.Tip="Remove the calibration entirely and return the pointer to its uncorrected default" />
                        </StackPanel>
                        <TextBlock Text="This tablet's calibration was made for a different display mapping — recalibrate to keep it accurate."
                                   Foreground="{DynamicResource WarningBrush}" TextWrapping="Wrap"
                                   IsVisible="{Binding CalibrationStale}" />
                    </StackPanel>
                </Border>

                <!-- One card per calibration density; START begins that mode. The card of the calibration
                     currently in use gets an accent outline + "In use" badge. Equal-size cards
                     (UniformGrid); the START button sits directly below the diagram with the explanatory
                     text last, so the button is at a consistent height across the cards. -->
                <UniformGrid Columns="3" IsVisible="{Binding CanCalibrate}">
                    <Border MaxWidth="280" Margin="0,0,12,12" Classes="GlassPanel" Classes.calCurrent="{Binding IsCurrent4Point}">
                        <StackPanel Spacing="10">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="4 points" Classes="CardTitle" VerticalAlignment="Center" />
                                <Border Grid.Column="1" Classes="calBadge" IsVisible="{Binding IsCurrent4Point}"><TextBlock Text="In use" /></Border>
                            </Grid>
                            <ctrl:CalibrationDots Points="4" Width="130" Height="80" HorizontalAlignment="Center" DotBrush="{DynamicResource AccentBrush}" />
                            <Button Content="START" Command="{Binding StartCalibrationCommand}" CommandParameter="{Binding CalibrationModeChoices[0]}"
                                    IsEnabled="{Binding CanRunCalibration}" HorizontalAlignment="Stretch"
                                    Theme="{StaticResource AccentButton}" Padding="14,7" />
                            <TextBlock Text="Recommended — best for most setups." TextWrapping="Wrap" TextAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                    <Border MaxWidth="280" Margin="0,0,12,12" Classes="GlassPanel" Classes.calCurrent="{Binding IsCurrent9Point}">
                        <StackPanel Spacing="10">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="9 points" Classes="CardTitle" VerticalAlignment="Center" />
                                <Border Grid.Column="1" Classes="calBadge" IsVisible="{Binding IsCurrent9Point}"><TextBlock Text="In use" /></Border>
                            </Grid>
                            <ctrl:CalibrationDots Points="9" Width="130" Height="80" HorizontalAlignment="Center" DotBrush="{DynamicResource AccentBrush}" />
                            <Button Content="START" Command="{Binding StartCalibrationCommand}" CommandParameter="{Binding CalibrationModeChoices[1]}"
                                    IsEnabled="{Binding CanRunCalibration}" HorizontalAlignment="Stretch"
                                    Theme="{StaticResource AccentButton}" Padding="14,7" />
                            <TextBlock Text="More taps for a steadier fit — try if 4-point feels slightly off." TextWrapping="Wrap" TextAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                    <Border MaxWidth="280" Margin="0,0,12,12" Classes="GlassPanel" Classes.calCurrent="{Binding IsCurrent25Point}">
                        <StackPanel Spacing="10">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="25 points" Classes="CardTitle" VerticalAlignment="Center" />
                                <Border Grid.Column="1" Classes="calBadge" IsVisible="{Binding IsCurrent25Point}"><TextBlock Text="In use" /></Border>
                            </Grid>
                            <ctrl:CalibrationDots Points="25" Width="130" Height="80" HorizontalAlignment="Center" DotBrush="{DynamicResource AccentBrush}" />
                            <Button Content="START" Command="{Binding StartCalibrationCommand}" CommandParameter="{Binding CalibrationModeChoices[2]}"
                                    IsEnabled="{Binding CanRunCalibration}" HorizontalAlignment="Stretch"
                                    Theme="{StaticResource AccentButton}" Padding="14,7" />
                            <TextBlock Text="The most taps — the steadiest fit for a finicky tablet." TextWrapping="Wrap" TextAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <TextBlock Text="Calibration is available in Absolute mode." Foreground="{DynamicResource TextMutedBrush}"
                           Margin="0,4,0,0" IsVisible="{Binding !CanCalibrate}" />
                <TextBlock Text="Connect this tablet to calibrate." Foreground="{DynamicResource TextMutedBrush}"
                           Margin="0,8,0,0" IsVisible="{Binding ShowConnectToCalibrateHint}" />
            </StackPanel>
        </ScrollViewer>

        <!-- Pen Switches tab: reflowing rows — pen tip + eraser · a horizontal pen (tip to the left) ·
             the buttons. Cards wrap when the window is narrow, so the layout survives resizing.
             Data-driven: only the buttons this pen actually has appear (in the graphic and as cards). -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto"
                      IsVisible="{Binding #PenTipTab.IsChecked}" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="16" HorizontalAlignment="Center" Margin="0,4,0,0">
                    <TextBlock Text="PEN INPUTS" Classes="TabTitle" HorizontalAlignment="Center" />
                    <!-- Horizontal pen (tip left → eraser right) at the top of the page (#494 follow-up),
                         matching the Pen Buttons tab. Decorative; no connectors. Canvas is 400×80. Eraser
                         is drawn first (lowest z) so the barrel end overlaps its left edge. -->
                    <Viewbox MaxWidth="440" MaxHeight="86" HorizontalAlignment="Center">
                        <Canvas Width="400" Height="80">
                            <!-- eraser nub (right) — first = lowest z, so the barrel end covers its left edge -->
                            <Rectangle Canvas.Left="342" Canvas.Top="31" Width="26" Height="18" RadiusX="6" RadiusY="6"
                                       Fill="{DynamicResource PenDiagramFillBrush}" Stroke="{DynamicResource PenDiagramStrokeBrush}" StrokeThickness="1.5" />
                            <!-- tip nib (far left, under the cone) -->
                            <Rectangle Canvas.Left="14" Canvas.Top="36" Width="20" Height="8" RadiusX="4" RadiusY="4"
                                       Fill="{DynamicResource PenDiagramFillBrush}" Stroke="{DynamicResource PenDiagramStrokeBrush}" StrokeThickness="1.5" />
                            <!-- tip cone (pointing left) -->
                            <Polygon Points="72,28 72,52 26,45 26,35" Fill="{DynamicResource PenDiagramFillBrush}"
                                     Stroke="{DynamicResource PenDiagramStrokeBrush}" StrokeThickness="1.5" StrokeJoin="Round" />
                            <!-- barrel -->
                            <Rectangle Canvas.Left="70" Canvas.Top="28" Width="287" Height="24"
                                       Fill="{DynamicResource PenDiagramFillBrush}" Stroke="{DynamicResource PenDiagramStrokeBrush}" StrokeThickness="1.5" />
                            <!-- side buttons, clustered toward the tip (left) -->
                            <Rectangle Canvas.Left="97" Canvas.Top="32" Width="25" Height="16" RadiusX="6" RadiusY="6"
                                       Fill="{DynamicResource PenDiagramButtonFillBrush}" Stroke="{DynamicResource PenDiagramStrokeBrush}" StrokeThickness="1.5"
                                       IsVisible="{Binding PenButton1Row, Converter={x:Static conv:ObjectConverters.IsNotNull}}" />
                            <Rectangle Canvas.Left="131" Canvas.Top="32" Width="25" Height="16" RadiusX="6" RadiusY="6"
                                       Fill="{DynamicResource PenDiagramButtonFillBrush}" Stroke="{DynamicResource PenDiagramStrokeBrush}" StrokeThickness="1.5"
                                       IsVisible="{Binding PenButton2Row, Converter={x:Static conv:ObjectConverters.IsNotNull}}" />
                            <Rectangle Canvas.Left="165" Canvas.Top="32" Width="25" Height="16" RadiusX="6" RadiusY="6"
                                       Fill="{DynamicResource PenDiagramButtonFillBrush}" Stroke="{DynamicResource PenDiagramStrokeBrush}" StrokeThickness="1.5"
                                       IsVisible="{Binding PenButton3Row, Converter={x:Static conv:ObjectConverters.IsNotNull}}" />
                        </Canvas>
                    </Viewbox>

                    <!-- Pen tip + eraser -->
                    <WrapPanel HorizontalAlignment="Center">
                        <views:PenSwitchCard Margin="6" DataContext="{Binding PenTipRow}" />
                        <views:PenSwitchCard Margin="6" DataContext="{Binding PenEraserRow}" />
                    </WrapPanel>

                    <!-- Pen barrel buttons moved to their own PEN BUTTONS tab (#494); Binary pressure moved
                         to Pressure Dynamics and Disable tilt to the Tilt Dynamics tab (#494 follow-up). -->
                    <Border Classes="GlassPanel" MaxWidth="560" HorizontalAlignment="Center">
                        <StackPanel Spacing="10">
                            <TextBlock Text="PEN INPUT" Classes="SectionLabel" />
                            <!-- #493: the tip is a binding, not a driver flag — "disable" clears TipButton
                                 and stashes it so it comes back when turned off. -->
                            <ctrl:ToggleSetting Label="Disable pen tip" InlineDescription="True"
                                                Description="Tapping does nothing; your tip binding returns when off."
                                                IsChecked="{Binding DisablePenTip}" />
                            <!-- Drag bindings hidden for now (#492); the binding + apply wiring stays.
                                 Re-enable by flipping IsVisible to True. -->
                            <ctrl:ToggleSetting Label="Drag bindings" IsVisible="False"
                                                Description="Pen button bindings only work while the pen is touching the tablet (drag-only), not while hovering."
                                                IsChecked="{Binding DragBindingsEnabled}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
        </ScrollViewer>

        <!-- Pen Buttons tab (#494): the pen's own barrel buttons, split out of PEN INPUTS. Only the
             buttons this pen actually has appear. The tab itself is hidden when the pen has none. -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto"
                      IsVisible="{Binding #PenBarrelTab.IsChecked}" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="16" HorizontalAlignment="Center" Margin="0,4,0,0">
                    <TextBlock Text="PEN BUTTONS" Classes="TabTitle" HorizontalAlignment="Center" />
                    <TextBlock Text="The buttons on the side of the pen. Set what each one does."
                               Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"
                               HorizontalAlignment="Center" TextAlignment="Center" MaxWidth="440" />

                    <!-- Horizontal pen (tip left → eraser right); the side buttons light up for the ones
                         this pen has, matching the cards below. -->
                    <Viewbox MaxWidth="440" MaxHeight="86" HorizontalAlignment="Center">
                        <Canvas Width="400" Height="80">
                            <Rectangle Canvas.Left="342" Canvas.Top="31" Width="26" Height="18" RadiusX="6" RadiusY="6"
                                       Fill="{DynamicResource PenDiagramFillBrush}" Stroke="{DynamicResource PenDiagramStrokeBrush}" StrokeThickness="1.5" />
                            <Rectangle Canvas.Left="14" Canvas.Top="36" Width="20" Height="8" RadiusX="4" RadiusY="4"
                                       Fill="{DynamicResource PenDiagramFillBrush}" Stroke="{DynamicResource PenDiagramStrokeBrush}" StrokeThickness="1.5" />
                            <Polygon Points="72,28 72,52 26,45 26,35" Fill="{DynamicResource PenDiagramFillBrush}"
                                     Stroke="{DynamicResource PenDiagramStrokeBrush}" StrokeThickness="1.5" StrokeJoin="Round" />
                            <Rectangle Canvas.Left="70" Canvas.Top="28" Width="287" Height="24"
                                       Fill="{DynamicResource PenDiagramFillBrush}" Stroke="{DynamicResource PenDiagramStrokeBrush}" StrokeThickness="1.5" />
                            <!-- side buttons, clustered toward the tip (left); accent-filled to read as the focus -->
                            <Rectangle Canvas.Left="97" Canvas.Top="32" Width="25" Height="16" RadiusX="6" RadiusY="6"
                                       Fill="{DynamicResource AccentBrush}" Stroke="{DynamicResource PenDiagramStrokeBrush}" StrokeThickness="1.5"
                                       IsVisible="{Binding PenButton1Row, Converter={x:Static conv:ObjectConverters.IsNotNull}}" />
                            <Rectangle Canvas.Left="131" Canvas.Top="32" Width="25" Height="16" RadiusX="6" RadiusY="6"
                                       Fill="{DynamicResource AccentBrush}" Stroke="{DynamicResource PenDiagramStrokeBrush}" StrokeThickness="1.5"
                                       IsVisible="{Binding PenButton2Row, Converter={x:Static conv:ObjectConverters.IsNotNull}}" />
                            <Rectangle Canvas.Left="165" Canvas.Top="32" Width="25" Height="16" RadiusX="6" RadiusY="6"
                                       Fill="{DynamicResource AccentBrush}" Stroke="{DynamicResource PenDiagramStrokeBrush}" StrokeThickness="1.5"
                                       IsVisible="{Binding PenButton3Row, Converter={x:Static conv:ObjectConverters.IsNotNull}}" />
                        </Canvas>
                    </Viewbox>

                    <WrapPanel HorizontalAlignment="Center">
                        <views:PenSwitchCard Margin="6" DataContext="{Binding PenButton1Row}"
                                             IsVisible="{Binding $parent[WrapPanel].DataContext.PenButton1Row, Converter={x:Static conv:ObjectConverters.IsNotNull}}" />
                        <views:PenSwitchCard Margin="6" DataContext="{Binding PenButton2Row}"
                                             IsVisible="{Binding $parent[WrapPanel].DataContext.PenButton2Row, Converter={x:Static conv:ObjectConverters.IsNotNull}}" />
                        <views:PenSwitchCard Margin="6" DataContext="{Binding PenButton3Row}"
                                             IsVisible="{Binding $parent[WrapPanel].DataContext.PenButton3Row, Converter={x:Static conv:ObjectConverters.IsNotNull}}" />
                    </WrapPanel>
                </StackPanel>
        </ScrollViewer>

        <!-- ExpressKeys tab content: one card per auxiliary button. -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto"
                      IsVisible="{Binding #PenButtonsTab.IsChecked}">
            <StackPanel>
                <!-- Header: title + master enable toggle and clear-all (when there are buttons). -->
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12" Margin="0,0,0,8">
                    <TextBlock Grid.Column="0" Text="TABLET BUTTONS" Classes="TabTitle" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                                VerticalAlignment="Center" IsVisible="{Binding ShowAuxControls}">
                        <TextBlock Text="Buttons enabled" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <ToggleSwitch IsChecked="{Binding AuxButtonsEnabled}" OnContent="" OffContent=""
                                      MinWidth="0" VerticalAlignment="Center"
                                      ToolTip.Tip="Turn all express keys on or off. Your mappings are kept and restored when you turn them back on." />
                    </StackPanel>
                    <Button Grid.Column="2" Content="Clear all" Command="{Binding ClearAuxButtonsCommand}"
                            IsVisible="{Binding ShowAuxControls}"
                            ToolTip.Tip="Remove every express-key mapping"
                            Theme="{StaticResource GhostButton}" Padding="12,6"
                            VerticalAlignment="Center" />
                </Grid>

                <!-- Two columns (at most), each card ~half the pane so more buttons fit while staying
                     comfortably wide. Each item is wrapped so the inter-column gutter can be set directly
                     on the wrapper (a style on the generated container isn't reliably applied); the shared
                     card template supplies the vertical gap between rows. -->
                <ItemsControl ItemsSource="{Binding AuxButtons}" IsVisible="{Binding !NoAuxButtons}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ContentControl Content="{Binding}" ContentTemplate="{StaticResource ButtonBindingCard}"
                                            Margin="0,0,16,0" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty state when the tablet has no auxiliary buttons. -->
                <Border Classes="GlassPanel" IsVisible="{Binding NoAuxButtons}">
                    <TextBlock Text="No auxiliary buttons configured"
                               Foreground="{DynamicResource TextMutedBrush}" />
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Wheel tab content: per-wheel rotation bindings (CW/CCW) + sensitivity, wheel buttons, and a
             master enable / clear-all. Reuses the ExpressKeys binding-editor card. Only shown when the
             tablet reports a wheel. -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto"
                      IsVisible="{Binding #WheelTab.IsChecked}">
            <StackPanel>
                <!-- Header: label + master enable toggle + clear-all (parity with ExpressKeys). -->
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12" Margin="0,0,0,8">
                    <TextBlock Grid.Column="0" Text="WHEELS" Classes="TabTitle" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                                VerticalAlignment="Center" IsVisible="{Binding ShowWheelControls}">
                        <TextBlock Text="Wheel enabled" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <ToggleSwitch IsChecked="{Binding WheelEnabled}" OnContent="" OffContent=""
                                      MinWidth="0" VerticalAlignment="Center"
                                      ToolTip.Tip="Turn all wheel bindings on or off. Your mappings are kept and restored when you turn them back on." />
                    </StackPanel>
                    <Button Grid.Column="2" Content="Clear all" Command="{Binding ClearWheelBindingsCommand}"
                            IsVisible="{Binding ShowWheelControls}"
                            ToolTip.Tip="Remove every wheel binding"
                            Theme="{StaticResource GhostButton}" Padding="12,6"
                            VerticalAlignment="Center" />
                </Grid>

                <TextBlock Text="Bind an action to each direction the wheel turns, plus its button. Sensitivity sets how far you turn before the action repeats."
                           Foreground="{DynamicResource TextMutedBrush}"
                           Margin="0,0,0,10" TextWrapping="Wrap" />

                <!-- One card per wheel: the live gauge on the left, and every mapping for that wheel
                     (clockwise + counter-clockwise actions with sensitivity, and the wheel button)
                     grouped on the right — so a wheel is a single self-contained unit (#310). -->
                <ItemsControl ItemsSource="{Binding Wheels}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Classes="GlassPanel" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}" Classes="SectionLabel"
                                               IsVisible="{Binding ShowTitle}" Margin="0,0,0,10" />

                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="18">
                                        <!-- Live gauge: marker + fading trail + current angle. -->
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <ctrl:WheelGauge Position="{Binding LivePosition}"
                                                             TurningClockwise="{Binding TurningClockwise}"
                                                             TurningCounterClockwise="{Binding TurningCounterClockwise}"
                                                             AccentBrush="{DynamicResource AccentBrush}"
                                                             Width="132" Height="132" HorizontalAlignment="Center" />
                                            <TextBlock Text="{Binding StepInfo}"
                                                       IsVisible="{Binding HasStepInfo}"
                                                       HorizontalAlignment="Center" TextAlignment="Center"
                                                       MaxWidth="150" TextWrapping="Wrap"
                                                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0" />
                                        </StackPanel>

                                        <!-- All mappings for this wheel. -->
                                        <StackPanel Grid.Column="1" MinWidth="0">
                                            <!-- Clockwise: binding card + sensitivity. -->
                                            <ContentControl Content="{Binding Clockwise}"
                                                            ContentTemplate="{StaticResource ButtonBindingCard}" />
                                            <ctrl:LabeledSlider Label="Sensitivity" LabelWidth="72" Margin="12,0,2,10"
                                                                Minimum="{Binding ThresholdMin}" Maximum="{Binding ThresholdMax}"
                                                                TickFrequency="{Binding ThresholdTick}" IsSnapToTickEnabled="True"
                                                                IsEnabled="{Binding CanEdit}"
                                                                Value="{Binding ClockwiseThreshold}"
                                                                ValueTextOverride="{Binding ClockwiseThresholdText}"
                                                                Monospace="True" ValueWidth="130" />

                                            <!-- Counter-clockwise: binding card + sensitivity. -->
                                            <ContentControl Content="{Binding CounterClockwise}"
                                                            ContentTemplate="{StaticResource ButtonBindingCard}" />
                                            <ctrl:LabeledSlider Label="Sensitivity" LabelWidth="72" Margin="12,0,2,10"
                                                                Minimum="{Binding ThresholdMin}" Maximum="{Binding ThresholdMax}"
                                                                TickFrequency="{Binding ThresholdTick}" IsSnapToTickEnabled="True"
                                                                IsEnabled="{Binding CanEdit}"
                                                                Value="{Binding CounterClockwiseThreshold}"
                                                                ValueTextOverride="{Binding CounterClockwiseThresholdText}"
                                                                Monospace="True" ValueWidth="130" />

                                            <!-- Wheel button(s). -->
                                            <ItemsControl ItemsSource="{Binding Buttons}" IsVisible="{Binding HasButtons}"
                                                          ItemTemplate="{StaticResource ButtonBindingCard}" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Pressure Dynamics tab content: the pressure curve + pressure smoothing + the curve/smooth order. -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto"
                      IsVisible="{Binding #PressureDynamicsTab.IsChecked}">
            <StackPanel IsEnabled="{Binding CanEditPressure}">
                <!-- Header row: title + reset. There's no On/Off — the filter is always enabled internally;
                     you neutralize it with a linear curve and zero smoothing. -->
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" Margin="2,2,2,4">
                    <TextBlock Grid.Column="0" Text="PRESSURE DYNAMICS" Classes="TabTitle" VerticalAlignment="Center" />
                    <Button Grid.Column="1" Content="Reset" Command="{Binding ResetPressureDynamicsCommand}"
                            Theme="{StaticResource GhostButton}" Padding="12,5" VerticalAlignment="Center"
                            ToolTip.Tip="Reset the curve, pressure smoothing, and order to their no-op defaults" />
                </Grid>

                <!-- Binary pressure (#494, moved here from Pen Inputs): a flat on/off contact that drops
                     pressure entirely, so the curve below is inert while it's on. -->
                <ctrl:ToggleSetting Label="Binary pressure" InlineDescription="True" Margin="2,2,0,6"
                                    Description="Flat on/off contact — ignores the curve below."
                                    IsChecked="{Binding DisablePressure}" />

                <!-- #469: when Binary pressure is on the output stage drops pressure, so this curve has no
                     effect. Flag it here so the tab isn't silently inert. -->
                <Border Background="{DynamicResource WarningMutedBrush}" BorderBrush="{DynamicResource WarningBrush}"
                        BorderThickness="1" CornerRadius="6" Padding="10,7" Margin="0,4,0,8"
                        IsVisible="{Binding PressureDisabledNote}">
                    <TextBlock Text="Binary pressure is on, so this curve has no effect right now. Turn it off above to use the curve."
                               Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
                </Border>

                <!-- Live status: whether the current settings actually change pressure. -->
                <TextBlock Text="{Binding PressureDynamicsStatusText}" TextWrapping="Wrap"
                           Margin="2,0,2,12" Foreground="{DynamicResource TextMutedBrush}" />

                <StackPanel>

                    <!-- Pressure curve: chart + presets + softness + dead zone + node read-outs -->
                    <Border Classes="GlassPanel" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="PRESSURE CURVE" Classes="SectionLabel" />

                            <!-- Two columns: compact chart on the left, controls on the right. -->
                            <Grid ColumnDefinitions="Auto,*" Margin="0,8,0,0">
                                <!-- Compact 1:1 chart; the green dot tracks live pen pressure (#102). -->
                                <ctrl:PressureCurveChart Grid.Column="0" Curve="{Binding Curve, Mode=TwoWay}"
                                                         LivePressure="{Binding LivePressure}"
                                                         Width="180" Height="180"
                                                         VerticalAlignment="Top" Margin="0,0,16,0" />

                                <StackPanel Grid.Column="1">
                                    <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,8">
                                        <TextBlock Grid.Column="0" Text="Presets" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" Width="70" />
                                        <WrapPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Content="Linear" Command="{Binding ApplyPresetCommand}" CommandParameter="linear"
                                                    Theme="{StaticResource GhostButton}" Padding="12,5" Margin="0,0,6,4" />
                                            <Button Content="Soft" Command="{Binding ApplyPresetCommand}" CommandParameter="soft"
                                                    Theme="{StaticResource GhostButton}" Padding="12,5" Margin="0,0,6,4" />
                                            <Button Content="Firm" Command="{Binding ApplyPresetCommand}" CommandParameter="firm"
                                                    Theme="{StaticResource GhostButton}" Padding="12,5" Margin="0,0,6,4" />
                                            <Button Content="Reset" Command="{Binding ResetCurveCommand}"
                                                    Theme="{StaticResource GhostButton}" Padding="12,5" Margin="0,0,0,4"
                                                    ToolTip.Tip="Reset the curve to the linear default" />
                                        </WrapPanel>
                                    </Grid>

                                    <!-- Capped at ±0.95 (±1.0 is mathematically degenerate); the end ticks
                                         sit at the slider ends so the marks read as -1/-0.5/0/0.5/1. -->
                                    <ctrl:LabeledSlider Label="Softness" LabelWidth="70" Margin="0,0,0,8"
                                                        Minimum="-0.95" Maximum="0.95"
                                                        Ticks="-0.95,-0.5,0,0.5,0.95" TickPlacement="BottomRight"
                                                        Value="{Binding Softness}" ValueTextOverride="{Binding SoftnessText}"
                                                        Monospace="True" ValueWidth="40"
                                                        ToolTip.Tip="Positive = lighter touch (concave) · Negative = firmer (convex)" />

                                    <CheckBox Content="Cut below input minimum (dead zone)"
                                              IsChecked="{Binding CutBelowMinimum}" Margin="0,0,0,8"
                                              Foreground="{DynamicResource TextSecondaryBrush}"
                                              ToolTip.Tip="Below the input minimum, produce zero output (a dead zone) instead of holding at the output minimum." />

                                    <Grid ColumnDefinitions="Auto,*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Input" Classes="SectionLabel"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Output" Classes="SectionLabel"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Min node" Width="70"
                                                   VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding InputMinimumText}"
                                                   FontFamily="{DynamicResource MonoFontFamily}" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" />
                                        <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding OutputMinimumText}"
                                                   FontFamily="{DynamicResource MonoFontFamily}" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" />
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Max node" Width="70"
                                                   VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding InputMaximumText}"
                                                   FontFamily="{DynamicResource MonoFontFamily}" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" />
                                        <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding OutputMaximumText}"
                                                   FontFamily="{DynamicResource MonoFontFamily}" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" />
                                        <!-- Live row (#468): live input pressure + output after the curve. Green like the
                                             live dot; "—" when the pen is up. Debug the activation point, wrapping, grounding. -->
                                        <Border Grid.Row="3" Grid.ColumnSpan="3" Height="1" Margin="0,6,0,4"
                                                Background="{DynamicResource DividerBrush}" />
                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Live" Width="70"
                                                   VerticalAlignment="Center" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SuccessBrush}" />
                                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding LiveInputText}"
                                                   FontFamily="{DynamicResource MonoFontFamily}" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SuccessBrush}" />
                                        <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding LiveOutputText}"
                                                   FontFamily="{DynamicResource MonoFontFamily}" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SuccessBrush}" />
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Pressure smoothing (EMA) -->
                    <Border Classes="GlassPanel" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="PRESSURE SMOOTHING (JITTER REDUCTION)" Classes="SectionLabel"
                                       ToolTip.Tip="EMA smoothing of pressure — evens out pressure jitter, at a little lag." />
                            <ctrl:LabeledSlider Label="Pressure" LabelWidth="80" Margin="0,8,0,0"
                                                Minimum="0" Maximum="1"
                                                Ticks="0,0.25,0.5,0.75,0.9,1" TickPlacement="BottomRight"
                                                Value="{Binding PressureSmoothing}"
                                                ValueTextOverride="{Binding PressureSmoothingText}"
                                                Monospace="True" ValueWidth="44" />
                        </StackPanel>
                    </Border>

                    <!-- Order (compact one-row card): how the curve and pressure smoothing interleave. -->
                    <Border Classes="GlassPanel" Margin="0,0,0,10">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <TextBlock Grid.Column="0" Text="ORDER" Classes="SectionLabel" VerticalAlignment="Center"
                                       ToolTip.Tip="Whether pressure smoothing runs after the curve (default) or before it." />
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding SmoothAfterCurve}"
                                          OnContent="Curve → Smooth" OffContent="Smooth → Curve" VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Position Dynamics tab content: position smoothing (steadies wobbly lines). -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto"
                      IsVisible="{Binding #PositionDynamicsTab.IsChecked}">
            <StackPanel IsEnabled="{Binding CanEditPressure}">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" Margin="2,2,2,4">
                    <TextBlock Grid.Column="0" Text="POSITION DYNAMICS" Classes="TabTitle" VerticalAlignment="Center" />
                    <Button Grid.Column="1" Content="Reset" Command="{Binding ResetPositionDynamicsCommand}"
                            Theme="{StaticResource GhostButton}" Padding="12,5" VerticalAlignment="Center"
                            ToolTip.Tip="Turn position smoothing back off" />
                </Grid>

                <TextBlock Text="{Binding PositionDynamicsStatusText}" TextWrapping="Wrap"
                           Margin="2,0,2,12" Foreground="{DynamicResource TextMutedBrush}" />

                <Border Classes="GlassPanel" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="POSITION SMOOTHING (JITTER REDUCTION)" Classes="SectionLabel"
                                   ToolTip.Tip="EMA smoothing of the pen position — steadies wobbly lines, at a little lag." />
                        <!-- Capped at 0.25 (#487): heavier position smoothing is too laggy to be useful. -->
                        <ctrl:LabeledSlider Label="Position" LabelWidth="80" Margin="0,8,0,0"
                                            Minimum="0" Maximum="{Binding PositionSmoothingMax}"
                                            Ticks="0,0.05,0.1,0.15,0.2,0.25" TickPlacement="BottomRight"
                                            Value="{Binding PositionSmoothing}"
                                            ValueTextOverride="{Binding PositionSmoothingText}"
                                            Monospace="True" ValueWidth="44" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Tilt Dynamics tab (#494): tilt controls. For now just the disable toggle; a tilt curve /
             smoothing may join later, matching Pressure/Position Dynamics. Gated on the same host-can-
             apply flag as the other dynamics tabs. -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto"
                      IsVisible="{Binding #TiltDynamicsTab.IsChecked}">
            <StackPanel IsEnabled="{Binding CanEditPressure}">
                <TextBlock Text="TILT DYNAMICS" Classes="TabTitle" Margin="2,2,2,4" />
                <TextBlock Text="How the pen's tilt is reported to your apps." TextWrapping="Wrap"
                           Margin="2,0,2,12" Foreground="{DynamicResource TextMutedBrush}" />

                <Border Classes="GlassPanel" Margin="0,0,0,10">
                    <StackPanel Spacing="10">
                        <TextBlock Text="TILT" Classes="SectionLabel" />
                        <!-- Moved here from Pen Inputs (#494). -->
                        <ctrl:ToggleSetting Label="Disable tilt" InlineDescription="True"
                                            Description="Apps receive no tilt from this tablet."
                                            IsChecked="{Binding DisableTilt}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Hover tab content (#188) -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto"
                      IsVisible="{Binding #HoverTab.IsChecked}">
            <StackPanel IsEnabled="{Binding CanEditHover}">
                <!-- Master On/Off header row. -->
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" Margin="2,2,2,10">
                    <TextBlock Grid.Column="0" Text="HOVER LIMIT" Classes="SectionLabel" VerticalAlignment="Center" />
                    <ToggleSwitch Grid.Column="1" VerticalAlignment="Center"
                                  OnContent="On" OffContent="Off"
                                  IsChecked="{Binding HoverLimitEnabled}" />
                </Grid>

                <Border Classes="GlassPanel" Margin="0,0,0,10"
                        IsEnabled="{Binding HoverLimitEnabled}" Opacity="{Binding HoverControlsOpacity}">
                    <StackPanel>
                        <TextBlock Text="Stops the cursor tracking once the pen lifts past this distance — useful to keep a raised pen from dragging the cursor. Drawing is unaffected."
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,10" />
                        <ctrl:LabeledSlider Label="Max hover" LabelWidth="80"
                                            Minimum="1" Maximum="{Binding HoverDistanceMax}"
                                            Value="{Binding MaxHoverDistance}"
                                            ValueTextOverride="{Binding MaxHoverDistanceText}"
                                            Monospace="True" ValueWidth="40"
                                            ToolTip.Tip="Lower = the cursor stops sooner as you lift the pen. Higher = allow more hover (255 = no limit)." />
                        <TextBlock Text="Hover distance is 0–255. Not all tablets report it — check the Diagnostics page for your tablet's live hover values to pick a limit."
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,10,0,0" />

                        <!-- Near-proximity gate (#311): track only in the tablet's close band (Wacom default). -->
                        <Border Height="1" Background="{DynamicResource GlassBorderBrush}" Margin="0,14,0,12" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Near proximity only"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                <TextBlock Text="Only track while the pen is close to the surface — matches Wacom's default hover range. Needs a tablet that reports proximity."
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextMutedBrush}" Margin="0,2,0,0" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" VerticalAlignment="Center" MinWidth="0"
                                          OnContent="" OffContent=""
                                          IsChecked="{Binding NearProximityOnly}" />
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Filters tab content: one card per filter on the profile. -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto"
                      IsVisible="{Binding #FiltersTab.IsChecked}">
            <StackPanel>
                <TextBlock Text="FILTERS" Classes="TabTitle" Margin="0,0,0,8" />

                <ItemsControl ItemsSource="{Binding Filters}" IsVisible="{Binding HasFilters}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Classes="GlassPanel" Padding="16,12" Margin="0,0,0,10">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       TextWrapping="Wrap" VerticalAlignment="Center" />
                                            <!-- Stale leftover from an older app/plugin name: inert, should be cleaned. -->
                                            <Border IsVisible="{Binding IsLegacy}"
                                                    Background="{DynamicResource WarningMutedBrush}" BorderBrush="{DynamicResource WarningBrush}" BorderThickness="1"
                                                    CornerRadius="4" Padding="6,1" VerticalAlignment="Center"
                                                    ToolTip.Tip="Left over from an older version. The driver has no plugin for this type, so it does nothing — it will be removed automatically.">
                                                <TextBlock Text="Legacy" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource WarningBrush}" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding FullPath}"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding StatusText}" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty state when the profile has no filters. -->
                <Border Classes="GlassPanel" IsVisible="{Binding !HasFilters}">
                    <TextBlock Text="No filters configured"
                               Foreground="{DynamicResource TextMutedBrush}" />
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- JSON tab content -->
        <Border Grid.Row="1" Grid.Column="1" Classes="GlassPanel"
                IsVisible="{Binding #JsonTab.IsChecked}">
            <TextBox Text="{Binding RawJson, Mode=OneWay}" IsReadOnly="True"
                     FontFamily="{DynamicResource MonoFontFamily}"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     Background="Transparent" BorderThickness="0"
                     TextWrapping="NoWrap"
                     AcceptsReturn="True" />
        </Border>
    </Grid>
</UserControl>
