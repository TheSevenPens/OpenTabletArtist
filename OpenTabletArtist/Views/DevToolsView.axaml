<UserControl x:Class="OpenTabletArtist.Views.DevToolsView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="using:OpenTabletArtist.Controls">

    <!-- DataContext is the DevToolsViewModel; the toggle binds to the shared DeveloperSettings singleton. -->
    <StackPanel MaxWidth="900" HorizontalAlignment="Left">
        <c:SettingCard Title="Developer tools">
            <c:ToggleSetting Label="Show the Developer tab"
                             Description="Adds a DEVELOPER tab to Settings with testing aids — induced warnings, the hidden Filters/JSON tablet tabs, config-error reproduction, and other advanced toggles. Off by default; for development only."
                             IsChecked="{Binding Settings.ShowDeveloperPage}" />
        </c:SettingCard>
    </StackPanel>
</UserControl>
