<UserControl x:Class="OpenTabletArtist.Views.AdvancedView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="using:OpenTabletArtist.Controls">

    <!-- The ADVANCED tabbed page. DataContext is the AdvancedViewModel (typed-nav DataTemplate, #15);
         the shared TabbedPageView renders the header + rail + content from its Tabs/SelectedContent. -->
    <c:TabbedPageView Title="ADVANCED" />
</UserControl>
