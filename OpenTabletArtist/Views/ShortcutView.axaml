<UserControl x:Class="OpenTabletArtist.Views.ShortcutView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="using:OpenTabletArtist.Controls">

    <!-- DataContext is the ShortcutViewModel. Moved out of the DEVELOPER page into SETTINGS. -->
    <StackPanel MaxWidth="900" HorizontalAlignment="Left">
        <c:SettingCard Title="Start-menu shortcut"
                       Description="Create a per-user Start-menu shortcut to this app. A dev build run from its build folder isn't a registered app; this registers it under its name (needed by desktop-automation / screenshot tooling).">
            <StackPanel Spacing="8">
                <Button Content="Create Start-menu shortcut"
                        Command="{Binding CreateStartMenuShortcutCommand}"
                        Theme="{StaticResource GhostButton}" Padding="12,6"
                        HorizontalAlignment="Left" />
                <TextBlock Text="{Binding ShortcutStatus}" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextMutedBrush}"
                           IsVisible="{Binding HasShortcutStatus}" />
            </StackPanel>
        </c:SettingCard>
    </StackPanel>
</UserControl>
