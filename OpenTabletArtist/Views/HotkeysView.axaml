<UserControl x:Class="OpenTabletArtist.Views.HotkeysView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="using:OpenTabletArtist.Controls">

    <!-- DataContext is the HotkeysViewModel — the SETTINGS > HOTKEYS tab (the tab rail supplies the title). -->
    <!-- Two columns: the tablet display-toggle hotkey on the left, preset-switching hotkeys on the right. -->
    <Grid ColumnDefinitions="*,*" ColumnSpacing="28">
        <!-- ── LEFT: tablet mapping (display toggle) ─────────────────────────────── -->
        <StackPanel Grid.Column="0" VerticalAlignment="Top">
        <c:Section Margin="0,0,0,24">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <StackPanel Grid.Column="0" VerticalAlignment="Center" MinWidth="0">
                    <TextBlock Classes="SectionLabel largetitle" Text="DISPLAY TOGGLE" TextWrapping="Wrap" />
                    <TextBlock Text="Moves the active tablet's area to the next monitor (wraps around)."
                               Foreground="{DynamicResource TextMutedBrush}"
                               TextWrapping="Wrap" Margin="0,2,0,0" />
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,6,0,0"
                                IsVisible="{Binding HasMonitorHotkey}">
                        <PathIcon Data="{StaticResource IconKeyboard}" Width="15" Height="15"
                                  VerticalAlignment="Center"
                                  Foreground="{DynamicResource AccentBrush}" />
                        <TextBlock Text="{Binding MonitorHotkeyDisplay}"
                                   FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}"
                                   VerticalAlignment="Center" />
                        <Button ToolTip.Tip="Clear hotkey"
                                AutomationProperties.Name="Clear hotkey"
                                Command="{Binding ClearMonitorHotkeyCommand}"
                                Theme="{StaticResource GhostButton}" Padding="6,4"
                                VerticalAlignment="Center">
                            <PathIcon Data="{StaticResource IconClose}" Width="10" Height="10" />
                        </Button>
                    </StackPanel>
                    <TextBlock Text="No hotkey assigned" FontStyle="Italic"
                               Foreground="{DynamicResource TextMutedBrush}" Margin="0,6,0,0"
                               IsVisible="{Binding !HasMonitorHotkey}" />
                </StackPanel>

                <Button Grid.Column="1" Content="Assign…" Theme="{StaticResource AccentButton}"
                        VerticalAlignment="Center" Padding="14,7"
                        Command="{Binding AssignMonitorHotkeyCommand}" />
            </Grid>
        </c:Section>
        </StackPanel>

        <!-- ── RIGHT: preset switching ───────────────────────────────────────────── -->
        <StackPanel Grid.Column="1" VerticalAlignment="Top">
        <TextBlock Classes="SectionLabel largetitle" Text="PRESET SWITCHING" Margin="2,0,0,8" />

        <ItemsControl ItemsSource="{Binding Snapshots}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <c:Entity Margin="0,0,0,10">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" MinWidth="0">
                                <TextBlock Classes="CardTitle" Text="{Binding Name}" TextWrapping="Wrap" />
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0"
                                            IsVisible="{Binding HasHotkey}">
                                    <PathIcon Data="{StaticResource IconKeyboard}" Width="15" Height="15"
                                              VerticalAlignment="Center"
                                              Foreground="{DynamicResource AccentBrush}" />
                                    <TextBlock Text="{Binding HotkeyDisplay}"
                                               FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}"
                                               VerticalAlignment="Center" />
                                    <Button ToolTip.Tip="Clear hotkey"
                                            AutomationProperties.Name="Clear hotkey"
                                            Command="{Binding $parent[ItemsControl].DataContext.ClearProfileHotkeyCommand}"
                                            CommandParameter="{Binding Name}"
                                            Theme="{StaticResource GhostButton}" Padding="6,4"
                                            VerticalAlignment="Center">
                                        <PathIcon Data="{StaticResource IconClose}" Width="10" Height="10" />
                                    </Button>
                                </StackPanel>
                                <TextBlock Text="No hotkey assigned" FontStyle="Italic"
                                           Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0"
                                           IsVisible="{Binding !HasHotkey}" />
                            </StackPanel>

                            <Button Grid.Column="1" Content="Assign…" Theme="{StaticResource GhostButton}"
                                    VerticalAlignment="Center" Padding="12,6"
                                    Command="{Binding $parent[ItemsControl].DataContext.AssignProfileHotkeyCommand}"
                                    CommandParameter="{Binding Name}" />
                        </Grid>
                    </c:Entity>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <c:Section Padding="24" IsVisible="{Binding !HasSnapshots}">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="No presets to bind" FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="Save a preset on the Presets page, then assign it a hotkey here."
                           Foreground="{DynamicResource TextMutedBrush}"
                           HorizontalAlignment="Center" TextAlignment="Center" Margin="0,6,0,0" />
            </StackPanel>
        </c:Section>
        </StackPanel>
    </Grid>
</UserControl>
