<UserControl x:Class="OpenTabletArtist.Views.TabletPageView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="using:Avalonia.Data.Converters">

    <UserControl.Styles>
        <!-- Status chip mirroring the detail view's: neutral grey when the selected tablet isn't detected,
             green when it is (#506). The page owns this header instead of the hosted detail view (#542). -->
        <Style Selector="Border.tabletStatusChip">
            <Setter Property="Background" Value="{DynamicResource NeutralBrush}" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="MinWidth" Value="104" />
        </Style>
        <Style Selector="Border.tabletStatusChip.connected">
            <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
        </Style>
        <!-- Status dot in the switcher dropdown rows. -->
        <Style Selector="Ellipse.statusDot">
            <Setter Property="Width" Value="9" />
            <Setter Property="Height" Value="9" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Fill" Value="{DynamicResource NeutralBrush}" />
        </Style>
        <Style Selector="Ellipse.statusDot.on">
            <Setter Property="Fill" Value="{DynamicResource SuccessBrush}" />
        </Style>
    </UserControl.Styles>

    <!-- DataContext is a TabletPageViewModel. The single TABLET page (#542): a switcher dropdown of every
         known tablet + the selected one's headerless detail view, or a placeholder when none is known. -->
    <Grid RowDefinitions="Auto,*" ColumnDefinitions="*">

        <!-- Header: [ TABLET / switcher dropdown ]  ................  [ chip ][ Refresh ][ Forget ].
             Kept tall (MinHeight) so the right-aligned actions clear the native caption buttons, the same
             way the detail view's two-line title does (#titlebar). Hidden when there's no tablet. -->
        <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,16" IsVisible="{Binding HasTablet}">
            <Grid ColumnDefinitions="*,Auto" MinHeight="56">
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                    <TextBlock Text="TABLET" Classes="SectionLabel" />
                    <ComboBox ItemsSource="{Binding Tablets}"
                              SelectedItem="{Binding SelectedTablet, Mode=TwoWay}"
                              MinWidth="260" HorizontalAlignment="Left"
                              ToolTip.Tip="Switch between your connected and remembered tablets">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse Classes="statusDot" Classes.on="{Binding IsDetected}" />
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <!-- Status + actions, bound to the currently-hosted tablet's detail VM. -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12"
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border Classes="tabletStatusChip" Classes.connected="{Binding Content.IsTabletDetected}">
                        <TextBlock Text="{Binding Content.DetectionText}" FontWeight="SemiBold" FontSize="12"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <Button Content="Refresh" Command="{Binding Content.RefreshCommand}"
                            ToolTip.Tip="Reload settings from daemon"
                            Theme="{StaticResource GhostButton}" Padding="12,6" />
                    <Button Content="Forget" Command="{Binding Content.ForgetCommand}"
                            IsVisible="{Binding Content.ShowForget}"
                            ToolTip.Tip="Remove this tablet's saved settings"
                            Theme="{StaticResource DeleteButton}" Padding="12,6" />
                </StackPanel>
            </Grid>
            <!-- When not detected, the chip just says "Not detected"; this line carries the fuller context. -->
            <TextBlock Text="{Binding Content.DetectionDetail}" FontStyle="Italic"
                       Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"
                       IsVisible="{Binding Content.DetectionDetail, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}}" />
        </StackPanel>

        <!-- The selected tablet's detail view (headerless — this page owns the header above). -->
        <ContentControl Grid.Row="1" Content="{Binding Content}" IsVisible="{Binding HasTablet}" />

        <!-- Placeholder when nothing is detected or remembered (#542). -->
        <Border Grid.Row="1" Classes="GlassPanel" Padding="28" VerticalAlignment="Top"
                IsVisible="{Binding !HasTablet}">
            <StackPanel Spacing="6" HorizontalAlignment="Left">
                <TextBlock Text="No tablet detected" FontSize="16" FontWeight="SemiBold" />
                <TextBlock Text="Connect a tablet and it will appear here — remembered tablets show up too."
                           Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" MaxWidth="520" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
