<UserControl x:Class="OpenTabletArtist.Views.TabletPageView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="using:Avalonia.Data.Converters">

    <UserControl.Styles>
        <!-- Status chip mirroring the detail view's: neutral grey when the selected tablet isn't detected,
             green when it is (#506). The page owns this header instead of the hosted detail view (#542). -->
        <Style Selector="Border.tabletStatusChip">
            <Setter Property="Background" Value="{DynamicResource NeutralBrush}" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="MinWidth" Value="104" />
        </Style>
        <Style Selector="Border.tabletStatusChip.connected">
            <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
        </Style>
        <!-- Status dot in the switcher dropdown rows. -->
        <Style Selector="Ellipse.statusDot">
            <Setter Property="Width" Value="9" />
            <Setter Property="Height" Value="9" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Fill" Value="{DynamicResource NeutralBrush}" />
        </Style>
        <Style Selector="Ellipse.statusDot.on">
            <Setter Property="Fill" Value="{DynamicResource SuccessBrush}" />
        </Style>
    </UserControl.Styles>

    <!-- DataContext is a TabletPageViewModel. The single TABLET page (#542): a switcher dropdown of every
         known tablet + the selected one's headerless detail view, or a placeholder when none is known. -->
    <Grid ColumnDefinitions="*">

        <!-- The selected tablet's detail view. It owns the toolbar row now (switcher · pivots · compact
             actions on one line), so this page just hosts it full-height — or the hero below when there's
             no tablet. -->
        <ContentControl Content="{Binding Content}" IsVisible="{Binding HasTablet}" />

        <!-- Placeholder when nothing is detected or remembered (#542): a quiet Zune hero straight over the
             sakura backdrop (no card), so the drifting petals read behind the big light headline. -->
        <StackPanel VerticalAlignment="Top" HorizontalAlignment="Left" Spacing="12"
                    Margin="4,24,0,0" IsVisible="{Binding !HasTablet}">
            <TextBlock Text="No tablet yet" FontFamily="{DynamicResource DisplayFontFamily}"
                       FontSize="36" FontWeight="Light" LetterSpacing="-0.3"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
            <TextBlock Text="Connect a tablet and it'll show up here — remembered tablets appear too."
                       FontSize="14" TextWrapping="Wrap" MaxWidth="540"
                       Foreground="{DynamicResource TextSecondaryBrush}" />
        </StackPanel>
    </Grid>
</UserControl>
