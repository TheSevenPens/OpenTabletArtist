<UserControl x:Class="OpenTabletArtist.Views.PenSwitchCard"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="using:OpenTabletArtist.Controls">

    <!-- One switch on the Pen Switches tab. DataContext is a PenSwitchRowViewModel, bound by the tab to
         a slot (Tip / Eraser / Button N). Same data/commands as the old list rows, laid out as a compact
         card that the rows layout flows into WrapPanels (tip + eraser, then the buttons). -->
    <!-- Adaptive is the only supported binding for pen switches — under Windows Ink (which OTA's output
         modes use) other binding types silently don't work (#495). So the card is a status read-out, with
         a single "Use Adaptive" fix when the switch has drifted onto something else. -->
    <Border Classes="GlassPanel" Padding="12,10" Width="240" HorizontalAlignment="Left">
        <StackPanel Spacing="6">
            <TextBlock Text="{Binding SectionLabel}" Classes="SectionLabel" />

            <TextBlock Text="{Binding BindingLabel}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap" />

            <c:StatusBadge Kind="Success" Text="Adaptive Binding — recommended"
                           IsVisible="{Binding IsRecommended}" />
            <c:StatusBadge Kind="Warning" Text="Not the recommended setting"
                           IsVisible="{Binding IsNotRecommended}" />

            <Button Content="Use Adaptive" Command="{Binding SetAutoCommand}"
                    IsVisible="{Binding ShowUseAdaptive}"
                    Theme="{StaticResource AccentButton}" Padding="12,5" HorizontalAlignment="Left"
                    ToolTip.Tip="Set this switch back to the recommended Adaptive Binding" />
        </StackPanel>
    </Border>
</UserControl>
