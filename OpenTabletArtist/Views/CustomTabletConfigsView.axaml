<UserControl x:Class="OpenTabletArtist.Views.CustomTabletConfigsView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="using:OpenTabletArtist.Controls">

    <!-- DataContext is the CustomTabletConfigsViewModel, supplied by the typed-nav DataTemplate (#15). -->
    <StackPanel MaxWidth="900" HorizontalAlignment="Left">
        <c:Section>
            <StackPanel>
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" MinWidth="0">
                        <TextBlock Classes="SectionLabel" Text="CONFIGURATIONS FOLDER" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding ConfigurationsDirectory}"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   TextTrimming="CharacterEllipsis" TextWrapping="Wrap" Margin="0,4,0,0" />
                    </StackPanel>
                    <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                        <Button Command="{Binding RefreshConfigurationsCommand}"
                                ToolTip.Tip="Reload list"
                                AutomationProperties.Name="Reload list"
                                Theme="{StaticResource GhostButton}" Width="34" Height="30" Padding="0"
                                HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                Margin="0,0,6,4">
                            <PathIcon Data="{StaticResource IconRefresh}" Width="16" Height="16"
                                      Foreground="{Binding $parent[Button].Foreground}" />
                        </Button>
                        <Button Theme="{StaticResource GhostButton}"
                                Command="{Binding OpenConfigurationsFolderCommand}"
                                ToolTip.Tip="Open the configurations folder in File Explorer"
                                AutomationProperties.Name="Open the configurations folder in File Explorer"
                                Width="34" Height="30" Padding="0"
                                HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                Margin="0,0,0,4">
                            <PathIcon Data="{StaticResource IconFolderOutline}" Width="16" Height="16"
                                      Foreground="{Binding $parent[Button].Foreground}" />
                        </Button>
                    </WrapPanel>
                </Grid>

                <!-- Empty state -->
                <TextBlock Text="No configurations in this folder."
                           FontStyle="Italic"
                           Foreground="{DynamicResource TextMutedBrush}"
                           Margin="0,12,0,0"
                           IsVisible="{Binding !HasConfigurations}" />

                <!-- Configurations list -->
                <ItemsControl ItemsSource="{Binding Configurations}"
                              Margin="0,12,0,0"
                              IsVisible="{Binding HasConfigurations}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource GlassBgBrush}"
                                    CornerRadius="0" Padding="12,8" Margin="0,0,0,6">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" MinWidth="0">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="{Binding FileName}"
                                                       Foreground="{DynamicResource TextMutedBrush}" />
                                            <TextBlock Text="  •  "
                                                       Foreground="{DynamicResource TextMutedBrush}" />
                                            <TextBlock Text="{Binding SizeText}"
                                                       Foreground="{DynamicResource TextMutedBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                                        <Button Content="View"
                                                Theme="{StaticResource GhostButton}"
                                                Command="{Binding $parent[ItemsControl].DataContext.ViewConfigurationCommand}"
                                                CommandParameter="{Binding Path}"
                                                Padding="10,4" Margin="0,0,6,4" />
                                        <Button Content="Delete"
                                                Theme="{StaticResource DeleteButton}"
                                                Command="{Binding $parent[ItemsControl].DataContext.DeleteConfigurationCommand}"
                                                CommandParameter="{Binding Path}"
                                                Padding="10,4" Margin="0,0,0,4" />
                                    </WrapPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </c:Section>

        <!-- #480: install approved tablet configs from OpenTabletDriver's repo that aren't bundled yet. -->
        <c:Section Margin="0,16,0,0">
            <StackPanel>
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" MinWidth="0">
                        <TextBlock Classes="SectionLabel" Text="ADD TABLET SUPPORT" TextWrapping="Wrap" />
                        <TextBlock Text="Install approved tablet configs from OpenTabletDriver that your version doesn't ship yet — useful for a newly-supported tablet."
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   TextWrapping="Wrap" Margin="0,4,0,0" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="Check for more configs"
                            VerticalAlignment="Center"
                            Command="{Binding FetchAvailableCommand}"
                            IsEnabled="{Binding !IsFetchingAvailable}"
                            Theme="{StaticResource GhostButton}" Padding="12,6" />
                </Grid>

                <TextBlock Text="{Binding AvailableStatus}" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextMutedBrush}"
                           Margin="0,10,0,0"
                           IsVisible="{Binding AvailableStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                <!-- Available (not-yet-installed) configs -->
                <ItemsControl ItemsSource="{Binding AvailableConfigs}"
                              Margin="0,12,0,0"
                              IsVisible="{Binding HasAvailableConfigs}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource GlassBgBrush}"
                                    CornerRadius="0" Padding="12,8" Margin="0,0,0,6">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" MinWidth="0">
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding Manufacturer}" Margin="0,2,0,0"
                                                   Foreground="{DynamicResource TextMutedBrush}" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Install"
                                            VerticalAlignment="Center"
                                            Theme="{StaticResource GhostButton}"
                                            Command="{Binding $parent[ItemsControl].DataContext.InstallApprovedCommand}"
                                            CommandParameter="{Binding}"
                                            Padding="10,4" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </c:Section>
    </StackPanel>
</UserControl>
