<UserControl x:Class="OpenTabletArtist.Views.DeveloperView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="using:OpenTabletArtist.Controls">

    <!-- DataContext is the DeveloperViewModel; controls bind to the shared DeveloperSettings singleton
         (Settings.*). Tabbed layout — a tab per topic — so the page stays short as options grow. -->
    <Grid RowDefinitions="Auto,*" ColumnDefinitions="Auto,*">

        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Spacing="6" Margin="0,0,0,16">
            <TextBlock Classes="PageTitle" Text="DEVELOPER" />
            <TextBlock Text="Testing aids for reviewing the app's UI. These aren't needed for normal use. Tip: right-click an induced card in Home's Needs attention list to dismiss it (real warnings can't be dismissed this way)."
                       Foreground="{DynamicResource TextMutedBrush}"
                       MaxWidth="900" HorizontalAlignment="Left" TextWrapping="Wrap" />
        </StackPanel>

        <!-- Tab rail — one tab per topic (matches the tablet page's rail). -->
        <Border Grid.Row="1" Grid.Column="0" Margin="0,0,16,0" BorderThickness="0,0,1,0"
                BorderBrush="{DynamicResource DividerBrush}">
            <StackPanel Width="170" Spacing="2">
                <RadioButton Content="ARTIFICIAL WARNINGS" IsChecked="True" x:Name="InduceTab"
                             Theme="{StaticResource TabRadioButton}" />
                <RadioButton Content="WARNINGS" x:Name="ActualTab"
                             Theme="{StaticResource TabRadioButton}" />
                <RadioButton Content="CONFIG ERRORS" x:Name="ConfigErrorsTab"
                             Theme="{StaticResource TabRadioButton}" />
                <RadioButton Content="TABLET TABS" x:Name="TabletTabsTab"
                             Theme="{StaticResource TabRadioButton}" />
                <RadioButton Content="SCREENSHOT" x:Name="ScreenshotTab"
                             Theme="{StaticResource TabRadioButton}" />
                <RadioButton Content="WINDOW SIZE" x:Name="WindowSizeTab"
                             Theme="{StaticResource TabRadioButton}" />
            </StackPanel>
        </Border>

        <!-- Induce health warnings: synthetic per-severity cards for reviewing the Needs-attention UI. -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto"
                      IsVisible="{Binding #InduceTab.IsChecked}">
            <c:SettingCard MaxWidth="720" HorizontalAlignment="Left" Title="Induce artificial warnings"
                           Description="Turn one on to make a synthetic warning appear in Home's Needs attention list at that severity. Its Fix button simply clears the toggle.">
                <StackPanel Spacing="10">
                    <c:ToggleSetting Label="Recommendation-level warning"
                                     Description="The mildest tier — works, but not the recommended configuration."
                                     IsChecked="{Binding Settings.InduceRecommendation}" />
                    <c:ToggleSetting Label="Misconfigured-level warning"
                                     Description="Set up incorrectly; a feature won't behave as expected."
                                     IsChecked="{Binding Settings.InduceMisconfigured}" />
                    <c:ToggleSetting Label="Broken-level warning"
                                     Description="A prerequisite is missing; core functionality won't work."
                                     IsChecked="{Binding Settings.InduceBroken}" />
                </StackPanel>
            </c:SettingCard>
        </ScrollViewer>

        <!-- Trigger actual health warnings: force each real catalog warning with its true copy. -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto"
                      IsVisible="{Binding #ActualTab.IsChecked}">
            <c:SettingCard MaxWidth="720" HorizontalAlignment="Left" Title="Trigger health warnings"
                           Description="Each toggle makes the real catalog warning appear in Home's Needs attention list with its true text and Fix button. Turn it off to remove the card.">
                <StackPanel Spacing="10">
                    <c:ToggleSetting Label="Windows Ink plugin not installed"
                                     IsChecked="{Binding Settings.ForceWinInkNotInstalled}" />
                    <c:ToggleSetting Label="Windows Ink plugin may be incompatible"
                                     IsChecked="{Binding Settings.ForceWinInkVersionMismatch}" />
                    <c:ToggleSetting Label="VMulti driver not installed"
                                     IsChecked="{Binding Settings.ForceVMultiNotInstalled}" />
                    <c:ToggleSetting Label="Conflicting tablet driver detected"
                                     IsChecked="{Binding Settings.ForceDriverConflict}" />
                    <c:ToggleSetting Label="Running as administrator"
                                     IsChecked="{Binding Settings.ForceRunningElevated}" />
                    <c:ToggleSetting Label="Using an external daemon"
                                     IsChecked="{Binding Settings.ForceForeignDaemon}" />
                    <c:ToggleSetting Label="Tablet: not using Windows Ink"
                                     Description="Emitted for a sample tablet; its Fix deep-links to that (absent) tablet."
                                     IsChecked="{Binding Settings.ForceTabletNotWinInk}" />
                    <c:ToggleSetting Label="Tablet: mapped area partly off-screen"
                                     IsChecked="{Binding Settings.ForceTabletMappingOffScreen}" />
                    <c:ToggleSetting Label="Tablet: custom display mapping"
                                     IsChecked="{Binding Settings.ForceTabletMappingCustom}" />
                    <c:ToggleSetting Label="Tablet: using a custom config override"
                                     Description="Emitted for a sample tablet; its Review deep-links to the CONFIGS tab."
                                     IsChecked="{Binding Settings.ForceTabletConfigOverride}" />
                </StackPanel>
            </c:SettingCard>
        </ScrollViewer>

        <!-- Introduce REAL misconfigurations (persisted settings changes) for reproducing UX issues. -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto"
                      IsVisible="{Binding #ConfigErrorsTab.IsChecked}">
            <c:SettingCard MaxWidth="720" HorizontalAlignment="Left" Title="Introduce config errors"
                           Description="Unlike the warning toggles above, these make a real, persisted change to the active tablet's settings so a genuinely broken configuration can be reproduced and debugged. Each is reversible from the tablet's page.">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Map active area partly off-screen" FontWeight="SemiBold" />
                        <TextBlock Text="Moves the active tablet's display mapping so it straddles the desktop's right edge — about half the mapped area lands in dead space beyond every monitor. Trips the real &quot;mapped area is partly off-screen&quot; health check. Restore it by remapping the tablet to a display on its page (or the tray's Switch display)."
                                   Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" />
                        <Button Content="Push active area off-screen"
                                Command="{Binding PushMappingOffScreenCommand}"
                                Theme="{StaticResource GhostButton}" Padding="12,6"
                                HorizontalAlignment="Left" Margin="0,4,0,0" />
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Create a slightly-wrong calibration" FontWeight="SemiBold" />
                        <TextBlock Text="Fabricates a real 4-point (perspective) calibration on the active tablet's mapped display, as if each corner were tapped a few pixels off. The pointer ends up slightly off, and the tablet's Calibration tab shows a populated report with small random deltas — handy for reviewing the report + fit-quality UI without a pen. Undo it with Clear calibration on that tab."
                                   Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" />
                        <Button Content="Create off calibration"
                                Command="{Binding CreateBadCalibrationCommand}"
                                Theme="{StaticResource GhostButton}" Padding="12,6"
                                HorizontalAlignment="Left" Margin="0,4,0,0" />
                    </StackPanel>

                    <TextBlock Text="{Binding ConfigErrorStatus}" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextMutedBrush}"
                               IsVisible="{Binding HasConfigErrorStatus}" Margin="0,2,0,0" />
                </StackPanel>
            </c:SettingCard>
        </ScrollViewer>

        <!-- Reveal the normally-hidden tablet-page tabs. -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto"
                      IsVisible="{Binding #TabletTabsTab.IsChecked}">
            <c:SettingCard MaxWidth="720" HorizontalAlignment="Left" Title="Tablet page tabs"
                           Description="Show extra diagnostic tabs on a tablet's page. Hidden by default because they're rarely useful.">
                <StackPanel Spacing="10">
                    <c:ToggleSetting Label="Show the Filters tab"
                                     Description="A raw view of the profile's output-mode filters."
                                     IsChecked="{Binding Settings.ShowFiltersTab}" />
                    <c:ToggleSetting Label="Show the JSON tab"
                                     Description="The tablet profile's raw settings JSON."
                                     IsChecked="{Binding Settings.ShowJsonTab}" />
                </StackPanel>
            </c:SettingCard>
        </ScrollViewer>

        <!-- Capture the live app UI to a PNG via RenderTargetBitmap (#437). Renders the actual controls,
             so it's pixel-perfect and free of window-focus / occlusion / DPI issues that plague manual
             capture. The render happens in code-behind (it needs the visual). -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto"
                      IsVisible="{Binding #ScreenshotTab.IsChecked}">
            <c:SettingCard MaxWidth="720" HorizontalAlignment="Left" Title="Screenshots"
                           Description="Developer aids for capturing the live UI to PNGs, saved to your Pictures\OpenTabletArtist folder with timestamped names.">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Screenshot all pages" FontWeight="SemiBold" />
                        <TextBlock Text="Visit every page in turn — Home, each nav item, and every Advanced sub-tab — saving a PNG of each, then return to this page."
                                   Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" />
                        <Button Content="Screenshot all pages" Click="OnScreenshotAllPages"
                                Theme="{StaticResource GhostButton}" Padding="12,6"
                                HorizontalAlignment="Left" Margin="0,4,0,0" />
                    </StackPanel>

                    <c:ToggleSetting Label="On-page screenshot control"
                                     Description="Show a small Capture page button at the bottom of the nav bar, so you can screenshot whichever page you're currently viewing."
                                     IsChecked="{Binding Settings.OnPageScreenshot}" />

                    <TextBlock x:Name="ScreenshotStatus" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextMutedBrush}" IsVisible="False" />
                </StackPanel>
            </c:SettingCard>
        </ScrollViewer>

        <!-- Force the window to an exact ACTUAL-PIXEL size (#546): preview how the layout responds on
             smaller displays, or get a consistent window for screenshots. The presets are real pixels
             (scaling-independent); forcing relaxes the window's normal minimum so small sizes aren't
             clamped up. Reset by restarting the app. -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto"
                      IsVisible="{Binding #WindowSizeTab.IsChecked}">
            <c:SettingCard MaxWidth="720" HorizontalAlignment="Left" Title="Window size"
                           Description="Force the app window to occupy an exact number of actual screen pixels (independent of Windows display scaling) — to preview how the layout responds on smaller displays, or for consistent screenshots. Forcing a size relaxes the window's normal minimum, so a small size can look cramped; restart the app to restore it.">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Current size:" FontWeight="SemiBold" />
                        <TextBlock x:Name="WindowSizeText" Text="—"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>
                    <!-- Wraps so every preset stays reachable when the window itself is forced narrow. -->
                    <WrapPanel>
                        <Button Content="1920 × 1080" Tag="1920,1080" Click="OnSetWindowSize"
                                Theme="{StaticResource GhostButton}" Padding="12,6" Margin="0,0,8,8" />
                        <Button Content="1600 × 900" Tag="1600,900" Click="OnSetWindowSize"
                                Theme="{StaticResource GhostButton}" Padding="12,6" Margin="0,0,8,8" />
                        <Button Content="1366 × 768" Tag="1366,768" Click="OnSetWindowSize"
                                Theme="{StaticResource GhostButton}" Padding="12,6" Margin="0,0,8,8" />
                        <Button Content="1280 × 720" Tag="1280,720" Click="OnSetWindowSize"
                                Theme="{StaticResource GhostButton}" Padding="12,6" Margin="0,0,8,8" />
                    </WrapPanel>
                </StackPanel>
            </c:SettingCard>
        </ScrollViewer>
    </Grid>
</UserControl>
