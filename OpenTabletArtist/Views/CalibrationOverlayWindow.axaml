<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OpenTabletArtist.Views.CalibrationOverlayWindow"
        Title="Calibrate"
        WindowDecorations="None" CanResize="False" ShowInTaskbar="False"
        Topmost="True" Background="#D9101018"
        WindowStartupLocation="Manual">

    <Grid>
        <!-- Targets + active-target emphasis are drawn onto this canvas from code-behind. -->
        <Canvas x:Name="Surface" />

        <!-- Instruction + actions. Colours (panel, text, buttons, targets) are set in code-behind so
             the overlay can flip between light/dark independently of the app theme. -->
        <Border x:Name="Panel" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,48"
                Background="#CC1B1B28" BorderThickness="1" CornerRadius="12" Padding="20,16" MaxWidth="640"
                BoxShadow="0 8 28 0 #66000000">
            <StackPanel Spacing="12">
                <Button x:Name="ThemeToggle" Content="Light mode" Click="OnToggleTheme"
                        HorizontalAlignment="Right" Theme="{StaticResource GhostButton}"
                        Padding="10,4"
                        ToolTip.Tip="Switch the calibration overlay between light and dark (does not change the app theme)" />
                <!-- Progress readout so the user can see how far through the capture they are. -->
                <TextBlock x:Name="ProgressLabel" Text="{Binding ProgressText}" Foreground="White"
                           FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center"
                           TextAlignment="Center" IsVisible="{Binding IsCapturing}" />
                <TextBlock x:Name="InstructionText" Text="{Binding Instruction}" Foreground="White"
                           TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" />
                <!-- #481: nudge users to calibrate at their natural pen angle, not bolt-upright. -->
                <TextBlock x:Name="HoldTip" Text="Tip: hold the pen at the natural angle you draw at — tilted, not straight up."
                           FontSize="12" Foreground="#B0FFFFFF" TextWrapping="Wrap"
                           HorizontalAlignment="Center" TextAlignment="Center"
                           IsVisible="{Binding IsCapturing}" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                    <Button x:Name="ApplyBtn" Content="Apply" IsVisible="{Binding ShowApply}" Command="{Binding ApplyCommand}"
                            Theme="{StaticResource AccentButton}" Padding="16,8"
                            ToolTip.Tip="Keep this calibration. Cancel reverts to the previous one." />
                    <Button x:Name="UndoBtn" Content="Undo last point" IsVisible="{Binding CanUndoPoint}" Command="{Binding UndoLastPointCommand}"
                            Theme="{StaticResource GhostButton}" Padding="16,8"
                            ToolTip.Tip="Remove just the most recently recorded point and re-tap that target." />
                    <Button x:Name="RedoBtn" Content="Redo all" IsVisible="{Binding ShowRedo}" Command="{Binding RedoCommand}"
                            Theme="{StaticResource GhostButton}" Padding="16,8"
                            ToolTip.Tip="Discard all recorded points and start over." />
                    <Button x:Name="ClearBtn" Content="Clear calibration" Command="{Binding ClearCommand}"
                            Theme="{StaticResource GhostButton}" Padding="16,8" />
                    <Button x:Name="CancelBtn" Content="Cancel (Esc)" Command="{Binding CancelCommand}"
                            Theme="{StaticResource GhostButton}" Padding="16,8" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
