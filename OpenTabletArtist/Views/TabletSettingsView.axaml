<UserControl x:Class="OpenTabletArtist.Views.TabletSettingsView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- DataContext is the TabletSettingsViewModel, supplied by the typed-nav DataTemplate (#15). -->
    <StackPanel MaxWidth="900" HorizontalAlignment="Left">
        <TextBlock Classes="PageTitle" Text="Paired Tablets" />
        <TextBlock Classes="PageSubtitle" Text="Tablets that have been detected" />

        <ItemsControl ItemsSource="{Binding Profiles}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Classes="GlassPanel" Margin="0,0,0,12" Padding="16"
                            Cursor="Hand"
                            DoubleTapped="ProfileCard_DoubleTapped">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" MinWidth="0">
                                <TextBlock Text="{Binding Tablet}" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Classes="statusMark" Classes.success="{Binding IsDetected}" />
                                    <TextBlock Text="{Binding StatusText}" FontSize="11"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               Classes.active="{Binding IsDetected}">
                                        <TextBlock.Styles>
                                            <Style Selector="TextBlock.active">
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                                            </Style>
                                        </TextBlock.Styles>
                                    </TextBlock>
                                </StackPanel>
                                <TextBlock Text="{Binding LastSeenDetail}" FontSize="10"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           FontStyle="Italic" Margin="0,2,0,0"
                                           IsVisible="{Binding LastSeenDetail, Converter={StaticResource NonEmptyToBool}}" />
                            </StackPanel>
                            <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                                <Button Content="Open" Theme="{StaticResource AccentButton}"
                                        Command="{Binding $parent[ItemsControl].DataContext.OpenTabletSettingsCommand}"
                                        CommandParameter="{Binding}"
                                        Padding="12,6" FontSize="12" Margin="0,0,6,4" />
                                <Button Content="Forget" Theme="{StaticResource DeleteButton}"
                                        Command="{Binding $parent[ItemsControl].DataContext.ForgetProfileCommand}"
                                        CommandParameter="{Binding Tablet}"
                                        Padding="12,6" FontSize="12" Margin="0,0,0,4" />
                            </WrapPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Border Classes="GlassPanel" Padding="32"
                IsVisible="{Binding !HasProfiles}">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="No Tablets Configured" FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="Connect a tablet and it will appear here"
                           FontSize="13" Foreground="{DynamicResource TextMutedBrush}"
                           HorizontalAlignment="Center" Margin="0,8,0,0" />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
