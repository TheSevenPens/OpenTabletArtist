<UserControl x:Class="OpenTabletArtist.Views.OpenTabletDriverView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="using:OpenTabletArtist.Controls">

    <!-- A tabbed page (see docs/design/ux-terminology.md): a complex header (its title) at the top,
         then a subpage navigation (tab rail) on the left and the selected subpage on the right
         (lazy-mounted on first visit, #388). -->
    <Grid RowDefinitions="Auto,*" ColumnDefinitions="Auto,*">
        <!-- Complex header — for this tabbed page it's just the title. -->
        <c:ComplexHeader Grid.Row="0" Grid.ColumnSpan="2" Title="OPENTABLETDRIVER" />

        <!-- Subpage navigation — tab rail, vertical, to the left of the content. -->
        <Border Grid.Row="1" Grid.Column="0" Margin="0,0,16,0" BorderThickness="0,0,1,0"
                BorderBrush="{DynamicResource DividerBrush}">
            <StackPanel Width="210" Spacing="2">
                <RadioButton Content="DAEMON" IsChecked="True" x:Name="DaemonTab"
                             Theme="{StaticResource TabRadioButton}" />
                <RadioButton Content="WINDOWS INK PLUGIN" x:Name="WinInkTab"
                             Theme="{StaticResource TabRadioButton}" />
                <RadioButton Content="CUSTOM TABLET COMPATIBILITY" x:Name="ConfigsTab"
                             Theme="{StaticResource TabRadioButton}" />
                <RadioButton Content="DIAGNOSTICS" x:Name="DiagnosticsTab"
                             Theme="{StaticResource TabRadioButton}" />
                <RadioButton Content="LOG" x:Name="LogTab"
                             Theme="{StaticResource TabRadioButton}" />
                <RadioButton Content="PLUGINS" x:Name="PluginsTab"
                             Theme="{StaticResource TabRadioButton}" />
            </StackPanel>
        </Border>

        <ContentControl x:Name="TabHost" Grid.Row="1" Grid.Column="1" />
    </Grid>
</UserControl>
