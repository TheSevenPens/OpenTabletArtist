<UserControl x:Class="OpenTabletArtist.Views.OpenTabletDriverView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- DataContext is OpenTabletDriverViewModel. Like a tablet's page: a secondary tab rail on the left
         and the selected engine page's existing view on the right (resolved by its typed DataTemplate). -->
    <Grid ColumnDefinitions="Auto,*">
        <!-- Tab rail — vertical, to the left of the content. -->
        <Border Grid.Column="0" Margin="0,0,16,0" BorderThickness="0,0,1,0"
                BorderBrush="{DynamicResource DividerBrush}">
            <StackPanel Width="210" Spacing="2">
                <RadioButton Content="DAEMON" IsChecked="True" x:Name="DaemonTab"
                             Theme="{StaticResource TabRadioButton}" />
                <RadioButton Content="WINDOWS INK PLUGIN" x:Name="WinInkTab"
                             Theme="{StaticResource TabRadioButton}" />
                <RadioButton Content="CUSTOM TABLET COMPATIBILITY" x:Name="ConfigsTab"
                             Theme="{StaticResource TabRadioButton}" />
                <RadioButton Content="DIAGNOSTICS" x:Name="DiagnosticsTab"
                             Theme="{StaticResource TabRadioButton}" />
                <RadioButton Content="LOG" x:Name="LogTab"
                             Theme="{StaticResource TabRadioButton}" />
                <RadioButton Content="PLUGINS" x:Name="PluginsTab"
                             Theme="{StaticResource TabRadioButton}" />
            </StackPanel>
        </Border>

        <!-- Content: the selected engine page's existing view (overlaid; only the active one is shown). -->
        <Panel Grid.Column="1">
            <ContentControl Content="{Binding Daemon}" IsVisible="{Binding #DaemonTab.IsChecked}" />
            <ContentControl Content="{Binding WindowsInk}" IsVisible="{Binding #WinInkTab.IsChecked}" />
            <ContentControl Content="{Binding Configs}" IsVisible="{Binding #ConfigsTab.IsChecked}" />
            <ContentControl Content="{Binding Diagnostics}" IsVisible="{Binding #DiagnosticsTab.IsChecked}" />
            <ContentControl Content="{Binding Log}" IsVisible="{Binding #LogTab.IsChecked}" />
            <ContentControl Content="{Binding Plugins}" IsVisible="{Binding #PluginsTab.IsChecked}" />
        </Panel>
    </Grid>
</UserControl>
