<UserControl x:Class="OpenTabletArtist.Views.AboutView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- DataContext is the AboutViewModel, supplied by the typed-nav DataTemplate (#15). -->
    <StackPanel MaxWidth="900" HorizontalAlignment="Left">
        <TextBlock Classes="PageTitle" Text="ABOUT" />

        <Border Classes="GlassPanel">
            <StackPanel>
                <TextBlock Classes="SectionLabel" Text="WHAT IS THIS?" Margin="0,0,0,12" />
                <TextBlock TextWrapping="Wrap" LineHeight="22"
                           Foreground="{DynamicResource TextSecondaryBrush}">
                    A simpler way of using OpenTabletDriver on Windows.
                </TextBlock>
                <!-- Version (moved here from the sidebar footer) -->
                <TextBlock Text="{Binding AppVersionLabel}" Margin="0,12,0,0"
                           Foreground="{DynamicResource TextMutedBrush}" />
            </StackPanel>
        </Border>

        <Border Classes="GlassPanel" Margin="0,12,0,0">
            <StackPanel>
                <TextBlock Classes="SectionLabel" Text="SOURCE CODE" Margin="0,0,0,12" />
                <!-- Clickable link: opens the GitHub repo in the default browser -->
                <Button Command="{Binding OpenUrlCommand}" CommandParameter="{Binding RepoUrl}"
                        Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand"
                        HorizontalAlignment="Left"
                        ToolTip.Tip="{Binding RepoUrl}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding RepoUrl}"
                                   Foreground="{DynamicResource AccentBrush}"
                                   TextDecorations="Underline" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <Border Classes="GlassPanel" Margin="0,12,0,0">
            <StackPanel>
                <TextBlock Classes="SectionLabel" Text="RELEASES" Margin="0,0,0,6" />
                <TextBlock TextWrapping="Wrap" LineHeight="22" Margin="0,0,0,10"
                           Foreground="{DynamicResource TextSecondaryBrush}">
                    Download the latest build and read the release notes.
                </TextBlock>
                <Button Command="{Binding OpenUrlCommand}" CommandParameter="{Binding ReleasesUrl}"
                        Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand"
                        HorizontalAlignment="Left"
                        ToolTip.Tip="{Binding ReleasesUrl}">
                    <TextBlock Text="View releases on GitHub"
                               Foreground="{DynamicResource AccentBrush}"
                               TextDecorations="Underline" VerticalAlignment="Center" />
                </Button>
            </StackPanel>
        </Border>

        <Border Classes="GlassPanel" Margin="0,12,0,0">
            <StackPanel>
                <TextBlock Classes="SectionLabel" Text="USER MANUAL" Margin="0,0,0,6" />
                <TextBlock TextWrapping="Wrap" LineHeight="22" Margin="0,0,0,10"
                           Foreground="{DynamicResource TextSecondaryBrush}">
                    Learn how to set up and use the app.
                </TextBlock>
                <Button Command="{Binding OpenUrlCommand}" CommandParameter="{Binding UserManualUrl}"
                        Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand"
                        HorizontalAlignment="Left"
                        ToolTip.Tip="{Binding UserManualUrl}">
                    <TextBlock Text="Open the user manual"
                               Foreground="{DynamicResource AccentBrush}"
                               TextDecorations="Underline" VerticalAlignment="Center" />
                </Button>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
