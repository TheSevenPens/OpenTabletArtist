<Window x:Class="OpenTabletArtist.Views.TabletSettingsDialog"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:v="using:OpenTabletArtist.Views"
        Title="Tablet Settings"
        Width="700" MinWidth="640" Height="640"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBaseBrush}"
        CanResize="True">

    <!-- Thin host for the shared per-tablet editor; used by the tray's focused Pen Dynamics view.
         DataContext (a TabletDetailViewModel) is set in code-behind and inherited by the view. -->
    <v:TabletDetailView Margin="24" />
</Window>
