<UserControl x:Class="OpenTabletArtist.Views.PluginsView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- DataContext is the PluginsViewModel, supplied by the typed-nav DataTemplate (#15). -->
    <StackPanel MaxWidth="900" HorizontalAlignment="Left">
        <!-- Header card: title + rescan/browse actions. -->
        <Border Classes="GlassPanel">
            <Grid RowDefinitions="Auto,Auto" ColumnSpacing="12">
                <TextBlock Grid.Row="0" Text="INSTALLED PLUGINS" Classes="SectionLabel"
                           VerticalAlignment="Center" />
                <WrapPanel Grid.Row="1" Orientation="Horizontal">
                    <Button Content="Refresh" Command="{Binding RefreshCommand}"
                            ToolTip.Tip="Rescan the plugin folder"
                            Theme="{StaticResource GhostButton}" Padding="12,6" Margin="0,0,6,4" />
                    <Button Content="Browse" Command="{Binding BrowseCommand}"
                            ToolTip.Tip="Open the plugin folder in File Explorer"
                            Theme="{StaticResource GhostButton}" Padding="12,6" Margin="0,0,0,4" />
                </WrapPanel>
            </Grid>
        </Border>

        <!-- Empty state -->
        <TextBlock Text="{Binding EmptyMessage}" FontStyle="Italic"
                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,10,0,0"
                   IsVisible="{Binding !HasPlugins}" />

        <!-- One card per installed plugin: name/version, with an Active/Installed badge. -->
        <ItemsControl ItemsSource="{Binding Plugins}" IsVisible="{Binding HasPlugins}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Classes="GlassPanel" Margin="0,10,0,0">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding Version}"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           IsVisible="{Binding Version, Converter={StaticResource NonEmptyToBool}}" />
                            </StackPanel>
                            <Border Grid.Column="1" Background="{DynamicResource AccentMutedBrush}"
                                    CornerRadius="10" Padding="10,3" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Status}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentBrush}" />
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</UserControl>
