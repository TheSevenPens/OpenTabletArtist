<UserControl x:Class="OpenTabletArtist.Views.PluginsView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- DataContext is the PluginsViewModel, supplied by the typed-nav DataTemplate (#15). -->
    <StackPanel MaxWidth="900" HorizontalAlignment="Left">
        <TextBlock Classes="PageTitle" Text="PLUGINS" />
        <TextBlock Classes="PageSubtitle"
                   Text="OpenTabletDriver plugins installed in the daemon's plugin folder (read-only)" />

        <Border Classes="GlassPanel" Padding="16">
            <StackPanel>
                <Grid RowDefinitions="Auto,Auto" ColumnSpacing="12">
                    <TextBlock Grid.Row="0" Text="INSTALLED PLUGINS" Classes="SectionLabel"
                               VerticalAlignment="Center" />
                    <WrapPanel Grid.Row="1" Orientation="Horizontal">
                        <Button Content="Refresh" Command="{Binding RefreshCommand}"
                                ToolTip.Tip="Rescan the plugin folder"
                                Theme="{StaticResource GhostButton}" Padding="12,6" FontSize="12" Margin="0,0,6,4" />
                        <Button Content="Browse" Command="{Binding BrowseCommand}"
                                ToolTip.Tip="Open the plugin folder in File Explorer"
                                Theme="{StaticResource GhostButton}" Padding="12,6" FontSize="12" Margin="0,0,0,4" />
                    </WrapPanel>
                </Grid>

                <!-- Empty state -->
                <TextBlock Text="{Binding EmptyMessage}" FontSize="11" FontStyle="Italic"
                           Foreground="{DynamicResource TextMutedBrush}" Margin="0,8,0,0"
                           IsVisible="{Binding !HasPlugins}" />

                <ItemsControl ItemsSource="{Binding Plugins}" Margin="0,8,0,0"
                              IsVisible="{Binding HasPlugins}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,5,0,5">
                                <TextBlock Grid.Column="0" Classes="statusMark"
                                           Classes.success="{Binding IsActive}" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <TextBlock Text="{Binding Version}" FontSize="10"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               IsVisible="{Binding Version, Converter={StaticResource NonEmptyToBool}}" />
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="{Binding Status}" FontSize="11"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
