<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OpenTabletArtist.Views.SupportedTabletsDialog"
        Title="Supported tablets"
        Width="1040" Height="600" MinWidth="820" MinHeight="440"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBaseBrush}">

    <Window.Styles>
        <!-- The connected tablet's row: accent tint + left accent bar. -->
        <Style Selector="Border.detectedRow">
            <Setter Property="Background" Value="{DynamicResource AccentMutedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="3,0,0,0" />
        </Style>
        <!-- Status pill colours: green Supported, amber Has Quirks, neutral Missing Features. -->
        <Style Selector="Border.stSupported"><Setter Property="Background" Value="{DynamicResource SuccessMutedBrush}" /></Style>
        <Style Selector="Border.stSupported TextBlock"><Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" /></Style>
        <Style Selector="Border.stQuirks"><Setter Property="Background" Value="{DynamicResource WarningMutedBrush}" /></Style>
        <Style Selector="Border.stQuirks TextBlock"><Setter Property="Foreground" Value="{DynamicResource WarningBrush}" /></Style>
        <Style Selector="Border.stMissing"><Setter Property="Background" Value="{DynamicResource GlassBgHoverBrush}" /></Style>
        <Style Selector="Border.stMissing TextBlock"><Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" /></Style>
    </Window.Styles>

    <DockPanel Margin="16">
        <!-- Header: title + count, search, column labels -->
        <StackPanel DockPanel.Dock="Top" Spacing="10">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="Supported tablets" FontSize="17" FontWeight="SemiBold"
                           VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" />
                <Border Grid.Column="1" Background="{DynamicResource AccentMutedBrush}" CornerRadius="0"
                        Padding="10,3" VerticalAlignment="Center">
                    <TextBlock Text="{Binding CountText}" FontFamily="{DynamicResource MonoFontFamily}"
                               FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}" />
                </Border>
            </Grid>
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBox Grid.Column="0" Text="{Binding SearchText, Mode=TwoWay}" PlaceholderText="Search tablets…" />
                <ComboBox Grid.Column="1" Width="160" VerticalAlignment="Stretch"
                          ItemsSource="{Binding Brands}" SelectedItem="{Binding SelectedBrand, Mode=TwoWay}"
                          ToolTip.Tip="Filter by brand" />
            </Grid>
            <!-- Clickable column headers; click sorts by that column, click again reverses. The active
                 column shows a ▲/▼ arrow. The # column (row numbers) isn't sortable. -->
            <Grid ColumnDefinitions="44,1.2*,120,80,64,126,1.8*" Margin="4,2,4,0">
                <TextBlock Grid.Column="0" Text="#" Classes="SectionLabel" HorizontalAlignment="Right" />
                <TextBlock Grid.Column="1" Text="{Binding NameHeader}" Classes="SectionLabel"
                           Cursor="Hand" Tag="Name" PointerPressed="OnHeaderClick" />
                <TextBlock Grid.Column="2" Text="{Binding AreaHeader}" Classes="SectionLabel" HorizontalAlignment="Right"
                           Cursor="Hand" Tag="Area" PointerPressed="OnHeaderClick" />
                <TextBlock Grid.Column="3" Text="{Binding PressureHeader}" Classes="SectionLabel" HorizontalAlignment="Right"
                           Cursor="Hand" Tag="Pressure" PointerPressed="OnHeaderClick" />
                <TextBlock Grid.Column="4" Text="{Binding ButtonsHeader}" Classes="SectionLabel" HorizontalAlignment="Right"
                           Cursor="Hand" Tag="Buttons" PointerPressed="OnHeaderClick" />
                <TextBlock Grid.Column="5" Text="{Binding StatusHeader}" Classes="SectionLabel"
                           Cursor="Hand" Tag="Status" PointerPressed="OnHeaderClick" Margin="12,0,0,0" />
                <TextBlock Grid.Column="6" Text="NOTES" Classes="SectionLabel" Margin="12,0,0,0" />
            </Grid>
        </StackPanel>

        <!-- Footer: Close -->
        <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*,Auto" Margin="0,12,0,0">
            <Button Grid.Column="1" Content="Close" Click="OnClose"
                    Theme="{StaticResource AccentButton}" Padding="18,7" />
        </Grid>

        <!-- The list -->
        <Border Margin="0,8,0,0" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1" CornerRadius="0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="List" ItemsSource="{Binding Rows}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Classes.detectedRow="{Binding IsDetected}">
                                <Grid ColumnDefinitions="44,1.2*,120,80,64,126,1.8*" Margin="4,6,4,6">
                                    <TextBlock Grid.Column="0" Text="{Binding Number}" HorizontalAlignment="Right"
                                               Margin="0,0,8,0" VerticalAlignment="Top" FontFamily="{DynamicResource MonoFontFamily}"
                                               Foreground="{DynamicResource TextMutedBrush}" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Top">
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                                        <Border Background="{DynamicResource SuccessBrush}" CornerRadius="0"
                                                Padding="7,1" VerticalAlignment="Center" IsVisible="{Binding IsDetected}">
                                            <TextBlock Text="Detected" Foreground="White" FontSize="{DynamicResource TypeCaptionSize}" FontWeight="SemiBold" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="{Binding ActiveArea}" HorizontalAlignment="Right"
                                               VerticalAlignment="Top" FontFamily="{DynamicResource MonoFontFamily}"
                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                    <TextBlock Grid.Column="3" Text="{Binding Pressure}" HorizontalAlignment="Right"
                                               VerticalAlignment="Top" FontFamily="{DynamicResource MonoFontFamily}"
                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                    <TextBlock Grid.Column="4" Text="{Binding Buttons}" HorizontalAlignment="Right"
                                               VerticalAlignment="Top" FontFamily="{DynamicResource MonoFontFamily}"
                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                    <Border Grid.Column="5" CornerRadius="0" Padding="9,1" Margin="12,0,0,0"
                                            HorizontalAlignment="Left" VerticalAlignment="Top" IsVisible="{Binding HasStatus}"
                                            Classes.stSupported="{Binding IsSupported}"
                                            Classes.stQuirks="{Binding IsQuirks}"
                                            Classes.stMissing="{Binding IsMissing}">
                                        <TextBlock Text="{Binding Status}" FontSize="{DynamicResource TypeCaptionSize}" FontWeight="SemiBold" />
                                    </Border>
                                    <TextBlock Grid.Column="6" Text="{Binding Notes}" TextWrapping="Wrap"
                                               VerticalAlignment="Top" Margin="12,0,0,0" IsVisible="{Binding HasNotes}"
                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </DockPanel>
</Window>
