<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OpenTabletArtist.Views.SupportedTabletsDialog"
        Title="Supported tablets"
        Width="660" Height="580" MinWidth="520" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBaseBrush}">

    <Window.Styles>
        <!-- The connected tablet's row: accent tint + left accent bar. -->
        <Style Selector="Border.detectedRow">
            <Setter Property="Background" Value="{DynamicResource AccentMutedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="3,0,0,0" />
        </Style>
    </Window.Styles>

    <DockPanel Margin="16">
        <!-- Header: title + count, search, column labels -->
        <StackPanel DockPanel.Dock="Top" Spacing="10">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="Supported tablets" FontSize="17" FontWeight="SemiBold"
                           VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" />
                <Border Grid.Column="1" Background="{DynamicResource AccentMutedBrush}" CornerRadius="20"
                        Padding="10,3" VerticalAlignment="Center">
                    <TextBlock Text="{Binding CountText}" FontFamily="{DynamicResource MonoFontFamily}"
                               FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}" />
                </Border>
            </Grid>
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBox Grid.Column="0" Text="{Binding SearchText, Mode=TwoWay}" PlaceholderText="Search tablets…" />
                <ComboBox Grid.Column="1" Width="160" VerticalAlignment="Stretch"
                          ItemsSource="{Binding Brands}" SelectedItem="{Binding SelectedBrand, Mode=TwoWay}"
                          ToolTip.Tip="Filter by brand" />
            </Grid>
            <!-- Clickable column headers; click sorts by that column, click again reverses. The active
                 column shows a ▲/▼ arrow. The # column (row numbers) isn't sortable. -->
            <Grid ColumnDefinitions="44,*,150,90,70" Margin="4,2,4,0">
                <TextBlock Grid.Column="0" Text="#" Classes="SectionLabel" HorizontalAlignment="Right" />
                <TextBlock Grid.Column="1" Text="{Binding NameHeader}" Classes="SectionLabel"
                           Cursor="Hand" Tag="Name" PointerPressed="OnHeaderClick" />
                <TextBlock Grid.Column="2" Text="{Binding AreaHeader}" Classes="SectionLabel" HorizontalAlignment="Right"
                           Cursor="Hand" Tag="Area" PointerPressed="OnHeaderClick" />
                <TextBlock Grid.Column="3" Text="{Binding PressureHeader}" Classes="SectionLabel" HorizontalAlignment="Right"
                           Cursor="Hand" Tag="Pressure" PointerPressed="OnHeaderClick" />
                <TextBlock Grid.Column="4" Text="{Binding ButtonsHeader}" Classes="SectionLabel" HorizontalAlignment="Right"
                           Cursor="Hand" Tag="Buttons" PointerPressed="OnHeaderClick" />
            </Grid>
        </StackPanel>

        <!-- Footer: Close -->
        <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*,Auto" Margin="0,12,0,0">
            <Button Grid.Column="1" Content="Close" Click="OnClose"
                    Theme="{StaticResource AccentButton}" Padding="18,7" />
        </Grid>

        <!-- The list -->
        <Border Margin="0,8,0,0" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1" CornerRadius="8">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="List" ItemsSource="{Binding Rows}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Classes.detectedRow="{Binding IsDetected}">
                                <Grid ColumnDefinitions="44,*,150,90,70" Margin="4,5,4,5">
                                    <TextBlock Grid.Column="0" Text="{Binding Number}" HorizontalAlignment="Right"
                                               Margin="0,0,8,0" FontFamily="{DynamicResource MonoFontFamily}"
                                               Foreground="{DynamicResource TextMutedBrush}" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                                        <Border Background="{DynamicResource SuccessBrush}" CornerRadius="20"
                                                Padding="7,1" VerticalAlignment="Center" IsVisible="{Binding IsDetected}">
                                            <TextBlock Text="Detected" Foreground="White" FontSize="10" FontWeight="SemiBold" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="{Binding ActiveArea}" HorizontalAlignment="Right"
                                               FontFamily="{DynamicResource MonoFontFamily}"
                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                    <TextBlock Grid.Column="3" Text="{Binding Pressure}" HorizontalAlignment="Right"
                                               FontFamily="{DynamicResource MonoFontFamily}"
                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                    <TextBlock Grid.Column="4" Text="{Binding Buttons}" HorizontalAlignment="Right"
                                               FontFamily="{DynamicResource MonoFontFamily}"
                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </DockPanel>
</Window>
