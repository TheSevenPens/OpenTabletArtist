<UserControl x:Class="OpenTabletArtist.Views.SettingsView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="using:OpenTabletArtist.Controls">

    <!-- The SETTINGS tabbed page. DataContext is the SettingsViewModel (typed-nav DataTemplate, #15);
         the shared TabbedPageView renders the header + rail + content from its Tabs/SelectedContent. -->
    <c:TabbedPageView Title="SETTINGS" />
</UserControl>
