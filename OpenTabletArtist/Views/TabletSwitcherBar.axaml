<UserControl x:Class="OpenTabletArtist.Views.TabletSwitcherBar"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">

    <!-- switcher · refresh, grouped at the right of the pivot row (#switcher-right/#580). Detection status
         now reads off the per-row link/link-off icon in the dropdown, so the separate chip was removed. -->
    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
        <!-- MinWidth is the floor for the selector AND its dropdown popup (Avalonia floors the popup at
             the ComboBox width), sized to fit long tablet names without clipping in the list; the popup
             still auto-grows beyond it for anything longer. -->
        <ComboBox VerticalAlignment="Center" MinWidth="300" Margin="0,0,4,0"
                  ItemsSource="{Binding #Root.Tablets}"
                  SelectedItem="{Binding #Root.SelectedTablet, Mode=TwoWay}"
                  ToolTip.Tip="Switch between your connected and remembered tablets">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <!-- Detection icon (matches the detection chip): green link when detected,
                             muted link-off when not. -->
                        <Panel Width="15" Height="15" VerticalAlignment="Center">
                            <PathIcon Data="{StaticResource IconLink}" Width="15" Height="15"
                                      Foreground="{DynamicResource SuccessBrush}"
                                      IsVisible="{Binding IsDetected}" />
                            <PathIcon Data="{StaticResource IconLinkOff}" Width="15" Height="15"
                                      Foreground="{DynamicResource NeutralBrush}"
                                      IsVisible="{Binding !IsDetected}" />
                        </Panel>
                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                    </StackPanel>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
        <Button Command="{Binding #Root.RefreshCommand}"
                ToolTip.Tip="Reload settings from daemon"
                AutomationProperties.Name="Reload settings from daemon"
                IsVisible="{Binding #Root.ShowRefresh}"
                Theme="{StaticResource GhostButton}" Width="34" Height="30" Padding="0"
                HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
            <PathIcon Data="{StaticResource IconRefresh}" Width="16" Height="16"
                      Foreground="{Binding $parent[Button].Foreground}" />
        </Button>
    </StackPanel>
</UserControl>
