<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="using:OpenTabletArtist.Converters"
             x:Class="OpenTabletArtist.Controls.TabbedPageView"
             x:Name="Root">

    <!-- Shared host for the SETTINGS + ADVANCED tabbed pages. Zune pivot layout (Phase 2): a horizontal
         row of lowercase pivots (the subpage names) over the selected subpage. No page-entity title — the
         highlighted wordmark in the top bar already names the section. Rail + content bind to the
         DataContext (the page view model); see TabbedPageView.axaml.cs. -->
    <Grid RowDefinitions="Auto,*">
        <!-- Pivots — horizontal, wrapping on narrow widths; active = accent + weight. -->
        <Border Grid.Row="0" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,0,1"
                Margin="0,0,0,14" Padding="0,0,0,7">
            <ItemsControl ItemsSource="{Binding Tabs}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <RadioButton Theme="{StaticResource PivotTab}" GroupName="Pivots"
                                     Content="{Binding Label, Converter={x:Static conv:LowerCaseConverter.Instance}}"
                                     IsVisible="{Binding IsVisible}"
                                     IsChecked="{Binding IsSelected, Mode=OneWay}"
                                     Command="{Binding $parent[ItemsControl].DataContext.SelectTabCommand}"
                                     CommandParameter="{Binding}"
                                     Margin="0,1,26,1" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- The selected subpage — crossfades on pivot switch (the shared Zune motion primitive). -->
        <TransitioningContentControl Grid.Row="1" Content="{Binding SelectedContent}"
                                     PageTransition="{DynamicResource PageFade}" />
    </Grid>
</UserControl>
