<Window x:Class="OpenTabletArtist.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OpenTabletArtist.ViewModels"
        xmlns:controls="using:OpenTabletArtist.Controls"
        Title="OpenTabletArtist"
        Icon="/Assets/appicon.png"
        Width="1100" Height="720"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgBaseBrush}"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <!-- Client area extended under the title bar (#titlebar): the Sakura backdrop now reaches the top
         edge instead of a gray system caption bar. The native min/max/close buttons stay (top-right);
         a drag strip below provides window move/maximize. OffScreenMargin keeps content on-screen when
         maximized (Windows over-sizes an extended-chrome window by the frame width). -->
    <Panel Margin="{Binding OffScreenMargin, RelativeSource={RelativeSource AncestorType=Window}}">
        <!-- Full-window backdrop layer. Transparent in Light/Dark; the sakura image in the Anime
             skin (#anime), or the user's chosen image in the Custom skin. Sits behind everything so
             the translucent sidebar + glass cards show it through. -->
        <Border Background="{DynamicResource AppBackdropBrush}" />

        <!-- Dimming scrim over the backdrop image (Custom skin only; transparent otherwise) so text on
             the translucent panels stays legible regardless of the chosen photo. -->
        <Border Background="{DynamicResource BackdropScrimBrush}" />

        <!-- Falling sakura petals — only animates in the Sakura skin and when enabled in Settings
             (#207). Hit-test invisible; sits above the backdrop, behind the sidebar/content. -->
        <controls:SakuraPetals />

    <Grid ColumnDefinitions="260,*">
        <!-- SIDEBAR -->
        <Border Grid.Column="0"
                Background="{DynamicResource SidebarBgBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Brand -->
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                            Margin="16,20,16,16">
                    <TextBlock Text="OpenTabletArtist"
                               FontFamily="Segoe UI, Inter" FontSize="26" FontWeight="Light"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- The page navigation bar: nodes (labels in all caps) that select a page. Most sit at
                     the root; the less-common ones are grouped under a collapsible ADVANCED group node.
                     Scrolls when taller than the window (many tablets, or ADVANCED expanded). See
                     docs/design/ux-terminology.md. -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="8,0,8,0">
                    <!-- HOME is a parent node: a leaf node (opens the merged home + tablets page) that
                         also has per-tablet child nodes nested under it (paired ∪ connected). Click a
                         child to open its page; right-click to forget. Empty-state when there are none. (#317) -->
                    <RadioButton Theme="{StaticResource NavNode}" Content="HOME"
                                 IsChecked="{Binding IsDashboard, Mode=OneWay}"
                                 Command="{Binding NavigateCommand}" CommandParameter="{Binding Dashboard}" />
                    <ItemsControl ItemsSource="{Binding Tablets}" Margin="12,0,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <RadioButton Theme="{StaticResource NavNode}" Content="{Binding Name}"
                                             IsChecked="{Binding IsSelected, Mode=OneWay}"
                                             Command="{Binding $parent[ItemsControl].DataContext.NavigateToTabletCommand}"
                                             CommandParameter="{Binding}"
                                             Margin="0,2,0,0">
                                    <RadioButton.Tag>
                                        <TextBlock Classes="statusMark" Classes.success="{Binding IsDetected}" />
                                    </RadioButton.Tag>
                                    <RadioButton.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Forget" Command="{Binding ForgetCommand}" />
                                        </ContextMenu>
                                    </RadioButton.ContextMenu>
                                </RadioButton>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="No tablets connected or remembered"
                               Margin="20,4,8,2" FontSize="11" FontStyle="Italic" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextMutedBrush}"
                               IsVisible="{Binding !HasTablets}" />
                    <RadioButton Theme="{StaticResource NavNode}" Content="PRESETS"
                                 IsChecked="{Binding IsPresets, Mode=OneWay}"
                                 Command="{Binding NavigateCommand}" CommandParameter="{Binding Presets}"
                                 Margin="0,2,0,0" />
                    <!-- Per-app auto-switching lives under Profiles (it maps apps to profiles). Hidden while
                         the feature is disabled (FeatureFlags.PerAppProfiles); flip the flag to restore it. -->
                    <RadioButton Theme="{StaticResource NavNode}" Content="PER-APP PRESETS"
                                 IsChecked="{Binding IsPerApp, Mode=OneWay}"
                                 IsVisible="{Binding ShowPerApp}"
                                 Command="{Binding NavigateCommand}" CommandParameter="{Binding PerApp}"
                                 Margin="12,2,0,0" />
                    <RadioButton Theme="{StaticResource NavNode}" Content="HOTKEYS"
                                 IsChecked="{Binding IsHotkeys, Mode=OneWay}"
                                 Command="{Binding NavigateCommand}" CommandParameter="{Binding Hotkeys}"
                                 Margin="0,2,0,0" />
                    <RadioButton Theme="{StaticResource NavNode}" Content="SCRIBBLE"
                                 IsChecked="{Binding IsTest, Mode=OneWay}"
                                 Command="{Binding NavigateCommand}" CommandParameter="{Binding Test}"
                                 Margin="0,2,0,0" />
                    <RadioButton Theme="{StaticResource NavNode}" Content="ABOUT"
                                 IsChecked="{Binding IsAbout, Mode=OneWay}"
                                 Command="{Binding NavigateCommand}" CommandParameter="{Binding About}"
                                 Margin="0,2,0,0" />

                    <!-- ADVANCED is a group node: a collapsible node that only groups its child nodes
                         (auto-expands when one of its pages is active, via IsAdvancedExpanded). -->
                    <ToggleButton Theme="{StaticResource NavGroupNode}" Content="ADVANCED"
                                  IsChecked="{Binding IsAdvancedExpanded, Mode=TwoWay}"
                                  Margin="0,8,0,0" />
                    <StackPanel IsVisible="{Binding IsAdvancedExpanded}" Margin="12,0,0,0">
                        <!-- OpenTabletDriver: a leaf node opening a tabbed page (its own subpage
                             navigation: Daemon / Windows Ink / Configs / Diagnostics / Log / Plugins). -->
                        <RadioButton Theme="{StaticResource NavNode}" Content="OPENTABLETDRIVER"
                                     IsChecked="{Binding IsOtd, Mode=OneWay}"
                                     Command="{Binding NavigateCommand}" CommandParameter="{Binding OpenTabletDriver}"
                                     Margin="0,2,0,0" />
                        <RadioButton Theme="{StaticResource NavNode}" Content="VMULTI DRIVER"
                                     IsChecked="{Binding IsVMulti, Mode=OneWay}"
                                     Command="{Binding NavigateCommand}" CommandParameter="{Binding VMulti}"
                                     Margin="0,2,0,0" />
                        <RadioButton Theme="{StaticResource NavNode}" Content="DRIVER CLEANUP"
                                     IsChecked="{Binding IsDriverCleanup, Mode=OneWay}"
                                     Command="{Binding NavigateCommand}" CommandParameter="{Binding DriverCleanup}"
                                     Margin="0,2,0,0" />
                        <RadioButton Theme="{StaticResource NavNode}" Content="STARTUP"
                                     IsChecked="{Binding IsStartup, Mode=OneWay}"
                                     Command="{Binding NavigateCommand}" CommandParameter="{Binding Startup}"
                                     Margin="0,2,0,0" />
                        <RadioButton Theme="{StaticResource NavNode}" Content="DEVELOPER"
                                     IsChecked="{Binding IsDeveloper, Mode=OneWay}"
                                     Command="{Binding NavigateCommand}" CommandParameter="{Binding Developer}"
                                     Margin="0,2,0,0" />
                        <RadioButton Theme="{StaticResource NavNode}" Content="THEME"
                                     IsChecked="{Binding IsTheme, Mode=OneWay}"
                                     Command="{Binding NavigateCommand}" CommandParameter="{Binding Theme}"
                                     Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- CONTENT AREA -->
        <ScrollViewer Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <!-- Content padding. Kept above the Sakura cards' glow extent (16px blur, see CardShadow)
                 so the soft glow isn't clipped by the scroll viewport on the left/right. Extra top space
                 (#titlebar) clears the native caption buttons now that the client area reaches the top. -->
            <Border Padding="20,44,20,18">
                <ContentControl Content="{Binding CurrentPage}" />
            </Border>
        </ScrollViewer>

        <!-- Bottom-left status cues, pinned to the content area (Grid.Column 1) — NOT the window's, so
             they can't overlap the sidebar's bottom nav items on a short window. Stacked so the per-app
             (#167) and override (#320) chips never collide when both are active. Mirrors the save chip. -->
        <StackPanel Grid.Column="1" VerticalAlignment="Bottom" HorizontalAlignment="Left"
                    Margin="24,0,0,20" Spacing="8">
            <!-- Active per-app profile (#167): a mapped app is in focus and its snapshot is applied live. -->
            <Border IsVisible="{Binding PerAppSwitch.HasActiveProfile}"
                    Background="{DynamicResource AccentMutedBrush}" BorderBrush="{DynamicResource AccentBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="12,7" BoxShadow="{DynamicResource CardShadow}">
                <TextBlock Text="{Binding PerAppSwitch.ActiveProfile, StringFormat='App preset: {0}'}"
                           FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}"
                           TextWrapping="Wrap" MaxWidth="280" />
            </Border>

            <!-- Active-profile override cue (#320): a live-only hotkey switch runs a temporary override on
                 the daemon, NOT your saved default. Persistent while overridden. -->
            <Border IsVisible="{Binding ProfileSwitch.HasOverride}"
                    Background="{DynamicResource AccentMutedBrush}" BorderBrush="{DynamicResource AccentBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="12,7" BoxShadow="{DynamicResource CardShadow}">
                <TextBlock Text="{Binding ProfileSwitch.ActiveSnapshot, StringFormat='Preset override: {0}'}"
                           FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}"
                           TextWrapping="Wrap" MaxWidth="280" />
            </Border>
        </StackPanel>
    </Grid>

    <!-- Settings auto-save indicator (#321): OTA has no Save button — every change is applied + saved
         immediately. This quietly confirms that, and stays as a warning if a disk save failed (so a
         live-but-unpersisted change isn't hidden). Overlays the content, bottom-right. -->
    <Border VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,24,20"
            IsVisible="{Binding Connection.ShowSaveStatus}"
            Background="{DynamicResource GlassBgBrush}" BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1" CornerRadius="8" Padding="12,7" BoxShadow="{DynamicResource CardShadow}">
        <TextBlock Text="{Binding Connection.SaveStatusText}" Classes="saveStatus"
                   Classes.failed="{Binding Connection.SaveFailed}"
                   FontSize="11" TextWrapping="Wrap" MaxWidth="300" />
    </Border>

    <!-- Title-bar drag strip (#titlebar): the top edge is app-coloured now, so this transparent strip
         gives the window its move/double-click-maximize behaviour. It stops short of the top-right so
         the native caption buttons still receive their clicks. -->
    <Border VerticalAlignment="Top" HorizontalAlignment="Stretch" Height="34" Margin="0,0,150,0"
            Background="Transparent" PointerPressed="OnTitleBarPressed" DoubleTapped="OnTitleBarDoubleTapped" />
    </Panel>
</Window>
