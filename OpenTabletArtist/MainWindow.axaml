<Window x:Class="OpenTabletArtist.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OpenTabletArtist.ViewModels"
        xmlns:controls="using:OpenTabletArtist.Controls"
        Title="OpenTabletArtist"
        Icon="/Assets/appicon.png"
        Width="1100" Height="720"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgBaseBrush}"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <!-- Client area extended under the title bar (#titlebar): the Sakura backdrop now reaches the top
         edge instead of a gray system caption bar. The native min/max/close buttons stay (top-right);
         a drag strip below provides window move/maximize. OffScreenMargin keeps content on-screen when
         maximized (Windows over-sizes an extended-chrome window by the frame width). -->
    <Panel Margin="{Binding OffScreenMargin, RelativeSource={RelativeSource AncestorType=Window}}">
        <!-- Full-window backdrop layer. Transparent in Light/Dark; the sakura image in the Anime
             skin (#anime), or the user's chosen image in the Custom skin. Sits behind everything so
             the translucent sidebar + glass cards show it through. -->
        <Border Background="{DynamicResource AppBackdropBrush}" />

        <!-- Dimming scrim over the backdrop image (Custom skin only; transparent otherwise) so text on
             the translucent panels stays legible regardless of the chosen photo. -->
        <Border Background="{DynamicResource BackdropScrimBrush}" />

        <!-- Falling sakura petals — only animates in the Sakura skin and when enabled in Settings
             (#207). Hit-test invisible; sits above the backdrop, behind the sidebar/content. -->
        <controls:SakuraPetals />

    <Grid ColumnDefinitions="140,*">
        <!-- SIDEBAR -->
        <Border Grid.Column="0"
                Background="{DynamicResource SidebarBgBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Brand -->
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                            Margin="16,20,16,16">
                    <TextBlock Text="OpenTabletArtist"
                               FontFamily="Segoe UI, Inter" FontSize="15" FontWeight="Light"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Version stamp, pinned to the bottom of the sidebar (moved out of the OS title-bar
                     caption so it no longer overlaps the top-left). -->
                <TextBlock DockPanel.Dock="Bottom" Text="{Binding TitleBarText}"
                           Margin="18,4,16,16" FontSize="12"
                           Foreground="{DynamicResource TextMutedBrush}"
                           VerticalAlignment="Center" />

                <!-- On-page screenshot control (#437): a developer aid, shown only when enabled on the
                     Developer tab. Pinned to the bottom-left of the nav so you can capture whatever page
                     you're currently viewing. -->
                <Button DockPanel.Dock="Bottom" x:Name="CapturePageButton"
                        Click="OnCapturePage"
                        IsVisible="{Binding Developer.Settings.OnPageScreenshot}"
                        Theme="{StaticResource GhostButton}"
                        Margin="12,4,12,12" Padding="10,6" HorizontalAlignment="Left"
                        Content="Capture page"
                        ToolTip.Tip="Save a PNG of the current page to Pictures\OpenTabletArtist" />

                <!-- The page navigation bar: nodes (labels in all caps) that select a page. Most sit at
                     the root; the less-common ones are grouped under a collapsible ADVANCED group node.
                     Scrolls when taller than the window (many tablets, or ADVANCED expanded). See
                     docs/design/ux-terminology.md. -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="8,0,8,0">
                    <!-- HOME opens the dashboard (health "Needs attention", daemon status, the YOUR TABLETS
                         overview, and the supported-tablets link). -->
                    <RadioButton Theme="{StaticResource NavNode}" Content="HOME"
                                 IsChecked="{Binding IsDashboard, Mode=OneWay}"
                                 Command="{Binding NavigateCommand}" CommandParameter="{Binding Dashboard}" />
                    <!-- TABLET is a single node (#542): its page hosts a switcher dropdown over the selected
                         tablet's settings. Always shown — the page carries a placeholder when none is known. -->
                    <RadioButton Theme="{StaticResource NavNode}" Content="TABLET"
                                 IsChecked="{Binding IsTabletPage, Mode=OneWay}"
                                 Command="{Binding NavigateCommand}" CommandParameter="{Binding TabletPage}"
                                 Margin="0,2,0,0" />
                    <!-- The flat leaves between HOME and ADVANCED, data-driven (#477): PRESETS, PER-APP
                         PRESETS (feature-gated → IsVisible), HOTKEYS, SCRIBBLE, ABOUT. Same NavNode look;
                         each item carries its own label / target page / selection. -->
                    <ItemsControl ItemsSource="{Binding NavLeaves}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <RadioButton Theme="{StaticResource NavNode}" Content="{Binding Label}"
                                             IsVisible="{Binding IsVisible}"
                                             IsChecked="{Binding IsSelected, Mode=OneWay}"
                                             Command="{Binding $parent[ItemsControl].DataContext.NavigateCommand}"
                                             CommandParameter="{Binding Page}"
                                             Margin="0,2,0,0" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- SETTINGS + ADVANCED are leaf nodes, each opening a tabbed page. SETTINGS hosts OTA's
                         own preference tabs (Startup / Theme / Dev Tools); ADVANCED hosts the driver/daemon
                         tabs (Daemon / Windows Ink / Configs / Diagnostics / Console / Plugins / VMulti /
                         Driver Cleanup) as a single flat list. -->
                    <RadioButton Theme="{StaticResource NavNode}" Content="SETTINGS"
                                 IsChecked="{Binding IsSettings, Mode=OneWay}"
                                 Command="{Binding NavigateCommand}" CommandParameter="{Binding Settings}"
                                 Margin="0,2,0,0" />
                    <RadioButton Theme="{StaticResource NavNode}" Content="ADVANCED"
                                 IsChecked="{Binding IsAdvanced, Mode=OneWay}"
                                 Command="{Binding NavigateCommand}" CommandParameter="{Binding Advanced}"
                                 Margin="0,2,0,0" />
                    <!-- DEVELOPER is a top-level node after ADVANCED, shown only when its visibility toggle
                         (SETTINGS → Dev Tools) is on. -->
                    <RadioButton Theme="{StaticResource NavNode}" Content="DEVELOPER"
                                 IsChecked="{Binding IsDeveloper, Mode=OneWay}"
                                 Command="{Binding NavigateCommand}" CommandParameter="{Binding Developer}"
                                 IsVisible="{Binding Developer.Settings.ShowDeveloperPage}"
                                 Margin="0,2,0,0" />
                </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- CONTENT AREA -->
        <!-- Caption-clearance inset (#titlebar): a MARGIN on the ScrollViewer (outside the scrollable
             content, so it's reserved at every scroll position). Kept small (16px) so the page title sits
             near the top — page titles are short and left-aligned, so they can live under the transparent
             drag strip (still draggable) and no interactive content lands near the top-right caption
             buttons. The tablet detail page is the exception — its complex header has right-aligned
             Refresh/Forget — so it adds its OWN top inset in TabletDetailView to stay clear of the caption
             buttons, pending a dedicated tablet-header pass. The drag strip below stays taller (40) to keep
             a comfortable window-move zone across the top. -->
        <!-- Most pages are plain content and use this outer scroll (Auto). The tablet detail page manages
             its own scrolling (fixed header + tab rail, per-tab scroll), so it sets this to Disabled — that
             bounds the page to the viewport height so its inner scroll engages and the header no longer
             scrolls away (#507). -->
        <ScrollViewer Grid.Column="1"
                      Margin="0,16,0,0"
                      VerticalScrollBarVisibility="{Binding ContentScrollBarVisibility}"
                      HorizontalScrollBarVisibility="Disabled">
            <!-- Content padding (top tiny since the caption clearance is the ScrollViewer margin above).
                 L/R/bottom stay above the Sakura cards' glow extent (16px blur, see CardShadow) so the
                 soft glow isn't clipped by the scroll viewport on those edges. -->
            <Border Padding="8,2,20,18">
                <ContentControl Content="{Binding CurrentPage}" />
            </Border>
        </ScrollViewer>

        <!-- Bottom-left status cues, pinned to the content area (Grid.Column 1) — NOT the window's, so
             they can't overlap the sidebar's bottom nav items on a short window. Stacked so the per-app
             (#167) and override (#320) chips never collide when both are active. Mirrors the save chip. -->
        <StackPanel Grid.Column="1" VerticalAlignment="Bottom" HorizontalAlignment="Left"
                    Margin="24,0,0,20" Spacing="8">
            <!-- Active per-app profile (#167): a mapped app is in focus and its snapshot is applied live. -->
            <Border IsVisible="{Binding PerAppSwitch.HasActiveProfile}"
                    Background="{DynamicResource AccentMutedBrush}" BorderBrush="{DynamicResource AccentBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="12,7" BoxShadow="{DynamicResource CardShadow}">
                <TextBlock Text="{Binding PerAppSwitch.ActiveProfile, StringFormat='App preset: {0}'}"
                           FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}"
                           TextWrapping="Wrap" MaxWidth="280" />
            </Border>

            <!-- Active-profile override cue (#320): a live-only hotkey switch runs a temporary override on
                 the daemon, NOT your saved default. Persistent while overridden. -->
            <Border IsVisible="{Binding ProfileSwitch.HasOverride}"
                    Background="{DynamicResource AccentMutedBrush}" BorderBrush="{DynamicResource AccentBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="12,7" BoxShadow="{DynamicResource CardShadow}">
                <TextBlock Text="{Binding ProfileSwitch.ActiveSnapshot, StringFormat='Preset override: {0}'}"
                           FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}"
                           TextWrapping="Wrap" MaxWidth="280" />
            </Border>
        </StackPanel>
    </Grid>

    <!-- Settings auto-save indicator (#321): OTA has no Save button — every change is applied + saved
         immediately. This quietly confirms that, and stays as a warning if a disk save failed (so a
         live-but-unpersisted change isn't hidden). Overlays the content, bottom-right. -->
    <Border VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,24,20"
            IsVisible="{Binding Connection.ShowSaveStatus}"
            Background="{DynamicResource GlassBgBrush}" BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1" CornerRadius="8" Padding="12,7" BoxShadow="{DynamicResource CardShadow}">
        <TextBlock Text="{Binding Connection.SaveStatusText}" Classes="saveStatus"
                   Classes.failed="{Binding Connection.SaveFailed}"
                   FontSize="11" TextWrapping="Wrap" MaxWidth="300" />
    </Border>

    <!-- Title-bar drag strip (#titlebar): the top edge is app-coloured now, so this transparent strip
         gives the window its move/double-click-maximize behaviour. It stops short of the top-right so
         the native caption buttons still receive their clicks. -->
    <Border VerticalAlignment="Top" HorizontalAlignment="Stretch" Height="40" Margin="0,0,150,0"
            Background="Transparent" PointerPressed="OnTitleBarPressed" DoubleTapped="OnTitleBarDoubleTapped" />
    </Panel>
</Window>
