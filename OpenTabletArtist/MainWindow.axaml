<Window x:Class="OpenTabletArtist.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OpenTabletArtist.ViewModels"
        xmlns:controls="using:OpenTabletArtist.Controls"
        Title="OpenTabletArtist"
        Icon="/Assets/appicon.png"
        Width="1100" Height="720"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgBaseBrush}">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Panel>
        <!-- Full-window backdrop layer. Transparent in Light/Dark; the sakura image in the Anime
             skin (#anime). Sits behind everything so the translucent sidebar + glass cards show it
             through. -->
        <Border Background="{DynamicResource AppBackdropBrush}" />

        <!-- Falling sakura petals — only animates in the Sakura skin and when enabled in Settings
             (#207). Hit-test invisible; sits above the backdrop, behind the sidebar/content. -->
        <controls:SakuraPetals />

    <Grid ColumnDefinitions="260,*">
        <!-- SIDEBAR -->
        <Border Grid.Column="0"
                Background="{DynamicResource SidebarBgBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Brand -->
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                            Margin="16,20,16,16">
                    <TextBlock Text="OpenTabletArtist"
                               FontFamily="Segoe UI" FontSize="20" FontWeight="Light"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Nav Items (labels in all caps). Most pages sit at the root; the less-common ones
                     are tucked under a collapsible ADVANCED group at the bottom. -->
                <StackPanel Margin="8,0,8,0">
                    <RadioButton Theme="{StaticResource NavButton}" Content="HOME"
                                 IsChecked="{Binding IsDashboard, Mode=OneWay}"
                                 Command="{Binding NavigateCommand}" CommandParameter="{Binding Dashboard}" />
                    <RadioButton Theme="{StaticResource NavButton}" Content="TABLETS"
                                 IsChecked="{Binding IsTabletSettings, Mode=OneWay}"
                                 Command="{Binding NavigateCommand}" CommandParameter="{Binding TabletSettings}"
                                 Margin="0,2,0,0" />
                    <RadioButton Theme="{StaticResource NavButton}" Content="SAVED SETTINGS"
                                 IsChecked="{Binding IsPresets, Mode=OneWay}"
                                 Command="{Binding NavigateCommand}" CommandParameter="{Binding Presets}"
                                 Margin="0,2,0,0" />
                    <RadioButton Theme="{StaticResource NavButton}" Content="TEST DRAWING"
                                 IsChecked="{Binding IsTest, Mode=OneWay}"
                                 Command="{Binding NavigateCommand}" CommandParameter="{Binding Test}"
                                 Margin="0,2,0,0" />
                    <RadioButton Theme="{StaticResource NavButton}" Content="SETTINGS"
                                 IsChecked="{Binding IsSettings, Mode=OneWay}"
                                 Command="{Binding NavigateCommand}" CommandParameter="{Binding Settings}"
                                 Margin="0,2,0,0" />
                    <RadioButton Theme="{StaticResource NavButton}" Content="ABOUT"
                                 IsChecked="{Binding IsAbout, Mode=OneWay}"
                                 Command="{Binding NavigateCommand}" CommandParameter="{Binding About}"
                                 Margin="0,2,0,0" />

                    <!-- ADVANCED group: collapsible header + indented children (auto-expands when one
                         of its pages is active, via IsAdvancedExpanded). -->
                    <ToggleButton Theme="{StaticResource NavGroupHeader}" Content="ADVANCED"
                                  IsChecked="{Binding IsAdvancedExpanded, Mode=TwoWay}"
                                  Margin="0,8,0,0" />
                    <StackPanel IsVisible="{Binding IsAdvancedExpanded}" Margin="12,0,0,0">
                        <RadioButton Theme="{StaticResource NavButton}" Content="OTD"
                                     IsChecked="{Binding IsOtd, Mode=OneWay}"
                                     Command="{Binding NavigateCommand}" CommandParameter="{Binding Otd}"
                                     Margin="0,2,0,0" />
                        <RadioButton Theme="{StaticResource NavButton}" Content="CUSTOM TABLET COMPATIBILITY"
                                     IsChecked="{Binding IsConfigs, Mode=OneWay}"
                                     Command="{Binding NavigateCommand}" CommandParameter="{Binding Configs}"
                                     Margin="0,2,0,0" />
                        <RadioButton Theme="{StaticResource NavButton}" Content="DIAGNOSTICS"
                                     IsChecked="{Binding IsDiagnostics, Mode=OneWay}"
                                     Command="{Binding NavigateCommand}" CommandParameter="{Binding Diagnostics}"
                                     Margin="0,2,0,0" />
                        <RadioButton Theme="{StaticResource NavButton}" Content="LOG"
                                     IsChecked="{Binding IsConsole, Mode=OneWay}"
                                     Command="{Binding NavigateCommand}" CommandParameter="{Binding Console}"
                                     Margin="0,2,0,0" />
                        <RadioButton Theme="{StaticResource NavButton}" Content="PLUGINS"
                                     IsChecked="{Binding IsPlugins, Mode=OneWay}"
                                     Command="{Binding NavigateCommand}" CommandParameter="{Binding Plugins}"
                                     Margin="0,2,0,0" />
                        <RadioButton Theme="{StaticResource NavButton}" Content="UTILITIES"
                                     IsChecked="{Binding IsUtilities, Mode=OneWay}"
                                     Command="{Binding NavigateCommand}" CommandParameter="{Binding Utilities}"
                                     Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- CONTENT AREA -->
        <ScrollViewer Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Border Padding="28">
                <ContentControl Content="{Binding CurrentPage}" />
            </Border>
        </ScrollViewer>
    </Grid>
    </Panel>
</Window>
