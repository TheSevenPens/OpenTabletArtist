<Window x:Class="OpenTabletArtist.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OpenTabletArtist.ViewModels"
        xmlns:controls="using:OpenTabletArtist.Controls"
        xmlns:conv="using:OpenTabletArtist.Converters"
        Title="OpenTabletArtist"
        Icon="/Assets/appicon.png"
        Width="1100" Height="720"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgBaseBrush}"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <!-- Client area extended under the title bar (#titlebar): the Sakura backdrop now reaches the top
         edge instead of a gray system caption bar. The native min/max/close buttons stay (top-right);
         a drag strip below provides window move/maximize. OffScreenMargin keeps content on-screen when
         maximized (Windows over-sizes an extended-chrome window by the frame width). -->
    <Panel Margin="{Binding OffScreenMargin, RelativeSource={RelativeSource AncestorType=Window}}">
        <!-- Full-window backdrop layer. Transparent in Light/Dark; the sakura image in the Anime
             skin (#anime), or the user's chosen image in the Custom skin. Sits behind everything so
             the translucent sidebar + glass cards show it through. -->
        <Border Background="{DynamicResource AppBackdropBrush}" />

        <!-- Dimming scrim over the backdrop image (Custom skin only; transparent otherwise) so text on
             the translucent panels stays legible regardless of the chosen photo. -->
        <Border Background="{DynamicResource BackdropScrimBrush}" />

        <!-- Falling sakura petals — only animates in the Sakura skin and when enabled in Settings
             (#207). Hit-test invisible; sits above the backdrop, behind the sidebar/content. -->
        <controls:SakuraPetals />

    <Grid RowDefinitions="Auto,*">
        <!-- TOP WORDMARK BAR (Zune Phase 1). Replaces the left sidebar: the whole top-level nav as one
             horizontal row of lowercase wordmarks (data-driven NavSections), the active one marked by
             accent colour + weight. The row sits below the caption/drag band (top ~40px, kept by the
             transparent drag strip near the bottom of this file), so the words are clickable while the
             native min/max/close buttons and window-drag still own the top edge.
             (PRESETS + PER-APP PRESETS live in SETTINGS tabs, #571; DEVELOPER too, #572.) -->
        <Border Grid.Row="0" Background="Transparent">
            <Grid ColumnDefinitions="Auto,*,Auto" Margin="24,34,20,2">
                <!-- The wordmarks, left-aligned. (No brand mark here — the OS window caption + taskbar
                     already carry the app name; a second one read as a duplicate.) Wraps to a second row
                     on a narrow window instead of clipping. -->
                <ItemsControl Grid.Column="0" ItemsSource="{Binding NavSections}" VerticalAlignment="Bottom">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <RadioButton Theme="{StaticResource WordmarkNav}" GroupName="Wordmarks"
                                         Content="{Binding Label, Converter={x:Static conv:LowerCaseConverter.Instance}}"
                                         IsVisible="{Binding IsVisible}"
                                         IsChecked="{Binding IsSelected, Mode=OneWay}"
                                         Command="{Binding $parent[ItemsControl].DataContext.NavigateCommand}"
                                         CommandParameter="{Binding Page}"
                                         Margin="0,3,22,3" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Right cluster: the dev screenshot aid (only when enabled) + the version stamp, pinned
                     to the top so the version sits just under the native close button (not down on the
                     wordmark baseline). -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="16" VerticalAlignment="Top">
                    <!-- On-page screenshot control (#437): a developer aid, shown only when enabled on the
                         Developer tab. Captures whatever page you're currently viewing. -->
                    <Button x:Name="CapturePageButton" Click="OnCapturePage"
                            IsVisible="{Binding Developer.Settings.OnPageScreenshot}"
                            Theme="{StaticResource GhostButton}" Padding="10,5"
                            Content="Capture page" VerticalAlignment="Center"
                            ToolTip.Tip="Save a PNG of the current page to Pictures\OpenTabletArtist" />
                    <TextBlock Text="{Binding TitleBarText}" FontSize="12"
                               Foreground="{DynamicResource TextMutedBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTENT AREA (full width, below the wordmark bar). Most pages are plain content and use this
             outer scroll (Auto). The tablet detail page manages its own scrolling (fixed header + tab
             rail, per-tab scroll), so it sets this to Disabled (#507). Caption clearance is now the
             wordmark bar itself, so no top inset is needed here. -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="{Binding ContentScrollBarVisibility}"
                      HorizontalScrollBarVisibility="Disabled">
            <!-- L/R/bottom padding stays above the Sakura cards' glow extent (16px blur, see CardShadow)
                 so the soft glow isn't clipped by the scroll viewport on those edges. -->
            <Border Padding="24,4,24,18">
                <!-- Top-level page switches snap (no transition). A crossfade here superimposed the two
                     pages for ~180ms, which read as a glitch when their content differed a lot (worst
                     Settings → Scribble, whose big flat canvas ghosted over Settings' cards). Sub-page
                     pivots keep their own PageFade. -->
                <TransitioningContentControl Content="{Binding CurrentPage}"
                                             PageTransition="{x:Null}" />
            </Border>
        </ScrollViewer>

        <!-- Bottom-left status cues, pinned to the content area (Row 1). Stacked so the per-app (#167)
             and override (#320) chips never collide when both are active. Mirrors the save chip. -->
        <StackPanel Grid.Row="1" VerticalAlignment="Bottom" HorizontalAlignment="Left"
                    Margin="24,0,0,20" Spacing="8">
            <!-- Active per-app profile (#167): a mapped app is in focus and its snapshot is applied live. -->
            <Border IsVisible="{Binding PerAppSwitch.HasActiveProfile}"
                    Background="{DynamicResource AccentMutedBrush}" BorderBrush="{DynamicResource AccentBrush}"
                    BorderThickness="1" CornerRadius="0" Padding="12,7" BoxShadow="{DynamicResource CardShadow}">
                <TextBlock Text="{Binding PerAppSwitch.ActiveProfile, StringFormat='App preset: {0}'}"
                           FontSize="{DynamicResource TypeCaptionSize}" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}"
                           TextWrapping="Wrap" MaxWidth="280" />
            </Border>

            <!-- Active-profile override cue (#320): a live-only hotkey switch runs a temporary override on
                 the daemon, NOT your saved default. Persistent while overridden. -->
            <Border IsVisible="{Binding ProfileSwitch.HasOverride}"
                    Background="{DynamicResource AccentMutedBrush}" BorderBrush="{DynamicResource AccentBrush}"
                    BorderThickness="1" CornerRadius="0" Padding="12,7" BoxShadow="{DynamicResource CardShadow}">
                <TextBlock Text="{Binding ProfileSwitch.ActiveSnapshot, StringFormat='Preset override: {0}'}"
                           FontSize="{DynamicResource TypeCaptionSize}" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}"
                           TextWrapping="Wrap" MaxWidth="280" />
            </Border>
        </StackPanel>
    </Grid>

    <!-- Settings auto-save indicator (#321): OTA has no Save button — every change is applied + saved
         immediately. This quietly confirms that, and stays as a warning if a disk save failed (so a
         live-but-unpersisted change isn't hidden). Overlays the content, bottom-right. -->
    <Border VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,24,20"
            IsVisible="{Binding Connection.ShowSaveStatus}"
            Background="{DynamicResource GlassBgBrush}" BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1" CornerRadius="0" Padding="12,7" BoxShadow="{DynamicResource CardShadow}">
        <TextBlock Text="{Binding Connection.SaveStatusText}" Classes="saveStatus"
                   Classes.failed="{Binding Connection.SaveFailed}"
                   FontSize="{DynamicResource TypeCaptionSize}" TextWrapping="Wrap" MaxWidth="300" />
    </Border>

    <!-- Title-bar drag strip (#titlebar): the top edge is app-coloured now, so this transparent strip
         gives the window its move/double-click-maximize behaviour. It stops short of the top-right so
         the native caption buttons still receive their clicks. -->
    <Border VerticalAlignment="Top" HorizontalAlignment="Stretch" Height="32" Margin="0,0,150,0"
            Background="Transparent" PointerPressed="OnTitleBarPressed" DoubleTapped="OnTitleBarDoubleTapped" />
    </Panel>
</Window>
