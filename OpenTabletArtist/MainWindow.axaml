<Window x:Class="OpenTabletArtist.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OpenTabletArtist.ViewModels"
        xmlns:controls="using:OpenTabletArtist.Controls"
        Title="OpenTabletArtist"
        Icon="/Assets/appicon.png"
        Width="1100" Height="720"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgBaseBrush}">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Panel>
        <!-- Full-window backdrop layer. Transparent in Light/Dark; the sakura image in the Anime
             skin (#anime). Sits behind everything so the translucent sidebar + glass cards show it
             through. -->
        <Border Background="{DynamicResource AppBackdropBrush}" />

        <!-- Falling sakura petals — only animates in the Sakura skin and when enabled in Settings
             (#207). Hit-test invisible; sits above the backdrop, behind the sidebar/content. -->
        <controls:SakuraPetals />

    <Grid ColumnDefinitions="260,*">
        <!-- SIDEBAR -->
        <Border Grid.Column="0"
                Background="{DynamicResource SidebarBgBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Brand -->
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                            Margin="16,20,16,16">
                    <TextBlock Text="OpenTabletArtist"
                               FontFamily="Segoe UI" FontSize="20" FontWeight="Light"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Nav Items (labels in all caps). Most pages sit at the root; the less-common ones
                     are tucked under a collapsible ADVANCED group at the bottom. -->
                <StackPanel Margin="8,0,8,0">
                    <!-- HOME lands on the merged home + tablets page; the per-tablet children nest under
                         it (paired ∪ connected). Click a child to edit it in-place; right-click to
                         forget. Empty-state message when there are none. (#317) -->
                    <RadioButton Theme="{StaticResource NavButton}" Content="HOME"
                                 IsChecked="{Binding IsDashboard, Mode=OneWay}"
                                 Command="{Binding NavigateCommand}" CommandParameter="{Binding Dashboard}" />
                    <ItemsControl ItemsSource="{Binding Tablets}" Margin="12,0,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <RadioButton Theme="{StaticResource NavButton}" Content="{Binding Name}"
                                             IsChecked="{Binding IsSelected, Mode=OneWay}"
                                             Command="{Binding $parent[ItemsControl].DataContext.NavigateToTabletCommand}"
                                             CommandParameter="{Binding}"
                                             Margin="0,2,0,0">
                                    <RadioButton.Tag>
                                        <TextBlock Classes="statusMark" Classes.success="{Binding IsDetected}" />
                                    </RadioButton.Tag>
                                    <RadioButton.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Forget" Command="{Binding ForgetCommand}" />
                                        </ContextMenu>
                                    </RadioButton.ContextMenu>
                                </RadioButton>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="No tablets connected or remembered"
                               Margin="20,4,8,2" FontSize="11" FontStyle="Italic" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextMutedBrush}"
                               IsVisible="{Binding !HasTablets}" />
                    <RadioButton Theme="{StaticResource NavButton}" Content="SAVED SETTINGS"
                                 IsChecked="{Binding IsPresets, Mode=OneWay}"
                                 Command="{Binding NavigateCommand}" CommandParameter="{Binding Presets}"
                                 Margin="0,2,0,0" />
                    <RadioButton Theme="{StaticResource NavButton}" Content="HOTKEYS"
                                 IsChecked="{Binding IsHotkeys, Mode=OneWay}"
                                 Command="{Binding NavigateCommand}" CommandParameter="{Binding Hotkeys}"
                                 Margin="0,2,0,0" />
                    <RadioButton Theme="{StaticResource NavButton}" Content="TEST DRAWING"
                                 IsChecked="{Binding IsTest, Mode=OneWay}"
                                 Command="{Binding NavigateCommand}" CommandParameter="{Binding Test}"
                                 Margin="0,2,0,0" />
                    <RadioButton Theme="{StaticResource NavButton}" Content="ABOUT"
                                 IsChecked="{Binding IsAbout, Mode=OneWay}"
                                 Command="{Binding NavigateCommand}" CommandParameter="{Binding About}"
                                 Margin="0,2,0,0" />

                    <!-- ADVANCED group: collapsible header + indented children (auto-expands when one
                         of its pages is active, via IsAdvancedExpanded). -->
                    <ToggleButton Theme="{StaticResource NavGroupHeader}" Content="ADVANCED"
                                  IsChecked="{Binding IsAdvancedExpanded, Mode=TwoWay}"
                                  Margin="0,8,0,0" />
                    <StackPanel IsVisible="{Binding IsAdvancedExpanded}" Margin="12,0,0,0">
                        <RadioButton Theme="{StaticResource NavButton}" Content="DAEMON"
                                     IsChecked="{Binding IsDaemon, Mode=OneWay}"
                                     Command="{Binding NavigateCommand}" CommandParameter="{Binding Daemon}"
                                     Margin="0,2,0,0" />
                        <RadioButton Theme="{StaticResource NavButton}" Content="WINDOWS INK PLUGIN"
                                     IsChecked="{Binding IsWindowsInk, Mode=OneWay}"
                                     Command="{Binding NavigateCommand}" CommandParameter="{Binding WindowsInk}"
                                     Margin="0,2,0,0" />
                        <RadioButton Theme="{StaticResource NavButton}" Content="VMULTI DRIVER"
                                     IsChecked="{Binding IsVMulti, Mode=OneWay}"
                                     Command="{Binding NavigateCommand}" CommandParameter="{Binding VMulti}"
                                     Margin="0,2,0,0" />
                        <RadioButton Theme="{StaticResource NavButton}" Content="CUSTOM TABLET COMPATIBILITY"
                                     IsChecked="{Binding IsConfigs, Mode=OneWay}"
                                     Command="{Binding NavigateCommand}" CommandParameter="{Binding Configs}"
                                     Margin="0,2,0,0" />
                        <RadioButton Theme="{StaticResource NavButton}" Content="DIAGNOSTICS"
                                     IsChecked="{Binding IsDiagnostics, Mode=OneWay}"
                                     Command="{Binding NavigateCommand}" CommandParameter="{Binding Diagnostics}"
                                     Margin="0,2,0,0" />
                        <RadioButton Theme="{StaticResource NavButton}" Content="LOG"
                                     IsChecked="{Binding IsLog, Mode=OneWay}"
                                     Command="{Binding NavigateCommand}" CommandParameter="{Binding Log}"
                                     Margin="0,2,0,0" />
                        <RadioButton Theme="{StaticResource NavButton}" Content="PLUGINS"
                                     IsChecked="{Binding IsPlugins, Mode=OneWay}"
                                     Command="{Binding NavigateCommand}" CommandParameter="{Binding Plugins}"
                                     Margin="0,2,0,0" />
                        <RadioButton Theme="{StaticResource NavButton}" Content="DRIVER CLEANUP"
                                     IsChecked="{Binding IsDriverCleanup, Mode=OneWay}"
                                     Command="{Binding NavigateCommand}" CommandParameter="{Binding DriverCleanup}"
                                     Margin="0,2,0,0" />
                        <RadioButton Theme="{StaticResource NavButton}" Content="THEME"
                                     IsChecked="{Binding IsTheme, Mode=OneWay}"
                                     Command="{Binding NavigateCommand}" CommandParameter="{Binding Theme}"
                                     Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- CONTENT AREA -->
        <ScrollViewer Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <!-- Content padding. Kept above the Sakura cards' glow extent (16px blur, see CardShadow)
                 so the soft glow isn't clipped by the scroll viewport on the left/right. -->
            <Border Padding="20,18">
                <ContentControl Content="{Binding CurrentPage}" />
            </Border>
        </ScrollViewer>

        <!-- Active-profile override cue (#320): a live-only profile switch (hotkey / per-app) runs a
             temporary override on the daemon, NOT your saved default. Persistent while overridden, so
             it's clear the active config isn't what's on disk. Pinned to the content area's bottom-left
             (Grid.Column 1) — NOT the window's, so it can't overlap the sidebar's bottom nav items when
             the ADVANCED group is expanded on a short window. Mirrors the bottom-right save chip. -->
        <Border Grid.Column="1" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="24,0,0,20"
                IsVisible="{Binding ProfileSwitch.HasOverride}"
                Background="{DynamicResource AccentMutedBrush}" BorderBrush="{DynamicResource AccentBrush}"
                BorderThickness="1" CornerRadius="8" Padding="12,7" BoxShadow="{DynamicResource CardShadow}">
            <TextBlock Text="{Binding ProfileSwitch.ActiveSnapshot, StringFormat='Profile override: {0}'}"
                       FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}"
                       TextWrapping="Wrap" MaxWidth="280" />
        </Border>
    </Grid>

    <!-- Settings auto-save indicator (#321): OTA has no Save button — every change is applied + saved
         immediately. This quietly confirms that, and stays as a warning if a disk save failed (so a
         live-but-unpersisted change isn't hidden). Overlays the content, bottom-right. -->
    <Border VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,24,20"
            IsVisible="{Binding Connection.ShowSaveStatus}"
            Background="{DynamicResource GlassBgBrush}" BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1" CornerRadius="8" Padding="12,7" BoxShadow="{DynamicResource CardShadow}">
        <TextBlock Text="{Binding Connection.SaveStatusText}" Classes="saveStatus"
                   Classes.failed="{Binding Connection.SaveFailed}"
                   FontSize="11" TextWrapping="Wrap" MaxWidth="300" />
    </Border>
    </Panel>
</Window>
